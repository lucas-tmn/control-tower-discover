[DataDestinations = {[Definition = [Kind = "Reference", QueryName = "SupplyPlanDetailToday_DataDestination", IsNewTarget = true], Settings = [Kind = "Manual", AllowCreation = true, ColumnSettings = [Mappings = {[SourceColumnName = "Item SKU", DestinationColumnName = "Item SKU"], [SourceColumnName = "Warehouse", DestinationColumnName = "Warehouse"], [SourceColumnName = "Week Ending", DestinationColumnName = "Week Ending"], [SourceColumnName = "Beginning Balance", DestinationColumnName = "Beginning Balance"], [SourceColumnName = "Prod - Firm", DestinationColumnName = "Prod - Firm"], [SourceColumnName = "Prod - Plan", DestinationColumnName = "Prod - Plan"], [SourceColumnName = "PO - Firm", DestinationColumnName = "PO - Firm"], [SourceColumnName = "PO - Plan", DestinationColumnName = "PO - Plan"], [SourceColumnName = "TI - In Trans", DestinationColumnName = "TI - In Trans"], [SourceColumnName = "TI - Firm", DestinationColumnName = "TI - Firm"], [SourceColumnName = "TI - Plan", DestinationColumnName = "TI - Plan"], [SourceColumnName = "Firm Demands", DestinationColumnName = "Firm Demands"], [SourceColumnName = "Promo Lift", DestinationColumnName = "Promo Lift"], [SourceColumnName = "Net Forecast", DestinationColumnName = "Net Forecast"], [SourceColumnName = "TO - Firm", DestinationColumnName = "TO - Firm"], [SourceColumnName = "TO - Plan", DestinationColumnName = "TO - Plan"], [SourceColumnName = "Total Receipts", DestinationColumnName = "Total Receipts"], [SourceColumnName = "Total Est Shipments", DestinationColumnName = "Total Est Shipments"], [SourceColumnName = "Total Prod", DestinationColumnName = "Total Prod"], [SourceColumnName = "Total PO", DestinationColumnName = "Total PO"], [SourceColumnName = "Total TI", DestinationColumnName = "Total TI"], [SourceColumnName = "Total Demand", DestinationColumnName = "Total Demand"], [SourceColumnName = "Total TO", DestinationColumnName = "Total TO"], [SourceColumnName = "SI", DestinationColumnName = "SI"], [SourceColumnName = "SS", DestinationColumnName = "SS"], [SourceColumnName = "SI -SS", DestinationColumnName = "SI -SS"], [SourceColumnName = "SI Neg", DestinationColumnName = "SI Neg"], [SourceColumnName = "Demand Fulfillment", DestinationColumnName = "Demand Fulfillment"], [SourceColumnName = "Snapshot Date", DestinationColumnName = "Snapshot Date"]}], DynamicSchema = false, UpdateMethod = [Kind = "Replace"], TypeSettings = [Kind = "Table"]]]}]
shared SupplyPlanDetailToday = let
    Source = Sql.Database("ashley-edw.database.windows.net", "ashley_edw"),
    SupplyPlanDetail = Source{[Schema="Wholesale_DemandPlanning_AFI",Item="SupplyPlanDetail"]}[Data],
    
    // Filter data
    FilteredData = Table.SelectRows(SupplyPlanDetail, each 
        Date.From([dtea]) = Date.From(List.Max(SupplyPlanDetail[dtea])) and 
        not List.Contains({"213", "215", "242"}, [spdWarehouse])),
    
    // Transform columns
    TransformedData = Table.TransformColumns(FilteredData, {
        {"spdItem", Text.Trim, type text},
        {"spdWarehouse", Text.Trim, type text},
        {"spdWeekEnding", Date.From, type date},
        {"dtea", Date.From, type date}
    }),
    
    // Add calculated columns one by one
    AddTotalEstShipments = Table.AddColumn(TransformedData, "Total Est Shipments", each try [spdDemandFulfillment] + [spdFirmTransferOut] + [spdPlannedTransferOut] otherwise null, type number),
    AddTotalProd = Table.AddColumn(AddTotalEstShipments, "Total Prod", each try [spdFirmProduction] + [spdPlannedProduction] otherwise null, type number),
    AddTotalPO = Table.AddColumn(AddTotalProd, "Total PO", each try [spdFirmPurchaseOrders] + [spdPlannedPurchaseOrders] otherwise null, type number),
    AddTotalTI = Table.AddColumn(AddTotalPO, "Total TI", each try [spdInTransitTransferIn] + [spdOnOrderTransferIn] + [spdPlannedTransferIn] otherwise null, type number),
    AddTotalDemand = Table.AddColumn(AddTotalTI, "Total Demand", each try [spdFirmDemands] + [spdNetForecast] otherwise null, type number),
    AddTotalTO = Table.AddColumn(AddTotalDemand, "Total TO", each try [spdFirmTransferOut] + [spdPlannedTransferOut] otherwise null, type number),
    AddSISS = Table.AddColumn(AddTotalTO, "SI -SS", each try [spdShippableInventory] - [spdSafetyStock] otherwise null, type number),
    AddSINeg = Table.AddColumn(AddSISS, "SI Neg", each if [spdShippableInventory] < 0 then [spdShippableInventory] else 0, type number),
    
    // Select final columns
    SelectColumns = Table.SelectColumns(AddSINeg, {
        "spdItem", "spdWarehouse", "spdWeekEnding", "spdBeginingBalance", 
        "spdFirmProduction", "spdPlannedProduction", "spdFirmPurchaseOrders",
        "spdPlannedPurchaseOrders", "spdInTransitTransferIn", "spdOnOrderTransferIn",
        "spdPlannedTransferIn", "spdFirmDemands", "spdWeeklyPromotionalLift",
        "spdNetForecast", "spdFirmTransferOut", "spdPlannedTransferOut",
        "spdTotalReceipts", "Total Est Shipments", "Total Prod", "Total PO",
        "Total TI", "Total Demand", "Total TO", "spdShippableInventory",
        "spdSafetyStock", "SI -SS", "SI Neg", "spdDemandFulfillment", "dtea"
    }),
    
    // Rename columns
    RenamedColumns = Table.RenameColumns(SelectColumns, {
        {"spdItem", "Item SKU"},
        {"spdWarehouse", "Warehouse"},
        {"spdWeekEnding", "Week Ending"},
        {"spdBeginingBalance", "Beginning Balance"},
        {"spdFirmProduction", "Prod - Firm"},
        {"spdPlannedProduction", "Prod - Plan"},
        {"spdFirmPurchaseOrders", "PO - Firm"},
        {"spdPlannedPurchaseOrders", "PO - Plan"},
        {"spdInTransitTransferIn", "TI - In Trans"},
        {"spdOnOrderTransferIn", "TI - Firm"},
        {"spdPlannedTransferIn", "TI - Plan"},
        {"spdFirmDemands", "Firm Demands"},
        {"spdWeeklyPromotionalLift", "Promo Lift"},
        {"spdNetForecast", "Net Forecast"},
        {"spdFirmTransferOut", "TO - Firm"},
        {"spdPlannedTransferOut", "TO - Plan"},
        {"spdTotalReceipts", "Total Receipts"},
        {"spdShippableInventory", "SI"},
        {"spdSafetyStock", "SS"},
        {"spdDemandFulfillment", "Demand Fulfillment"},
        {"dtea", "Snapshot Date"}
    }),
  #"Changed column type" = Table.TransformColumnTypes(RenamedColumns, {{"Beginning Balance", Int64.Type}, {"Prod - Firm", Int64.Type}, {"Prod - Plan", Int64.Type}, {"PO - Firm", Int64.Type}, {"PO - Plan", Int64.Type}, {"TI - In Trans", Int64.Type}, {"TI - Firm", Int64.Type}, {"TI - Plan", Int64.Type}, {"Firm Demands", Int64.Type}, {"Promo Lift", Int64.Type}, {"Net Forecast", Int64.Type}, {"TO - Firm", Int64.Type}, {"TO - Plan", Int64.Type}, {"Total Receipts", Int64.Type}, {"Total Est Shipments", Int64.Type}, {"Total Prod", Int64.Type}, {"Total PO", Int64.Type}, {"Total TI", Int64.Type}, {"Total Demand", Int64.Type}, {"Total TO", Int64.Type}, {"SI", Int64.Type}, {"SS", Int64.Type}, {"SI -SS", Int64.Type}, {"SI Neg", Int64.Type}, {"Demand Fulfillment", Int64.Type}}),
  #"Trimmed text" = Table.TransformColumns(#"Changed column type", {{"Item SKU", each Text.Trim(_), type text}, {"Warehouse", each Text.Trim(_), type text}})
in
    #"Trimmed text";
shared SupplyPlanDetailToday_DataDestination = let
  Pattern = Fabric.Warehouse([CreateNavigationProperties = false]),
  Navigation_1 = Pattern{[workspaceId = "c8d9fc83-18b6-4e1d-8264-0b49eed36fe0"]}[Data],
  Navigation_2 = Navigation_1{[warehouseId = "3ca38f6c-666b-4f50-ab1b-bb72cf1778ea"]}[Data],
  TableNavigation = Navigation_2{[Item = "SupplyPlanDetailToday", Schema = "dbo"]}?[Data]?
in
  TableNavigation;
