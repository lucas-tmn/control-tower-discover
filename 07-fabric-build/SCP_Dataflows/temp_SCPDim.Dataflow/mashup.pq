shared ItemMaster = // Current Product Details
let
  Source = Sql.Database("ashley-edw.database.windows.net", "ashley_edw", [CommandTimeout = #duration(0, 1, 0, 0), CreateNavigationProperties = false]),
  #"Navigation 1" = Source{[Schema = "PowerBI_SupplyChain", Item = "CurrentProductDetails"]}[Data],
  #"Filtered rows" = Table.SelectRows(#"Navigation 1", each [Series Number] <> "#TRUD" and [Series Number] <> ".620 " and [Series Number] <> "00000" and [Series Number] <> "00001"),
  #"Sorted rows" = Table.Sort(#"Filtered rows", {{"Item SKU", Order.Ascending}}),
  #"Trimmed text" = Table.TransformColumns(#"Sorted rows", {{"Item SKU", each Text.Trim(_), type text}}),
  #"Duplicated column" = Table.DuplicateColumn(#"Trimmed text", "HS Exclusive Flag", "HSExclusiveFlag"),
  #"Removed duplicates" = Table.Distinct(#"Duplicated column", {"Item SKU"})
in
  #"Removed duplicates";
shared ItemMaster_DataDestination = let
  Pattern = Fabric.Warehouse([CreateNavigationProperties = false]),
  Navigation_1 = Pattern{[workspaceId = "c8d9fc83-18b6-4e1d-8264-0b49eed36fe0"]}[Data],
  Navigation_2 = Navigation_1{[warehouseId = "3ca38f6c-666b-4f50-ab1b-bb72cf1778ea"]}[Data],
