let
  Source = Sql.Database("ashley-edw.database.windows.net", "ashley_edw", [CommandTimeout = #duration(0, 1, 0, 0), Query = "/***** PowerBI_SupplyChain.AshleyFiscalCalendar ******/#(lf)#(lf)SELECT [DateID] AS [Transaction Date]#(lf)      ,[DateKey] AS [Integer Date]#(lf)      ,[MapicsDate] AS [Mapics Date]#(lf)#(tab)  ,[CalendarDayOfWeekName] AS [Day of Week]#(lf)#(tab)  ,[FiscalWeek] AS [Fiscal Week Num]#(lf)#(tab)  ,CONCAT('FW ', RIGHT(CONCAT('00',[FiscalWeek]),2)) AS [FW Desc]#(lf)#(tab)  ,[FiscalWeekYear] AS [Fiscal Year Week Num]#(lf)#(tab)  ,[FiscalMonth] AS [Fiscal Month Num]#(lf)#(tab)  ,CONCAT('FM ', RIGHT(CONCAT('00',[FiscalMonth]),2)) AS [FM Desc]#(lf)#(tab)  ,FORMAT(CONVERT(DATE,CONCAT([FiscalMonthYear],'01')), 'MMM') AS [Fiscal Month Name]#(lf)#(tab)  ,[FiscalMonthYear] AS [Fiscal Year Month Num]#(lf)#(tab)  ,FORMAT(CONVERT(DATE,CONCAT([FiscalMonthYear],'01')), 'MMM yyyy') AS [Fiscal Month Year Desc]#(lf)#(tab)  ,CONVERT(DATE,CONCAT([FiscalMonthYear],'01')) AS [Fiscal Month Calendar Start]#(lf)#(tab)  ,[FiscalQuarter] AS [Fiscal Quarter Num]#(lf)#(tab)  ,CONCAT('FQ ', RIGHT(CONCAT('00',[FiscalQuarter]),2)) AS [FQ Desc]#(lf)#(tab)  ,[FiscalSemesterYear] AS [Fiscal Year Half Num]#(lf)#(tab)  ,[FiscalSemester] AS [Fiscal Half Num]  #(lf)#(tab)  ,CONCAT('FH ', RIGHT(CONCAT('00',[FiscalSemester]),2)) AS [FH Desc]#(lf)#(tab)  ,[FiscalYear] AS [Fiscal Year]#(lf)#(tab)  ,CONCAT('FY ', [FiscalYear]) AS [FY Desc]#(lf)#(tab)  ,CONVERT(DATE,[FiscalWeekFirstDate]) AS [Fiscal Week Start]#(lf)#(tab)  ,CONVERT(DATE, [FiscalWeekLastDate]) AS [Fiscal Week End]#(lf)#(tab)  ,CONVERT(DATE,[FiscalMonthFirstDate]) AS [Fiscal Month Start]#(lf)#(tab)  ,CONVERT(DATE,[FiscalMonthLastDate]) AS [Fiscal Month End]#(lf)#(tab)  ,CONVERT(DATE,[FiscalYearFirstDate]) AS [Fiscal Year Start]#(lf)#(tab)  ,CONVERT(DATE,[FiscalYearLastDate]) AS [Fiscal Year End]#(lf)#(tab)  ,[HolidayIndicator] AS [Holiday Indicator]#(lf)#(tab)  ,[HolidayName] AS [Holiday Name]#(lf)#(tab)  ,[WeekdayWeekend]#(lf)#(tab)  ,[CalendarWeek] AS [Calendar Week Num]#(lf)#(tab)  ,[CalendarMonth] AS [Calendar Month Num]#(lf)#(tab)  ,[CalendarQuarter] AS [Calendar Quarter Num]#(lf)#(tab)  ,[CalendarYear] AS [Calendar Year]#(lf)#(tab)  ,[FiscalDateIndicator] AS [Fiscal Day Indicator]#(lf)      ,[FiscalWeekIndicator] AS [Fiscal Week Indicator]#(lf)      ,[FiscalMonthIndicator] AS [Fiscal Month Indicator]#(lf)      ,[FiscalQuarterIndicator] AS [Fiscal Quarter Indicator]#(lf)      ,[FiscalYearIndicator] AS [Fiscal Year Indicator]#(lf)  FROM [Enterprise_DW].[DimDate]#(lf)  WHERE [FiscalYearIndicator] BETWEEN -4 AND 4#(lf)", CreateNavigationProperties = false]),
  #"Changed column type" = Table.TransformColumnTypes(Source, {{"Transaction Date", type date}, {"Fiscal Month Calendar Start", type date}, {"Fiscal Week Start", type date}, {"Fiscal Week End", type date}, {"Fiscal Month Start", type date}, {"Fiscal Month End", type date}, {"Fiscal Year Start", type date}, {"Fiscal Year End", type date}, {"Fiscal Month Num", Int64.Type}, {"Fiscal Quarter Num", Int64.Type}, {"Fiscal Half Num", Int64.Type}, {"Calendar Week Num", Int64.Type}, {"Calendar Month Num", Int64.Type}, {"Calendar Quarter Num", Int64.Type}, {"Fiscal Week Num", Int64.Type}})
