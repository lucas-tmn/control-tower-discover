	measure Pct_wMAPE = ```
			DIVIDE([Qty_Abs_Bias] , [Qty_Actual] , BLANK() ) 
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: ec0572e3-a4ba-4bb0-a420-db626c8c8aad

	measure Pct_MPE = DIVIDE([Qty_Bias] , [Qty_Actual] , BLANK())
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: f02ed56f-1f56-4593-81df-672aca3cd9ae

	measure Pct_MAPE = ```
			
			AVERAGEX(
			    FILTER(fact_forecast_kpi , NOT ISBLANK(fact_forecast_kpi[qty_actual]) && fact_forecast_kpi[qty_actual] <> 0) , 
			    DIVIDE(fact_forecast_kpi[qty_abs_fcst_error] , fact_forecast_kpi[qty_actual] , BLANK() ))
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 5ea554a0-13f0-4a53-a329-23d55674b077

	measure Pct_RMSE_Final_Fcst = ```
			
			// VAR x2 = POWER(SELECTEDVALUE(fact_forecast_kpi[qty_fcst_error]) , 2) 
			// VAR RME = DIVIDE( x2 , DISTINCTCOUNT(fact_for 
			// RETURN 
			SQRT(
			    AVERAGEX(
			       fact_forecast_kpi,
			        POWER(fact_forecast_kpi[qty_fcst_error], 2)
			    )
			)
			
			```
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 5d8f3f9b-fe59-4908-a108-545ba165cbe7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ProcessValueAdd = ```
			[Pct_NwMAPE] - [Pct_wMAPE] 
			```
		formatString: #,0.0%;-#,0.0%;#,0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 07e5c8e3-8fc7-4921-8925-63e5e2780bcf

	measure Pct_NwMAPE = ```
			DIVIDE([Qty_Abs_NBias] , [Qty_Actual] , BLANK() ) 
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 8ef262eb-e12d-4ae0-b592-6aba3a04911f

	measure Pct_ForecastAccuracy = ```
			
			VAR MaxDateInRow = MAX('fact_forecast_kpi'[dt_fsc_month_last])
			VAR CurrentDate = TODAY()
			VAR wMAPE = [Pct_wMAPE]
			
			RETURN
			IF (
			    -- Điều kiện: Nếu ngày tháng dự báo nhỏ hơn hoặc bằng hôm nay
			    MaxDateInRow <= CurrentDate,
			    
			    -- Thực hiện công thức gốc, cho phép kết quả âm
			    1 - wMAPE,
			    
			    -- Nếu là ngày tương lai thì để trống
			    BLANK()
			)
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 75955bb4-f1fd-453a-971a-9a5431dbd1c8

	measure Pct_ForecastAccuracy_lm = CALCULATE([Pct_ForecastAccuracy] , DATEADD(dim_calendar[dt_date] , -1 , MONTH))
