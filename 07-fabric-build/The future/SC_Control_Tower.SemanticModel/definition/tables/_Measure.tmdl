	measure Pct_ForecastAccuracy_lq =
			VAR CurrentMonths =
			    VALUES(dim_calendar[num_fsc_month_year])
			VAR MonthCount =
			    COUNTROWS(CurrentMonths)
			VAR CurrentQuarters =
			    VALUES(dim_calendar[num_fsc_quarter_year])
			VAR PrevQuarter =
			    SELECTCOLUMNS(
			        CurrentQuarters,
			        "num_fsc_quarter_year",
			            VAR CurrentQuarterKey = dim_calendar[num_fsc_quarter_year]
			            RETURN
			                MAXX(
			                    FILTER(
			                        ALL(dim_calendar[num_fsc_quarter_year]),
			                        dim_calendar[num_fsc_quarter_year] < CurrentQuarterKey
			                    ),
			                    dim_calendar[num_fsc_quarter_year]
			                )
			    )
			VAR RollingPrevQuarterMonths =
			    SELECTCOLUMNS(
			        CurrentMonths,
			        "num_fsc_month_year",
			            VAR CurrentMonthKey = dim_calendar[num_fsc_month_year]
			            VAR PriorThreeMonths =
			                TOPN(
			                    3,
			                    FILTER(
			                        ALL(dim_calendar[num_fsc_month_year]),
			                        dim_calendar[num_fsc_month_year] < CurrentMonthKey
			                    ),
			                    dim_calendar[num_fsc_month_year], DESC
			                )
			            RETURN
			                MINX(
			                    PriorThreeMonths,
			                    dim_calendar[num_fsc_month_year]
			                )
			    )
			RETURN
			IF(
			    MonthCount = 1,
			    CALCULATE(
			        [Pct_ForecastAccuracy],
			        REMOVEFILTERS(dim_calendar),
			        TREATAS(
			            PrevQuarter,
			            dim_calendar[num_fsc_quarter_year]
			        )
			    ),
			    CALCULATE(
			        [Pct_ForecastAccuracy],
			        REMOVEFILTERS(dim_calendar),
			        TREATAS(
			            RollingPrevQuarterMonths,
			            dim_calendar[num_fsc_month_year]
			        )
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: e3c126db-6991-47d3-a9ba-9579570b85df

