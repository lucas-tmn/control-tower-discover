/// Primary KPI fact table for forecast accuracy. Stores forecast, actual, naive forecast, signed error, absolute error, squared error, and validation flags at item-warehouse-horizon-fiscal month grain.
table fact_forecast_kpi
	lineageTag: 9c255cc1-3896-4edb-99dc-9cd835013b78
	sourceLineageTag: [dbo].[fact_forecast_kpi]

	/// Item SKU identifier for joining to the product dimension and evaluating KPI performance at item level.
	column id_item_sku
		dataType: string
		lineageTag: ea038dd9-c48d-4d08-b5ee-b3b130b0a513
		sourceLineageTag: id_item_sku
		summarizeBy: none
		sourceColumn: id_item_sku

		annotation SummarizationSetBy = Automatic

	/// Warehouse code for joining to the warehouse dimension and evaluating KPI performance by location.
