			    CALCULATE(
			        MAX('fact_flat_forecast_actual'[name_version]),
			        FILTER(
			            VersionTable,
			            'fact_flat_forecast_actual'[name_version] < LatestVersion
			        )
			    )
			
			VAR YearText = MID(SecondLatestVersion, 3, 4)
