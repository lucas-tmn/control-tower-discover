	/// Root mean squared naive forecast error across valid observations. Used to compare the naive baseline against the consensus forecast.
	measure RMSE_Naive = SQRT ( DIVIDE ( SUM ( fact_forecast_kpi[qty_squared_naive_fcst_error] ), SUM ( fact_forecast_kpi[valid_obs_flag] ) ) )
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 10fc8df1-4b5c-4177-b855-1cdc8c64e26d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Forecast accuracy for the prior fiscal quarter comparison. For multi-month selections, compares against the same-length window shifted back one fiscal quarter.
	measure Pct_ForecastAccuracy_lq =
			VAR CurrentMonths =
			    VALUES(dim_calendar[num_fsc_month_year])
			VAR MonthCount =
			    COUNTROWS(CurrentMonths)
			VAR CurrentQuarters =
			    VALUES(dim_calendar[num_fsc_quarter_year])
			VAR PrevQuarter =
			    SELECTCOLUMNS(
			        CurrentQuarters,
			        "num_fsc_quarter_year",
			            VAR CurrentQuarterKey = dim_calendar[num_fsc_quarter_year]
			            RETURN
			                MAXX(
			                    FILTER(
			                        ALL(dim_calendar[num_fsc_quarter_year]),
			                        dim_calendar[num_fsc_quarter_year] < CurrentQuarterKey
			                    ),
			                    dim_calendar[num_fsc_quarter_year]
			                )
			    )
			VAR RollingPrevQuarterMonths =
			    SELECTCOLUMNS(
			        CurrentMonths,
			        "num_fsc_month_year",
			            VAR CurrentMonthKey = dim_calendar[num_fsc_month_year]
			            VAR PriorThreeMonths =
			                TOPN(
			                    3,
			                    FILTER(
			                        ALL(dim_calendar[num_fsc_month_year]),
			                        dim_calendar[num_fsc_month_year] < CurrentMonthKey
			                    ),
			                    dim_calendar[num_fsc_month_year], DESC
			                )
			            RETURN
			                MINX(
			                    PriorThreeMonths,
			                    dim_calendar[num_fsc_month_year]
			                )
			    )
			RETURN
			IF(
			    MonthCount = 1,
			    CALCULATE(
			        [Pct_ForecastAccuracy],
			        REMOVEFILTERS(dim_calendar),
			        TREATAS(
			            PrevQuarter,
			            dim_calendar[num_fsc_quarter_year]
			        )
			    ),
			    CALCULATE(
			        [Pct_ForecastAccuracy],
			        REMOVEFILTERS(dim_calendar),
			        TREATAS(
			            RollingPrevQuarterMonths,
			            dim_calendar[num_fsc_month_year]
			        )
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: 4f3c9dc7-00db-4d23-9073-436de685e8fa

	/// Static background color value used for RMSE table visual conditional formatting.
	measure RMSE_Table_Background_Color = "#D9D9D9"
		displayFolder: 3. Narrative
		lineageTag: ed672d4d-4f71-4299-b26c-cb3509a15ac6

	/// Returns the current date for report refresh or display context.
	measure UpdatedTime = TODAY()
		formatString: Short Date
		displayFolder: 1. Main KPIs - Forecast Accuracy
		lineageTag: a6f930f8-9803-4f65-9c74-86c9964b885a

	column Column
		formatString: 0
		lineageTag: 217e11fc-f4f8-4877-bbca-2be96a883c17
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Column]

		annotation SummarizationSetBy = Automatic

	partition _Measure = calculated
		mode: import
		source = Row("Column", BLANK())

	annotation PBI_Id = a0e04b233e184edda29637f74fe09972

	annotation 436ba87b-9c83-4389-a31b-ebd06a36be98 = {"Expression":""}

