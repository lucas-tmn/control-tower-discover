                                                                           "expression":  [
                                                                                              "// Current Product Details (BI Dev Dataflow)",
                                                                                              "    // Source PowerBI_Supplychain.CurrentProductDetails",
                                                                                              "let",
                                                                                              "    Source = PowerBI.Dataflows(null),",
                                                                                              "    #\"a47e4573-c455-40af-a9ad-e22c81a07926\" = Source{[workspaceId=\"a47e4573-c455-40af-a9ad-e22c81a07926\"]}[Data],",
                                                                                              "    #\"346f2aa1-dd50-4c11-9630-b17f75854663\" = #\"a47e4573-c455-40af-a9ad-e22c81a07926\"{[dataflowId=\"346f2aa1-dd50-4c11-9630-b17f75854663\"]}[Data],",
                                                                                              "    CurrentProductDetails1 = #\"346f2aa1-dd50-4c11-9630-b17f75854663\"{[entity=\"CurrentProductDetails\"]}[Data],",
                                                                                              "    #\"Added Custom\" = Table.AddColumn(CurrentProductDetails1, \"Initial Invoice Date\", each if [Initial Invoice Period] = \"\" then Date.FromText(\"01/01/2000\") else Date.FromText(Text.Combine({Text.BeforeDelimiter([Initial Invoice Period],\"/\"),\"15\",Text.End([Initial Invoice Period],4)},\"/\"))),",
                                                                                              "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Added Custom\",{{\"Initial Invoice Date\", type date}}),",
                                                                                              "    #\"Added Custom1\" = Table.AddColumn(#\"Changed Type\", \"Invoiced Months\", each Number.Round(Number.IntegerDivide(Duration.Days(Date.From(DateTime.LocalNow()) - [Initial Invoice Date]), 30.4), 0)),",
                                                                                              "    #\"Changed Type1\" = Table.TransformColumnTypes(#\"Added Custom1\",{{\"Invoiced Months\", Int64.Type}})",
                                                                                              "in",
                                                                                              "    #\"Changed Type1\""
                                                                                          ],
                                                                           "type":  "m"
                                                                       }
                                                        }
                                                    ]
                                 },
