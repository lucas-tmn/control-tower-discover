                                     "hierarchies":  [
                                                         {
                                                             "name":  "SeriesNumber Hierarchy",
                                                             "levels":  [
                                                                            {
                                                                                "name":  "SeriesNumber",
                                                                                "column":  "SeriesNumber",
                                                                                "lineageTag":  "bb578f81-3431-439b-ad25-0d333abf8ba7",
                                                                                "ordinal":  0
                                                                            },
                                                                            {
                                                                                "name":  "Item",
                                                                                "column":  "Item",
                                                                                "lineageTag":  "ede2b703-3970-4fca-b24d-5b4125da8f21",
                                                                                "ordinal":  1
                                                                            }
                                                                        ],
                                                             "lineageTag":  "b1a0dad9-02ff-4f09-b6ac-150141baf27e"
                                                         }
                                                     ],
                                     "lineageTag":  "0ec7f830-b283-4737-9da7-e24ed44fb32d",
                                     "partitions":  [
                                                        {
                                                            "name":  "InventoryHistory-7af24d9d-1787-4aa4-aaa6-feabb03a7aa9",
                                                            "mode":  "import",
                                                            "source":  {
                                                                           "expression":  [
                                                                                              "// InventoryHistory data for Complete Series In Stock report",
                                                                                              "    // Converted to dataflow 03/31/2020",
                                                                                              "   ",
                                                                                              "let",
                                                                                              "    Source = PowerBI.Dataflows(null),",
                                                                                              "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                                                                                              "    #\"db1585dc-c1b6-4785-a831-2d559d866767\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"db1585dc-c1b6-4785-a831-2d559d866767\"]}[Data],",
                                                                                              "    InventoryHistory1 = #\"db1585dc-c1b6-4785-a831-2d559d866767\"{[entity=\"InventoryHistory\"]}[Data]",
                                                                                              "in",
                                                                                              "    InventoryHistory1",
                                                                                              "",
                                                                                              "",
                                                                                              "",
                                                                                              "/* Original query driving dataflow ",
                                                                                              "",
                                                                                              "let",
                                                                                              "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                                                                                              "    --Dev.CompleteSeriesInStock Update",
                                                                                              "",
                                                                                              "",
                                                                                              "",
                                                                                              "-- Get most recently completed week from Demand Fulfillment",
                                                                                              "DECLARE @EndDate date",
                                                                                              "SET @EndDate = (SELECT MAX([WeekEnding]) FROM [SupplyChain_Enh].[DemandFulfillmentCommonContainer_Logility])",
                                                                                              "",
                                                                                              "-- Most recently completed",
                                                                                              "DECLARE @EndDateAvg date",
                                                                                              "SET @EndDateAvg = DATEADD(WEEK,-1,@EndDate)",
                                                                                              "",
                                                                                              "DECLARE @StartDateAvg date",
                                                                                              "SET @StartDateAvg = DATEADD(WEEK,-26,@EndDateAvg)",
                                                                                              "",
                                                                                              "DECLARE @StartDate date",
                                                                                              "SET @StartDate = DATEADD(WEEK,-13,@EndDateAvg)",
                                                                                              "",
                                                                                              "DECLARE @SeriesProp DECIMAL(4,3)",
                                                                                              "SET @SeriesProp = .05",
                                                                                              "",
                                                                                              "--SELECT @StartDate AS StartDate, @EndDate AS EndDate, @StartDateAvg AS StartDateAvg, @EndDateAvg AS EndDateAvg",
                                                                                              "",
                                                                                              "",
                                                                                              "-- ALT Series for Upholstery U Skus",
                                                                                              "SELECT [I].[ItemSKU]",
                                                                                              "\t  ,[I].[SeriesNumber]",
                                                                                              "\t  ,[I].[SeriesName]",
                                                                                              "\t  ,[I].[SeriesColor]",
                                                                                              "\t  ,CONCAT([I].[SeriesNumber],\u0027 - \u0027,[I].[SeriesName]) AS SeriesDescription",
                                                                                              "\t  ,[AltSeriesNumber] = ",
                                                                                              "\t\t\tCASE ",
                                                                                              "\t\t\t\tWHEN LEFT([I].[SeriesNumber],1) = \u0027U\u0027",
                                                                                              "\t\t\t\t\tTHEN LEFT([I].[ItemSKU],6)",
                                                                                              "\t\t\t\tELSE [I].[SeriesNumber]",
                                                                                              "\t\t\tEND",
                                                                                              "\t  ,[AltSeriesDescription] = ",
                                                                                              "\t\t\tCASE ",
                                                                                              "\t\t\t\tWHEN LEFT([I].[SeriesNumber],1) = \u0027U\u0027",
                                                                                              "\t\t\t\t\tTHEN CONCAT(LEFT([I].[ItemSKU],6),\u0027 - \u0027,[I].[SeriesName],\u0027 \u0027,[I].[SeriesColor])",
                                                                                              "\t\t\t\tELSE CONCAT([I].[SeriesNumber],\u0027 - \u0027,[I].[SeriesName])",
                                                                                              "\t\t\tEND",
                                                                                              "\t  ,[I].[InitialInvoicePeriod]",
                                                                                              "\t  ,[I].[SellableItemFlag]",
                                                                                              "\t  ,[I].[ManufacturingStatus]",
                                                                                              "\t  ,[I].[AFISalesDivision]",
                                                                                              "INTO #AltSeries",
                                                                                              "  FROM [Enterprise_DW].[DimItemMaster] AS I",
                                                                                              "  WHERE [I].[InitialInvoicePeriod] IS NOT NULL",
                                                                                              "\t  AND [I].[SellableItemFlag] = \u0027Y\u0027",
                                                                                              "\t  AND [I].[ManufacturingStatus] NOT IN (\u0027Discontinued\u0027,\u0027Deleted\u0027,\u0027Tentative\u0027,\u0027Replaced\u0027)",
                                                                                              "",
                                                                                              "",
                                                                                              "",
                                                                                              "-- Get Order History last 26 weeks by original request date",
                                                                                              "SELECT O2.ADITEM",
                                                                                              "      ,O2.AHWHSE",
                                                                                              "\t  ,SUM([ORIG].[ADQNTY]) AS OrigReqQty",
                                                                                              "\t  --,CONVERT(DATE,[NetQ].[AHORDT_Date]) AS OrderEntry",
                                                                                              "\t  ,CONVERT(DATE,DATEADD(DAY,7 - DATEPART(WEEKDAY, [ORIG].[ADRQDT_Date]),[ORIG].[ADRQDT_Date])) AS [OrigReqWeekEnding]",
                                                                                              "\t  --,CONVERT(DATE,[LCHNG].[ADRQDT_Date]) AS [CurrentReqDate]",
                                                                                              "\t  --,[NetQ].[ADQNTY] AS [CurrentReqQty]",
                                                                                              "\t  --,[LCHNG].[ADQNTY] AS [LastQtyAdjustment]",
                                                                                              "INTO #OrdHist",
                                                                                              "FROM (",
                                                                                              "",
                                                                                              "-- Pull in 6 columns for unique combinations",
                                                                                              "      SELECT O.AHORNO",
                                                                                              "            ,O.AHCUST",
                                                                                              "            ,O.AHSHIP",
                                                                                              "            ,O.AHWHSE",
                                                                                              "            ,O.ADITEM",
                                                                                              "            ,O.ADITMS",
                                                                                              "            --,[O].[AHORDT_Date]",
                                                                                              "            ,MIN(O.ADCHGD_Date + CAST(T.TimeOfDayMilitary AS DATETIME)) AS [InitialOrderEntry]",
                                                                                              "            --,MAX(O.ADCHGD_Date + CAST(T.TimeOfDayMilitary AS DATETIME)) AS [LastOrderChange]",
                                                                                              "        FROM [AFISales_Enh].[OrderHistory] AS O",
                                                                                              "            ",
                                                                                              "            LEFT JOIN Enterprise_DW.DimTime AS T",
                                                                                              "                  ON T.TimeID = O.ADCHGT",
                                                                                              "            ",
                                                                                              "            WHERE  DATEADD(dd, 7 - DATEPART(dw, CONVERT(date,O.[ADRQDT_Date])), CONVERT(date,O.[ADRQDT_Date])) BETWEEN @StartDateAvg AND @EndDateAvg",
                                                                                              "\t\t\t  AND O.ADITEM IN (SELECT [ItemSKU] FROM #AltSeries)",
                                                                                              "\t\t\t\t\t\t  AND O.AHWHSE NOT IN (\u002755 \u0027,\u0027CNW\u0027,\u0027C  \u0027,\u0027232\u0027)",
                                                                                              "            GROUP BY [O].[AHORNO],",
                                                                                              "                  [O].[AHCUST],",
                                                                                              "                  [O].[AHSHIP],",
                                                                                              "                  [O].[AHWHSE],",
                                                                                              "                  [O].[ADITEM],",
                                                                                              "                  [O].[ADITMS]",
                                                                                              "                        --[O].[AHORDT_Date]",
                                                                                              "\t) AS O2",
                                                                                              "",
                                                                                              "      -- Use initial order entry to find original qty and request date to O2",
                                                                                              "            LEFT JOIN (",
                                                                                              "                  SELECT O.AHORNO",
                                                                                              "                        ,O.AHCUST",
                                                                                              "                        ,O.AHSHIP",
                                                                                              "                        ,O.AHWHSE",
                                                                                              "                        ,O.ADITEM",
                                                                                              "                        ,O.ADITMS",
                                                                                              "                        ,SUM(O.[ADQNTY]) AS ADQNTY",
                                                                                              "                        ,[O].[ADRQDT_Date]",
                                                                                              "                        ,O.ADCHGD_Date + CAST(T.TimeOfDayMilitary AS DATETIME) AS [OrdChange]",
                                                                                              "                  FROM [AFISales_Enh].[OrderHistory] AS O",
                                                                                              "                        ",
                                                                                              "                        LEFT JOIN Enterprise_DW.DimTime AS T",
                                                                                              "                              ON T.TimeID = O.ADCHGT",
                                                                                              "                        ",
                                                                                              "                        WHERE  DATEADD(dd, 7 - DATEPART(dw, CONVERT(date,O.[ADRQDT_Date])), CONVERT(date,O.[ADRQDT_Date])) BETWEEN @StartDateAvg AND @EndDateAvg",
                                                                                              "\t\t\t\t\t\t\tAND O.ADITEM IN (SELECT [ItemSKU] FROM #AltSeries)",
                                                                                              "\t\t\t\t\t\t  AND O.AHWHSE NOT IN (\u002755 \u0027,\u0027CNW\u0027,\u0027C  \u0027,\u0027232\u0027)",
                                                                                              "                        GROUP BY O.ADCHGD_Date + CAST(T.TimeOfDayMilitary AS DATETIME),",
                                                                                              "                              [O].[AHORNO],",
                                                                                              "                              [O].[AHCUST],",
                                                                                              "                              [O].[AHSHIP],",
                                                                                              "                              [O].[AHWHSE],",
                                                                                              "                              [O].[ADITEM],",
                                                                                              "                              [O].[ADITMS],",
                                                                                              "                              [O].[ADRQDT_Date]",
                                                                                              "            ) AS ORIG",
                                                                                              "                  ON [O2].[InitialOrderEntry] = [ORIG].[OrdChange]",
                                                                                              "                  AND [O2].[AHORNO] = [ORIG].[AHORNO]",
                                                                                              "                  AND [O2].[AHCUST] = [ORIG].[AHCUST]",
                                                                                              "                  AND [O2].[AHSHIP] = [ORIG].[AHSHIP]",
                                                                                              "                  AND [O2].[AHWHSE] = [ORIG].[AHWHSE]",
                                                                                              "                  AND [O2].[ADITEM] = [ORIG].[ADITEM]",
                                                                                              "                  AND [O2].[ADITMS] = [ORIG].[ADITMS]",
                                                                                              "      ",
                                                                                              "      -- Use Last Change datetime to pull in current request date to O2",
                                                                                              "            --LEFT JOIN (",
                                                                                              "            --      SELECT O.AHORNO",
                                                                                              "            --            ,O.AHCUST",
                                                                                              "            --            ,O.AHSHIP",
                                                                                              "            --            ,O.AHWHSE",
                                                                                              "            --            ,O.ADITEM",
                                                                                              "            --            ,O.ADITMS",
                                                                                              "            --            ,SUM(O.[ADQNTY]) AS ADQNTY",
                                                                                              "            --            ,[O].[ADRQDT_Date]",
                                                                                              "            --            ,O.ADCHGD_Date + CAST(T.TimeOfDayMilitary AS DATETIME) AS [OrdChange]",
                                                                                              "            --        FROM [AFISales_Enh].[OrderHistory] AS O",
                                                                                              "                        ",
                                                                                              "            --            LEFT JOIN Enterprise_DW.DimTime AS T",
                                                                                              "            --                  ON T.TimeID = O.ADCHGT",
                                                                                              "                        ",
                                                                                              "            --            WHERE  DATEADD(dd, 7 - DATEPART(dw, CONVERT(date,O.[ADRQDT_Date])), CONVERT(date,O.[ADRQDT_Date])) BETWEEN @StartDate AND @EndDate",
                                                                                              "            --            GROUP BY O.ADCHGD_Date + CAST(T.TimeOfDayMilitary AS DATETIME),",
                                                                                              "            --                  [O].[AHORNO],",
                                                                                              "            --                  [O].[AHCUST],",
                                                                                              "            --                  [O].[AHSHIP],",
                                                                                              "            --                  [O].[AHWHSE],",
                                                                                              "            --                  [O].[ADITEM],",
                                                                                              "            --                  [O].[ADITMS],",
                                                                                              "            --                  [O].[ADRQDT_Date]",
                                                                                              "            --      ) AS LCHNG",
                                                                                              "            --            ON [O2].[LastOrderChange] = [LCHNG].[OrdChange]",
                                                                                              "            --            AND [O2].[AHORNO] = [LCHNG].[AHORNO]",
                                                                                              "            --            AND [O2].[AHCUST] = [LCHNG].[AHCUST]",
                                                                                              "            --            AND [O2].[AHSHIP] = [LCHNG].[AHSHIP]",
                                                                                              "            --            AND [O2].[AHWHSE] = [LCHNG].[AHWHSE]",
                                                                                              "            --            AND [O2].[ADITEM] = [LCHNG].[ADITEM]",
                                                                                              "            --            AND [O2].[ADITMS] = [LCHNG].[ADITMS]",
                                                                                              "            ",
                                                                                              "      -- Sum all PO changes to get final result (ie. cancellations net to zero) Join to 02",
                                                                                              "            LEFT JOIN (",
                                                                                              "                  SELECT O.AHORNO",
                                                                                              "                        ,O.AHCUST",
                                                                                              "                        ,O.AHSHIP",
                                                                                              "                        ,O.AHWHSE",
                                                                                              "                        ,O.ADITEM",
                                                                                              "                        ,O.ADITMS",
                                                                                              "                        ,[O].[AHORDT_Date]",
                                                                                              "                        ,SUM(O.[ADQNTY]) AS ADQNTY",
                                                                                              "                        --,[O].[ADRQDT_Date]",
                                                                                              "                  --   ,O.ADCHGD_Date + CAST(T.TimeOfDayMilitary AS DATETIME) AS [OrdChange]",
                                                                                              "                    FROM [AFISales_Enh].[OrderHistory] AS O",
                                                                                              "                        ",
                                                                                              "                        --LEFT JOIN Enterprise_DW.DimTime AS T",
                                                                                              "                        --     ON T.TimeID = O.ADCHGT",
                                                                                              "                        ",
                                                                                              "                        WHERE O.ADITEM IN (SELECT [ItemSKU] FROM #AltSeries)",
                                                                                              "\t\t\t\t\t\t  AND O.AHWHSE NOT IN (\u002755 \u0027,\u0027CNW\u0027,\u0027C  \u0027,\u0027232\u0027)",
                                                                                              "                        GROUP BY [O].[AHORNO],",
                                                                                              "                              [O].[AHCUST],",
                                                                                              "                              [O].[AHSHIP],",
                                                                                              "                              [O].[AHWHSE],",
                                                                                              "                              [O].[ADITEM],",
                                                                                              "                              [O].[ADITMS],",
                                                                                              "                                    [O].[AHORDT_Date]",
                                                                                              "                  ) AS NetQ",
                                                                                              "                        ON [O2].[AHORNO] = [NetQ].[AHORNO]",
                                                                                              "                        AND [O2].[AHCUST] = [NetQ].[AHCUST]",
                                                                                              "                        AND [O2].[AHSHIP] = [NetQ].[AHSHIP]",
                                                                                              "                        AND [O2].[AHWHSE] = [NetQ].[AHWHSE]",
                                                                                              "                        AND [O2].[ADITEM] = [NetQ].[ADITEM]",
                                                                                              "                        AND [O2].[ADITMS] = [NetQ].[ADITMS]",
                                                                                              "-- End table conditions",
                                                                                              "      WHERE [NetQ].[ADQNTY] \u003e 0 -- remove cancellations",
                                                                                              "\t    --AND O2.[AHWHSE] NOT IN (\u002755 \u0027,\u0027CNW\u0027,\u0027C  \u0027,\u0027232\u0027)",
                                                                                              "",
                                                                                              "\t  GROUP BY O2.ADITEM",
                                                                                              "\t\t\t  ,O2.AHWHSE",
                                                                                              "\t\t\t  ,CONVERT(DATE,DATEADD(DAY,7 - DATEPART(WEEKDAY, [ORIG].[ADRQDT_Date]),[ORIG].[ADRQDT_Date]))",
                                                                                              "",
                                                                                              "",
                                                                                              "",
                                                                                              "",
                                                                                              "",
                                                                                              "-- Calculate 13 wk moving averages at Item-WH Level",
                                                                                              "SELECT A3.ADITEM",
                                                                                              "\t  ,A3.AHWHSE",
                                                                                              "\t  ,[AltSer].[AltSeriesDescription]",
                                                                                              "\t  ,A3.ADQNTY AS AvgItemQty",
                                                                                              "\t  ,A3.WeekEnding",
                                                                                              "INTO #ItemAvg",
                                                                                              "FROM (",
                                                                                              "\tSELECT [A2].[ADITEM]",
                                                                                              "\t\t  ,[A2].[AHWHSE]",
                                                                                              "\t\t  ,CAST(AVG(CAST([A2].[ADQNTY] AS DECIMAL(10,2))) OVER (PARTITION BY A2.[ADITEM], A2.[AHWHSE] ORDER BY [A2].[WeekEnding] ROWS BETWEEN 12 PRECEDING AND CURRENT ROW) AS DECIMAL(10,2)) AS ADQNTY",
                                                                                              "\t\t  ,[A2].[WeekEnding]",
                                                                                              "\t\tFROM (",
                                                                                              "",
                                                                                              "\t\t\tSELECT [A].[ADITEM]",
                                                                                              "\t\t\t\t  ,[A].[AHWHSE]",
                                                                                              "\t\t\t\t  ,[A].[WeekEnding]",
                                                                                              "\t\t\t\t  ,ADQNTY = ",
                                                                                              "\t\t\t\t\t\tCASE ",
                                                                                              "\t\t\t\t\t\t\tWHEN [Dem].[OrigReqQty] IS NULL",
                                                                                              "\t\t\t\t\t\t\t\tTHEN 0",
                                                                                              "\t\t\t\t\t\t\tELSE [Dem].[OrigReqQty]",
                                                                                              "\t\t\t\t\t\tEND",
                                                                                              "\t\t\tFROM (",
                                                                                              "\t\t\tSELECT DISTINCT D.[ADITEM]",
                                                                                              "\t\t\t\t  ,D.[AHWHSE]",
                                                                                              "\t\t\t\t  ,T.[WeekEnding]",
                                                                                              "\t\t\t  FROM [#OrdHist] AS D",
                                                                                              "\t\t\t  CROSS JOIN ( ",
                                                                                              "\t\t\t\t\tSELECT DISTINCT CONVERT(DATE,[FiscalWeekLastDate]) AS WeekEnding",
                                                                                              "\t\t\t\t\t  FROM [Enterprise_DW].[DimDate]",
                                                                                              "\t\t\t\t\t  WHERE [FiscalWeekLastDate] BETWEEN @StartDateAvg AND @EndDateAvg",
                                                                                              "\t\t\t\t\t) AS T",
                                                                                              "\t\t\t  ) AS A",
                                                                                              "\t\tLEFT JOIN [#OrdHist] AS Dem",
                                                                                              "\t\t  ON [A].[ADITEM] = [Dem].[ADITEM]",
                                                                                              "\t\t\tAND [A].[AHWHSE] = [Dem].[AHWHSE]",
                                                                                              "\t\t\tAND [A].[WeekEnding] = [Dem].[OrigReqWeekEnding]",
                                                                                              "",
                                                                                              "\t\t) AS A2",
                                                                                              "\t) AS A3",
                                                                                              "LEFT JOIN [#AltSeries] AS AltSer",
                                                                                              "  ON [A3].[ADITEM] = [AltSer].[ItemSKU]",
                                                                                              "WHERE A3.WeekEnding \u003e= @StartDate ",
                                                                                              "",
                                                                                              "",
                                                                                              "",
                                                                                              "-- Calculate Series Averages",
                                                                                              "SELECT [ItemAvg].[AltSeriesDescription]",
                                                                                              "\t  ,[ItemAvg].[AHWHSE]",
                                                                                              "\t  ,SUM([ItemAvg].AvgItemQty) AS AvgSeriesQty",
                                                                                              "\t  ,[ItemAvg].[WeekEnding]",
                                                                                              "INTO #SeriesAvg",
                                                                                              "  FROM #ItemAvg AS ItemAvg ",
                                                                                              "",
                                                                                              "  GROUP BY [ItemAvg].[AltSeriesDescription]",
                                                                                              "\t\t  ,[ItemAvg].[AHWHSE]",
                                                                                              "\t\t  ,[ItemAvg].[WeekEnding]",
                                                                                              "",
                                                                                              "",
                                                                                              "-- Calculate Averages and Proportions",
                                                                                              "SELECT Avgs.[ADITEM] AS [Item]",
                                                                                              "\t  ,Avgs.[AHWHSE] AS [Location]",
                                                                                              "\t  ,Avgs.[AltSeriesDescription] AS [SeriesDescription]",
                                                                                              "\t  ,Avgs.[AvgItemQty]",
                                                                                              "\t  ,Avgs.[AvgSeriesQty]",
                                                                                              "\t  ,Avgs.[Proportion]",
                                                                                              "\t  ,Avgs.[Week Ending]",
                                                                                              "INTO #Avgs",
                                                                                              "FROM (",
                                                                                              "\tSELECT I.[ADITEM],",
                                                                                              "\t\t   I.[AHWHSE],",
                                                                                              "\t\t   I.[AltSeriesDescription],",
                                                                                              "\t\t   I.[AvgItemQty],",
                                                                                              "\t\t   S.[AvgSeriesQty],",
                                                                                              "\t\t   [Proportion] = ",
                                                                                              "\t\t\t\tCASE ",
                                                                                              "\t\t\t\t\tWHEN S.[AvgSeriesQty] \u003c= 0",
                                                                                              "\t\t\t\t\t\tTHEN 0",
                                                                                              "\t\t\t\t\tELSE (I.[AvgItemQty]/S.[AvgSeriesQty])",
                                                                                              "\t\t\t\tEND,",
                                                                                              "\t\t  [I].[WeekEnding] AS [Week Ending]",
                                                                                              "\t  FROM [#ItemAvg] AS I",
                                                                                              "\t  LEFT JOIN [#SeriesAvg] AS S",
                                                                                              "  \t\tON I.[AltSeriesDescription] = S.[AltSeriesDescription] ",
                                                                                              "  \t\t  AND [I].[AHWHSE] = S.AHWHSE",
                                                                                              "  \t\t  AND [I].[WeekEnding] = [S].[WeekEnding]",
                                                                                              "  \t\t--ORDER BY [I].[SeriesDescription]",
                                                                                              "",
                                                                                              "",
                                                                                              "\tUNION ",
                                                                                              "",
                                                                                              "-- Use Last weeks avg and append with current week ending",
                                                                                              "\tSELECT I.[ADITEM],",
                                                                                              "\t\t   I.[AHWHSE],",
                                                                                              "\t\t   I.[AltSeriesDescription],",
                                                                                              "\t\t   I.[AvgItemQty],",
                                                                                              "\t\t   S.[AvgSeriesQty],",
                                                                                              "\t\t   [Proportion] = ",
                                                                                              "\t\t\t\tCASE ",
                                                                                              "\t\t\t\t\tWHEN S.[AvgSeriesQty] \u003c= 0",
                                                                                              "\t\t\t\t\t\tTHEN 0",
                                                                                              "\t\t\t\t\tELSE (I.[AvgItemQty]/S.[AvgSeriesQty])",
                                                                                              "\t\t\t\tEND,",
                                                                                              "\t\t  DATEADD(DAY, 7, I.[WeekEnding]) AS [Week Ending]",
                                                                                              "\t  FROM [#ItemAvg] AS I",
                                                                                              "\t  LEFT JOIN [#SeriesAvg] AS S",
                                                                                              "  \t\tON I.[AltSeriesDescription] = S.[AltSeriesDescription] ",
                                                                                              "  \t\t  AND [I].[AHWHSE] = S.AHWHSE",
                                                                                              "  \t\t  AND [I].[WeekEnding] = [S].[WeekEnding]",
                                                                                              "  \t\tWHERE I.[WeekEnding] = (SELECT MAX([WeekEnding]) FROM #ItemAvg)",
                                                                                              "\t) AS Avgs",
                                                                                              "",
                                                                                              "",
                                                                                              "-- Get On Hand History and Current OH ",
                                                                                              "SELECT [OH].[Item]",
                                                                                              "      ,[OH].[Location]",
                                                                                              "      ,[OH].[Week Ending]",
                                                                                              "      ,[OH].[OnHandQty]",
                                                                                              "INTO #ItemOH",
                                                                                              "  FROM (",
                                                                                              "\tSELECT D.[Item]",
                                                                                              "\t\t  ,D.[Whse] AS [Location]",
                                                                                              "\t\t  ,D.[WeekEnding] AS [Week Ending]",
                                                                                              "\t\t  ,D.[OnHandQty]",
                                                                                              "\t  FROM [SupplyChain_Enh].[DemandFulfillmentCommonContainer_Logility] AS D",
                                                                                              "\t\tWHERE D.[WeekEnding] BETWEEN @StartDate AND @EndDateAvg",
                                                                                              "\t\t  AND [D].[Item] IN (SELECT [ItemSKU] FROM [#AltSeries])",
                                                                                              "",
                                                                                              "\tUNION",
                                                                                              "",
                                                                                              "\tSELECT S.[spdItem] AS [Item]",
                                                                                              "\t\t  ,S.[spdWarehouse] AS [Warehouse]",
                                                                                              "\t\t  ,CONVERT(DATE,S.[spdWeekEnding]) AS [Week Ending]",
                                                                                              "\t\t  --,[spdBeginingBalance] AS [OnHandQty]",
                                                                                              "\t\t  ,[B].[MOHTQ] AS [OnHandQty]",
                                                                                              "\t  FROM [PowerBI_SupplyChain].[SupplyPlanDetailCurrentDay] AS S",
                                                                                              "\t    LEFT JOIN [MasterData_ItemMaster_AFI].[ITEMBL] AS B",
                                                                                              "\t\t  ON [S].[spdItem] = [B].[ITNBR]",
                                                                                              "\t\t    AND [S].[spdWarehouse] = [B].[HOUSE]",
                                                                                              "\t\tWHERE [spdWeekEnding] = @EndDate",
                                                                                              "\t\t  AND [spdItem] IN (SELECT [ItemSKU] FROM [#AltSeries])",
                                                                                              "\t) AS OH",
                                                                                              "",
                                                                                              "",
                                                                                              "",
                                                                                              "",
                                                                                              "SELECT [D].[Item]",
                                                                                              "\t  ,[AltSer].[AltSeriesNumber] AS [SeriesNumber]",
                                                                                              "\t  ,[AltSer].[AltSeriesDescription]",
                                                                                              "      ,[D].[Location]",
                                                                                              "      ,[D].[Week Ending]",
                                                                                              "      ,[D].[OnHandQty]",
                                                                                              "\t  ,A.[AvgItemQty] AS AvgQty",
                                                                                              "\t  ,QtyShort = ",
                                                                                              "\t\t\tCASE ",
                                                                                              "\t\t\t\tWHEN D.[OnHandQty] - [A].[AvgItemQty] \u003e 0",
                                                                                              "\t\t\t\t\tTHEN 0",
                                                                                              "\t\t\t\tELSE D.[OnHandQty] - [A].[AvgItemQty]",
                                                                                              "\t\t\tEND",
                                                                                              "\t  ,[SKU On Hand] = ",
                                                                                              "\t\t\tCASE ",
                                                                                              "\t\t\t\tWHEN D.[OnHandQty] \u003e 0",
                                                                                              "\t\t\t\t\tTHEN 1",
                                                                                              "\t\t\t\tELSE 0",
                                                                                              "\t\t\tEND",
                                                                                              "\t  ,[SKU In Stock] = ",
                                                                                              "\t\t\tCASE ",
                                                                                              "\t\t\t\tWHEN (D.[OnHandQty] - A.[AvgItemQty]) \u003e= 0",
                                                                                              "\t\t\t\t\tTHEN 1",
                                                                                              "\t\t\t\tELSE 0",
                                                                                              "\t\t\tEND",
                                                                                              "\t\t,A.Proportion AS [PropOfSeries]",
                                                                                              "",
                                                                                              "  FROM [#ItemOH] AS D",
                                                                                              "\tLEFT JOIN [#AltSeries] AS AltSer",
                                                                                              "\t  ON [D].[Item] = [AltSer].[ItemSKU]",
                                                                                              "",
                                                                                              "\tLEFT JOIN [#Avgs] AS A",
                                                                                              "\t  ON [D].[Item] = [A].[Item] ",
                                                                                              "\t  AND [D].[Location] = [A].[Location]",
                                                                                              "\t  AND D.[Week Ending] = A.[Week Ending]",
                                                                                              "",
                                                                                              "\tWHERE [AltSer].[InitialInvoicePeriod] IS NOT NULL",
                                                                                              "\t  AND [AltSer].[SellableItemFlag] = \u0027Y\u0027 ",
                                                                                              "\t  AND [AltSer].[ItemSKU] NOT LIKE \u0027%SW\u0027",
                                                                                              "\t  AND [AltSer].[ManufacturingStatus] NOT IN (\u0027Discontinued\u0027,\u0027Deleted\u0027,\u0027Tentative\u0027,\u0027Replaced\u0027)",
                                                                                              "\t  AND ((AltSer.AFISalesDivision = \u0027Signature Accessory\u0027 AND A.AvgItemQty \u003e 5) OR (AltSer.AFISalesDivision \u003c\u003e \u0027Signature Accessory\u0027 AND A.AvgItemQty \u003e 0))",
                                                                                              "\t  --AND A.AvgItemQty \u003e 0",
                                                                                              "\t  AND A.[Proportion] \u003e= @SeriesProp",
                                                                                              "",
                                                                                              "",
                                                                                              "DROP TABLE [#AltSeries]",
                                                                                              "DROP TABLE [#OrdHist]",
                                                                                              "DROP TABLE [#ItemAvg]",
                                                                                              "DROP TABLE [#SeriesAvg]",
                                                                                              "DROP TABLE [#Avgs]",
                                                                                              "DROP TABLE [#ItemOH]",
                                                                                              "\", CommandTimeout=#duration(0, 1, 0, 0)]),",
                                                                                              "    #\"Renamed Columns\" = Table.RenameColumns(Source,{{\"SKU On Hand\", \"SKUs w/ On Hand\"}})",
                                                                                              "in",
                                                                                              "    #\"Renamed Columns\"",
                                                                                              "",
                                                                                              "*/"
                                                                                          ],
                                                                           "type":  "m"
                                                                       }
                                                        }
                                                    ]
                                 },
                                 {
                                     "name":  "SeriesInvHist",
                                     "columns":  [
