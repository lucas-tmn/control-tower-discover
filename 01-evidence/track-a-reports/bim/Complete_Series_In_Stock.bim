                                                         "expression":  "CALCULATE(AVERAGE(InventoryHistory[OnHandQty]),FILTER(z_ProductDetails,z_ProductDetails[Series Number]=EARLIER(z_ProductDetails[Series Number])))",
                                                         "isDataTypeInferred":  true,
