                                                                                 "value":  "{\"isText\":true}"
                                                                             }
                                                                         ],
                                                         "dataType":  "string",
                                                         "isDataTypeInferred":  true,
                                                         "isNameInferred":  true,
                                                         "lineageTag":  "67df9e93-02e4-40f6-82c5-743e44bd8002",
                                                         "sourceColumn":  "InventoryHistory[SeriesNumber]",
                                                         "summarizeBy":  "none",
                                                         "type":  "calculatedTableColumn"
                                                     },
                                                     {
                                                         "name":  "Series Description",
                                                         "annotations":  [
                                                                             {
                                                                                 "name":  "SummarizationSetBy",
                                                                                 "value":  "Automatic"
                                                                             },
