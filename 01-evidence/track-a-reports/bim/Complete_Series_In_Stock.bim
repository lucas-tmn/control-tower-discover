                                                         "dataType":  "string",
                                                         "expression":  "IF(LEFT(z_ProductDetails[Item SKU],1)=\"U\",CONCATENATE(LEFT(z_ProductDetails[Item SKU],6),CONCATENATE(\" - \",CONCATENATE(z_ProductDetails[Series Name],CONCATENATE(\" \",z_ProductDetails[Series Color])))),z_ProductDetails[Series Description])",
