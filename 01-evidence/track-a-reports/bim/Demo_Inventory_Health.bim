      {
        "name": "_Measure",
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ],
        "columns": [
          {
            "name": "Column1",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "lineageTag": "a970086e-bb00-4745-84ec-2c7d2d632c24",
            "sourceColumn": "Column1",
            "summarizeBy": "none"
          }
        ],
        "lineageTag": "00771292-0acb-4053-a8ca-4141e7d95a54",
        "measures": [
          {
            "name": "OH Quantity",
            "expression": "SUM(FactInventoryPosition[OnHandQty])",
            "formatString": "0",
            "lineageTag": "bc495fe0-7bf5-4565-a4e3-eaace8d86e9d"
          },
          {
            "name": "SS Target",
            "expression": "SUM(FactInventoryPosition[SafetyStockQty])",
            "formatString": "0",
            "lineageTag": "d2f3945f-2fcd-46cd-b4d8-2a5079f1c061"
          },
          {
            "name": "Qty Trend LM",
            "expression": [
              "",
              "VAR Percent_Gap = FORMAT(DIVIDE([OH Quantity] , [OH Quantity LM] , BLANK()) , \"0%\") RETURN ",
              "SWITCH(TRUE(), [OH Quantity] > [OH Quantity LM] , \"Trend Up + \" & Percent_Gap &\" with LM\" , ",
              "                [OH Quantity] < [OH Quantity LM] , \"Trend Down - \" & Percent_Gap &\" with LM\" , \"Not Change\" )"
            ],
            "lineageTag": "c352beee-4e2e-475a-a36a-8fde7acd5408"
          },
          {
            "name": "OH Quantity LM",
            "expression": "CALCULATE([OH Quantity] , DATEADD(DimDate[FiscalMonthFirstDate] , -1 , MONTH))",
            "formatString": "0",
            "lineageTag": "da2a757d-c1ea-4c17-a131-862bc5efa995"
          },
          {
            "name": "Qty Conditional Color Format w Target",
            "expression": [
              "",
              "VAR Percent_Gap = FORMAT(DIVIDE([OH Quantity] , [SS Target] , BLANK()) , \"0%\") RETURN ",
              "\"~ \" & Percent_Gap & \" w Target\""
            ],
            "lineageTag": "deb4e9c5-43df-42d1-91e9-2a588d3d85fe"
          },
          {
            "name": "Obsolete Ratio",
            "expression": [
              "",
              "VAR inv_movement = CALCULATE(SUM(FactInventoryTransactions[TransactionQty])*25600",
              " , FactInventoryTransactions[DaysSinceLastMovement] > 90 )",
              "VAR inv_value = [OH Quantity]* [Inv_$]",
              "RETURN ",
              "DIVIDE(inv_movement, inv_value, BLANK())",
              ""
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "065aa8c2-d49c-48aa-a2d0-415f35526f6c"
          },
          {
            "name": "Inv_$",
            "expression": "120600",
            "formatString": "0",
            "lineageTag": "88c441b0-c2c7-49a2-bdfd-265fdac2e2c9"
          },
          {
            "name": "Excess Ratio",
            "expression": [
              "",
              "VAR inv_movement = CALCULATE(SUM(FactInventoryTransactions[TransactionQty])*40600",
              " , FactInventoryTransactions[DaysSinceLastMovement] > 90 )",
              "VAR inv_value = [OH Quantity]* [Inv_$]",
              "RETURN ",
              "DIVIDE(inv_movement, inv_value, BLANK())",
              ""
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "b7b104e2-c5fa-415a-9a67-97e85a4bacd0"
          },
          {
            "name": "In-Stock Ratio",
            "expression": [
              "",
              "1 - [Excess Ratio] - [Obsolete Ratio]",
              ""
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "89dfe878-3afe-4496-b348-af9949d1cdfc"
          },
          {
            "name": "SKU count",
            "expression": "DISTINCTCOUNT(FactInventoryPosition[InTransitQty])",
            "formatString": "0",
            "lineageTag": "52a3df7c-5180-4b38-912f-7d62e608cc67"
          },
          {
            "name": "Inventory Value",
            "expression": "[OH Quantity] * [Inv_$]",
            "formatString": "0",
            "lineageTag": "07105d64-1c2f-4168-a8aa-e45ffbb1fc7a"
          },
          {
            "name": "Turns",
            "expression": [
              "12",
              "//DIVIDE([Inventory Value] , "
            ],
            "formatString": "0",
            "lineageTag": "ac089ca0-0d42-4ffd-9ef7-da4a02c35c63"
          },
          {
            "name": "Excess Value",
            "expression": "CALCULATE(SUM(FactInventoryTransactions[TransactionQty]))*40600",
            "formatString": "0",
            "lineageTag": "72dbfe71-bc77-4805-ac2b-3a2e7e85ee78"
          },
          {
            "name": "Excess Quantity",
            "expression": "CALCULATE(SUM(FactInventoryTransactions[TransactionQty]))",
            "formatString": "0",
            "lineageTag": "6c548497-666e-4d74-aadc-78636a808020"
          },
          {
            "name": "Excess Quantity Ratio",
            "expression": "DIVIDE([Excess Quantity] , [OH Quantity] , BLANK()) * 0.2",
            "formatString": "0%;-0%;0%",
            "lineageTag": "8231b96e-7508-4c9d-864f-b1a9d83c1721"
          },
          {
            "name": "Excess SKU count",
            "expression": "CALCULATE(DISTINCTCOUNT(FactActualDemand[GrossMargin]) , FactInventoryPosition[Status] = \"Excess\")",
            "formatString": "0",
            "lineageTag": "7b790570-1254-4349-825a-3dacfe6872f8"
          },
          {
            "name": "Excess SKU Ratio",
            "expression": "DIVIDE([Excess SKU count] , [SKU count] , BLANK())",
            "formatString": "0%;-0%;0%",
            "lineageTag": "13b0df5c-5759-4925-acbe-5aa0374be88a"
          },
          {
            "name": "Current short Items",
            "expression": "10",
            "formatString": "0",
            "lineageTag": "0cdc0c72-18be-469b-8226-634de90fcbf7"
          },
          {
            "name": "Revenue Short",
            "expression": "100000",
            "formatString": "0",
            "lineageTag": "61ee027f-bb40-4b6e-b527-c7eb58eb731f"
          },
          {
            "name": "Current Quantity",
            "expression": "1000",
            "formatString": "0",
            "lineageTag": "3bbaabf5-359d-4840-b031-19e353652ac7"
          },
          {
            "name": "Next Short Item expected in 60 days",
            "expression": "8",
            "formatString": "0",
            "lineageTag": "50635d2b-0654-4e37-a388-e451155a571b"
          },
          {
            "name": "Avg Forecast Demand",
            "expression": "100",
            "formatString": "0",
            "lineageTag": "1f159735-5765-4825-a822-a3f05e7932c4"
          },
          {
            "name": "WOS",
            "expression": "10",
            "formatString": "0",
            "lineageTag": "b4902c0d-ea42-47bf-bb05-1bab8950c10f"
          },
          {
            "name": "Short Qty Trend LM",
            "expression": [
              "",
              "VAR Percent_Gap = FORMAT(DIVIDE([OH Quantity] , [OH Quantity LM] , BLANK()) , \"0%\") RETURN ",
              "SWITCH(TRUE(), [OH Quantity] > [OH Quantity LM] , \"▲ \" & Percent_Gap &\" vs LM\" , ",
              "                [OH Quantity] < [OH Quantity LM] , \"▼ \" & Percent_Gap &\" vs LM\" , \"Not Change\" )"
            ],
            "lineageTag": "6080ff76-88ba-40b4-8ea9-f967389da7f6"
          }
        ],
        "partitions": [
          {
            "name": "_Measure",
            "mode": "import",
            "source": {
              "expression": [
                "let",
