            "name": "WOS Cat",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "SWITCH( TRUE() , ",
              "   FactInventoryPosition[WeeksOfSupply] < 5 , \"1. < 5 Weeks\" , ",
              "   FactInventoryPosition[WeeksOfSupply] < 13 , \"2. 5 - 13 Weeks\" , ",
              "   FactInventoryPosition[WeeksOfSupply] < 25 , \"3. 13 - 25 Weeks\" ,  ",
              "      FactInventoryPosition[WeeksOfSupply] < 52 , \"4. 25 - 52 Weeks\" ,  ",
              "    \"5. > 52 Weeks\"   ) "
            ],
            "isDataTypeInferred": true,
            "lineageTag": "e7dd11ee-4e7f-4aad-866a-199f60930300",
            "summarizeBy": "none",
            "type": "calculated"
