        "partitions": [
          {
            "name": "Logility - Current Mo-4d585071-7818-4e08-8252-7d1afb322ee6",
            "mode": "import",
            "queryGroup": "Dataflows",
            "source": {
              "expression": [
                "// PR - Logility - Logility Current Mo",
                "",
                "let",
                "    Source = PowerBI.Dataflows(null),",
                "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                "    #\"1d89d8d0-baad-4df3-b64b-545c17b9c132\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"1d89d8d0-baad-4df3-b64b-545c17b9c132\"]}[Data],",
                "    #\"Logility - Current Mo1\" = #\"1d89d8d0-baad-4df3-b64b-545c17b9c132\"{[entity=\"Logility - Current Mo\"]}[Data]",
                "in",
                "    #\"Logility - Current Mo1\"",
                "",
                "",
                "/* Dataflow Query",
                "",
                "let",
                "  Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "  Declare @MonthEnded AS Date",
                "Set @MonthEnded = (SELECT [Last_Date_Of_Fiscal_Month]",
                "FROM [PowerBI_Enterprise].[DimDate] ",
                "WHERE [Date_ID] = CONVERT(Date,GetDate()))",
                "",
                "SELECT L.[Item-Lvl1]",
                "      ,L.[Location]",
                "      ,L.[Field-21]",
                "      ,L.[On_hand_Qty]",
                "      ,L.[Result_Fc_0]",
                "      ,L.[Result_Fc_1]",
                "      ,L.[Result_Fc_2]",
                "      ,L.[Result_Fc_3]",
                "      ,L.[Result_Fc_4]",
                "      ,L.[Result_Fc_5]",
                "      ,L.[Result_PROL_0]",
                "      ,L.[Result_PROL_1]",
                "      ,L.[Result_PROL_2]",
                "      ,L.[Result_PROL_3]",
                "      ,L.[Result_PROL_4]",
                "      ,L.[Result_PROL_5]",
                "      ,L.[FileDate]",
                "      ,L.[FORECASTPLANNER]",
                "      ,L.[UNIT CST]",
                "      ,L.[UnitPrice]",
                "      ,L.[Field1]",
                "      ,L.[Field8]",
                "      ,L.[Field9]",
                "      ,L.[Field10]",
                "      ,L.[Field-17]",
                "      ,L.[Field-35]",
                "      ,L.[Field-19]",
                "      ,L.[MgmtValidDemand]",
                "\t  ,D.[Last_Date_Of_Fiscal_Month]",
                "  FROM [PowerBI_SupplyChain].[FCC_Logility90DayHist] AS L",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_ID] = L.[FileDate]",
                "  LEFT JOIN [PowerBI_SupplyChain].[CurrentProductDetails] AS P",
                "  ON P.[Item SKU] = L.[Item-Lvl1]",
                "  WHERE D.[Last_Date_Of_Fiscal_Month] = @MonthEnded",
                "  AND P.[Item Class Code] NOT LIKE 'Z__K'",
                "  AND P.[Item Class Code] <> 'ZARP'",
                "  AND P.[Item Class Code] <> 'ZAHM'",
                "  AND L.[Item-Lvl1] NOT LIKE '%UN'",
                "  AND L.[Item-Lvl1] NOT LIKE '%SW'",
                "  AND L.[Item-Lvl1] NOT LIKE '%CARD'",
                "  \"])",
                "in",
                "  Source",
                "",
                "  */"
              ],
              "type": "m"
            }
          }
        ]
      },
