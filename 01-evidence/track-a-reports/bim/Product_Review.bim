        "partitions": [
          {
            "name": "Inventory Turns-aa47f3de-aeaa-442f-a46e-34dbc849aead",
            "mode": "import",
            "queryGroup": "Dataflows",
            "source": {
              "expression": [
                "// PR -  Inventory - Inventory Turns",
                "",
                "let",
                "    Source = PowerBI.Dataflows(null),",
                "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                "    #\"09eddbaa-3af1-4cf0-bfaa-0195ba01f232\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"09eddbaa-3af1-4cf0-bfaa-0195ba01f232\"]}[Data],",
                "    #\"Inventory Turns1\" = #\"09eddbaa-3af1-4cf0-bfaa-0195ba01f232\"{[entity=\"Inventory Turns\"]}[Data]",
                "in",
                "    #\"Inventory Turns1\"",
                "",
                "",
                "/* Dataflow Query",
                "",
                "let",
                "  Query1 = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "  DECLARE @Startdate DATE",
                "SET @Startdate = ( ",
                "\t\tSELECT DISTINCT CONVERT(DATE,[FiscalYearFirstDate])",
                "\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\tWHERE [FiscalYear] = (",
                "\t\t\tSELECT DISTINCT [FiscalYear] - 2 ",
                "\t\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\t\tWHERE [DateID] = CONVERT(DATE,GETDATE())",
                "\t\t) ",
                "\t)",
                "SELECT [ituCalctype]",
                "      ,[ituWeekEnded] AS 'Fiscal Date'",
                "      ,[ituItemNumber] AS 'Item SKU'",
                "      ,[ituWarehouse] AS 'Warehouse Code'",
                "      ,SUM([ituTotalStdSales]) AS '12 Month Annualized Cost Of Goods'",
                "      ,SUM([ituAverageStdCost]) AS '12 Month On Hand Cost - Weekly Average'",
                "      ,SUM([ituQuantityShipped]) AS '12 Month Rolling Quantity Shipped' ",
                "      ,SUM([ituAverageOnHandQty]) AS '12 Month On Hand Quantity - Weekly Average'",
                "  FROM [Inventory_Enh].[TurnsDetail]",
                "  WHERE [ituWeekEnded] >= @StartDate",
                "  AND [ituCalctype] = '52'",
                "  GROUP BY [ituCalctype]",
                "      ,[ituWeekEnded]",
                "      ,[ituItemNumber]",
                "      ,[ituWarehouse]",
                "  \"]),",
                "  #\"Removed Columns\" = Table.RemoveColumns(Query1, {\"ituCalctype\"})",
                "in",
                "  #\"Removed Columns\"",
                "",
                "*/"
              ],
              "type": "m"
            }
          }
        ]
