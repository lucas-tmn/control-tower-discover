        "measures": [
          {
            "name": "SI-SS",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM(SupplyPlanDetail[spdShippableInventory])) - CALCULATE(SUM(SupplyPlanDetail[spdSafetyStock])) ",
            "formatString": "#,0",
            "lineageTag": "62e3e952-860e-4aeb-b9d5-b549d881115f"
          },
          {
            "name": "SI as % of SS",
            "expression": "DIVIDE(CALCULATE(SUM(SupplyPlanDetail[spdShippableInventory])),CALCULATE(SUM(SupplyPlanDetail[spdSafetyStock]))) ",
            "formatString": "#,0%;-#,0%;#,0%",
            "lineageTag": "0cf1b35b-e363-4294-83a8-e4b439b63cce"
          },
          {
            "name": "*SI Neg",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM(SupplyPlanDetail[SI Negative]))",
            "formatString": "#,0",
            "lineageTag": "fc295ad8-e031-4dec-9fd4-a5a80c243e05"
          },
          {
            "name": "*FirmDemands+NetForecast",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM(SupplyPlanDetail[spdFirmDemands]))+CALCULATE(SUM(SupplyPlanDetail[spdNetForecast]))",
            "formatString": "#,0",
            "lineageTag": "aeec0351-24be-4abd-a7dd-f47aafc8f314"
          },
          {
            "name": "*% COC w/ NetForecast",
            "expression": [
              "IFERROR(IF(DIVIDE(([*FirmDemands+NetForecast]+[*SI Neg]),[*FirmDemands+NetForecast]) > 1, 1, ",
              "    IF(DIVIDE(([*FirmDemands+NetForecast]+[*SI Neg]),[*FirmDemands+NetForecast]) < 0, 0, ",
              "        DIVIDE(([*FirmDemands+NetForecast]+[*SI Neg]),[*FirmDemands+NetForecast]))),0)"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "30c91bfd-1a8f-4966-9cac-6b63ed84ce72"
          },
          {
            "name": "*DF",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM(SupplyPlanDetail[spdDemandFulfillment]))",
            "formatString": "#,0",
            "lineageTag": "e90a92ef-5fc1-486c-9828-e64bbb6db068"
          },
          {
            "name": "*DF YTD",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "TOTALYTD([*DF],SupplyPlanDetail[spdWeekEnding])",
            "formatString": "#,0",
            "lineageTag": "44335a06-e82f-4b04-9683-9176bdbb1ad0"
          },
          {
            "name": "*SCP Team DF_2 YTD",
            "expression": [
              "IF(DIVIDE([*DF YTD],[*FirmDemands+NetForecast YTD])>1,1,",
              "    IF(DIVIDE([*DF YTD],[*FirmDemands+NetForecast YTD])<0,0,",
              "        DIVIDE([*DF YTD],[*FirmDemands+NetForecast YTD])))"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "f3c61a53-76ef-4890-82dd-fd3a857f47f3"
          },
          {
            "name": "*SCP Team DF_2",
            "expression": [
              "IF(DIVIDE([*DF],[*FirmDemands+NetForecast])>1,1,",
              "    IF(DIVIDE([*DF],[*FirmDemands+NetForecast])<0,0,",
              "        DIVIDE([*DF],[*FirmDemands+NetForecast])))"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "2e4ef852-a37b-4eae-b8c4-216012faf78c"
          },
          {
            "name": "*SCP Team DF_2 YTD w/o NetForecast",
            "expression": [
              "IF(DIVIDE([*DF YTD],[*FirmDemands YTD])>1,1,",
              "    IF(DIVIDE([*DF YTD],[*FirmDemands YTD])<0,0,",
              "        DIVIDE([*DF YTD],[*FirmDemands YTD])))"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "7c9f0400-6a57-4c98-8443-f2d061b1fe1b"
          },
          {
            "name": "*FirmDemands",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM(SupplyPlanDetail[spdFirmDemands]))",
            "formatString": "#,0",
            "lineageTag": "2426288f-5084-4eb0-b4be-d93131402373"
          },
          {
            "name": "*FirmDemands YTD",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "TOTALYTD([*FirmDemands],SupplyPlanDetail[spdWeekEnding])",
            "formatString": "#,0",
            "lineageTag": "29fcb6fe-caee-4a63-9f98-dd8eb0b6bdb3"
          },
          {
            "name": "*FirmDemands+NetForecast YTD",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "TOTALYTD([*FirmDemands+NetForecast],SupplyPlanDetail[spdWeekEnding])",
            "formatString": "#,0",
            "lineageTag": "a494fd2b-ebfa-47b5-9a01-4f3469241e9b"
          },
          {
            "name": "*SI Neg YTD",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "TOTALYTD([*SI Neg],SupplyPlanDetail[spdWeekEnding])",
            "formatString": "#,0",
            "lineageTag": "13b52fea-8f08-49fc-8348-f3aba74ee257"
          },
          {
            "name": "*SCP Team DF_2 w/o NetForecast",
            "expression": [
              "IF(DIVIDE([*DF],[*FirmDemands])>1,1,",
              "    IF(DIVIDE([*DF],[*FirmDemands])<0,0,",
              "        DIVIDE([*DF],[*FirmDemands])))"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "c0f4d854-cbab-4a30-a9b3-d79496620a49"
          },
          {
            "name": "WeeksOfSupply",
            "expression": "DIVIDE(CALCULATE(SUM(SupplyPlanDetail[spdShippableInventory])),(CALCULATE(SUM(SupplyPlanDetail[spdNetForecast]))+CALCULATE(SUM(SupplyPlanDetail[spdFirmDemands]))))",
            "formatString": "#,0.0",
            "lineageTag": "8583dcbb-04dd-4472-b9f5-dab02fa60cf0"
          },
          {
            "name": "*% COC",
            "expression": [
              "IFERROR(IF(DIVIDE(([*FirmDemands]+[*SI Neg]),[*FirmDemands]) > 1, 1, ",
              "    IF(DIVIDE(([*FirmDemands]+[*SI Neg]),[*FirmDemands]) < 0, 0, ",
              "        DIVIDE(([*FirmDemands]+[*SI Neg]),[*FirmDemands]))),0)"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "7a23f6f3-61cc-4df0-b0ad-1c42884323c7"
          },
          {
            "name": "*% of Out of Stock",
            "expression": "DIVIDE([*SI Neg],[*FirmDemands])",
            "formatString": "0.0%;-0.0%;0.0%",
            "isHidden": true,
            "lineageTag": "e0895829-437e-443a-83d3-d9ea0c75fbed"
          },
          {
            "name": "*Fill Rate_2b",
            "expression": [
              "IF(DIVIDE([*DF],[*SI Neg])>1,1,",
              "    IF(DIVIDE([*DF],[*SI Neg])<0,0,",
              "        DIVIDE([*DF],[*SI Neg])))"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "isHidden": true,
            "lineageTag": "b3a04d08-9ce8-49e5-8208-785f2ed994a2"
          },
          {
            "name": "*Inventory Velocity",
            "expression": [
              "IFERROR(",
              "    DIVIDE(",
              "        CALCULATE(SUM(SupplyPlanDetail[BeginningOnHandQty])),",
              "        (CALCULATE(SUM(SupplyPlanDetail[spdResultantForecast]))+CALCULATE(SUM(SupplyPlanDetail[spdPromotionalLift])))),",
              "    BLANK()",
              "    )"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "ce14b5ac-9bcf-43dd-b845-f23ae7111672"
          },
          {
            "name": "Promoted Resultant",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM(SupplyPlanDetail[spdResultantForecast])) + CALCULATE(SUM(SupplyPlanDetail[spdPromotionalLift]))",
            "formatString": "#,0",
            "lineageTag": "10fb6b5f-5121-4020-86ab-788120738d12"
          },
          {
            "name": "Production + Purchase Orders",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "changedProperties": [
