            "source": {
              "expression": [
                "// PR - Logility - Demand Data",
                "",
                "let",
                "    Source = PowerBI.Dataflows(null),",
                "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                "    #\"1d89d8d0-baad-4df3-b64b-545c17b9c132\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"1d89d8d0-baad-4df3-b64b-545c17b9c132\"]}[Data],",
                "    #\"Demand Data1\" = #\"1d89d8d0-baad-4df3-b64b-545c17b9c132\"{[entity=\"Demand Data\"]}[Data]",
                "in",
                "    #\"Demand Data1\"",
                "    ",
                "",
                "/* Dataflow Query",
                "",
                "let",
                "  Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "  DECLARE @Startdate DATE",
                "SET @Startdate = ( ",
                "\t\tSELECT DISTINCT CONVERT(DATE,[FiscalYearFirstDate])",
                "\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\tWHERE [FiscalYear] = (",
                "\t\t\tSELECT DISTINCT [FiscalYear] - 2 ",
                "\t\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\t\tWHERE [DateID] = CONVERT(DATE,GETDATE())",
                "\t\t) ",
                "\t)",
                "SELECT D.[Last_Date_Of_Fiscal_Month] AS 'Fiscal Date'",
                "      ,L.[Item] AS 'Item SKU'",
                "      ,L.[Location] AS 'Warehouse Code' ",
                "\t  ,L.[Actual demand] AS 'Actual Demand'",
                "  FROM [SupplyChain_Enh].[ItemActualDemand_Logility] AS L",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_ID] = L.[Year Period]",
                "  WHERE [Last_Date_Of_Fiscal_Month] >= @StartDate",
                "  \"])",
                "in",
                "  Source",
                "",
                "*/"
              ],
              "type": "m"
            }
          }
        ]
