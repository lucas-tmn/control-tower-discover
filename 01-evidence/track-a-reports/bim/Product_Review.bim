            "expression": "IF([Total Written Sales (Retail) - YTD Previous Year] = BLANK(), BLANK(), DIVIDE([Total Written Sales (Retail) - YTD Current Year], [Total Written Sales (Retail) - YTD Previous Year],BLANK())-1) ",
            "formatString": "0.0%;-0.0%;0.0%",
