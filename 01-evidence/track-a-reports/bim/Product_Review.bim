            "source": {
              "expression": [
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"SELECT I.[ItemId]#(lf)      ,I.[Warehouse]#(lf)      ,I.[Uom]#(lf)      ,I.[ForecastLevel]#(lf)      ,I.[SeasonalityControlFile]#(lf)      ,F.[Period]#(lf)      ,F.[Factor]#(lf)  FROM [Wholesale_DemandPlanning_AFI].[ItemSeasonalFactor] AS I#(lf)  #(lf)  LEFT JOIN [Wholesale_DemandPlanning_AFI].[SeasonalityFactorMaster] AS F#(lf)  ON F.[SeasonalityControlFile] = I.[SeasonalityControlFile]#(lf)  #(lf)  WHERE I.[ForecastLevel] = '2'\"])",
