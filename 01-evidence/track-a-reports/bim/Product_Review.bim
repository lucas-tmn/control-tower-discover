        "lineageTag": "ea784254-26ee-44f5-8c7e-2dcef599b294",
        "measures": [
          {
            "name": "Current SI as % of SS",
            "expression": "IFERROR(DIVIDE(CALCULATE(SUM('Current SS/SI'[spdShippableInventory])),CALCULATE(SUM('Current SS/SI'[spdSafetyStock]))),0)",
            "formatString": "#,0%;-#,0%;#,0%",
            "lineageTag": "af4da8a5-3398-4bbc-b829-8aabe5ac4866"
          },
          {
            "name": "SI Neg",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM('Current SS/SI'[SI Negative]))",
            "formatString": "#,0",
            "lineageTag": "ced5b918-52a0-452d-ba60-e17005751049"
          },
          {
            "name": "Firm Demands",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM('Current SS/SI'[spdFirmDemands]))",
            "formatString": "#,0",
            "lineageTag": "cb2c0fc3-68f1-49c8-9659-b57310a9fe8c"
          },
          {
            "name": "Firm Demands & Net Forecast",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM('Current SS/SI'[spdFirmDemands])) + CALCULATE(SUM('Current SS/SI'[spdNetForecast]))",
            "formatString": "#,0",
            "lineageTag": "ee12b803-24d0-47af-a0bd-51008c2a9c31"
          },
          {
            "name": "% COC",
            "expression": [
              "IFERROR(IF(([Firm Demands] + [SI Neg]) / [Firm Demands] > 1, 1, ",
              "    IF(([Firm Demands] + [SI Neg]) / [Firm Demands] < 0, 0, ",
              "        ([Firm Demands] + [SI Neg]) / [Firm Demands])),0)"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "bda446ee-b915-4673-9afe-dbceeabb9f12"
          },
          {
            "name": "% COC w/ Net Forecast",
            "expression": [
              "IFERROR(IF(([Firm Demands & Net Forecast] + [SI Neg]) / [Firm Demands & Net Forecast] > 1, 1, ",
              "    IF(([Firm Demands & Net Forecast] + [SI Neg]) / [Firm Demands & Net Forecast] < 0, 0, ",
              "        ([Firm Demands & Net Forecast] + [SI Neg]) / [Firm Demands & Net Forecast])),0)"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "de0a6fc4-f7a3-43dc-aad0-985c6724acd5"
          },
          {
            "name": "WeeksSupply",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "DIVIDE(CALCULATE(SUM('Current SS/SI'[spdShippableInventory])),(CALCULATE(SUM('Current SS/SI'[spdNetForecast]))+CALCULATE(SUM('Current SS/SI'[spdFirmDemands]))))",
            "lineageTag": "b54569a2-c9df-4f3a-8774-1697c1b81dc7"
          }
        ],
        "partitions": [
          {
            "name": "Current SS/SI-405da7f6-d0ff-467b-ab3b-d1deaaa96f72",
            "mode": "import",
            "queryGroup": "Dataflows",
            "source": {
              "expression": [
                "// PR - Product - CurrentSS/SI",
                "",
                "let",
                "    Source = PowerBI.Dataflows(null),",
                "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                "    #\"1804c594-ad6e-4ef8-bb3e-2f992ba34972\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"1804c594-ad6e-4ef8-bb3e-2f992ba34972\"]}[Data],",
                "    #\"Current SS/SI1\" = #\"1804c594-ad6e-4ef8-bb3e-2f992ba34972\"{[entity=\"Current SS/SI\"]}[Data]",
                "in",
                "    #\"Current SS/SI1\"",
                "",
                "    ",
                "/* Dataflow Query",
                "",
                "let",
                "  Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "DECLARE @Startdate DATE",
                "SET @Startdate = ( ",
                "\t\tSELECT DISTINCT CONVERT(DATE,[FiscalYearFirstDate])",
                "\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\tWHERE [FiscalYear] = (",
                "\t\t\tSELECT DISTINCT [FiscalYear] - 2 ",
                "\t\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\t\tWHERE [DateID] = CONVERT(DATE,GETDATE())",
                "\t\t) ",
                "\t)",
                "SELECT S.[spdItem]",
                "      ,S.[spdWarehouse]",
                "      ,S.[spdWeekEnding]",
                "      ,S.[spdFirmDemands]",
                "      ,S.[spdNetForecast]",
                "      ,S.[spdShippableInventory]",
                "      ,S.[spdSafetyStock]",
                "      ,S.[dtea]",
                "  FROM [PowerBI_SupplyChain].[ProdRevCurrentSSSI] AS S",
                "  LEFT JOIN [PowerBI_SupplyChain].[CurrentProductDetails] AS P",
                "  ON P.[Item SKU] = S.[spdItem]",
                "  WHERE [spdWeekEnding] >= @StartDate",
                "  AND P.[Item Class Code] NOT LIKE 'Z__K'",
                "  AND P.[Item Class Code] <> 'ZARP'",
                "  AND P.[Item Class Code] <> 'ZAHM'",
                "  AND [spdItem] NOT LIKE '%SW'",
                "  AND [spdItem] NOT LIKE '%CARD'",
                "  AND [spdItem] NOT LIKE '%UN'",
                "  , CommandTimeout=#duration(0, 1, 0, 0)\"])",
                "in",
                "  Source",
                "",
                "  */"
              ],
              "type": "m"
            }
          }
        ]
