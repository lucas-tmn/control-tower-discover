        "partitions": [
          {
            "name": "Nailed-381273c4-919d-4949-85f7-216e770b09a2",
            "mode": "import",
            "queryGroup": "Dataflows",
            "source": {
              "expression": [
                "// PR -  Inventory - Nailed",
                "",
                "let",
                "    Source = PowerBI.Dataflows(null),",
                "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                "    #\"09eddbaa-3af1-4cf0-bfaa-0195ba01f232\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"09eddbaa-3af1-4cf0-bfaa-0195ba01f232\"]}[Data],",
                "    Nailed1 = #\"09eddbaa-3af1-4cf0-bfaa-0195ba01f232\"{[entity=\"Nailed\"]}[Data]",
                "in",
                "    Nailed1",
                "",
                "/* Dataflow Query ",
                "let",
                "  Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "Declare @CurrentDay AS Date",
                "Set @CurrentDay = (SELECT [Date_ID]",
                "FROM [PowerBI_Enterprise].[DimDate] ",
                "WHERE [Date_ID] = CONVERT(Date,GetDate()))",
                "",
                "SELECT D.[Date_ID] AS 'Fiscal Date'",
                "      ,L.[EnterpriseLocation] AS 'Enterprise Location'",
                "      ,L.[EnterpriseStore] AS 'Enterprise Store'",
                "      ,M.[ItemID] AS 'Item SKU'",
                "      --,I.[Aisle]",
                "      --,I.[Level]",
                "      --,I.[Bay]",
                "      ,SUM(I.[OnHandQuantity]) AS 'On Hand Quantity'",
                "      --,I.[OnHandAverageCost]",
                "      ,SUM(ISNULL(I.[OnHandReservedQuantity], 0)) AS 'On Hand Reserved Quantity'",
                "      --,I.[OnHandReservedAverageCost]",
                "      ,SUM(ISNULL(I.[OnHandAvailableQuantity], 0)) AS 'On Hand Available Quantity'",
                "      --,I.[OnHandAvailableAverageCost]",
                "      ,SUM(ISNULL(I.[OnHandFloorStockQuantity], 0)) AS 'On Hand Floor Stock Quantity'",
                "      --,I.[OnHandFloorStockAverageCost]",
                "      ,SUM(ISNULL(I.[OnHandDamagedQuantity], 0)) AS 'On Hand Damaged Quantity'",
                "      --,I.[OnHandDamagedAverageCost]",
                "  FROM [Retail_DW].[FactInventory] AS I",
                "  LEFT JOIN [Retail_DW].[DimItemMaster] AS M",
                "  ON M.[ItemKey] = I.[ItemKey]",
                "  LEFT JOIN [Retail_DW].[DimLocation] AS L",
                "  ON L.[LocationKey] = I.[LocationKey]",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_Key] = I.[SnapshotDateKey]",
                "  WHERE D.[Date_ID] = @CurrentDay",
                "  AND L.[EnterpriseOperation] = '1'",
                "  AND L.[EnterpriseStore] = 'Yes'",
                "  GROUP BY D.[Date_ID]",
                "      ,L.[EnterpriseLocation]",
                "      ,L.[EnterpriseStore] ",
                "      ,M.[ItemID]",
                "  \"])",
                "in",
                "  Source",
                "",
                "*/"
              ],
              "type": "m"
            }
          }
        ]
      },
