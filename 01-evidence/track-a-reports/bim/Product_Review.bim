        "partitions": [
          {
            "name": "Sales Trend - AFI-ba748059-376c-46fe-a407-6eb5fd2a0ad3",
            "mode": "import",
            "queryGroup": "Dataflows",
            "source": {
              "expression": [
                "// PR - Logility2 - Sales Trend - AFI",
                "let",
                "    Source = PowerBI.Dataflows(null),",
                "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                "    #\"e6afbf37-5510-45b3-b4e0-aa9dcbb5263f\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"e6afbf37-5510-45b3-b4e0-aa9dcbb5263f\"]}[Data],",
                "    #\"Sales Trend - AFI1\" = #\"e6afbf37-5510-45b3-b4e0-aa9dcbb5263f\"{[entity=\"Sales Trend - AFI\"]}[Data]",
                "in",
                "    #\"Sales Trend - AFI1\"",
                "",
                "/* Dataflow Query",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "DECLARE @Startdate DATE",
                "SET @Startdate = ( ",
                "\tSELECT DISTINCT CONVERT(DATE,[FiscalYearFirstDate])",
                "\tFROM [Enterprise_DW].[DimDate]",
                "\tWHERE [FiscalYear] = (",
                "\t\tSELECT DISTINCT [FiscalYear] - 2 ",
                "\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\tWHERE [DateID] = CONVERT(DATE,GETDATE())",
                "\t) ",
                " )",
                "",
                "DECLARE @Enddate DATE",
                "SET @Enddate = DATEADD(DAY,-1,GETDATE())",
                "",
                "SELECT DATEPART(YEAR,I.[Fiscal Date]) AS 'Fiscal Year'",
                "\t  ,DATEPART(MONTH,I.[Fiscal Date]) AS 'Fiscal Month'",
                "\t  ,I.[Fiscal Date]",
                "\t  ,I.[Item SKU]",
                "\t  ,I.[Warehouse] AS 'AFI Warehouse Code'",
                "      --,I.[Account And ShipTo Number]",
                "\t  --,R.[ABC Account-Current Year]",
                "\t  --,R.[Reporting Business Type]",
                "\t  ,SUM(I.[Quantity Shipped]) AS 'Gross Quantity Shipped'",
                "\t  --,I.[Amount Shipped]",
                "\t  ,SUM(I.[Amount Shipped] ",
                "\t\t\t- I.[Invoiced Discount] ",
                "\t\t\t+ I.[Other Allowances] ",
                "\t\t\t- C.[Quality] ",
                "\t\t\t- C.[Returns] ",
                "\t\t\t- C.[Shortages]",
                "\t\t) AS 'Net Sales'",
                "\t  --,I.[Other Allowances]",
                "\t  --,I.[Invoiced Discount]",
                "\t  --,C.[Quality]",
                "\t  --,C.[Returns]",
                "\t  --,C.[Shortages]",
                "      ,SUM(O.[Quantity Ordered]) AS 'Quantity Ordered'",
                "      ,SUM(O.[Amount Ordered]) AS 'Amount Ordered'",
                "",
                "FROM",
                "",
                " (SELECT D.[Last_Date_Of_Fiscal_Month] AS 'Fiscal Date'",
                "\t  ,I.[Item SKU]",
                "      ,I.[Warehouse]",
                "      --,I.[Account And ShipTo Number]",
                "      ,SUM(I.[Quantity Shipped]) AS 'Quantity Shipped'",
                "      ,SUM(I.[Amount Shipped]) AS 'Amount Shipped'",
                "      ,SUM([Other Allowances]) AS 'Other Allowances'",
                "      ,SUM([Invoice Discount]) AS 'Invoiced Discount'",
                "  FROM [PowerBI_Wholesale].[InvoiceHistory] AS I",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_ID] = I.[Invoice Date]",
                "  WHERE I.[Invoice Date] BETWEEN @Startdate AND @Enddate",
                "  GROUP BY D.[Last_Date_Of_Fiscal_Month]",
                "\t  ,I.[Item SKU]",
                "      ,I.[Warehouse]",
                "      --,I.[Account And ShipTo Number]",
                "  ) AS I",
                "  ",
                "  LEFT JOIN ",
                "",
                "  (SELECT D.[Last_Date_Of_Fiscal_Month] AS 'Fiscal Date'",
                "      ,C.[Item SKU]",
                "      ,C.[Warehouse Code]",
                "\t  --,C.[Account And ShipTo Number]",
                "      ,SUM(C.[Quality Credits]) AS 'Quality'",
                "      ,SUM(C.[Returns Amount]) AS 'Returns'",
                "      ,SUM(C.[Short Ship Amount]) AS 'Shortages'",
                "  FROM [PowerBI_Wholesale].[QualityCosts] AS C",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_ID] = C.[Transaction Date]",
                "  WHERE C.[Transaction Date] BETWEEN @Startdate AND @Enddate",
                "  GROUP BY D.[Last_Date_Of_Fiscal_Month]",
                "      ,C.[Item SKU]",
                "\t  ,C.[Warehouse Code]",
                "\t  --,C.[Account And ShipTo Number]",
                "  ) AS C ",
                "",
                "  ON C.[Fiscal Date] = I.[Fiscal Date]",
                "  AND C.[Item SKU] = I.[Item SKU]",
                "  AND C.[Warehouse Code] = I.[Warehouse]",
                "  --AND C.[Account And ShipTo Number] = I.[Account And ShipTo Number]",
                "",
                "  LEFT JOIN",
                "",
                "  (SELECT D.[Last_Date_Of_Fiscal_Month] AS 'Fiscal Date'",
                "\t  ,O.[Item SKU]",
                "\t  ,O.[Warehouse]",
                "      --,O.[Account And ShipTo Number]",
                "      ,SUM(O.[Quantity Ordered]) AS 'Quantity Ordered'",
                "      ,SUM(O.[Amount Ordered]) AS 'Amount Ordered'",
                "  FROM [PowerBI_Wholesale].[OrderHistory] AS O",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_ID] = O.[Invoice Date]",
                "  WHERE O.[Invoice Date] BETWEEN @Startdate AND @Enddate",
                "  GROUP BY D.[Last_Date_Of_Fiscal_Month]",
                "      ,O.[Item SKU]",
                "\t  ,O.[Warehouse]",
                "      --,O.[Account And ShipTo Number]",
                "  ) AS O",
                "",
                "  ON O.[Fiscal Date] = I.[Fiscal Date]",
                "  AND O.[Item SKU] = I.[Item SKU]",
                "  AND O.[Warehouse] = I.[Warehouse]",
                "  --AND O.[Account And ShipTo Number] = I.[Account And ShipTo Number]",
                "",
                "  --LEFT JOIN [PowerBI_Wholesale].[Customers] AS R",
                "  --ON R.[Account And ShipTo Number] = I.[Account And ShipTo Number]",
                "",
                "  GROUP BY I.[Fiscal Date]",
                "\t  ,I.[Item SKU]",
                "\t  ,I.[Warehouse]",
                "\t  --,R.[Reporting Business Type]    ",
                "    ",
                "    \", CommandTimeout=#duration(0, 3, 0, 0)])",
                "in",
                "    Source",
                "",
                "*/"
              ],
              "type": "m"
            }
          }
        ]
      },
