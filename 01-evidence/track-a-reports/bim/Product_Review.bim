        "partitions": [
          {
            "name": "Sales Trend - Ashcomm-a4ef2109-a008-4420-9e35-f49c3f16f509",
            "mode": "import",
            "queryGroup": "Dataflows",
            "source": {
              "expression": [
                "// PR - Retail - Sales Trend Ashcomm",
                "",
                "let",
                "    Source = PowerBI.Dataflows(null),",
                "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                "    #\"268f23ba-d319-421a-8c21-b15b05a728e8\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"268f23ba-d319-421a-8c21-b15b05a728e8\"]}[Data],",
                "    #\"Sales Trend - Ashcomm1\" = #\"268f23ba-d319-421a-8c21-b15b05a728e8\"{[entity=\"Sales Trend - Ashcomm\"]}[Data]",
                "in",
                "    #\"Sales Trend - Ashcomm1\"",
                "",
                "    ",
                "/* Dataflow Query",
                "let",
                "  Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "DECLARE @Startdate DATE",
                "SET @Startdate = ( ",
                "\t\tSELECT DISTINCT CONVERT(DATE,[FiscalYearFirstDate])",
                "\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\tWHERE [FiscalYear] = (",
                "\t\t\tSELECT DISTINCT [FiscalYear] - 2 ",
                "\t\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\t\tWHERE [DateID] = CONVERT(DATE,GETDATE())",
                "\t\t) ",
                "\t)",
                "",
                "DECLARE @Enddate DATE",
                "SET @Enddate = DATEADD(DAY,-1,GETDATE())",
                "",
                "SELECT\tW.[Corporate Market]",
                "\t\t,W.[Item SKU]",
                "\t\t,W.[Fiscal Year]",
                "\t\t,W.[Fiscal Month]",
                "\t\t,W.[Fiscal Date]",
                "\t\t,W.[Quantity Ordered]",
                "\t\t,W.[Written Sales]\t   ",
                "\t\t,I.[Quantity Sold]",
                "\t\t,I.[Invoiced Sales]",
                "",
                "FROM",
                "",
                "(SELECT W.[HomestoreOperation] AS 'Corporate Market'",
                "\t\t,M.[ItemID] AS 'Item SKU'",
                "\t\t--,RTRIM(SUBSTRING(W.[ItemKey],8,20)) AS 'Item SKU'",
                "\t\t,DATEPART(Year,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Year'",
                "\t\t,DATEPART(Month,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Month'",
                "\t\t,CONVERT(DATE,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Date'",
                "\t\t,SUM(W.[QuantityOrdered]) AS 'Quantity Ordered'",
                "\t    ,(SUM(W.[WrittenSales]) + SUM(W.[WrittenDiscounts])) AS 'Written Sales'",
                "FROM [Retail_DW].[FactWrittenSalesAshcomm] AS W",
                "LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "ON D.[Date_ID] = (CONVERT(DATE,W.[OrderChangeDate]))",
                "LEFT JOIN [Retail_DW].[DimItemMaster] AS M",
                "ON M.[ItemKey] = W.[ItemKey]",
                "WHERE (CONVERT(DATE,W.[OrderChangeDate])) BETWEEN @Startdate AND @Enddate",
                "GROUP BY W.[HomestoreOperation]",
                "\t\t,M.[ItemID]",
                "\t\t,D.[Last_Date_Of_Fiscal_Month]) AS W",
                "",
                "LEFT JOIN",
                "",
                "(SELECT I.[HomestoreOperation] AS 'Corporate Market'",
                "\t\t,M.[ItemID] AS 'Item SKU'",
                "\t\t--,RTRIM(SUBSTRING(I.[ItemKey],8,20)) AS 'Item SKU'",
                "\t\t,DATEPART(Year,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Year'",
                "\t\t,DATEPART(Month,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Month'",
                "\t\t,CONVERT(DATE,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Date'",
                "\t\t,SUM(I.[QuantitySold]) AS 'Quantity Sold'",
                "\t\t,(SUM(I.[InvoicedSales]) + SUM(I.[InvoicedDiscounts])) AS 'Invoiced Sales'",
                "FROM [Retail_DW].[FactInvoicedSalesAshcomm] AS I",
                "LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "ON D.[Date_ID] = (CONVERT(DATE,I.[InvoiceDate]))",
                "LEFT JOIN [Retail_DW].[DimItemMaster] AS M",
                "ON M.[ItemKey] = I.[ItemKey]",
                "WHERE (CONVERT(DATE,I.[InvoiceDate])) BETWEEN @Startdate AND @Enddate",
                "GROUP BY I.[HomestoreOperation]",
                "\t\t,M.[ItemID]",
                "\t\t,D.[Last_Date_Of_Fiscal_Month]) AS I",
                "",
                "ON I.[Item SKU] = W.[Item SKU]",
                "AND I.[Fiscal Date] = W.[Fiscal Date]",
                "  \", CommandTimeout=#duration(0, 3, 0, 0)])",
                "in",
                "  Source",
                "",
                "*/"
              ],
              "type": "m"
            }
          }
        ]
      },
