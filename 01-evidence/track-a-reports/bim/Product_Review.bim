        "partitions": [
          {
            "name": "Sales Trend - Retail-fcf63517-80c5-40d4-9772-eb25c8bae096",
            "mode": "import",
            "queryGroup": "Dataflows",
            "source": {
              "expression": [
                "// PR - Retail - Sales Trend Retail",
                "",
                "let",
                "    Source = PowerBI.Dataflows(null),",
                "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                "    #\"268f23ba-d319-421a-8c21-b15b05a728e8\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"268f23ba-d319-421a-8c21-b15b05a728e8\"]}[Data],",
                "    #\"Sales Trend - Retail1\" = #\"268f23ba-d319-421a-8c21-b15b05a728e8\"{[entity=\"Sales Trend - Retail\"]}[Data]",
                "in",
                "    #\"Sales Trend - Retail1\"",
                "",
                "    ",
                "/* Dataflow Query",
                "let",
                "  Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "  DECLARE @Startdate DATE",
                "SET @Startdate = ( ",
                "\t\tSELECT DISTINCT CONVERT(DATE,[FiscalYearFirstDate])",
                "\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\tWHERE [FiscalYear] = (",
                "\t\t\tSELECT DISTINCT [FiscalYear] - 2 ",
                "\t\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\t\tWHERE [DateID] = CONVERT(DATE,GETDATE())",
                "\t\t) ",
                "\t)",
                "",
                "DECLARE @Enddate DATE",
                "SET @Enddate = DATEADD(DAY,-1,GETDATE())",
                "",
                "SELECT DATEPART(YEAR,W.[Fiscal Date]) AS 'Fiscal Year'",
                "\t  ,DATEPART(MONTH,W.[Fiscal Date]) AS 'Fiscal Month'",
                "\t  ,W.[Fiscal Date]",
                "\t  ,W.[Item SKU]",
                "\t  ,SUM(W.[Quantity Ordered]) AS 'Quantity Ordered'",
                "\t  ,SUM(W.[Written Sales] + W.[Written Discounts]) AS 'Written Sales'",
                "\t  ,SUM(I.[Quantity Sold]) AS 'Quantity Sold'",
                "\t  ,SUM(I.[Invoiced Sales] + I.[Invoiced Discounts]) AS 'Invoiced Sales'",
                "",
                "FROM",
                "",
                "(SELECT DATEPART(YEAR,W.[Fiscal Date]) AS 'Fiscal Year'",
                "\t  ,DATEPART(MONTH,W.[Fiscal Date]) AS 'Fiscal Month'",
                "\t  ,W.[Fiscal Date]",
                "\t  ,W.[Item SKU]",
                "\t  ,SUM(W.[Quantity Ordered]) AS 'Quantity Ordered'",
                "\t  ,SUM(W.[Written Sales]) AS 'Written Sales'",
                "\t  ,SUM(W.[Written Discounts]) AS 'Written Discounts'",
                "",
                "FROM",
                "",
                "(SELECT CONVERT(DATE,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Date'",
                "\t  ,M.[ItemID] AS 'Item SKU'",
                "      ,SUM(WC.[QuantityOrdered]) AS 'Quantity Ordered'",
                "      ,SUM(WC.[WrittenSales]) AS 'Written Sales'",
                "\t  ,SUM(ISNULL(WC.[WrittenDiscounts],0)) AS 'Written Discounts'",
                "  FROM [Retail_DW].[FactWrittenSalesHomesCorporate] AS WC",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_ID] = (CONVERT(DATE,WC.[OrderChangeDate]))",
                "  LEFT JOIN [Retail_DW].[DimItemMaster] AS M",
                "  ON M.[ItemKey] = WC.[ItemKey]",
                "  WHERE WC.[OrderChangeDate] BETWEEN @Startdate AND @Enddate",
                "  AND WC.[ItemKey] LIKE 'Ashley_%'",
                "  GROUP BY D.[Last_Date_Of_Fiscal_Month]",
                "\t  ,M.[ItemID]",
                "",
                "UNION",
                "",
                "SELECT CONVERT(DATE,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Date'",
                "\t  ,M.[ItemID] AS 'Item SKU'",
                "      ,SUM(WL.[QuantityOrdered]) AS 'Quantity Ordered'",
                "      ,SUM(WL.[WrittenSales]) AS 'Written Sales'",
                "\t  ,SUM(ISNULL(WL.[WrittenDiscounts],0)) AS 'Written Discounts'",
                "  FROM [Retail_DW].[FactWrittenSalesHomesLicensee] AS WL",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_ID] = (CONVERT(DATE,WL.[OrderChangeDate]))",
                "  LEFT JOIN [Retail_DW].[DimItemMaster] AS M",
                "  ON M.[ItemKey] = WL.[ItemKey]",
                "  WHERE WL.[OrderChangeDate] BETWEEN @Startdate AND @Enddate",
                "  AND WL.[ItemKey] LIKE 'Ashley_%'",
                "  GROUP BY D.[Last_Date_Of_Fiscal_Month]",
                "\t  ,M.[ItemID]",
                "",
                "UNION",
                "",
                "SELECT CONVERT(DATE,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Date'",
                "\t  ,M.[ItemID] AS 'Item SKU'",
                "      ,SUM(WS.[QuantityOrdered]) AS 'Quantity Ordered'",
                "      ,SUM(WS.[WrittenSales]) AS 'Written Sales'",
                "\t  ,SUM(ISNULL(WS.[WrittenDiscounts],0)) AS 'Written Discounts'",
                "  FROM [Retail_DW].[FactWrittenSalesStoris] AS WS",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_ID] = (CONVERT(DATE,WS.[OrderChangeDate]))",
                "  LEFT JOIN [Retail_DW].[DimItemMaster] AS M",
                "  ON M.[ItemKey] = WS.[ItemKey]",
                "  WHERE WS.[OrderChangeDate] BETWEEN @Startdate AND @Enddate",
                "  AND WS.[ItemKey] LIKE 'Ashley_%'",
                "  GROUP BY D.[Last_Date_Of_Fiscal_Month]",
                "\t  ,M.[ItemID]",
                ") AS W",
                "GROUP BY W.[Fiscal Date]",
                "\t  ,W.[Item SKU]",
                ") AS W",
                "",
                "LEFT JOIN",
                "",
                "(SELECT DATEPART(YEAR,I.[Fiscal Date]) AS 'Fiscal Year'",
                "\t  ,DATEPART(MONTH,I.[Fiscal Date]) AS 'Fiscal Month'",
                "\t  ,I.[Fiscal Date]",
                "\t  ,I.[Item SKU]",
                "\t  ,SUM(I.[Quantity Sold]) AS 'Quantity Sold'",
                "\t  ,SUM(I.[Invoiced Sales]) AS 'Invoiced Sales' ",
                "\t  ,SUM(I.[Invoiced Discounts]) AS 'Invoiced Discounts'",
                "",
                "FROM",
                "",
                "(SELECT CONVERT(DATE,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Date'",
                "\t  ,M.[ItemID] AS 'Item SKU'",
                "      ,SUM(IC.[QuantitySold]) AS 'Quantity Sold'",
                "      ,SUM(IC.[InvoicedSales]) AS 'Invoiced Sales'",
                "      ,SUM(ISNULL(IC.[InvoicedDiscounts],0)) AS 'Invoiced Discounts'",
                "  FROM [Retail_DW].[FactInvoicedSalesHomesCorporate] AS IC",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_ID] = (CONVERT(DATE,IC.[InvoiceDate]))",
                "  LEFT JOIN [Retail_DW].[DimItemMaster] AS M",
                "  ON M.[ItemKey] = IC.[ItemKey]",
                "  WHERE IC.[InvoiceDate] BETWEEN @Startdate AND @Enddate",
                "  AND IC.[ItemKey] LIKE 'Ashley_%'",
                "  GROUP BY D.[Last_Date_Of_Fiscal_Month]",
                "\t  ,M.[ItemID]",
                "",
                "UNION",
                "",
                "SELECT CONVERT(DATE,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Date'",
                "\t  ,M.[ItemID] AS 'Item SKU'",
                "      ,SUM(IL.[QuantitySold]) AS 'Quantity Sold'",
                "      ,SUM(IL.[InvoicedSales]) AS 'Invoiced Sales'",
                "      ,SUM(ISNULL(IL.[InvoicedDiscounts],0)) AS 'Invoiced Discounts'",
                "  FROM [Retail_DW].[FactInvoicedSalesHomesLicensee] AS IL",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_ID] = (CONVERT(DATE,IL.[InvoiceDate]))",
                "  LEFT JOIN [Retail_DW].[DimItemMaster] AS M",
                "  ON M.[ItemKey] = IL.[ItemKey]",
                "  WHERE IL.[InvoiceDate] BETWEEN @Startdate AND @Enddate",
                "  AND IL.[ItemKey] LIKE 'Ashley_%'",
                "  GROUP BY D.[Last_Date_Of_Fiscal_Month]",
                "\t  ,M.[ItemID]",
                "",
                "UNION",
                "",
                " SELECT CONVERT(DATE,D.[Last_Date_Of_Fiscal_Month]) AS 'Fiscal Date'",
                "\t  ,M.[ItemID] AS 'Item SKU'",
                "      ,SUM(ISt.[QuantitySold]) AS 'Quantity Sold'",
                "      ,SUM(ISt.[InvoicedSales]) AS 'Invoiced Sales'",
                "      ,SUM(ISNULL(ISt.[InvoicedDiscounts],0)) AS 'Invoiced Discounts'",
                "  FROM [Retail_DW].[FactInvoicedSalesStoris] AS ISt",
                "  LEFT JOIN [PowerBI_Enterprise].[DimDate] AS D",
                "  ON D.[Date_ID] = (CONVERT(DATE,ISt.[InvoiceDate]))",
                "  LEFT JOIN [Retail_DW].[DimItemMaster] AS M",
                "  ON M.[ItemKey] = ISt.[ItemKey]",
                "  WHERE Ist.[InvoiceDate] BETWEEN @Startdate AND @Enddate",
                "  AND ISt.[ItemKey] LIKE 'Ashley_%'",
                "  GROUP BY D.[Last_Date_Of_Fiscal_Month]",
                "\t  ,M.[ItemID]",
                ") AS I",
                "  GROUP BY I.[Fiscal Date]",
                "\t  ,I.[Item SKU]",
                ") AS I",
                "",
                "ON I.[Item SKU] = W.[Item SKU]",
                "AND I.[Fiscal Date] = W.[Fiscal Date]",
                "",
                "GROUP BY W.[Fiscal Date]",
                "\t  ,W.[Item SKU]",
                "  \", CommandTimeout=#duration(0, 3, 0, 0)])",
                "in",
                "  Source",
                "",
                "*/"
              ],
              "type": "m"
            }
          }
        ]
      },
      {
