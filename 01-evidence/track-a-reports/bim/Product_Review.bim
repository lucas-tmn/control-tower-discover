            "expression": "CALCULATE(SUM(SupplyPlanDetail[Production])) + CALCULATE(SUM(SupplyPlanDetail[PurchaseOrders]))",
            "formatString": "#,0",
            "lineageTag": "44cfa035-5930-4ac8-b8f0-18ba81f773e5"
          }
