        ],
        "partitions": [
          {
            "name": "Forecast Accuracy-ab8fe802-ac54-4411-ad0f-85a11b370d22",
            "mode": "import",
            "queryGroup": "Dataflows",
            "source": {
              "expression": [
                "// PR - Logility - Forecast Accuracy",
                "",
                "let",
                "    Source = PowerBI.Dataflows(null),",
                "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                "    #\"1d89d8d0-baad-4df3-b64b-545c17b9c132\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"1d89d8d0-baad-4df3-b64b-545c17b9c132\"]}[Data],",
                "    #\"Forecast Accuracy1\" = #\"1d89d8d0-baad-4df3-b64b-545c17b9c132\"{[entity=\"Forecast Accuracy\"]}[Data]",
                "in",
                "    #\"Forecast Accuracy1\"",
                "",
                "/* Dataflow Query",
                "let",
                "  Query1 = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "  DECLARE @Startdate DATE",
                "SET @Startdate = ( ",
                "\t\tSELECT DISTINCT CONVERT(DATE,[FiscalYearFirstDate])",
                "\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\tWHERE [FiscalYear] = (",
                "\t\t\tSELECT DISTINCT [FiscalYear] - 2 ",
                "\t\t\tFROM [Enterprise_DW].[DimDate]",
                "\t\t\tWHERE [DateID] = CONVERT(DATE,GETDATE())",
                "\t\t) ",
                "\t)",
                "",
                "SELECT [SCP Item] = FC.Item ",
                "\t,[Fiscal Date] = CAST(B.[Fiscal Month End] As Date) ",
                "\t,[AFI Warehouse Code] = FC.[Location] ",
                "\t,[Forecast Period] = ",
                "\t\tCASE ",
                "\t\t\tWHEN FC.[Source File Name] LIKE '%2 Week%'  THEN '2 Week'",
                "\t\t\tWHEN FC.[Source File Name] LIKE '%30 Day%'  THEN '30 Day'",
                "\t\t\tWHEN FC.[Source File Name] LIKE '%60 Day%'  THEN '60 Day'",
                "\t\t\tWHEN FC.[Source File Name] LIKE '%90 Day%'  THEN '90 Day'",
                "\t\t\tWHEN FC.[Source File Name] LIKE '%120 Day%' THEN '120 Day'",
                "\t\tEND",
                "\t,[Actual Demand Quantity] = Dmd.[Actual Demand]",
                "\t,[Promoted Resultant Forecast Quantity] = ",
                "\t\tCASE ",
                "\t\t\tWHEN Ima.ImaClass NOT LIKE 'Z%K' ",
                "\t\t\tTHEN (FC.[Forecast Value] + Isnull(FC.[PROL Value],0)) ",
                "\t\t\tELSE NULL ",
                "\t\tEND ",
                "\t,[Naive Forecast] = NF.[Actual Demand]\t",
                "",
                "\tFROM [SupplyChain_Enh].[ItemForecast_Logility] FC",
                "\t\tLEFT OUTER JOIN",
                "\t\t\t(SELECT [Item] = F.[Item]",
                "\t\t\t\t,[Year Period] = F.[Year Period]",
                "\t\t\t\t,[Forecast Value] = SUM(F.[Forecast Value])",
                "\t\t\t\t,[PROL Value] = SUM(ISNULL(F.[PROL Value],0))",
                "\t\t\t\t,[Actual Demand] = SUM(D.[Actual Demand])",
                "\t\t\t\t,[SumActuals] = SUM(ISNULL(F.[Forecast Value],0) + ISNULL(F.[PROL Value],0) + ISNULL(D.[Actual Demand],0)) ",
                "\t\t\t\t,[Company] = F.[Company]",
                "\t\t\t\t,[Country] = F.[Country]",
                "\t\t\tFROM [SupplyChain_Enh].[ItemForecast_Logility] F",
                "\t\t\t\tLEFT OUTER JOIN [SupplyChain_Enh].[ItemActualDemand_Logility] D",
                "\t\t\t\tON D.[Item] = F.[Item] ",
                "\t\t\t\tAND D.[Location] = F.[Location]",
                "\t\t\t\tAND D.[Year Period] = F.[Year Period] ",
                "\t\t\t\tAND D.[Country] = F.[Country] ",
                "\t\t\t\tAND D.[Company] = F.[Company]",
                "\t\t\tGROUP BY F.[Item], F.[Year Period], F.[Company], F.[Country]",
                "\t\t\tHAVING SUM([Forecast Value] + ISNULL([PROL Value],0)) = 0",
                "\t\t\t\tAND SUM([Actual Demand]) = 0) FC1",
                "\t\tON FC.[Year Period] = FC1.[Year Period]",
                "\t\tAND FC.[Item] = FC1.[Item] ",
                "\t\tAND FC.[Company] = FC1.[Company] ",
                "\t\tAND FC.[Country] = FC1.[Country]",
                "\t\tLEFT OUTER JOIN\t[SupplyChain_Enh].[ItemActualDemand_Logility] Dmd",
                "\t\tON Dmd.[Item] = FC.[Item] ",
                "\t\tAND Dmd.[Location] = FC.[Location] ",
                "\t\tAND Dmd.[Year Period] = FC.[Year Period] ",
                "\t\tAND Dmd.[Country] = FC.[Country] ",
                "\t\tAND Dmd.[Company] = FC.[Company]",
                "\t\tLEFT OUTER JOIN Wholesale_Marketing.ItemMaster IMA",
                "\t\tON IMA.[imaItnbr] = FC.[Item]",
                "\t\tLEFT OUTER JOIN MasterData_ProductKnowledge.ItemStatusCode SC",
                "\t\tON SC.[iscCode] = IMA.[imaStatus]",
                "\t\tLEFT OUTER JOIN\t",
                "\t\t\t(SELECT [Fiscal Month End] = MAX([Transaction Date])",
                "\t\t\t\t,[Fiscal Month]",
                "\t\t\t\t,[Fiscal Year]",
                "\t\t\t\t,[Year Period1] = CAST([Fiscal Month] + '/' + '1/' + [Fiscal Year] As Datetime) ",
                "\t\t\tFROM [SupplyChain_DW].[DimDateFile]",
                "\t\t\tGROUP BY [Fiscal Month],[Fiscal Year]) B",
                "\t\tON FC.[Year Period] = B.[Year Period1]",
                "",
                "\t\tLEFT OUTER JOIN",
                "\t\t\t(SELECT Item,Location,DMD.[Year Period],[Year Period1],SUM([Actual Demand])[Actual Demand]  ",
                "\t\t\tFROM [SupplyChain_Enh].[ItemActualDemand_Logility] DMD",
                "\t\t\tLEFT OUTER JOIN ",
                "\t\t\t\t(SELECT [Year Period1],DATEADD(MM,-3,[Year Period1])[Year Period]",
                "\t\t\t\tFROM (SELECT[Year Period1] = CAST([Fiscal Month]+'/'+'1/'+[Fiscal Year] As Datetime)  ",
                "\t\t\t\tFROM [SupplyChain_DW].[DimDateFile]",
                "\t\t\t\tGROUP BY [Fiscal Month],[Fiscal Year]) A)",
                "\t\t\t\tNFCST ON DMD.[Year Period] = NFCST.[Year Period]",
                "\t\t\tGROUP BY Item,Location,DMD.[Year Period],[Year Period1]) NF ",
                "\t\t\tON FC.[Item] = NF.[Item]",
                "\t\t\tAND FC.[Location] = NF.[Location]",
                "\t\t\tAND FC.[Year Period] = NF.[Year Period1]",
                "",
                "\tWHERE CAST('1 ' + [ForeCast Year Period] AS DATETIME) = FC.[Year Period]",
                "\t\tAND FC.[Location] IN ('1', '5', 'ECR', '17', '15','232','28','335','16','42')",
                "\t\tAND FC.[Forecast Type] <> 'I' ",
                "\t\tAND FC.[Forecast Type] <> ''",
                "\t\tAND FC.[Year Period] >= @StartDate",
                "  \", CommandTimeout=#duration(0, 3, 0, 0)]),",
                "  #\"Duplicated Column\" = Table.DuplicateColumn(Query1, \"Forecast Period\", \"Forecast Period - Copy\"),",
                "  #\"Split Column by Delimiter\" = Table.SplitColumn(#\"Duplicated Column\", \"Forecast Period - Copy\", Splitter.SplitTextByEachDelimiter({\" \"}, QuoteStyle.Csv), {\"Forecast Period - Copy.1\", \"Forecast Period - Copy.2\"}),",
                "  #\"Changed Type1\" = Table.TransformColumnTypes(#\"Split Column by Delimiter\", {{\"Forecast Period - Copy.1\", Int64.Type}, {\"Forecast Period - Copy.2\", type text}}),",
                "  #\"Removed Columns1\" = Table.RemoveColumns(#\"Changed Type1\", {\"Forecast Period - Copy.2\"}),",
                "  #\"Renamed Columns1\" = Table.RenameColumns(#\"Removed Columns1\", {{\"Forecast Period - Copy.1\", \"Forecast Period - sort\"}})",
                "in",
                "  #\"Renamed Columns1\"",
                "",
                "  */"
              ],
              "type": "m"
            }
          }
        ]
      },
