        "partitions": [
          {
            "name": "Forecast - Logility-8bef6a8d-a15e-412f-8d00-7d28ba284d8b",
            "mode": "import",
            "queryGroup": "Dataflows",
            "source": {
              "expression": [
                "// PR -  Inventory - Forecast Logility",
                "",
                "let",
                "    Source = PowerBI.Dataflows(null),",
                "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                "    #\"09eddbaa-3af1-4cf0-bfaa-0195ba01f232\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"09eddbaa-3af1-4cf0-bfaa-0195ba01f232\"]}[Data],",
                "    #\"Forecast - Logility1\" = #\"09eddbaa-3af1-4cf0-bfaa-0195ba01f232\"{[entity=\"Forecast - Logility\"]}[Data]",
                "in",
                "    #\"Forecast - Logility1\"",
                "",
                "/* Dataflow Query",
                "let",
                "  Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "SELECT L.[dfcItem]",
                "      ,L.[dfcWarehouse]",
                "      ,L.[dfcFiscalMonth]",
                "      ,L.[dfcResultantForecast]",
                "      ,L.[dfcPromotionalLift]",
                "      ,L.[dfcForcedForecast]",
                "      ,L.[dfcOrderFutureQty]",
                "      ,L.[dtea]",
                "\t  ,D.[Last_Date_Of_Fiscal_Month] AS 'Forecasted Month'",
                "  FROM [SupplyChain_Enh].[DemandForecastSnapshot] AS L",
                "  LEFT JOIN (SELECT DISTINCT [Fiscal_Month_Number_As_Integer], [Last_Date_Of_Fiscal_Month] FROM [PowerBI_Enterprise].[DimDate]) AS D",
                "  ON D.[Fiscal_Month_Number_As_Integer] = L.[dfcFiscalMonth]",
                "  LEFT JOIN [PowerBI_SupplyChain].[CurrentProductDetails] AS P",
                "  ON P.[Item SKU] = L.[dfcItem]",
                "  WHERE [dtea] = (SELECT MAX([dtea]) FROM [SupplyChain_Enh].[DemandForecastSnapshot])",
                "  AND [Last_Date_Of_Fiscal_Month] <= DATEADD(Month,+15,GETDATE())",
                "  AND P.[Item Class Code] NOT LIKE 'Z__K'",
                "  AND P.[Item Class Code] <> 'ZARP'",
                "  AND P.[Item Class Code] <> 'ZAHM'",
                "  AND L.[dfcItem] NOT LIKE '%UN'",
                "  AND L.[dfcItem] NOT LIKE '%SW'",
                "  AND L.[dfcItem] NOT LIKE '%CARD'",
                "  \"])",
                "in",
                "  Source",
                "",
                "*/"
              ],
              "type": "m"
            }
          }
        ]
      },
      {
