              },
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "dataType": "double",
            "expression": [
              "IF('Vendor/SKU Lead Time'[SecondaryVendorLeadTime]=BLANK(),'Vendor/SKU Lead Time'[PrimaryVendorLeadTime],",
              "(('Vendor/SKU Lead Time'[dinPrimaryVendorSplit]*'Vendor/SKU Lead Time'[PrimaryVendorLeadTime])+('Vendor/SKU Lead Time'[dinSecondaryVendorSplit]*'Vendor/SKU Lead Time'[SecondaryVendorLeadTime])))"
            ],
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "8ee34aea-b52a-471d-b9f6-9212a5aeef77",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "LeadTimeForecastPeriod",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "IF('Vendor/SKU Lead Time'[AverageVendorLeadTime]=BLANK(),\"Unknown\",",
              "IF('Vendor/SKU Lead Time'[AverageVendorLeadTime]<=30, \"30 Day\",",
              "IF(AND('Vendor/SKU Lead Time'[AverageVendorLeadTime]>30,'Vendor/SKU Lead Time'[AverageVendorLeadTime]<=60), \"60 Day\",",
              "IF(AND('Vendor/SKU Lead Time'[AverageVendorLeadTime]>60,'Vendor/SKU Lead Time'[AverageVendorLeadTime]<=90), \"90 Day\",",
              "IF(AND('Vendor/SKU Lead Time'[AverageVendorLeadTime]>90,'Vendor/SKU Lead Time'[AverageVendorLeadTime]<=120), \"120 Day\",",
              "IF('Vendor/SKU Lead Time'[AverageVendorLeadTime]>120, \">120 Day\"))))))"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "6c49c2be-36bd-4da8-bdc2-cb1da804a754",
            "summarizeBy": "none",
            "type": "calculated"
          }
        ],
