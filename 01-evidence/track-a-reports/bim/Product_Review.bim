          {
            "name": "InsertedDateWeekEnding",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              },
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDateTimeCustom\":true}"
              }
            ],
            "dataType": "dateTime",
            "expression": "LOOKUPVALUE(AshleyFiscalCalendar[Fiscal Week Ended],AshleyFiscalCalendar[Transaction Date],'ATP Week Ending'[InsertedDate])",
            "formatString": "m/d/yy",
            "isDataTypeInferred": true,
            "lineageTag": "ac4a97b9-2824-4701-8341-3df1642e8682",
            "summarizeBy": "none",
