        "partitions": [
          {
            "name": "ATP (2)-cdb0080a-5b24-4df7-b320-2879ee3a63fd",
            "mode": "import",
            "queryGroup": "Dataflows",
            "source": {
              "expression": [
                "//PR - Available To Promise - ATP(2)",
                "",
                "let",
                "    Source = PowerBI.Dataflows(null),",
                "    #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\" = Source{[workspaceId=\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"]}[Data],",
                "    #\"e770a268-8b9a-4156-85a2-7a53a2753859\" = #\"f0e1bc90-35c4-4e31-bc00-ff4a225152b7\"{[dataflowId=\"e770a268-8b9a-4156-85a2-7a53a2753859\"]}[Data],",
                "    #\"ATP(2)1\" = #\"e770a268-8b9a-4156-85a2-7a53a2753859\"{[entity=\"ATP(2)\"]}[Data]",
                "in",
                "    #\"ATP(2)1\"",
                "",
                "/* Dataflow Query",
                "let",
                "  Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "  ",
                "SELECT A.[ItemSKU]",
                "      ,A.[Warehouse]",
                "      ,A.[ATPWeek]",
                "      ,A.[WeekEnding]",
                "      ,A.[ATPQty]",
                "      ,A.[RunDate]",
                "      ,A.[InsertedDate]",
                "      ,A.[InsertedVersion]",
                "\t  --,P.[Item Class Code]",
                "  FROM [SupplyChain_Enh].[ATPWeekEnding] AS A",
                "  LEFT JOIN [PowerBI_SupplyChain].[CurrentProductDetails] AS P",
                "  ON P.[Item SKU] = A.[ItemSKU]",
                "  WHERE [InsertedDate] >= DATEADD(WEEK,-13,GETDATE())",
                "  AND A.[InsertedVersion] = '2'",
                "  AND P.[Item Class Code] NOT LIKE 'Z__K'",
                "  AND P.[Item Class Code] <> 'ZARP'",
                "  AND P.[Item Class Code] <> 'ZAHM'",
                "  AND A.[ItemSKU] NOT LIKE '%SW'",
                "  AND A.[ItemSKU] NOT LIKE '%CARD'",
                "  AND A.[ItemSKU] NOT LIKE '%UN'",
                "  AND A.[Warehouse] IN ('1','5','15','16','17','28','42','232','335','ECR')",
                "",
                "  \", CommandTimeout=#duration(0, 3, 0, 0)]),",
                "  #\"Changed Type\" = Table.TransformColumnTypes(Source, {{\"InsertedDate\", type date}, {\"WeekEnding\", type date}, {\"RunDate\", type date}})",
                "in",
                "  #\"Changed Type\"",
                "",
                "  */"
              ],
              "type": "m"
            }
          }
        ]
      },
