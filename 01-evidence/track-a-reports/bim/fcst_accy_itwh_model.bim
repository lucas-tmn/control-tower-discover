        ],
        "lineageTag": "232081fb-e99f-43d6-9213-20fa7feb86cb",
        "partitions": [
          {
            "name": "ItWHAccy",
            "mode": "import",
            "source": {
              "expression": [
                "// SQL Query Template",
                "",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\",",
                "                [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "",
                "SELECT [FC].[Item SKU]",
                "      ,[FC].[Warehouse]",
                "      ,[FC].[FiscalMonthYear]",
                "      ,[FC].[FiscalMonthLastDate]",
                "      ,[FC].[SortFcstPer]",
                "      ,[FC].[ForecastPeriod]",
                "      ,[FC].[Total Forecast]",
                "\t  ,ISNULL([ACT].[Actual Demand],0) AS [Actual Demand]",
                "\t  ,ISNULL([NF].[NaiveFcst],0) AS [NaiveFcst]",
                "\t  ,ISNULL([NF_2].[NaiveFcst],0) AS [NaiveFcst_v2]",
                "      ,[FC].[Snapshot Date] ",
                "\t  ,[FC].[Snapshot Year Month]",
                "  FROM (",
                "",
                "SELECT [DFC].[dfcItem] AS [Item SKU]",
                "      ,[DFC].[dfcWarehouse] AS [Warehouse]",
                "      ,[DFC].[dfcFiscalMonth] AS [FiscalMonthYear]",
                "\t  ,[FTP].[FiscalMonthLastDate]",
                "\t  ,[FTP].[SortFcstPer]",
                "\t  ,[FTP].[ForecastPeriod]",
                "\t  ,SUM([DFC].[dfcResultantForecast] + [DFC].[dfcPromotionalLift]) AS [Total Forecast]",
                "      ,CONVERT(DATE, [DFC].[dfcSnapshot]) AS [Snapshot Date]",
                "\t  ,(YEAR([DFC].[dfcSnapshot]) * 100) + MONTH([DFC].[dfcSnapshot]) as [Snapshot Year Month]",
                "  FROM [SupplyChain_Enh].[DemandForecastSnapshot] AS DFC",
                "  INNER JOIN (SELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '2Week'",
                "\t\t\t\t\t\t,[SortFcstPer] = 14",
                "\t\t\t\t\t\t,CASE WHEN dateadd(day,15,lag2wk.[FiscalMonthFirstDate]) = '11/10/2025' -- add Nov cycle deviation",
                "\t\t\t\t\t\t    THEN '11/12/2025'",
                "\t\t\t\t\t\tWHEN dateadd(day,15,lag2wk.[FiscalMonthFirstDate]) = '12/08/2025' -- add Dec cycle deviation",
                "\t\t\t\t\t\t    THEN '12/16/2025'",
                "\t\t\t\t\t\t\twhen lag2wk.[FiscalMonthFirstDate] = '12/28/2025' then '1/15/2026' -- add Jan cycle deviation",
                "\t\t\t\t\t\t\twhen lag2wk.[FiscalMonthFirstDate] = '01/25/2025' then '2/16/2026' -- add Feb cycle deviation",
                "      when  lag2wk.[FiscalMonthFirstDate] = '2/22/2026' then '3/16/2026'",
                "      when  lag2wk.[FiscalMonthFirstDate] = '3/29/2026' then '4/20/2026'",
                "      when  lag2wk.[FiscalMonthFirstDate] = '4/26/2026' then '5/16/2026'",
                "      when  lag2wk.[FiscalMonthFirstDate] = '5/24/2026' then '6/15/2026'",
                "\t\t\t\t\t\t\tELSE dateadd(day,15,lag2wk.[FiscalMonthFirstDate]) --default 3rd Monday as forecast cycle",
                "\t\t\t\t\tEND  as [SnapshotDate]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -24 and 0",
                "\t\t\t\t\t\t\t\t\t)lag2wk",
                "\t\t\t\t\t\ton lag2wk.[FiscalMonthIndicator]+0 = dd.[FiscalMonthIndicator]",
                "",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1",
                "",
                "\t\t\t\t\tUNION",
                "",
                "\t\t\t\t\tSELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '30Days'",
                "\t\t\t\t\t\t,[SortFcstPer] = 30",
                "\t\t\t\t\t\t,CASE WHEN dateadd(day,15,lag30d.[FiscalMonthFirstDate]) = '11/10/2025' -- add Nov cycle deviation",
                "\t\t\t\t\t\t    THEN '11/12/2025'",
                "\t\t\t\t\t\tWHEN dateadd(day,15,lag30d.[FiscalMonthFirstDate]) = '12/08/2025' -- add Dec cycle deviation",
                "\t\t\t\t\t\t    THEN '12/16/2025'",
                "\t\t\t\t\t\t\twhen lag30d.[FiscalMonthFirstDate] = '12/28/2025' then '1/15/2026' -- add Jan cycle deviation",
                "\t\t\t\t\t\t\twhen lag30d.[FiscalMonthFirstDate] = '01/25/2025' then '2/16/2026' -- add Feb cycle deviation",
                "      when  lag30d.[FiscalMonthFirstDate] = '2/22/2026' then '3/16/2026'",
                "      when  lag30d.[FiscalMonthFirstDate] = '3/29/2026' then '4/20/2026'",
                "      when  lag30d.[FiscalMonthFirstDate] = '4/26/2026' then '5/16/2026'",
                "      when  lag30d.[FiscalMonthFirstDate] = '5/24/2026' then '6/15/2026'",
                "\t\t\t\t\t\t\tELSE dateadd(day,15,lag30d.[FiscalMonthFirstDate]) --default 3rd Monday as forecast cycle",
                "\t\t\t\t\tEND   as [30Days]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -25 and -1",
                "\t\t\t\t\t\t\t\t\t)lag30d",
                "\t\t\t\t\t\ton lag30d.[FiscalMonthIndicator]+1 = dd.[FiscalMonthIndicator]",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1",
                "",
                "\t\t\t\t\tUNION",
                "",
                "\t\t\t\t\tSELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '60Days'",
                "\t\t\t\t\t\t,[SortFcstPer] = 60",
                "\t\t\t\t\t\t,CASE WHEN dateadd(day,15,lag60d.[FiscalMonthFirstDate]) = '11/10/2025' -- add Nov cycle deviation",
                "\t\t\t\t\t\t    THEN '11/12/2025'",
                "\t\t\t\t\t\tWHEN dateadd(day,15,lag60d.[FiscalMonthFirstDate]) = '12/08/2025' -- add Dec cycle deviation",
                "\t\t\t\t\t\t    THEN '12/16/2025'",
                "\t\t\t\t\t\t\twhen lag60d.[FiscalMonthFirstDate] = '12/28/2025' then '1/15/2026' -- add Jan cycle deviation",
                "\t\t\t\t\t\t\twhen lag60d.[FiscalMonthFirstDate] = '01/25/2025' then '2/16/2026' -- add Feb cycle deviation",
                "      when  lag60d.[FiscalMonthFirstDate] = '2/22/2026' then '3/16/2026'",
                "      when  lag60d.[FiscalMonthFirstDate] = '3/29/2026' then '4/20/2026'",
                "      when  lag60d.[FiscalMonthFirstDate] = '4/26/2026' then '5/16/2026'",
                "      when  lag60d.[FiscalMonthFirstDate] = '5/24/2026' then '6/15/2026'",
                "\t\t\t\t\t\t\tELSE dateadd(day,15,lag60d.[FiscalMonthFirstDate]) --default 3rd Monday as forecast cycle",
                "\t\t\t\t\tEND  as [60Days]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -26 and -2",
                "\t\t\t\t\t\t\t\t\t)lag60d",
                "\t\t\t\t\t\ton lag60d.[FiscalMonthIndicator]+2 = dd.[FiscalMonthIndicator]",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1",
                "",
                "\t\t\t\t\tUNION",
                "",
                "\t\t\t\t\tSELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '90Days'",
                "\t\t\t\t\t\t,[SortFcstPer] = 90",
                "\t\t\t\t\t\t,CASE WHEN dateadd(day,15,lag90d.[FiscalMonthFirstDate]) = '11/10/2025' -- add Nov cycle deviation",
                "\t\t\t\t\t\t    THEN '11/12/2025'",
                "\t\t\t\t\t\tWHEN dateadd(day,15,lag90d.[FiscalMonthFirstDate]) = '12/08/2025' -- add Dec cycle deviation",
                "\t\t\t\t\t\t    THEN '12/16/2025'",
                "\t\t\t\t\t\t\twhen lag90d.[FiscalMonthFirstDate] = '12/28/2025' then '1/15/2026' -- add Jan cycle deviation",
                "\t\t\t\t\t\t\twhen lag90d.[FiscalMonthFirstDate] = '01/25/2025' then '2/16/2026' -- add Feb cycle deviation",
                "      when  lag90d.[FiscalMonthFirstDate] = '2/22/2026' then '3/16/2026'",
                "      when  lag90d.[FiscalMonthFirstDate] = '3/29/2026' then '4/20/2026'",
                "      when  lag90d.[FiscalMonthFirstDate] = '4/26/2026' then '5/16/2026'",
                "      when  lag90d.[FiscalMonthFirstDate] = '5/24/2026' then '6/15/2026'",
                "\t\t\t\t\t\t\tELSE dateadd(day,15,lag90d.[FiscalMonthFirstDate]) --default 3rd Monday as forecast cycle",
                "\t\t\t\t\tEND   as [90Days]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -27 and -3",
                "\t\t\t\t\t\t\t\t\t)lag90d",
                "\t\t\t\t\t\ton lag90d.[FiscalMonthIndicator]+3 = dd.[FiscalMonthIndicator]",
                "",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1   \t\t\t \t\t  \t\t  \t\t \t   ",
                "",
                "",
                "\t",
                "\t\t\tUNION",
                "",
                "\t\t\tSELECT DISTINCT",
                "\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t,[ForecastPeriod] = '120Days'",
                "\t\t\t\t,[SortFcstPer] = 120",
                "\t\t\t\t,CASE WHEN dateadd(day,15,lag120d.[FiscalMonthFirstDate]) = '3/10/2025' ",
                "\t\t\t\t\t\t\tTHEN '3/24/2025'",
                "\t\t\t\t\t\tWHEN dateadd(day,15,lag120d.[FiscalMonthFirstDate]) = '11/10/2025' -- add Nov cycle deviation",
                "\t\t\t\t\t\t    THEN '11/12/2025'",
                "\t\t\t\t\t\tWHEN dateadd(day,15,lag120d.[FiscalMonthFirstDate]) = '12/08/2025' -- add Dec cycle deviation",
                "\t\t\t\t\t\t    THEN '12/16/2025'",
                "\t\t\t\t\t\twhen  lag120d.[FiscalMonthFirstDate] = '12/28/2025' then '1/15/2026'",
                "\t\t\t\t\t\twhen  lag120d.[FiscalMonthFirstDate] = '01/25/2025' then '2/16/2026' -- add Feb cycle deviation",
                "      when  lag120d.[FiscalMonthFirstDate] = '2/22/2026' then '3/16/2026'",
                "      when  lag120d.[FiscalMonthFirstDate] = '3/29/2026'then '4/20/2026'",
                "      when  lag120d.[FiscalMonthFirstDate] = '4/26/2026' then '5/16/2026'",
                "      when  lag120d.[FiscalMonthFirstDate] = '5/24/2026' then '6/15/2026'",
                "\t\t\t\t\t\t\tELSE dateadd(day,15,lag120d.[FiscalMonthFirstDate])",
                "\t\t\t\t\tEND as [90Days]",
                "\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -28 and -5",
                "\t\t\t\t\t\t\t)lag120d",
                "\t\t\t\ton lag120d.[FiscalMonthIndicator]+4 = dd.[FiscalMonthIndicator]",
                "",
                "\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1\t\t\t\t\t   \t\t\t \t\t  \t\t  \t\t \t   ",
                "",
                "",
                "  ) AS FTP",
                "  ON [DFC].[dfcFiscalMonth] = [FTP].[FiscalMonthYear]",
                "    AND [DFC].[dfcSnapshot] = [FTP].[SnapshotDate]",
                "",
                "   GROUP BY [DFC].[dfcItem]",
                "           ,[DFC].[dfcWarehouse]",
                "           ,[DFC].[dfcFiscalMonth]",
                "           ,[FTP].[FiscalMonthLastDate]",
                "           ,[FTP].[ForecastPeriod]",
                "           ,[FTP].[SortFcstPer]",
                "           ,[DFC].[dfcSnapshot]",
                "\t) AS FC",
                "",
                "\tLEFT JOIN (",
                "SELECT [IAD].[Item]",
                "      ,[IAD].[Location]",
                "\t  ,FORMAT([IAD].[Year Period],'yyyyMM') AS [Year Period]",
                "      ,SUM([IAD].[Actual demand]) AS [Actual Demand]",
                "",
                "  FROM [SupplyChain_Enh].[ItemActualDemand_Logility] AS IAD",
                "  INNER JOIN (SELECT DISTINCT [FiscalMonthYear],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -12 and -1",
                "\t\t\t\t\t\t\t)dd_act",
                "\t\t\t\ton dd_act.[FiscalMonthYear] = FORMAT([IAD].[Year Period],'yyyyMM')",
                "  WHERE [IAD].[Company] = 'AFI'",
                "  --  AND FORMAT([IAD].[Year Period],'yyyyMM') > 202409",
                "\t",
                "",
                "  GROUP BY [IAD].[Item]",
                "\t\t  ,[IAD].[Location]",
                "\t\t  ,[IAD].[Year Period]",
                "\t) AS ACT",
                "\tON [FC].[Item SKU] = [ACT].[Item]",
                "      AND [FC].[Warehouse] = [ACT].[Location]",
                "      AND [FC].[FiscalMonthYear] = [ACT].[Year Period]",
                "",
                "LEFT JOIN (",
                "SELECT [N].[Item SKU] AS [Item SKU]",
                "      ,[N].[Warehouse] AS [Warehouse]",
                "\t  ,[D2].[FiscalMonthYear]",
                "      ,CAST([N].[Qty] * [D2].[NumWeeks] AS INT) AS [NaiveFcst]",
                "  FROM (",
                "SELECT [ACT].[Item SKU]",
                "\t  ,[ACT].[Warehouse]",
                "\t  ,[DD].[FiscalMonthIndicator]",
                "\t  ,[D2].[FiscalMonthYear]",
                "\t  ,SUM([ACT].[Order Quantity])/[D2].[NumWeeks] AS [Qty]",
                "",
                "  FROM [SupplyChain_Enh].[ActualsCustItemWH_AFI] AS ACT",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [ACT].[CurReqWkEnding] = [DD].[DateID]",
                "  --LEFT JOIN [PowerBI_SupplyChain].[CustomerAcctMaster_AFI] AS CUS",
                "  --  ON [ACT].[Account And ShipTo Number] = [CUS].[Account And ShipTo Number]",
                "  INNER JOIN (",
                "SELECT [FiscalMonthYear]",
                "      ,[FiscalMonthLastDate]",
                "\t  ,COUNT(DISTINCT [FiscalWeekLastDate]) AS [NumWeeks]",
                "  FROM [Enterprise_DW].[DimDate]",
                "  WHERE [FiscalMonthIndicator] >= -13",
                "  GROUP BY [FiscalMonthYear]",
                "          ,[FiscalMonthLastDate]",
                "  ) AS D2 ",
                "  ON [DD].[FiscalMonthLastDate] = [D2].[FiscalMonthLastDate]",
                "  ",
                "  WHERE [ACT].[Warehouse] NOT IN ('C','CNW','C35','55')",
                "",
                "",
                "GROUP BY [ACT].[Item SKU]",
                "        ,[ACT].[Warehouse]",
                "        ,[DD].[FiscalMonthIndicator]",
                "        ,[D2].[NumWeeks]",
                "\t\t,[D2].[FiscalMonthYear]",
                "",
                "\t) AS N",
                "  INNER JOIN (",
                "SELECT [FiscalMonthYear]",
                "      ,[FiscalMonthLastDate]",
                "\t  ,[FiscalMonthIndicator]",
                "\t  ,COUNT(DISTINCT [FiscalWeekLastDate]) AS [NumWeeks]",
                "  FROM [Enterprise_DW].[DimDate]",
                "  WHERE [FiscalMonthIndicator] < 0",
                "  GROUP BY [FiscalMonthYear]",
                "          ,[FiscalMonthLastDate]",
                "\t\t  ,[FiscalMonthIndicator]",
                "  ) AS D2",
                "  ON ([N].[FiscalMonthIndicator]+1) = [D2].[FiscalMonthIndicator]",
                "",
                "",
                ") AS NF",
                "  ON [FC].[Item SKU] = [NF].[Item SKU]",
                "   AND [FC].[Warehouse] = [NF].[Warehouse]",
                "   AND [FC].[FiscalMonthYear] = [NF].[FiscalMonthYear]",
                "",
                "",
                "LEFT JOIN (",
                "SELECT [N].[Item SKU] AS [Item SKU]",
                "      ,[N].[Warehouse] AS [Warehouse]",
                "\t  ,[D2].[FiscalMonthYear]",
                "      ,CAST([N].[Qty] * [D2].[NumWeeks] AS INT) AS [NaiveFcst]",
                "  FROM (",
                "SELECT [ACT].[Item SKU]",
                "\t  ,[ACT].[Warehouse]",
                "\t  ,[DD].[FiscalMonthIndicator]",
                "\t  ,[D2].[FiscalMonthYear]",
                "\t  ,SUM([ACT].[Order Quantity])/[D2].[NumWeeks] AS [Qty]",
                "",
                "  FROM [SupplyChain_Enh].[ActualsCustItemWH_AFI] AS ACT",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [ACT].[CurReqWkEnding] = [DD].[DateID]",
                "  --LEFT JOIN [PowerBI_SupplyChain].[CustomerAcctMaster_AFI] AS CUS",
                "  --  ON [ACT].[Account And ShipTo Number] = [CUS].[Account And ShipTo Number]",
                "  INNER JOIN (",
                "SELECT [FiscalMonthYear]",
                "      ,[FiscalMonthLastDate]",
                "\t  ,COUNT(DISTINCT [FiscalWeekLastDate]) AS [NumWeeks]",
                "  FROM [Enterprise_DW].[DimDate]",
                "  WHERE [FiscalMonthIndicator] >= -13",
                "  GROUP BY [FiscalMonthYear]",
                "          ,[FiscalMonthLastDate]",
                "  ) AS D2 ",
                "  ON [DD].[FiscalMonthLastDate] = [D2].[FiscalMonthLastDate]",
                "  ",
                "  WHERE [ACT].[Warehouse] NOT IN ('C','CNW','C35','55')",
                "",
                "",
                "GROUP BY [ACT].[Item SKU]",
                "        ,[ACT].[Warehouse]",
                "        ,[DD].[FiscalMonthIndicator]",
                "        ,[D2].[NumWeeks]",
                "\t\t,[D2].[FiscalMonthYear]",
                "",
                "\t) AS N",
                "  INNER JOIN (",
                "SELECT [FiscalMonthYear]",
                "      ,[FiscalMonthLastDate]",
                "\t  ,[FiscalMonthIndicator]",
                "\t  ,COUNT(DISTINCT [FiscalWeekLastDate]) AS [NumWeeks]",
                "  FROM [Enterprise_DW].[DimDate]",
                "  WHERE [FiscalMonthIndicator] < 0",
                "  GROUP BY [FiscalMonthYear]",
                "          ,[FiscalMonthLastDate]",
                "\t\t  ,[FiscalMonthIndicator]",
                "  ) AS D2",
                "  ON ([N].[FiscalMonthIndicator]+1) = [D2].[FiscalMonthIndicator]",
                "",
                "",
                ") AS NF_2",
                "  ON [FC].[Item SKU] = [NF_2].[Item SKU]",
                "   AND [FC].[Warehouse] = [NF_2].[Warehouse]",
                "   AND [FC].[Snapshot Year Month] = [NF_2].[FiscalMonthYear]",
                "",
                "",
                "  WHERE ([FC].[Total Forecast] > 0 OR ISNULL([ACT].[Actual Demand], 0) > 0)",
                "    AND [FC].[FiscalMonthLastDate] < GETDATE()",
                "",
                "",
                "    ",
                "    \", CreateNavigationProperties=false]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"FiscalMonthLastDate\", type date}, {\"Snapshot Date\", type date}, {\"Total Forecast\", Int64.Type}})",
                "in",
                "    #\"Changed Type\""
              ],
              "type": "m"
            }
          }
        ]
      },
