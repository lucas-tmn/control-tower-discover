          {
            "name": "FiscalMonthLastDate",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "dataType": "dateTime",
            "formatString": "General Date",
            "lineageTag": "833fbab6-d509-4f9c-af22-d3046971042e",
            "sourceColumn": "FiscalMonthLastDate",
            "summarizeBy": "none"
          },
          {
            "name": "Status Snapshot",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "dataType": "string",
            "expression": [
              "switch(true(),",
              "                'Month End Status Snapshots'[FutureStatus]=\"F\",\"_DROP\",",
              "                'Month End Status Snapshots'[FutureStatus]=\"P\",\"_DROP\",",
              "                'Month End Status Snapshots'[ItemStatus]=\"D\",\"DISCO\",",
              "                'Month End Status Snapshots'[FutureStatus]=\"L\",\"_DROP\",",
              "                'Month End Status Snapshots'[ItemStatus]=\"D\",\"DISCO\",",
              "                'Month End Status Snapshots'[ItemStatus]=\"R\",\"DISCO\",",
              "                'Month End Status Snapshots'[ItemStatus]=\"N\",\"___NEW\",",
              "                \"__IN LINE\")"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "3c844772-0632-4a87-b687-09cd02081d32",
            "summarizeBy": "none",
            "type": "calculated"
          }
        ],
        "lineageTag": "bcda9516-5977-4477-a3b4-ec43dd422d50",
        "partitions": [
          {
            "name": "Month End Status Snapshots",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Sql.Database(\"Ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "SELECT DISTINCT",
                " dfL.[Item]",
                ",dfl.[ItemStatus]",
                ",dfL.[FutureStatus]",
                ",CASE WHEN dfL.[FutureStatus] = 'W' THEN 1 ELSE 0 END AS [WatchFlag]",
                ",CASE WHEN dfL.[FutureStatus] = 'F' THEN 1 ELSE 0 END AS [FutreDropFlag]",
                ",CASE WHEN dfL.[FutureStatus] = 'P' THEN 1 ELSE 0 END AS [PlanDropFlag]",
                ",CASE WHEN dfL.[FutureStatus] = 'L' THEN 1 ELSE 0 END AS [LiquidatedFlag]",
                ",CASE WHEN dfL.[FutureStatus] = 'E' THEN 1 ELSE 0 END AS [ScrapFlag]",
                ",CASE WHEN dfL.[FutureStatus] in ('F','P','L','E') THEN 1 ELSE 0 END AS [DropFlag]",
                ",CASE WHEN dfL.[FutureStatus] not in ('F','P','L','E') THEN 1 ELSE 0 END AS [InLineFlag]",
                ",dd.[FiscalMonthLastDate]",
                "FROM PowerBI_SupplyChain.DemandFulfillmentCommonContainer_Logility dfL",
                "inner join (select Distinct  --get snapshot date for last monday for prior months",
                "\t\t\t\tFiscalMonthLastDate",
                "\t\t\t\t,dateadd(day,-5,FiscalMonthLastDate) SnapshotDate --Demand Fulfillment Common Container is a Monday Snapshot",
                "\t\t\tfrom Enterprise_DW.DimDate",
                "\t\t\twhere FiscalMonthIndicator between -12 and -1",
                "\t\t\t) dd",
                "\ton cast(dfL.[FileDate] as date) = dd.SnapshotDate",
                "",
                "inner join PowerBI_SupplyChain.CurrentProductDetails cpd",
                "\ton  dfL.[Item] = cpd.[Item Sku]",
                "\tand cpd.[Sellable Item Flag] = 'Y'",
                "\", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
