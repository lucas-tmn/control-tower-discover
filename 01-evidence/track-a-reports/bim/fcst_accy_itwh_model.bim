        "lineageTag": "b0bd4189-7b3f-4eff-94df-97283fa3963f",
        "partitions": [
          {
            "name": "Demand Planner Assignment Rules",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = SharePoint.Tables(\"https://masterashley.sharepoint.com/sites/supplychain-DemandPlanning\", [ApiVersion = 15]),",
                "    #\"531a515e-a80c-46ba-be53-5a789f7b2b5f\" = Source{[Id=\"531a515e-a80c-46ba-be53-5a789f7b2b5f\"]}[Items],",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"531a515e-a80c-46ba-be53-5a789f7b2b5f\",{{\"ID\", \"ID.1\"}}),",
                "    #\"Removed Other Columns\" = Table.SelectColumns(#\"Renamed Columns\",{\"Id\", \"CollectiveClass\", \"CategoryAnalystId\"}),",
                "    #\"Removed Duplicates\" = Table.Distinct(#\"Removed Other Columns\", {\"CollectiveClass\"}),",
                "    #\"Merged Queries2\" = Table.NestedJoin(#\"Removed Duplicates\", {\"CategoryAnalystId\"}, Users, {\"Id\"}, \"Category Analyst\", JoinKind.LeftOuter),",
                "    #\"Expanded Category Analyst\" = Table.ExpandTableColumn(#\"Merged Queries2\", \"Category Analyst\", {\"PlannerName\"}, {\"Category Analyst.PlannerName\"}),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Expanded Category Analyst\",{{\"Category Analyst.PlannerName\", \"CategoryAnalyst\"}})",
                "in",
                "    #\"Renamed Columns1\""
              ],
              "type": "m"
            }
          }
        ]
      },
