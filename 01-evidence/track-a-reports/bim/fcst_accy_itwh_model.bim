          {
            "name": "Collective Class (groups)",
            "annotations": [
              {
                "name": "GroupingDesignState",
                "value": "{\"Version\":0,\"Sources\":[{\"Name\":\"z\",\"Entity\":\"z_ProductDetails\"}],\"GroupedColumns\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"z\"}},\"Property\":\"Collective Class\"}}],\"GroupItems\":[{\"DisplayName\":\"(Blank)\",\"BlankDefaultPlaceholder\":true},{\"DisplayName\":\"ACCENTS\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"z\"}},\"Property\":\"Collective Class\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'ACCESSORIES'\"}}],[{\"Literal\":{\"Value\":\"'LAMPS'\"}}],[{\"Literal\":{\"Value\":\"'RUGS'\"}}],[{\"Literal\":{\"Value\":\"'THROWS & PILLOWS'\"}}]]}}},{\"DisplayName\":\"CASEGOODS\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"z\"}},\"Property\":\"Collective Class\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'BEDROOM'\"}}],[{\"Literal\":{\"Value\":\"'DINING'\"}}]]}}},{\"DisplayName\":\"HO WALL OCC\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"z\"}},\"Property\":\"Collective Class\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'HOME OFFICE'\"}}],[{\"Literal\":{\"Value\":\"'OCCASIONAL TABLES'\"}}],[{\"Literal\":{\"Value\":\"'WALL & ENTERTAINMENT'\"}}]]}}},{\"DisplayName\":\"OTHER\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"z\"}},\"Property\":\"Collective Class\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"''\"}}],[{\"Literal\":{\"Value\":\"'KIDS FURNITURE'\"}}],[{\"Literal\":{\"Value\":\"'POP'\"}}],[{\"Literal\":{\"Value\":\"'SUPPLIER DIRECT SHIP'\"}}],[{\"Literal\":{\"Value\":\"'TOB'\"}}]]}}},{\"DisplayName\":\"RTA & METAL BEDS\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"z\"}},\"Property\":\"Collective Class\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'ACCESSORY RTA'\"}}],[{\"Literal\":{\"Value\":\"'CASEGOOD RTA'\"}}],[{\"Literal\":{\"Value\":\"'METAL BEDS'\"}}],[{\"Literal\":{\"Value\":\"'STATIONARY UPH RTA'\"}}]]}}}]}"
              },
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "dataType": "string",
            "expression": [
              "SWITCH(",
              "\tTRUE,",
              "\tISBLANK('z_ProductDetails'[Collective Class]),",
              "\t\"(Blank)\",",
              "\t'z_ProductDetails'[Collective Class] IN {\"ACCESSORIES\",",
              "\t\t\"LAMPS\",",
              "\t\t\"RUGS\",",
              "\t\t\"THROWS & PILLOWS\"},",
              "\t\"ACCENTS\",",
              "\t'z_ProductDetails'[Collective Class] IN {\"BEDROOM\",",
              "\t\t\"DINING\"},",
              "\t\"CASEGOODS\",",
              "\t'z_ProductDetails'[Collective Class] IN {\"HOME OFFICE\",",
              "\t\t\"OCCASIONAL TABLES\",",
              "\t\t\"WALL & ENTERTAINMENT\"},",
              "\t\"HO WALL OCC\",",
              "\t'z_ProductDetails'[Collective Class] IN {\"\",",
              "\t\t\"KIDS FURNITURE\",",
              "\t\t\"POP\",",
              "\t\t\"SUPPLIER DIRECT SHIP\",",
              "\t\t\"TOB\"},",
              "\t\"OTHER\",",
              "\t'z_ProductDetails'[Collective Class] IN {\"ACCESSORY RTA\",",
              "\t\t\"CASEGOOD RTA\",",
              "\t\t\"METAL BEDS\",",
              "\t\t\"STATIONARY UPH RTA\"},",
              "\t\"RTA & METAL BEDS\",",
              "\t'z_ProductDetails'[Collective Class]",
              ")"
            ],
            "extendedProperties": [
              {
                "name": "GroupingMetadata",
                "type": "json",
                "value": {
                  "groupedColumns": [
                    {
                      "Column": {
                        "Expression": {
                          "SourceRef": {
                            "Entity": "z_ProductDetails"
                          }
                        },
                        "Property": "Collective Class"
                      }
                    }
                  ],
                  "version": 0
                }
              }
            ],
            "isDataTypeInferred": true,
            "lineageTag": "f8532cdf-ee69-4951-9cfb-069f3bcd44c3",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "PR Categories",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "dataType": "string",
            "expression": [
              "switch(TRUE()",
              "                            ,RIGHT(z_ProductDetails[Collective Class],3) = \"RTA\",\"RTA\"",
              "                            ,z_ProductDetails[Collective Class] = \"METAL BEDS\",\"CASEGOODS\",z_ProductDetails[Collective Class] = \"BEDROOM\",\"CASEGOODS\"",
              "                            ,z_ProductDetails[Collective Class] = \"DINING\",\"CASEGOODS\"",
              "                            ,OR(z_ProductDetails[AFI Sales Division]=\"MOTION\",z_ProductDetails[AFI Sales Division]=\"SIGNATURE MOTION\"),\"MOTION\"",
              "                            ,OR(z_ProductDetails[AFI Sales Division]=\"Stationary\",z_ProductDetails[AFI Sales Division]=\"SIGNATURE STATIONARY\"),\"STATIONARY\"",
              "                            ,z_ProductDetails[Collective Class] = \"ACCESSORIES\",\"Accents\"",
              "                            ,z_ProductDetails[Collective Class] = \"LAMPS\",\"Accents\"",
              "                            ,z_ProductDetails[Collective Class] = \"RUGS\",\"Accents\"",
              "                            ,z_ProductDetails[Collective Class] = \"THROWS & PILLOWS\",\"Accents\"",
              "                            ,z_ProductDetails[Collective Class]",
              ")"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "06ec3f3d-92b0-47f2-8a35-c707c2219b83",
            "summarizeBy": "none",
            "type": "calculated"
