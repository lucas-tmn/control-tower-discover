          }
        ],
        "lineageTag": "d3ffbfeb-9127-482f-be08-90be2a94e213",
        "measures": [
          {
            "name": "Forecast",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "CALCULATE(SUM(ItWHAccy[Total Forecast]))",
            "formatString": "#,0",
            "lineageTag": "2cc26fcc-3b8b-467b-86a6-873f49e91bee"
          },
          {
            "name": "Actuals",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "CALCULATE(SUM(ItWHAccy[Actual Demand]))",
            "formatString": "#,0",
            "lineageTag": "65c26607-9be1-4492-8f05-35ea85fdc6fa"
          },
          {
            "name": "Error Qty",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "[Forecast] - [Actuals]",
            "formatString": "#,0",
            "lineageTag": "7fc0c547-063d-4f73-857a-b9d8f721c6d9"
          },
          {
            "name": "Bias %",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "DIVIDE([Error Qty],[Actuals])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "b3df8d3c-c4e5-4684-9fff-79e1c32cce91"
          },
          {
            "name": "Mean ABS Dev",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "AVERAGEX(ItWHAccy,[ABS(Error)])",
            "formatString": "0",
            "lineageTag": "c37dd194-333c-4203-ae47-6308c1082f72"
          },
          {
            "name": "Mean Act Dmd",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "AVERAGEX(ItWHAccy,[Actual Demand])",
            "lineageTag": "f08ef1af-5e11-4de1-943c-2081b8608e47"
          },
          {
            "name": "wMAPE",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "DIVIDE([Mean ABS Dev],[Mean Act Dmd])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "b4ea9080-befb-4d44-8768-355570542e10"
          },
          {
            "name": "(N)Mean ABS Dev",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "AVERAGEX(ItWHAccy,[(N)ABS(Error)])",
            "lineageTag": "b9cf6082-40f7-41e0-b56c-021cd7b24f28"
          },
          {
            "name": "Naive wMAPE",
            "changedProperties": [
