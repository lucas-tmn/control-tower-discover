            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "isDataTypeInferred": true,
            "isNameInferred": true,
            "lineageTag": "8d94d6b1-96fe-4447-b21c-59757511fcf2",
