              }
            ]
          }
        ],
        "lineageTag": "d5aa464b-2882-42f5-9125-fe836c725b4f",
        "partitions": [
          {
            "name": "RequireVerification",
            "mode": "import",
            "source": {
              "expression": [
                "",
                "DISTINCT(",
                "    SELECTCOLUMNS(",
                "        POAdjusment,",
                "        \"PO #\", POAdjusment[PONumber],",
                "        \"Vendor #\", POAdjusment[VendorNumber],",
                "        \"PO Created Date\", POAdjusment[POCreatedDate],",
                "        \"ETD\", POAdjusment[PO_ETD],",
                "        \"ETA\", POAdjusment[PO_ETA],",
                "        \"Whse\", POAdjusment[POWarehouse],",
                "        \"Status\", POAdjusment[PO Status],",
                "        \"Total Finished Goods ($)\", POAdjusment[POAmount],",
                "        \"FCA Service\", POAdjusment[FCA_SERVICE],",
                "        \"Audit Status\", POAdjusment[Status],",
                "        \"Invoice Adjustment Amount\", POAdjusment[AdjustmentAmount],",
                "        \"Invoice Adjustment Note\", POAdjusment[AdjustmentNote],",
                "        \"Office\", POAdjusment[VendorOffice]",
                "    )",
                ")"
              ],
              "type": "calculated"
            }
          }
        ]
      },
