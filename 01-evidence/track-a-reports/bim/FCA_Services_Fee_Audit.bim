        "lineageTag": "5fbf2d89-2e60-4366-b2f4-3acd257d605e",
        "partitions": [
          {
            "name": "POAdjusment",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ASHLEY_EDW\", [Query=\"With POAdjustments as (#(lf)#(tab)Select OrderNum , AdjAmount , Note , Created , adjcategory#(lf)#(tab)From Wholesale_ProductSourcing.POAdjustments#(lf)#(tab)Where 1=1#(lf)#(tab)--AND [adjcategory] = 6#(lf)#(tab)--AND [Note] = 'Fumigation Charges'#(lf))#(lf)#(lf)Select#(lf)    PM.pomordernum as 'PONumber',#(lf)    PM.pomcreated as 'POCreatedDate',#(lf)    PM.pomIncoTermsCode as 'POIncoterm',#(lf)    PM.pomstatuscode as 'POStatusCode',#(lf)    PM.pometd as 'PO_ETD',#(lf)    PM.pometa as 'PO_ETA',#(lf)    PM.pomWarehouse as 'POWarehouse',#(lf)    PM.pomvendornum as 'VendorNumber',#(lf)    VD.VNAME as 'VendorName',#(lf)    VD.VNAMA as 'VendorOffice',#(lf)    PM.pomorderamt as 'POAmount',#(lf)    PA.AdjAmount as 'AdjustmentAmount',#(lf)    PA.Note as 'AdjustmentNote'#(lf)#(tab)--, ROUND((PM.pomorderamt * 0.05) / (1 - 0.05),2) as 'FCAService'#(lf)From [Wholesale_ProductSourcing_AFI].[PoMaster] PM#(lf)LEFT JOIN Wholesale_Purchasing_AFI.VENNAM VD#(lf)    on VD.VNDNR = PM.pomvendornum#(lf)LEFT JOIN POAdjustments PA#(lf)    on PA.OrderNum = PM.pomordernum#(lf)Where 1=1#(lf)    AND PM.POmStatuscode > 20 AND PM.POmStatuscode < 60 --Choose PO Status In-Transit, Partial RcToStock, Rc. To Stk, Receiver#(lf)    AND PM.pomIncoTermsCode = 'FCA'#(lf)    AND PM.[pomcreated] >= '2025-09-01'\", CreateNavigationProperties=false]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"PONumber\", type text}, {\"POCreatedDate\", type datetime}, {\"POIncoterm\", type text}, {\"POStatusCode\", Int64.Type}, {\"PO_ETD\", type datetime}, {\"POWarehouse\", type text}, {\"VendorNumber\", type text}, {\"VendorName\", type text}, {\"VendorOffice\", type text}, {\"POAmount\", type number}, {\"AdjustmentAmount\", type number}, {\"AdjustmentNote\", type text}})",
                "in",
                "    #\"Changed Type\""
              ],
              "type": "m"
            }
          }
        ]
      },
