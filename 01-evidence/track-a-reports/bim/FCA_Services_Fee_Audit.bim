        ],
        "lineageTag": "f3b21a2f-7d67-4fce-921f-1f4cfa4dabd8",
        "partitions": [
          {
            "name": "Refreshed date",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    // Lấy UTC time dưới dạng DateTime (không có zone)",
                "    UtcNow = DateTime.From(DateTimeZone.UtcNow()),",
                "    // Add 7 hours để ra Vietnam time",
                "    VietnamTime = UtcNow + #duration(0, 7, 0, 0),",
                "    ConvertedToTable = #table(1, {{VietnamTime}}),",
                "    ChangedType = Table.TransformColumnTypes(ConvertedToTable, {{\"Column1\", type datetime}}),",
                "    RenamedColumns = Table.RenameColumns(ChangedType, {{\"Column1\", \"Refreshed date\"}})",
                "in",
                "    RenamedColumns"
              ],
              "type": "m"
            }
          }
        ]
      },
