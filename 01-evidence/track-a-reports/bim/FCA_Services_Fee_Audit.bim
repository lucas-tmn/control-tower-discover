          },
          {
            "name": "Invoice Adjustment Note",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "isDataTypeInferred": true,
            "isNameInferred": true,
            "lineageTag": "24fda3e0-c85c-4876-aff7-d7638ab78e24",
            "sourceColumn": "[Invoice Adjustment Note]",
            "summarizeBy": "none",
            "type": "calculatedTableColumn"
          },
          {
            "name": "FCA_Count",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "expression": [
              "",
              "VAR CurrentPO = RequireVerification[PO #]",
              "RETURN",
              "CALCULATE(",
              "    COUNTROWS(",
              "        FILTER(",
              "            POAdjusment,",
              "            POAdjusment[PONumber] = CurrentPO &&",
              "            SEARCH(\"FCA\", POAdjusment[AdjustmentNote], 1, 0) > 0",
              "        )",
              "    )",
              ")"
            ],
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "4150b72c-71e6-4814-9996-77c94765ce85",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "Classification",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "VAR FCA_Count = RequireVerification[FCA_Count]",
              "VAR InvAdj = RequireVerification[Invoice Adjustment Amount]",
              "VAR FCAService = RequireVerification[FCA Service]",
              "VAR Office = RequireVerification[Office]",
              "VAR Warehouse = RequireVerification[Whse]",
              "",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    InvAdj = 0 && FCAService = 0, BLANK(),",
              "    ISBLANK(FCA_Count) && Warehouse = \"335\" && Office = \"CVRO\", BLANK(),",
              "    FCA_Count = 1 && Warehouse = \"335\" && Office = \"CVRO\", \"FCA Serivce is ineligible for Ashton shipment from CVRO suppliers\",",
              "    FCA_Count > 1, \"Duplicate FCA Service\",",
              "    FCA_Count < 1, \"Missing FCA Service\",",
              "    InvAdj > FCAService, \"FCA Service Adjustment is more than expected\",",
              "    InvAdj < FCAService, \"FCA Service Adjustment is less than expected\",",
              "    BLANK()",
              ")"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "c32977e2-dce2-484b-ac67-4a6cb6ecdc92",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Audit Status",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
