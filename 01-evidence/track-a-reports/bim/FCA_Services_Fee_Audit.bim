          {
            "name": "FCA_SERVICE",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              },
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ],
            "dataType": "double",
            "expression": "'POAdjusment'[POAmount]*RELATED(PISAdjustment[PIS Adjustment %])/(1 - RELATED(PISAdjustment[PIS Adjustment %]))",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "isDataTypeInferred": true,
            "lineageTag": "fd8590e6-55d0-4cac-be9b-e4ce43015a37",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "Status",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    POAdjusment[VendorOffice] = \"CVRO\" && POAdjusment[POWarehouse] = \"335\", \"FAILED\",",
              "    ABS('POAdjusment'[AdjustmentAmount]-POAdjusment[FCA_SERVICE])/POAdjusment[FCA_SERVICE] < 0.005,\"PASSED\",",
              "    \"FAILED\"",
              ")",
              "",
              "",
              "//IF(ABS('POAdjusment'[AdjustmentAmount]-POAdjusment[FCA_SERVICE])/POAdjusment[FCA_SERVICE] < 0.005,\"PASSED\",\"FAILED\")) //"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "256475df-06a9-4282-85a7-8374c54e07c7",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "PO Status",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "SWITCH(",
              "    TRUE(),",
              "    POAdjusment[POStatusCode] = 10, \"Cfm Required\",",
              "    POAdjusment[POStatusCode] = 20,  \"On-Order\",",
              "    POAdjusment[POStatusCode] = 30,  \"In-Transit\",",
              "    POAdjusment[POStatusCode] = 35,  \"Partial RctoStk\",",
              "    POAdjusment[POStatusCode] = 40,  \"Rc. To Stk.\",",
              "    POAdjusment[POStatusCode] = 50,  \"Receiver\",",
              "    POAdjusment[POStatusCode] = 60,  \"Closed\",",
              "    POAdjusment[POStatusCode] = 99,  \"Canceled\",",
              "    \"NA\"",
              ")"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "27303de9-56f5-41aa-8578-57586b8dea6f",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "FCA_Count",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "expression": [
              "",
              "LOOKUPVALUE(RequireVerification[FCA_Count],RequireVerification[PO #],POAdjusment[PONumber])"
            ],
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "1104535c-34f5-4ac7-a835-931b6caa359b",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "PO_ETA",
            "annotations": [
              {
                "name": "SummarizationSetBy",
