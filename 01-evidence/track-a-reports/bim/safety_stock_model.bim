        ],
        "lineageTag": "bcf05f24-21f8-416a-9258-cb28dc099396",
        "partitions": [
          {
            "name": "z_CostDefault",
            "mode": "import",
            "source": {
              "expression": [
                "// SQL Query Template",
                "",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\",",
                "                [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "",
                "SELECT RTRIM([ASA].[ITNBR]) AS [ItemSKU]",
                "      ,[ASA].[UCDEF] AS [CostDefault]",
                "      ,ISNULL([PD].[PlanDropDecision],DATEADD(YEAR,5,CONVERT(DATE,GETDATE()))) AS [PlanDropDecision]",
                "  FROM [MasterData_ItemMaster_AFI].[ITEMASA] AS [ASA]",
                "  INNER JOIN [SupplyChain_DW].[DimCurrentProductDetails] AS CPD",
                "    ON [ASA].[ITNBR] = [CPD].[Item SKU]",
                "  LEFT JOIN (",
                " SELECT [DFL].[Item]",
                "      ,MIN([DFL].[WeekEnding]) AS [PlanDropDecision]",
                "  FROM [SupplyChain_Enh].[DemandFulfillmentCommonContainer_Logility] AS DFL",
                " ",
                "  WHERE [DFL].[FutureStatus] IN ('F','P')",
                "  GROUP BY [DFL].[Item]",
                "  ) AS PD",
                "  ON [ASA].[ITNBR] = [PD].[Item]",
                "",
                "                      \", CreateNavigationProperties=false]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"PlanDropDecision\", type date}})",
                "in",
                "    #\"Changed Type\""
              ],
              "type": "m"
            }
          }
        ]
      },
