      {
        "name": "z_KitMkt",
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ],
        "columns": [
          {
            "name": "Item SKU",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "lineageTag": "82476a5c-4f96-4864-abb3-a8e4ec3309dd",
            "sourceColumn": "Item SKU",
            "summarizeBy": "none"
          },
          {
            "name": "Kit - Mkt Intro At",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "lineageTag": "0693a76e-337c-4fe4-87d6-456939bebc02",
            "sourceColumn": "Kit - Mkt Intro At",
            "summarizeBy": "none"
          }
        ],
        "excludeFromModelRefresh": true,
        "lineageTag": "6a023c22-1850-4b9c-b39e-c32d9989a1be",
        "partitions": [
          {
            "name": "z_KitMkt",
            "mode": "import",
            "source": {
              "expression": [
                "// SQL Query Template",
                "",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\",",
                "                [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "",
                "SELECT [CPD].[Item SKU]",
                "\t  ,[MIA].[Market Introduced At] AS [Kit - Mkt Intro At]",
                "  FROM [SupplyChain_DW].[DimCurrentProductDetails] AS CPD",
                "  LEFT JOIN (",
                "",
                "SELECT [CPD].[Item Ext Series Number]",
                "      ,MAX([CPD].[Market Introduced At]) AS [Market Introduced At]",
                "  FROM [SupplyChain_DW].[dimCurrentProductDetails] AS CPD",
                "  WHERE [CPD].[Collective Class] IN ('STATIONARY UPH','MOTION UPH')",
                "    AND [CPD].[Responsible Office] <> 'ECOM'",
                "",
                "  GROUP BY [CPD].[Item Ext Series Number]",
                "",
                "  ) AS MIA",
                "",
                "  ON [CPD].[Item Ext Series Number] = [MIA].[Item Ext Series Number]",
                "  WHERE [CPD].[Item Class Code] LIKE 'Z__K'",
                "  ",
                "                      \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
