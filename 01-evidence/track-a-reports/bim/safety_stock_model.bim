        "lineageTag": "33ee81ae-f973-4c9b-87ef-cca1220ce7e5",
        "measures": [
          {
            "name": "FcastCOGS",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "CALCULATE(SUM(InvGoal[12Mo COGS]))",
            "lineageTag": "4f144791-ae2b-4b3f-a46f-0be7d8a3667f"
          },
          {
            "name": "GoalInvCost",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "CALCULATE(SUM(InvGoal[Goal Inv Cost]))",
            "lineageTag": "9c5a4d4c-5145-4677-b92a-f53d7821c50b"
          },
          {
            "name": "GoalInvTurns",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "DIVIDE([FcastCOGS],[GoalInvCost])",
            "lineageTag": "f0f3a24c-07cd-4a83-8799-ae0188777839"
          }
        ],
        "partitions": [
          {
            "name": "InvGoal",
            "mode": "import",
            "source": {
              "expression": [
                "// SQL Query Template",
                "",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\",",
                "                [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "",
                "SELECT [DFC].[dfcItem] AS [Item SKU]",
                "      ,[DFC].[dfcWarehouse] AS [Warehouse]",
                "\t  ,[RVB].[STDUC] AS [Std Cost]",
                "\t  ,SUM([DFC].[dfcResultantForecast]+[DFC].[dfcPromotionalLift]) AS [12Mo Fcst]",
                "\t  ,CAST(SUM([DFC].[dfcResultantForecast]+[DFC].[dfcPromotionalLift])*[RVB].[STDUC] AS DEC(12,2)) AS [12Mo COGS]",
                "\t  ,[Inv].[Goal Inv]",
                "\t  ,[Inv].[Goal Inv] * [RVB].[STDUC] AS [Goal Inv Cost]",
                "\t  ,[DFC].[dtea] AS [FcastSnapshot]",
                "\t  ,[Inv].[InvSnapshot]",
                "  FROM [SupplyChain_Enh].[DemandForecastSnapshot] AS DFC",
                "  INNER JOIN ( ",
                "SELECT DISTINCT [FiscalMonthYear]",
                "  FROM [Enterprise_DW].[DimDate] ",
                "  WHERE [FiscalMonthIndicator] BETWEEN 0 AND 11",
                "  ) AS DD",
                "  ON [DFC].[dfcFiscalMonth] = [DD].[FiscalMonthYear]",
                "",
                "LEFT JOIN ( ",
                "SELECT [DIN].[dinItem]",
                "      ,[DIN].[dinWarehouse]",
                "      ,AVG([DIN].[dinSafetyStock]) AS [Goal Inv]",
                "\t  ,[DIN].[dtea] AS [InvSnapshot]",
                "  FROM [SupplyChain_Enh].[DemandInventorySnapshot] AS DIN",
                "  INNER JOIN ( ",
                "SELECT DISTINCT [FiscalMonthYear]",
                "  FROM [Enterprise_DW].[DimDate] ",
                "  WHERE [FiscalMonthIndicator] BETWEEN 0 AND 11",
                "  ) AS DD",
                "    ON [DIN].[dinFiscalMonth] = [DD].[FiscalMonthYear]",
                "  LEFT JOIN [PowerBI_SupplyChain].[CurrentProductDetails] AS CPD",
                "    ON [DIN].[dinItem] = [CPD].[Item SKU]",
                "  WHERE [DIN].[dtea] = (SELECT MAX([dtea]) FROM [SupplyChain_Enh].[DemandInventorySnapshot])",
                "    --AND [DIN].[dinItem] = 'M69731'",
                "",
                "\tGROUP BY [DIN].[dinItem]",
                "            ,[DIN].[dinWarehouse]",
                "\t\t\t,[DIN].[dtea]",
                ") AS Inv ",
                "  ON [DFC].[dfcItem] = [Inv].[dinItem]",
                "    AND [DFC].[dfcWarehouse] = [Inv].[dinWarehouse]",
                "",
                "  LEFT JOIN [MasterData_ItemMaster_AFI].[ITMRVB] AS RVB",
                "    ON [DFC].[dfcItem] = [RVB].[ITNBR]",
                "\t  AND [RVB].[STID] = '000'",
                "  WHERE [DFC].[dtea] = (SELECT MAX([dtea]) FROM [SupplyChain_Enh].[DemandForecastSnapshot])",
                "    --AND [DFC].[dfcItem] = 'M69731'",
                "",
                "  GROUP BY [DFC].[dfcItem]",
                "          ,[DFC].[dfcWarehouse]",
                "          ,[RVB].[STDUC]",
                "          ,[Inv].[Goal Inv]",
                "          ,[DFC].[dtea]",
                "          ,[Inv].[InvSnapshot]",
                "",
                "                      \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
