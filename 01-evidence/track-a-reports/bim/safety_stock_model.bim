                  "hierarchy": "Date Hierarchy",
                  "table": "LocalDateTable_2a8f7292-bf51-4a40-99dd-440b910320cb"
                },
                "isDefault": true,
                "relationship": "30266f13-d1fa-44bf-8303-3db3ed8e8e07"
