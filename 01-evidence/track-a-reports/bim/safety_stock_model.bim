        "partitions": [
          {
            "name": "InvTurns",
            "mode": "import",
            "source": {
              "expression": [
                "// SQL Query Template",
                "",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\",",
                "                [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "",
                "/* Inventory Turns */",
                "",
                "DECLARE @Periods INT ",
                "SET @Periods = -36",
                "",
                "-- Get STD Cost History by Week Ending ",
                "SELECT [MEIR].[FiscalWeekLastDate]",
                "      ,[MEIR].[SiteIdentifier]",
                "\t  ,TRIM([MEIR].[ItemNumber]) AS [ItemNumber]",
                "\t  ,[MEIR].[StandardCost]",
                "\t  --,COALESCE([WM].[Warehouse Code],[IB].[Warehouse]) AS [Warehouse]",
                "\t  --,SUM(ISNULL([IB].[OnHandQty],0)) AS [OnHandQty]",
                "\t  ,[DD].[FiscalMonthIndicator]",
                "\t  ,[DD].[FiscalWeekIndicator]",
                "\t  ,[DD].[FiscalMonthLastDate]",
                "\t  ,[DD].[FiscalMonthFirstDate]",
                "INTO #STDUC",
                "  FROM [Inventory_Enh_History].[MonthEndItemRevision] AS MEIR",
                "",
                "  INNER JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [MEIR].[FiscalWeekLastDate] = [DD].[DateID]",
                "\t  AND [DD].[FiscalMonthIndicator] BETWEEN @Periods AND -1",
                "",
                "  INNER JOIN [Enterprise_DW].[DimItemMaster] AS CPD",
                "    ON  [MEIR].[ItemNumber] = [CPD].[ItemSKU]",
                "\t AND [CPD].[SellableItemFlag] = 'Y'",
                "\t AND [CPD].[MarketIntroducedAt] <> 'Supplier Direct Ship'",
                "     AND [CPD].[ItemClassCode] NOT LIKE 'Z__K'",
                "     AND [CPD].[ItemClassCode] <> 'ZAHM'",
                "     AND [CPD].[ItemClassCode] <> 'ZARP'",
                "     AND [CPD].[ItemSKU] NOT LIKE '%SW'",
                "     AND [CPD].[ItemSKU] NOT LIKE '%CARD'",
                "     AND [CPD].[ItemSKU] NOT LIKE '%UN'",
                "     AND [CPD].[ItemSKU] NOT LIKE '%HIDES'",
                "     AND [CPD].[ItemSKU] NOT LIKE '%VINYL'",
                " ",
                " WHERE  [MEIR].[SiteIdentifier] = '000' ",
                "    AND LEFT([MEIR].[ChargeNature], 3) = '159'",
                "",
                "",
                "/* Get Sales Data*/",
                "",
                "SELECT [FSH].[Item SKU]",
                "      ,[FSH].[Warehouse]",
                "\t  ,[DD].[FiscalWeekLastDate]",
                "\t  ,SUM([FSH].[Quantity Shipped]) AS [Qty]",
                "\t  ,SUM([FSH].[Amount Shipped] ",
                "\t        - [FSH].[Invoice Discount]",
                "\t\t\t+ [FSH].[Other Allowances])",
                "\t\t\t- (ISNULL([Q].[Quality]+[Q].[Returns]+[Q].[Shortage],0))",
                "\t\t\tAS [NetSales]",
                "INTO #Sales\t\t",
                "  FROM [AFISales_DW].[FactShippedHistory] AS FSH",
                "  INNER JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [FSH].[Invoice date] = [DD].[DateID]",
                "\t  AND [DD].[FiscalMonthIndicator] BETWEEN @Periods AND -1",
                "",
                "LEFT JOIN ( ",
                "SELECT [FQC].[Item SKU]",
                "      ,[IH].[Warehouse]",
                "\t  ,[DD].[FiscalWeekLastDate]",
                "\t  ,SUM([FQC].[Quality Credits]) AS [Quality]",
                "\t  ,SUM([FQC].[Returns Amount]) AS [Returns]",
                "\t  ,SUM([FQC].[Short Ship Amount]) AS [Shortage]",
                "  FROM [AFISales_DW].[FactQualityCosts] AS FQC",
                "  ",
                "  LEFT JOIN [Wholesale_SalesHistory_AFI].[InvoiceHeader] AS IH",
                "    ON [FQC].[Original Invoice] = [IH].[InvoiceNumber]",
                "\t  AND [FQC].[Original Order] = [IH].[OrderNumber]",
                "  ",
                "  INNER JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [IH].[InvoiceDate] = [DD].[DateID]",
                "\t  AND [DD].[FiscalMonthIndicator] BETWEEN @Periods AND -1",
                "  --WHERE [FQC].[Item SKU] = 'M69731'",
                "",
                "  GROUP BY [FQC].[Item SKU]",
                "          ,[IH].[Warehouse]",
                "\t\t  ,[DD].[FiscalWeekLastDate]",
                ") AS Q ",
                "  ON [FSH].[Item SKU] = [Q].[Item SKU]",
                "    AND [FSH].[Warehouse] = [Q].[Warehouse]",
                "\tAND [DD].[FiscalWeekLastDate] = [Q].[FiscalWeekLastDate]",
                "  ",
                "  WHERE [FSH].[Warehouse] NOT IN ('55','C','CNW','C35')",
                "",
                "GROUP BY [FSH].[Item SKU]",
                "        ,[FSH].[Warehouse]",
                "        ,[DD].[FiscalWeekLastDate]",
                "        ,[Q].[Quality]",
                "        ,[Q].[Returns]",
                "        ,[Q].[Shortage]",
                "",
                "",
                "-- Calculate Rolling 12Mo Cogs",
                "SELECT [Roll].[FiscalMonthFirstDate]",
                "      ,[Roll].[FiscalMonthLastDate]",
                "      ,[Roll].[FiscalMonthIndicator]",
                "      ,[Roll].[SiteIdentifier]",
                "      ,[Roll].[ItemNumber]",
                "      ,[Roll].[Warehouse]",
                "      ,[Roll].[Avg Std Cost]",
                "      ,[Roll].[Qty]",
                "      ,[Roll].[COGS - STD Cost]",
                "      ,[Roll].[NetSales]",
                "\t  ,CAST(SUM([Roll].[COGS - STD Cost])  OVER (PARTITION BY [Roll].[ItemNumber],[Roll].[Warehouse]",
                "\t\t\t\t\t\t\t\t\t\t\t\tORDER BY [Roll].[FiscalMonthLastDate]",
                "\t\t\t\t\t\t\t\t\t\t\t\t\tROWS BETWEEN 11 PRECEDING AND 0 PRECEDING",
                "\t\t\t\t\t) AS DEC(10,2)",
                "\t\t\t\t) AS [12mo COGS - STD Cost]",
                "\t  ,COUNT(*) OVER (PARTITION BY [Roll].[ItemNumber], [Roll].[Warehouse]",
                "\t\t\t\t\t\t\t\t\t\t\t\tORDER BY [Roll].[FiscalMonthLastDate]",
                "\t\t\t\t\t\t\t\t\t\t\t\t\tROWS BETWEEN 11 PRECEDING AND 0 PRECEDING) as [PeriodCount]",
                "INTO #RollCOGS",
                "FROM (",
                "",
                "SELECT [C].[FiscalMonthFirstDate]",
                "      ,[C].[FiscalMonthLastDate]",
                "      ,[C].[FiscalMonthIndicator]",
                "      ,[C].[SiteIdentifier]",
                "      ,[C].[ItemNumber]",
                "      ,[S].[Warehouse]",
                "      --,[C].[StandardCost]",
                "\t  ,CASE ",
                "\t\t\tWHEN SUM([S].[Qty]) = 0",
                "\t\t\t  THEN 0",
                "\t\t\tELSE CAST(SUM(([C].[StandardCost]*[S].[Qty]))/SUM([S].[Qty]) AS DEC(10,2)) ",
                "\t\tEND AS [Avg Std Cost]",
                "      ,SUM([S].[Qty]) AS [Qty]",
                "\t  ,CAST(SUM(([C].[StandardCost]*[S].[Qty])) AS DEC(10,2)) AS [COGS - STD Cost]",
                "      ,SUM([S].[NetSales] ) AS [NetSales]",
                "  FROM [#STDUC] AS C",
                "  LEFT JOIN [#Sales] AS S",
                "    ON [C].[ItemNumber] = [S].[Item SKU]",
                "\t  AND [C].[FiscalWeekLastDate] = [S].[FiscalWeekLastDate]",
                "  --WHERE [C].[ItemNumber] = 'M69731'",
                "  --  AND [S].[Warehouse] = '1'",
                "",
                "\tGROUP BY [C].[FiscalMonthFirstDate]",
                "\t        ,[C].[FiscalMonthLastDate]",
                "            ,[C].[FiscalMonthIndicator]",
                "            ,[C].[SiteIdentifier]",
                "            ,[C].[ItemNumber]",
                "            ,[S].[Warehouse]",
                "",
                "\t) AS Roll",
                "",
                "",
                "-- Pull Item Balance Records",
                "SELECT [IB1].[FiscalMonthLastDate]",
                "      ,[IB1].[ItemNumber]",
                "      ,[IB1].[Warehouse]",
                "      ,AVG([IB1].[End OH Qty]) AS [Avg OH Qty]",
                "\t  ,AVG([IB1].[Inv Dollars]) AS [Avg Inv Dollars]",
                "INTO #ItemBal",
                "FROM ( ",
                "",
                "SELECT [STC].[FiscalMonthFirstDate]",
                "      ,[STC].[FiscalMonthLastDate]",
                "\t  ,[STC].[FiscalWeekLastDate]",
                "\t  ,[STC].[ItemNumber]",
                "\t  ,COALESCE([WM].[Warehouse Code],[EIB].[Warehouse]) AS [Warehouse]",
                "\t  ,SUM(ISNULL([EIB].[OnHandQty],0)) AS [End OH Qty]",
                "\t  ,SUM(ISNULL([EIB].[OnHandQty],0)*[STC].[StandardCost]) AS [Inv Dollars]",
                "",
                "  FROM  [#STDUC] AS STC",
                "",
                "",
                "  LEFT JOIN [Inventory_Enh_History].[ItemBalance] AS EIB",
                "    ON [EIB].[ItemNumber] = [STC].[ItemNumber]",
                "\t  AND [EIB].[DateWeekEnding] = [STC].[FiscalWeekLastDate]",
                "  LEFT JOIN [PowerBI_SupplyChain].[WarehouseMaster] AS WM",
                "    ON [EIB].[Warehouse] = [WM].[Intransit Warehouse]",
                "",
                "\tWHERE [EIB].[Warehouse] NOT IN ('55','C','CNW','C35')",
                "",
                "",
                "  GROUP BY COALESCE([WM].[Warehouse Code],[EIB].[Warehouse])",
                "          ,[STC].[FiscalMonthFirstDate]",
                "          ,[STC].[FiscalMonthLastDate]",
                "\t\t  ,[STC].[FiscalWeekLastDate]",
                "          ,[STC].[ItemNumber]",
                "",
                "\t) AS IB1",
                "\tGROUP BY [IB1].[FiscalMonthLastDate]",
                "            ,[IB1].[ItemNumber]",
                "            ,[IB1].[Warehouse]",
                "",
                "",
                "",
                "-- Return End Table",
                "",
                "SELECT [RC].[FiscalMonthLastDate]",
                "      ,[RC].[ItemNumber] AS [Item SKU]",
                "      ,[RC].[Warehouse]",
                "      ,[RC].[Qty]",
                "      ,[RC].[NetSales]",
                "      ,[RC].[Avg Std Cost]",
                "      ,[RC].[COGS - STD Cost]",
                "\t  ,[RC].[12mo COGS - STD Cost]",
                "\t  ,CAST(ISNULL([IB].[Avg OH Qty],0) AS DEC(10,2)) AS [Avg OH Qty]",
                "\t  ,CAST(ISNULL([IB].[Avg Inv Dollars],0)  AS DEC(10,2)) AS [Avg Inv Dollars]",
                "\t  ,[RC].[PeriodCount]",
                "\t  ,CAST(([RC].[12mo COGS - STD Cost]/NULLIF(([RC].[PeriodCount]/12.0000), 0)) AS DEC(10,2)) AS [Adj Roll COGS]",
                "  FROM [#RollCOGS] AS RC",
                "  LEFT JOIN [#ItemBal] AS IB",
                "    ON [RC].[ItemNumber] = [IB].[ItemNumber]",
                "\t  AND [RC].[Warehouse] = [IB].[Warehouse]",
                "\t  AND [RC].[FiscalMonthLastDate] = [IB].[FiscalMonthLastDate]",
                "  ",
                "  WHERE [RC].[FiscalMonthIndicator] BETWEEN (@Periods+12) AND -1",
                "    AND [RC].[Warehouse] IS NOT NULL",
                "",
                "",
                "",
                "",
                "",
                "DROP TABLE [#STDUC]",
                "DROP TABLE [#Sales]",
                "DROP TABLE [#RollCOGS]",
                "DROP TABLE [#ItemBal]",
                "",
                "                      \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
