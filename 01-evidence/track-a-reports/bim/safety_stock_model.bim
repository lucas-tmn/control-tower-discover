          {
            "name": "Avg Wkly Fcast",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "formatString": "0",
            "lineageTag": "565da49e-ef27-4842-8f29-171c863f1010",
            "sourceColumn": "Avg Wkly Fcast",
            "summarizeBy": "sum"
          }
        ],
        "lineageTag": "55ab5a3a-0a77-4382-b933-052e811e2572",
        "partitions": [
          {
            "name": "z_ItemWHMaster",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\",",
                "                [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "",
                "SELECT DISTINCT CONCAT(TRIM([DIN].[dinItem]),'_',TRIM([DIN].[dinWarehouse])) AS [Item_WH]",
                "      ,[DIN].[dinItem] AS [Item SKU]",
                "      ,[DIN].[dinWarehouse] AS [Warehouse]",
                "      ,[DIN].[dinMakeBuyCode] AS [MBX]",
                "      ,[DIN].[dinSource1] AS [MBX Source]",
                "      ,[DIN].[dinInventoryPlanningABCCode] AS [IP ABC]",
                "      ,[DIN].[dinInvPlanning1stChoice] AS [IP 1st Choice]",
                "      ,[DIN].[dinInvPlanning4thChoice] AS [IP 4th Choice]",
                "\t  ,RTRIM([TIM].[PICKPUT]) AS [PickPut]",
                "\t  ,CAST(ISNULL([FCCL].[Avg Wkly Fcast],0) AS INT) AS [Avg Wkly Fcast]",
                "  FROM [SupplyChain_Enh].[DemandInventorySnapshot] AS DIN",
                "  LEFT JOIN [MasterData_ItemMaster_AFI].[ITBEXT] AS TIM",
                "    ON [DIN].[dinItem] = [TIM].[ITNBR]",
                "\tAND [DIN].[dinWarehouse] = [TIM].[HOUSE]",
                "\t",
                "LEFT JOIN (",
                " SELECT [FCCL].[Item-Lvl1]",
                "      ,[FCCL].[Location]",
                "\t  ,SUM([FCCL].[Result_PROL_0]+[FCCL].[Result_PROL_1]+[FCCL].[Result_PROL_2]",
                "\t    +[FCCL].[Result_Fc_0]+[FCCL].[Result_Fc_1]+[FCCL].[Result_Fc_2])/13 AS [Avg Wkly Fcast]",
                "      ,[FCCL].[FileDate]",
                "  FROM [SupplyChain_Enh].[ForecastCommonContainer_Logility] AS FCCL",
                "",
                " ",
                "  WHERE CONVERT(DATE, [FCCL].[FileDate]) = (SELECT CONVERT(DATE, MAX([FileDate])) FROM [SupplyChain_Enh].[ForecastCommonContainer_Logility])",
                "",
                "  GROUP BY [FCCL].[Item-Lvl1]",
                "          ,[FCCL].[Location]",
                "          ,[FCCL].[FileDate]",
                "  ) AS FCCL",
                "  ON [DIN].[dinItem] = [FCCL].[Item-Lvl1]",
                "    AND [DIN].[dinWarehouse] = [FCCL].[Location]",
                "",
                "  WHERE [DIN].[dtea] = (SELECT MAX([dtea]) FROM [SupplyChain_Enh].[DemandInventorySnapshot]) ",
                "",
                "                      \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
