        "lineageTag": "ceea9a41-9494-496c-8310-b387a8b4758b",
        "measures": [
          {
            "name": "Total Shipped Qty",
            "expression": "CALCULATE(SUM('On Time (day)'[Shipped Quantity]))",
            "formatString": "0",
            "lineageTag": "b46f5e37-c6ef-4fcd-a292-e65f8a395227"
          },
          {
            "name": "Total On-Time % - Original Request Day",
            "expression": "DIVIDE(CALCULATE(SUM('On Time (day)'[Qty On Time - Orig Request Day])),[Total Shipped Qty])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "788ab7b9-7507-4578-96b2-32c2161072d1"
          },
          {
            "name": "Total On-Time % - Original Promise Day",
            "expression": "DIVIDE(CALCULATE(SUM('On Time (day)'[Qty On Time - Orig Promise Day])),[Total Shipped Qty])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "4c241f8f-dc15-46c2-b6da-26902d3a9aec"
          },
          {
            "name": "Total Avg Days - Original Promise Day",
            "expression": "DIVIDE(CALCULATE(SUM('On Time (day)'[Orig Promise To Delivery])),[Total Shipped Qty])",
            "formatString": "#,0.0",
            "lineageTag": "5f2b411d-b87c-4119-841c-eee3c1380c1c"
          },
          {
            "name": "Total Avg Days - Original Request Day",
            "expression": "DIVIDE(CALCULATE(SUM('On Time (day)'[Orig Request To Delivery])),[Total Shipped Qty])",
            "formatString": "#,0.0",
            "lineageTag": "5df6b57f-5305-44f6-a17a-e67ff5ddb7e5"
          },
          {
            "name": "Total On-Time % - Current Promise Day",
            "expression": "DIVIDE(CALCULATE(SUM('On Time (day)'[Qty On Time - Cur Promise Day])),[Total Shipped Qty])",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "39a06f20-2cfc-4e80-91e9-ef2bceecf3dd"
          },
          {
            "name": "Total On-Time % - Current Request Day",
            "expression": "DIVIDE(CALCULATE(SUM('On Time (day)'[Qty On Time - Cur Request Day])),[Total Shipped Qty])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "eb5ec435-8f12-40b4-992c-92db3867e8aa"
          },
          {
            "name": "Total Avg Days - Current Promise Day",
            "expression": "DIVIDE(CALCULATE(SUM('On Time (day)'[Cur Promise to Delivery])),[Total Shipped Qty])",
            "formatString": "#,0.0",
            "lineageTag": "f9ab2324-03fd-4a01-b560-81813584409f"
          },
          {
            "name": "Total Avg Days - Current Request Day",
            "expression": "DIVIDE(CALCULATE(SUM('On Time (day)'[Cur Request To Delivery])),[Total Shipped Qty])",
            "formatString": "#,0.0",
            "lineageTag": "a0d62911-2878-4014-a6f8-8fca11464170"
          }
        ],
        "partitions": [
          {
            "name": "On Time (day)-98d00c5c-b9b0-4b60-ab97-ffcdfa6f14e4",
            "mode": "import",
            "queryGroup": "ASHLEY_EDW - Tables",
            "source": {
              "expression": [
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "    ",
                "SELECT D.[otdAccountNum] AS 'Account Number'",
                "      --,D.[otdWeek] AS 'Fiscal Week'",
                "      ,D.[otdWarehouse] AS 'Warehouse'",
                "      --,D.[otdShipto] AS 'ShipTo Number'",
                "      ,R.[Customer Name]",
                "      --,R.[Customer Shipto Name]",
                "      ,D.[otdItemNum] AS 'Item SKU'",
                "      --,D.[otdYear] AS 'Fiscal Year'",
                "      --,D.[otdPeriod] AS 'Fiscal Month'",
                "      ,[DD].[FiscalWeekLastDate] AS 'Fiscal Wk End Date'",
                "      ,D.[otdOrderType2] AS 'Order Type 2'",
                "      ,SUM(D.[otdShippedQuantity]) AS 'Shipped Quantity'",
                "      --,[otdOrderToDelivery]",
                "      ,SUM((D.[otdOrgPromToDelivery])/24) AS 'Orig Promise To Delivery'",
                "      --,[otdInvoiceToDelivery]",
                "      ,SUM((D.[otdCurReqToDelivery])/24) AS 'Cur Request To Delivery'",
                "      --,[otdFirstScanToTripClose]",
                "      --,[otdTripCloseToDelivery]",
                "      ,SUM((D.[otdOrigReqtoDelivery])/24) AS 'Orig Request To Delivery'",
                "      --,[otdOrderToFirstScan]",
                "      --,[otdTripCreateToTripClose]",
                "      --,[otdTripCreateToFirstScan]",
                "      --,[otdOrdertoTripCreate]",
                "      ,SUM((D.[otdCurPromisetoDelivery])/24) AS 'Cur Promise to Delivery'",
                "      ,SUM(D.[otdQtyOnTimeOrigPromiseDay]) AS 'Qty On Time - Orig Promise Day'",
                "      --,SUM(D.[otdQtyOnTimeOrigPromiseWeek]) AS 'Qty On Time - Orig Promise Week'",
                "      ,SUM(D.[otdQtyOnTimeCurReqDay]) AS 'Qty On Time - Cur Request Day'",
                "      --,SUM(D.[otdQtyOnTimeCurReqWeek]) AS 'Qty On Time - Cur Request Week'",
                "      ,SUM(D.[otdQtyOnTimeOrigReqDay]) AS 'Qty On Time - Orig Request Day'",
                "      --,SUM(D.[otdQtyOnTimeOrigReqWeek]) AS 'Qty On Time - Orig Request Week'",
                "      ,SUM(D.[otdQtyOnTimeCurPromDay]) AS 'Qty On Time - Cur Promise Day'",
                "      --,SUM(D.[otdQtyOnTimeCurPromWeek]) AS 'Qty On Time - Cur Promise Week'",
                "      --,D.[otdItemClass] AS 'Item Class Code'",
                "      ,R.[ABC Account-Current Year]",
                "      ,R.[Reporting Business Type]",
                "      ,P.[AFI Finance Division]",
                "\t  ,P.[Collective Class]",
                "\t -- ,CASE",
                "\t\t--WHEN fac.[Customer Account Number] IS NOT NULL THEN 'Enterprise Retail'",
                "\t\t--ELSE 'Other'",
                "\t\t--\tEND AS 'Enterprise Retail Flag'",
                "  FROM [AFISales_Enh].[OnTimeDeliveryDetail] AS D",
                "  LEFT JOIN [PowerBI_Wholesale].[Customers] AS R",
                "  ON R.[Customer Account Number] = D.[otdAccountNum] AND D.[otdShipto] = R.[Customer Shipto Number]",
                "--    LEFT JOIN (",
                "--  SELECT fac.facility_id",
                "--     , fac.name",
                "--     , fac.type_id",
                "--     , fac.Country",
                "--     , fac.postal_code",
                "--     , fac.latitude",
                "--     , fac.longitude",
                "--     , fac.address",
                "--     , fac.region_id",
                "--\t , geo.[AddressID]",
                "--\t , cust.[Customer Account Number]",
                "",
                "--FROM Ashley_Network_Model.facility fac",
                "--LEFT JOIN (",
                "--SELECT ",
                "--Latitude",
                "--,Longitude",
                "--,MAX([Address ID]) AS [AddressID]",
                "--FROM AFISales_DW.DimGeographicLocations",
                "--GROUP BY",
                "--Latitude",
                "--,Longitude",
                "--) geo ON geo.Latitude = fac.latitude",
                "--AND geo.Longitude = fac.longitude",
                "",
                "--LEFT JOIN AFISales_DW.DimCustomers cust ON cust.[Shipto AddressID] = geo.AddressID",
                "--WHERE fac.facility_id LIKE 'RDC_AGR%'",
                "--) fac ON fac.[Customer Account Number] = D.otdAccountNum",
                "  LEFT JOIN [PowerBI_SupplyChain].[CurrentProductDetails] AS P",
                "  ON P.[Item SKU] = D.[otdItemNum]",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [D].[InvoiceDate] = [DD].[DateID]",
                "  WHERE [DD].[FiscalWeekIndicator] >= -55",
                "  AND D.[otdItemClass] NOT LIKE 'Z__K'",
                "  AND D.[otdItemClass] <> 'ZARP'",
                "  AND D.[otdItemClass] <> 'ZAHM'",
                "  AND D.[otdItemNum] NOT LIKE '%SW'",
                "  AND D.[otdItemNum] NOT LIKE '%CARD'",
                "  GROUP BY D.[otdAccountNum]",
                "\t  ,D.[otdWarehouse]",
                "\t  ,D.[otdItemNum]",
                "\t  ,[DD].[FiscalWeekLastDate]",
                "\t  ,D.[otdOrderType2]",
                "\t  --,D.[otdShipto]",
                "\t  ,R.[ABC Account-Current Year]",
                "\t  ,R.[Reporting Business Type]",
                "\t  ,R.[Customer Name]",
                "\t  --,R.[Customer Shipto Name]",
                "\t  ,P.[AFI Finance Division]",
                "\t  ,P.[Collective Class]",
                "\t  --,fac.[Customer Account Number]",
                "    ",
                "    \", CommandTimeout=#duration(0, 3, 0, 0), CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
