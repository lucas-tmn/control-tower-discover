        "partitions": [
          {
            "name": "WH335OnTime",
            "mode": "import",
            "queryGroup": "ASHLEY_EDW - Tables",
            "source": {
              "expression": [
                "// SQL Query Template",
                "",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "    ",
                "",
                "",
                "SELECT [Pvt].[Customer Account Number]",
                "      ,[Pvt].[Customer Name]",
                "\t  ,[Pvt].[ItemNumber]",
                "      ,[Pvt].[Invoiced Week]",
                "\t  ,[Pvt].[Customer Shipto Number]",
                "\t ,[Pvt].[Account And ShipTo Number]",
                "\t  ,[Pvt].[Customer Service Agent Name]",
                "\t  ,[Pvt].[Bill To Country]",
                "\t  ,[Pvt].[Warehouse]",
                "\t  --  ,CASE",
                "\t\t--WHEN fac.[Customer Account Number] IS NOT NULL THEN 'Enterprise Retail'",
                "\t\t--ELSE 'Other'",
                "\t\t--\tEND AS 'Enterprise Retail Flag'",
                "\t  --,[Pvt].[Marketing Specialist ID]",
                "      ,ISNULL([Pvt].[Late Req Qty],0) AS [Late Req Qty]",
                "      ,ISNULL([Pvt].[On Time Req Qty],0) AS [On Time Req Qty]",
                "      ,ISNULL([Pvt].[Late Req Qty],0)+ISNULL([Pvt].[On Time Req Qty],0) AS [Total Inv Qty (Req)]",
                "      ,ISNULL([Pvt].[Late Prom Qty],0) AS [Late Prom Qty]",
                "      ,ISNULL([Pvt].[On Time Prom Qty],0) AS [On Time Prom Qty]",
                "      ,ISNULL([Pvt].[Late Prom Qty],0)+ISNULL([Pvt].[On Time Prom Qty],0) AS [Total Inv Qty (Prom)] ",
                "FROM (",
                "",
                "SELECT distinct [DC].[Customer Account Number]",
                "      ,[DC].[Customer Name]",
                "\t  ,[ID].[ItemNumber]",
                "      --,[DR].[FiscalWeekLastDate] AS [Requested Week]",
                "\t  ,[DI].[FiscalWeekLastDate] AS [Invoiced Week]",
                "\t  ,DC.[Customer Shipto Number]",
                "\t  ,DC.[Account And ShipTo Number]",
                "\t  ,DC.[Customer Service Agent Name]",
                "\t  ,DC.[Bill To Country]",
                "\t  ,[ID].[Warehouse] ",
                "\t  --,[FS].[Marketing Specialist ID]",
                "\t  ,CASE",
                "\t\t\tWHEN [DI].[FiscalWeekLastDate] > [DR].[FiscalWeekLastDate]",
                "\t\t\t\tTHEN 'Late Req Qty'",
                "\t\t\tELSE 'On Time Req Qty'",
                "\t\tEND AS [Status]",
                "\t ,[ID].[QuantityShipped]",
                "  FROM [Wholesale_SalesHistory_AFI].[InvoiceDetail] AS ID",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DI",
                "    ON [ID].[InvoiceDate] = [DI].[DateID]",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DR",
                "    ON [ID].[RequestDate] = [DR].[DateID]",
                "  LEFT JOIN [AFISales_DW].[DimCustomers] AS DC",
                "    ON [ID].[CustomerNumber] = [DC].[Customer Account Number]",
                "\t  AND [ID].[ShiptoNumber] = [DC].[Customer Shipto Number]",
                " --LEFT JOIN (select distinct [Marketing Specialist ID],[Account Number],[Shipto Number] from  AFISales_DW.FactShippedHistory) FS",
                " --   ON [ID].[CustomerNumber] = [FS].[Account Number]",
                "\t--  AND [ID].[ShiptoNumber] = [FS].[Shipto Number]",
                "  WHERE [DI].[FiscalMonthIndicator] >= -9",
                "    AND [ID].[Warehouse] = '335'",
                "\tAND [ID].[QuantityShipped] > 0",
                "",
                "UNION ",
                "",
                "SELECT distinct [DC].[Customer Account Number]",
                "      ,[DC].[Customer Name]",
                "\t  ,[ID].[ItemNumber]",
                "      --,[DR].[FiscalWeekLastDate] AS [Requested Week]",
                "\t  ,[DI].[FiscalWeekLastDate] AS [Invoiced Week]",
                "\t  ,DC.[Customer Shipto Number]",
                "\t  ,DC.[Account And ShipTo Number]",
                "\t  ,DC.[Customer Service Agent Name]",
                "\t  ,DC.[Bill To Country]",
                "\t  ,[ID].[Warehouse] ",
                "\t  --,[FS].[Marketing Specialist ID]",
                "\t  ,CASE",
                "\t\t\tWHEN [DI].[FiscalWeekLastDate] > [DR].[FiscalWeekLastDate]",
                "\t\t\t\tTHEN 'Late Prom Qty'",
                "\t\t\tELSE 'On Time Prom Qty'",
                "\t\tEND AS [Status]",
                "\t ,[ID].[QuantityShipped]",
                "  FROM [Wholesale_SalesHistory_AFI].[InvoiceDetail] AS ID",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DI",
                "    ON [ID].[InvoiceDate] = [DI].[DateID]",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DR",
                "    ON [ID].[PromisedDelivery] = [DR].[DateID]",
                "  LEFT JOIN [AFISales_DW].[DimCustomers] AS DC",
                "    ON [ID].[CustomerNumber] = [DC].[Customer Account Number]",
                "\t  AND [ID].[ShiptoNumber] = [DC].[Customer Shipto Number]",
                "\t  --LEFT JOIN (select distinct [Marketing Specialist ID],[Account Number],[Shipto Number] from  AFISales_DW.FactShippedHistory) FS",
                "   -- ON [ID].[CustomerNumber] = [FS].[Account Number]",
                "\t  --AND [ID].[ShiptoNumber] = [FS].[Shipto Number]",
                "  WHERE [DI].[FiscalMonthIndicator] >= -9",
                "    AND [ID].[Warehouse] = '335'",
                "\tAND [ID].[QuantityShipped] > 0",
                "",
                "\t) AS P",
                "",
                "PIVOT ( ",
                "\tSUM([QuantityShipped]) FOR [Status] IN ",
                "\t  ([Late Req Qty],[On Time Req Qty],[Late Prom Qty],[On Time Prom Qty])",
                "\t  ) AS Pvt",
                "",
                "--\t  LEFT JOIN (",
                "--\t  SELECT fac.facility_id",
                "--     , fac.name",
                "--     , fac.type_id",
                "--     , fac.Country",
                "--     , fac.postal_code",
                "--     , fac.latitude",
                "--     , fac.longitude",
                "--     , fac.address",
                "--     , fac.region_id",
                "--\t , geo.[AddressID]",
                "--\t , cust.[Customer Account Number]",
                "",
                "--FROM Ashley_Network_Model.facility fac",
                "--LEFT JOIN (",
                "--SELECT ",
                "--Latitude",
                "--,Longitude",
                "--,MAX([Address ID]) AS [AddressID]",
                "--FROM AFISales_DW.DimGeographicLocations",
                "--GROUP BY",
                "--Latitude",
                "--,Longitude",
                "--) geo ON geo.Latitude = fac.latitude",
                "--AND geo.Longitude = fac.longitude",
                "",
                "--LEFT JOIN AFISales_DW.DimCustomers cust ON cust.[Shipto AddressID] = geo.AddressID",
                "--WHERE fac.facility_id LIKE 'RDC_AGR%'",
                "--) fac ON fac.[Customer Account Number] = pvt.[Customer Account Number]",
                "",
                "",
                "    \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      }
    ]
  }
}
