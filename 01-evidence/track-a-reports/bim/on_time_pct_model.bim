              "                   ,\"9947500\",\"DSG - All Accounts\"",
              "                   ,\"9977000\",\"DSG - All Accounts\"",
              "                   ,\"9971700\",\"DSG - All Accounts\"",
              "                   ,CONCATENATE('On Time (day)'[Customer Name],CONCATENATE(\" - \",'On Time (day)'[Account Number]))",
