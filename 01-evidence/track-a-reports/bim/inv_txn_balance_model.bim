                "    ",
                "SELECT [ITW].[ItemSKU] as [Item SKU]",
                "      ,[ITW].[Warehouse]",
                "      ,CASE ",
                "\t\t\tWHEN [CPD].[Item Class Code] IN ('MATT','UESW','USKE','UTRK','WVBC',",
                "                                        'WVCD','WVCS','WVCU','WVHC','WVHD',",
                "                                        'WVUP','WVWB','ZACK','ZAMK',",
                "                                        'ZDCK','ZDLK','ZDMK','ZJBK','ZJFK',",
                "                                        'ZKBK','ZMCK','ZMLK','ZUCK','ZUMK',",
                "                                        'ZXCK','ZXLK','ZXMK'",
                "\t\t\t\t\t\t\t\t\t\t) ",
                "\t\t\t\t\tTHEN 'Part'",
                "\t\t\tELSE [ITW].[ItemFlag]",
                "\t\tEND AS [ItemFlag]",
                "\t  ,CASE ",
                "\t\t\tWHEN [CPD].[Item Class Code] IN ('MATT','UESW','USKE','UTRK','WVBC',",
                "                                        'WVCD','WVCS','WVCU','WVHC','WVHD',",
                "                                        'WVUP','WVWB','ZACK','ZAMK',",
                "                                        'ZDCK','ZDLK','ZDMK','ZJBK','ZJFK',",
                "                                        'ZKBK','ZMCK','ZMLK','ZUCK','ZUMK',",
                "                                        'ZXCK','ZXLK','ZXMK'",
                "\t\t\t\t\t\t\t\t\t\t) AND RIGHT(TRIM([ITW].[ItemSKU]),2) = 'UN'",
                "\t\t\t\t\tTHEN 'KIT'",
                "\t\t\tWHEN [CPD].[Item Class Code] IN ('MATT','UESW','USKE','UTRK','WVBC',",
                "                                        'WVCD','WVCS','WVCU','WVHC','WVHD',",
                "                                        'WVUP','WVWB','ZACK','ZAMK',",
                "                                        'ZDCK','ZDLK','ZDMK','ZJBK','ZJFK',",
                "                                        'ZKBK','ZMCK','ZMLK','ZUCK','ZUMK',",
                "                                        'ZXCK','ZXLK','ZXMK'",
                "\t\t\t\t\t\t\t\t\t\t) AND RIGHT(TRIM([ITW].[ItemSKU]),2) <> 'UN'",
                "\t\t\t\t\tTHEN 'CMP'",
                "\t\t\tELSE 'FG'",
                "\t\tEND AS [ItemFlag]",
                "      ,[ITW].[TransactionCode]",
                "      ,[ITW].[TransactionCodeDesc]",
                "      ,[ITW].[TransactionType]",
                "      ,[ITW].[Qty]",
                "\t  ,ABS([ITW].[Qty]) as [Absolute Qty]",
                "\t  ,CASE WHEN [ITW].[Qty]>0 then 'Incoming'",
                "\t\t\tWHEN[ITW]. [Qty]<0 then 'Outbound'",
                "\t\t\tELSE 'Incoming'",
                "\t   END AS [Transaction Type]",
                "      ,[ITW].[WeekEnding]",
                "  FROM [Inventory_Enh].[InventoryTransactionsWeeklySummary] ITW",
                "  INNER JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [ITW].[WeekEnding] = [DD].[DateID]",
                "\t  AND [DD].[FiscalMonthIndicator] BETWEEN -18 AND 0",
                "  LEFT JOIN [SupplyChain_DW].[DimCurrentProductDetails] AS CPD",
                "    ON [ITW].[ItemSKU] = [CPD].[Item SKU]",
                "  WHERE ( [ITW].[ItemFlag] = 'Finished Goods' ",
                "\t\t\tOR [CPD].[Item Class Code] IN  ('MATT','UESW','USKE','UTRK','WVBC',",
                "               'WVCD','WVCS','WVCU','WVHC','WVHD',",
                "               'WVUP','WVWB','ZACK','ZAMK',",
                "               'ZDCK','ZDLK','ZDMK','ZJBK','ZJFK',",
                "               'ZKBK','ZMCK','ZMLK','ZUCK','ZUMK',",
                "               'ZXCK','ZXLK','ZXMK')",
                "\t\t\t)",
                "  and [ITW].[Warehouse] in ('1' , '12', '15', '151', '16', '17', '19', '20' , '28' , '3', '335', '42', '49', '5', '50', 'ECR','70','101','20','60')",
                "  and [ITW].[TransactionCode] in( 'SA','RP','IW', 'RW','RM','IP')",
                "",
                "    ",
                "    ",
                "",
                "    \", CreateNavigationProperties=false]),",
                "    #\"Renamed Columns\" = Table.RenameColumns(Source,{{\"Qty\", \"Transaction Qty\"}})",
                "in",
                "    #\"Renamed Columns\""
              ],
              "type": "m"
            }
          }
        ]
      },
