                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "dataType": "double",
            "expression": "'Item Balance'[On Hand Quantity]*RELATED(z_ProductDetails[FOB Price])",
            "isDataTypeInferred": true,
            "lineageTag": "b2b081fe-63f1-42df-98dc-22eef103fd04",
