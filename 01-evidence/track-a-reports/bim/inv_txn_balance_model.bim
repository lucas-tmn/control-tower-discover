          }
        ],
        "lineageTag": "d06535c2-26a7-4d87-be3c-d7f762b4087d",
        "measures": [
          {
            "name": "Issuing Transfer",
            "expression": "CALCULATE(SUM('Inventory Transaction History'[Transaction Qty]),'Inventory Transaction History'[TransactionCodeDesc] = \"Transfer: Issuing Warehouse\")",
            "formatString": "#,0",
            "lineageTag": "425ffb1c-23ba-4a2d-9237-2e8f8b1ff3ac"
          },
          {
            "name": "Receiving Transfer",
            "expression": "CALCULATE(SUM('Inventory Transaction History'[Transaction Qty]),'Inventory Transaction History'[TransactionCodeDesc] = \"Transfer: Receiving Warehouse\")",
            "formatString": "#,0",
            "lineageTag": "277eb86d-9302-48f8-afa6-602fd03bd673"
          },
          {
            "name": "Sales Shipments",
            "expression": "CALCULATE(SUM('Inventory Transaction History'[Absolute Qty]),'Inventory Transaction History'[TransactionCodeDesc] = \"Sales Shipments\")",
            "formatString": "#,0",
            "lineageTag": "ca651587-fd83-4d9c-adac-f57d310b7822"
          },
          {
            "name": "Receipts in to WH",
            "expression": "CALCULATE(SUM('Inventory Transaction History'[Transaction Qty]),'Inventory Transaction History'[TransactionCodeDesc] = \"Receipt from manufacturing order\") + CALCULATE(SUM('Inventory Transaction History'[Transaction Qty]),'Inventory Transaction History'[TransactionCodeDesc] = \"Receipt from purchase order\")",
            "formatString": "#,0",
            "lineageTag": "b34ef51f-cb66-4dcb-a4f7-3004f522f73f"
          },
          {
            "name": "Net Inv Change",
            "expression": "[Issuing Transfer] + [Receipts in to WH] + [Receiving Transfer] - [Sales Shipments]",
            "formatString": "#,0",
            "lineageTag": "7a168c8f-0644-41e9-bda5-599d8ef2c268"
          },
          {
            "name": "Purchase Order",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM('Inventory Transaction History'[Transaction Qty]),'Inventory Transaction History'[TransactionCode] = \"RP\")",
            "formatString": "#,0",
            "lineageTag": "67c41395-db1b-4105-a18c-8180d4c359f9"
          },
          {
            "name": "On Hand Qty",
            "expression": "CALCULATE(SUM('Item Balance'[On Hand Quantity]))",
            "formatString": "#,0",
            "lineageTag": "8e90668c-eec1-4291-a214-adab8bc43681"
          },
          {
            "name": "On Hand Cubes",
            "expression": "SUMX(z_ProductDetails,z_ProductDetails[Cubes]*[On Hand Qty])",
            "formatString": "#,0",
            "lineageTag": "3710ce82-e79d-4a31-ac11-42287b0ea35e"
          },
          {
            "name": "Manufacturing Receipt",
            "expression": "CALCULATE(SUM('Inventory Transaction History'[Transaction Qty]),'Inventory Transaction History'[TransactionCode] = \"RM\")",
            "formatString": "#,0",
            "lineageTag": "7fcff397-6840-4893-bc11-c08c7106d96e"
          },
          {
            "name": "L2 Cubes % of Storage Type",
            "expression": "DIVIDE([On Hand Cubes],CALCULATE([On Hand Cubes],ALLSELECTED(z_ProductDetails)))",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "7c13d4d0-1c5d-4fa9-8bb8-0a5171329fe8"
          },
          {
            "name": "L2 Unit % of Storage Type",
            "expression": "DIVIDE([On Hand Qty],CALCULATE([On Hand Qty],ALLSELECTED(z_ProductDetails)))",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "b1f0d076-267c-42ab-b883-02c2ece07b39"
          }
        ],
        "partitions": [
