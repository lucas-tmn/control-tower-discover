        ],
        "lineageTag": "19d4ea4f-10dc-4d7e-af08-3674869a9602",
        "partitions": [
          {
            "name": "Item Balance-f796e10e-27f8-4999-b644-f29c3f92f41b",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "    ",
                "    ",
                "SELECT [IB].[ItemNumber] AS [Item SKU]",
                "      ,[IB].[Warehouse] as [Warehouse]",
                "      ,[IB].[DateWeekEnding] as [Week Ending]",
                "      ,[IB].[OnHandQty] as [On Hand Quantity]",
                "      ,[IB].[ItemStatus] as [Item Status]",
                "  FROM [Inventory_Enh_History].[ItemBalance] IB",
                "    ",
                "\tINNER JOIN [MasterData_ItemMaster_AFI].[ITMEXT] AS EXT",
                "    ON [IB].[ItemNumber] = [EXT].[ITNBR]",
                "      AND ([EXT].[FRTNAT] BETWEEN 15900 AND 15999",
                "\t  OR [EXT].[ITMITCLS] IN ('MATT','UESW','USKE','UTRK','WVBC',",
                "                               'WVCD','WVCS','WVCU','WVHC','WVHD',",
                "                               'WVUP','WVWB','ZACK','ZAMK',",
                "                               'ZDCK','ZDLK','ZDMK','ZJBK','ZJFK',",
                "                               'ZKBK','ZMCK','ZMLK','ZUCK','ZUMK',",
                "                               'ZXCK','ZXLK','ZXMK'",
                "\t\t\t\t\t\t\t  )",
                "\t\t\t\t\t\t\t  )",
                "\tINNER JOIN [Enterprise_DW].[DimDate] AS DD",
                "\t  ON [IB].[DateWeekEnding] = [DD].[DateTimeID]",
                "\t  AND [DD].[FiscalMonthIndicator] BETWEEN -18 AND 0",
                "  WHERE [IB].[Warehouse] NOT IN (",
                "\t\t\t\t\t\t\t\t\t'18 ','2  ','213','215','242',",
                "\t\t\t\t\t\t\t\t\t'55 ','A  ','B  ','C  ','CNW','E  ',",
                "\t\t\t\t\t\t\t\t\t'F  ','H  ','J  ','K  ','L  ','M  ','N  ',",
                "\t\t\t\t\t\t\t\t\t'P  ','P12','P13','P15','P17','P18','P19',",
                "\t\t\t\t\t\t\t\t\t'P28','P42','P5 ','PE ','R  ','S  ','T  ',",
                "\t\t\t\t\t\t\t\t\t'U  ','V  ','W  ','X  ','Y  '",
                "\t\t\t\t\t\t\t\t)",
                "    ",
                "    \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
