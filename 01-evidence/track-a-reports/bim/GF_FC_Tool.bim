stomer Account Number]#(lf)        , [Item Sku]#(lf)        , [Warehouse]#(lf)        , [Open Order Quantity]#(lf)        , [Inserted Date]#(lf)        , [Original Request Fiscal Month]#(lf)        , [Current Request Fiscal Month]#(lf)        , CASE #(lf)            WHEN [Inserted Date] > LAG([Current Request Fiscal Month]) OVER (#(lf)                    PARTITION BY [Customer Account Number]#(lf)                    , [Item Sku]#(lf)                    , [Warehouse]#(lf)                    , [Open Order Quantity]#(lf)                    , [Original Request Fiscal Month] ORDER BY [Current Request Fiscal Month]#(lf)                    )#(lf)                THEN 1#(lf)            ELSE 0#(lf)            END AS [Changed After Posted Flag]#(lf)        , LAG([Current Request Fiscal Month]) OVER (#(lf)                    PARTITION BY [Customer Account Number]#(lf)                    , [Item Sku]#(lf)                    , [Warehouse]#(lf)                    , [Open Order Quantity]#(lf)                    , [Original Request Fiscal Month] ORDER BY [Current Request Fiscal Month]#(lf)                    ) [Previous Month]#(lf)    FROM (#(lf)        SELECT --[Order Number]#(lf)            [Customer Account Number]#(lf)            , [Item Sku]#(lf)            , [Warehouse]#(lf)            , SUM([Open Order Quantity]) [Open Order Quantity]#(lf)            , CONVERT(DATE, [Inserted Date]) [Inserted Date]#(lf)            -- , [Original Request Date]#(lf)            , [d1].[FiscalMonthLastDate] AS [Original Request Fiscal Month]#(lf)            -- , [Current Request Date]#(lf)            , [d2].[FiscalMonthLastDate] AS [Current Request Fiscal Month]#(lf)            , ROW_NUMBER() OVER (#(lf)                PARTITION BY [Customer Account Number]#(lf)                , [Item Sku]#(lf)                , [Warehouse]#(lf)                , [d1].[FiscalMonthLastDate]#(lf)                , [d2].[FiscalMonthLastDate] ORDER BY [Inserted Date] DESC#(lf)                ) AS [ROW NUM]#(lf)        FROM [AFISales_DW].[FactOpenOrdersSnapshot] [oo]#(lf)        INNER JOIN [Enterprise_DW].[DimDate_NonRetail] [d1]#(lf)            ON (dateadd(day, - [oo].[Load Lead Time], [oo].[Original Request Date])) = [d1].[DateID]#(lf)        LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [d2]#(lf)            ON (dateadd(day, - [oo].[Load Lead Time], [oo].[Current Request Date])) = [d2].[DateID]#(lf)        LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [d3]#(lf)            ON CONVERT(DATE, [Inserted Date]) = [d3].[DateID]#(lf)        WHERE [Warehouse] NOT IN ('C', 'CNW')#(lf)            AND [d3].[FiscalMonthIndicator] >= - 24#(lf)            AND [Inventory Allocated Flag] = 2#(lf)            -- -- AND [Warehouse] = '42'#(lf)            -- AND [Customer Account Number] = '8888300'#(lf)        -- AND [Order Number] = 'D029431'#(lf)        GROUP BY --[Order Number]#(lf)            [Customer Account Number]#(lf)            , [Item Sku]#(lf)            , [Warehouse]#(lf)            -- , [Original Request Date]#(lf)            -- , [Current Request Date]#(lf)            , [Inserted Date]#(lf)            , [d1].[FiscalMonthLastDate]#(lf)            , [d2].[FiscalMonthLastDate]#(lf)        ) step_1#(lf)    WHERE [ROW NUM] = 1#(lf)    ) step_2#(lf)WHERE [Inserted Date] = (#(lf)        SELECT MAX(CONVERT(DATE, [Inserted Date]))#(lf)        FROM [AFISales_DW].[FactOpenOrdersSnapshot] [oo]#(lf)        )\", CreateNavigationProperties=false]),","    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"Inserted Date\", type date}, {\"Original Request Fiscal Month\", type date}, {\"Current Request Fiscal Month\", type date}, {\"Previous Month\", type date}})","in","    #\"Changed Type\""],"type":"m"}}]},{"name":"LocalDateTable_f48047a0-e751-4958-be22-9fefc07e2985","annotations":[{"name":"__PBI_LocalDateTable","value":"true"}],"columns":[{"name":"Date","annotations":[{"name":"SummarizationSetBy","value":"User"}],"dataCategory":"PaddedDateTableDates","dataType":"dateTime","isHidden":true,"isNa