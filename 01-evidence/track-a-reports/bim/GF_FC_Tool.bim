pany\",","        'Fact BedroomDining Balancing'[Metric] = \"Forecast\", ","        'Fact BedroomDining Balancing'[Imbalance by FC] = \"Imbalance\"","    )","VAR SS_List = ","    CALCULATETABLE(","        VALUES('Fact BedroomDining Balancing'[Series Number]), ","        'Fact BedroomDining Balancing'[Level] = \"Company\",","        'Fact BedroomDining Balancing'[Metric] = \"Safety Stock\", ","        'Fact BedroomDining Balancing'[Imbalance by SS] = \"Imbalance\"","    )","RETURN ","    COUNTROWS(EXCEPT(FC_List, SS_List))"],"formatString":"0","lineageTag":"eadc66af-e419-41aa-8bd3-a8b7633842dd"},{"name":"Imbalanced Series (SS Only)","displayFolder":"BD Imbalance","expression":["","VAR FC_List = ","    CALCULATETABLE(","        VALUES('Fact BedroomDining Balancing'[Series Number]), ","        'Fact BedroomDining Balancing'[Level] = \"Company\",","        'Fact BedroomDining Balancing'[Metric] = \"Forecast\", ","        'Fact BedroomDining Balancing'[Imbalance by FC] = \"Imbalance\"","    )","VAR SS_List = ","    CALCULATETABLE(","        VALUES('Fact BedroomDining Balancing'[Series Number]), ","        'Fact BedroomDining Balancing'[Level] = \"Company\",","        'Fact BedroomDining Balancing'[Metric] = \"Safety Stock\", ","        'Fact BedroomDining Balancing'[Imbalance by SS] = \"Imbalance\"","    )","RETURN ","    COUNTROWS(EXCEPT(SS_List, FC_List))"],"formatString":"0","lineageTag":"b6f2e280-b084-4ed7-b30e-ba329a596524"},{"name":"Imbalanced Series (FC)","displayFolder":"BD Imbalance","expression":["","CALCULATE(","    DISTINCTCOUNT('Fact BedroomDining Balancing'[Series Number]),","    'Fact BedroomDining Balancing'[Level] = \"Company\",","    'Fact BedroomDining Balancing'[Metric] = \"Forecast\",","    'Fact BedroomDining Balancing'[Imbalance by FC] = \"Imbalance\"",")"],"formatString":"0","lineageTag":"de33bc10-b1a8-4401-80f1-fc5d11247da5"},{"name":"Imbalanced Series (SS)","displayFolder":"BD Imbalance","expression":["","CALCULATE(","    DISTINCTCOUNT('Fact Bed