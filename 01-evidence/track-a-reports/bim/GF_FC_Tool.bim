 Qty])))","formatString":"\"TRUE\";\"TRUE\";\"FALSE\"","isDataTypeInferred":true,"lineageTag":"4f5b7c46-fd13-429f-9f79-0b7bf297c5ae","summarizeBy":"none","type":"calculated"},{"name":"Account Number","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"b5eb71ca-8847-4793-97b5-f6e169a1b830","sourceColumn":"Account Number","summarizeBy":"none"},{"name":"Account Name","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"1c6e10d0-2a9c-48bc-bc98-b371394f1451","sourceColumn":"Account Name","summarizeBy":"none"},{"name":"Country","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"2846429b-040e-447e-8c52-9681ad346b24","sourceColumn":"Country","summarizeBy":"none"}],"lineageTag":"3c5a2fbf-f52a-4f96-9782-f4e8b9eeef86","partitions":[{"name":"Dim Customer","mode":"import","queryGroup":"Dim Query","source":{"expression":["let","    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"SELECT [Account Number], [Customer Name], [Account Name], [Customer Group], [Country]#(lf)FROM (#(lf)SELECT COUNT([Account And ShipTo Number]) [Count_Acc]#(lf)    , ROW_NUMBER() OVER (#(lf)        PARTITION BY [Account Number] ORDER BY COUNT([Account And ShipTo Number]) DESC#(lf)        ) [Row_Num]#(lf)    , [Account Number]#(lf)    , [Customer Name]#(lf)    , [Account Name]#(lf)    , [Customer Group]#(lf)    , [Country]#(lf)FROM [PowerBI_SupplyChain].[CustomerAcctMaster_AFI]#(lf)GROUP BY#(lf)     [Account Number]#(lf)    , [Customer Name]#(lf)    , [Account Name]#(lf)    , [Customer Group]#(lf)    , [Country]#(lf)) T#(lf)WHERE [Row_Num] = 1\", CreateNavigationProperties=false])","in","    Source"],"type":"m"}}]},{"name":"Fact Actuals","annotations":[{"name":"PBI_ResultType","value":"Exception"},{"name":"PBI_NavigationStepName","value":"Navigation"}],"columns":[{"name":"Customer Account Number","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"4214c88a-8aa2-41b3-bd29-51165174c94a","sourceColumn":"Customer Account Number","summarizeBy":"none"},{"name":"Item SKU","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"6b7d9468-2e80-4a9f-8945-0f23cd03d00f","sourceColumn":"Item SKU","summarizeBy":"none"},{"name":"Warehouse","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"4242b506-67f6-4f73-a9f3-b53d364e847f","sourceColumn":"Warehouse","summarizeBy":"none"},{"name":"Order Quantity","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"double","formatString":"#,0","lineageTag":"428d65fe-f2f3-4c26-a623-b496dcd9c519","sourceColumn":"Order Quantity","summarizeBy":"sum"},{"name":"Order Amount","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"4bed48e4-40c5-43f5-a2ce-131185b60d51","sourceColumn":"Order Amount","summarizeBy":"sum"},{"name":"OrigReqWkEnding","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"UnderlyingDateTimeDataType","value":"Date"}],"dataType":"dateTime","formatString":"Short Date","lineageTag":"5b469287-47db-49c7-8471-b7d612312cab","sourceColumn":"OrigReqWkEnding","summarizeBy":"none"},{"name":"CurReqWkEnding","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"UnderlyingDateTimeDataType","value":"Date"}],"dataType":"dateTime","formatString":"Short Date","lineageTag":"36056c3a-17e9-4a6d-9f40-513e586057da","sourceColumn":"CurReqWkEnding","summarizeBy":"none"},{"name":"ShipWkEnding","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"UnderlyingDateTimeDataType","value":"Date"}],"dataType":"dateTime","formatString":"Short Date","lineageTag":"dc97a8fd-aac7-4ac0-bd3d-fab835f5903b","sourceColumn":"ShipWkEnding","summarizeBy":"none"},{"name":"Sales Type","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"91f62360-0339-4c16-bd35-0602c5f9b840","sourceColumn":"Sales Type","summarizeBy":"none"},{"name":"Status","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"952bfd3f-ce71-4649-94db-2852ad200ef9","sourceColumn":"Status","summarizeBy":"none"},{"name":"WrittenWkEnding","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"dateTime","formatString":"General Date","lineageTag":"32a3aecb-b685-453c-8b37-516253cd5f10","sourceColumn":"WrittenWkEnding","summarizeBy":"none"},{"name":"Inventory Allocated Flag","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"dataType":"double","formatString":"0","lineageTag":"f7d08299-81f6-4aa5-8cc3-bcd39e64da4b","sourceColumn":"Inventory Allocated Flag","summarizeBy":"sum"},{"name":"WeekDiff","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"0","lineageTag":"8ae9cff5-0853-499e-9267-12514164d0e2","sourceColumn":"WeekDiff","summarizeBy":"sum"}],"lineageTag":"aace1a39-b0e2-4ae7-bee1-4b8c36faf8d0","partitions":[{"name":"Fact Actuals","mode":"import","queryGroup":"Fact Query","source":{"expression":["let","    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"#(lf)DECLARE @StartDate DATE#(lf)SET @StartDate = (#(lf)SELECT DISTINCT [FiscalYearFirstDate]#(lf)  FROM [Enterprise_DW].[DimDate]#(lf)  WHERE [FiscalYearIndicator] = -2#(lf)  )#(lf)#(lf)DECLARE @EndDate DATE#(lf)SET @EndDate = (#(lf)SELECT DISTINCT [FiscalMonthLastDate]#(lf)  FROM [Enterprise_DW].[DimDate]#(lf)  WHERE [DateID] = CONVERT(DATE,DATEADD(MONTH, 9, GETDATE()))#(lf)  )#(lf)#(lf)SELECT#(lf)    [ACT].[Customer Account Number]#(lf)    , [ACT].[Item SKU]#(lf)    , [ACT].[Warehouse]#(lf)    , [Order Quantity] / ISNULL([MC].[Qty In Box],1) [Order Quantity]#(lf)    , [Order Amount]#(lf)    , DATEDIFF(#(lf)        WEEK,#(lf)        DATEADD(WEEK, [D4].[FiscalWeekYear] % 100 - 1, DATEFROMPARTS([D4].[FiscalWeekYear] / 100, 1, 1)),#(lf)        DATEADD(WEEK, [D2].[FiscalWeekYear] % 100 - 1, DATEFROMPARTS([D2].[FiscalWeekYear] / 100, 1, 1))#(lf)    ) [WeekDiff]#(lf)    , [OrigReqWkEnding]#(lf)    , [CurReqWkEnding]#(lf)    , [ShipWkEnding]#(lf)    , [WrittenWkEnding]#(lf)    , [Sales Type]#(lf)    , [Status]#(lf)    , [Inventory Allocated Flag]#(lf)FROM (#(lf)    -- Get Invoiced Orders#(lf)    SELECT TRIM([C].[Customer Account Number]) AS [Customer Account Number]#(lf)        , TRIM([ID].[ItemNumber]) AS [Item SKU]#(lf)        , TRIM([ID].[Warehouse]) AS [Warehouse]#(lf)        , SUM([ID].[QuantityShipped]) AS [Order Quantity]#(lf)        , SUM([ID].[NetSales]) AS [Order Amount]#(lf)        , CASE #(lf)            WHEN CONVERT(DATE, [D2].[FiscalWeekLastDate]) IS NULL#(lf)                THEN CONVERT(DATE, [D3].[FiscalWeekLastDate])#(lf)            ELSE CONVERT(DATE, [D2].[FiscalWeekLastDate])#(lf)            END AS [OrigReqWkEnding]#(lf)        , CASE #(lf)            WHEN CONVERT(DATE, [D].[FiscalWeekLastDate]) IS NULL#(lf)                THEN CONVERT(DATE, [D3].[FiscalWeekLastDate])#(lf)            ELSE CONVERT(DATE, [D].[FiscalWeekLastDate])#(lf)            END AS [CurReqWkEnding]#(lf)        , CONVERT(DATE, [D3].[FiscalWeekLastDate]) AS [ShipWkEnding]#(lf)        , CONVERT(DATE, [D4].[FiscalWeekLastDate]) AS [WrittenWkEnding]#(lf)        , [Sales Type] = 'Actuals'#(lf)        , [Status] = 'Invoiced'#(lf)        , [Inventory Allocated Flag] = '2'#(lf)    FROM Wholesale_SalesHistory_AFI.InvoiceDetail AS ID#(lf)    LEFT JOIN Wholesale_SalesHistory_AFI.InvoiceHeader AS IH#(lf)        ON [ID].[InvoiceNumber] = [IH].[InvoiceNumber]#(lf)            AND [ID].[OrderNumber] = [IH].[OrderNumber]#(lf)            AND [ID].[Warehouse] = [IH].[Warehouse]#(lf)    LEFT JOIN [AFISales_DW].[DimCustomers] AS C#(lf)        ON [IH].[CustomerNumber] = [C].[Customer Account Number]#(lf)            AND [IH].[ShiptoNumber] = [C].[Customer Shipto Number]#(lf)    LEFT JOIN [Enterprise_DW].[DimDate] AS D#(lf)        ON DATEADD(DAY, - [IH].[LeadTime], CONVERT(DATE, [ID].[RequestDate])) = [D].[DateID]#(lf)    LEFT JOIN [Enterprise_DW].[DimDate] AS D2#(lf)        ON DATEADD(DAY, - [IH].[LeadTime], CONVERT(DATE, [ID].[OriginalRequestDate])) = [D2].[DateID]#(lf)    LEFT JOIN [Enterprise_DW].[DimDate] AS D3#(lf)        ON CONVERT(DATE, [ID].[InvoiceDate]) = [D3].[DateID]#(lf)    LEFT JOIN [Enterprise_DW].[DimDate] AS D4#(lf)        ON CONVERT(DATE, [ID].[OrderDate]) = [D4].[DateID]#(lf)    WHERE ID.[QuantityShipped] > 0#(lf)        AND TRIM([ID].[Warehouse]) <> '232'#(lf)        AND (#(lf)            [D].[FiscalWeekLastDate] BETWEEN @StartDate AND @EndDate#(lf)            OR [D2].[FiscalWeekLastDate] BETWEEN @StartDate AND @EndDate#(lf)            OR [D3].[FiscalWeekLastDate] BETWEEN @StartDate AND @EndDate#(lf)            )#(lf)        AND ID.[Warehouse] NOT IN#(lf)            ('232', '   ','10 ','14 ','18 ','2  ','21 ','55 ','6  ','7  ','8  ','9  ','C99','N/A','P  ','R  ','W  ')#(lf)    GROUP BY [C].[Customer Account Number]#(lf)        , [ID].[ItemNumber]#(lf)        , [ID].[Warehouse]#(lf)        , [D].[FiscalWeekLastDate]#(lf)        , [D2].[FiscalWeekLastDate]#(lf)        , [D3].[FiscalWeekLastDate]#(lf)        , [D4].[FiscalWeekLastDate]#(lf)#(lf)    UNION ALL#(lf)#(lf)    -- Get Open Orders#(lf)    SELECT TRIM([OO].[Customer Account Number]) AS [Customer Account Number]#(lf)        , TRIM([OO].[Item Sku]) AS [Item SKU]#(lf)        , TRIM([OO].[Warehouse]) AS [Warehouse]#(lf)        , SUM([OO].[Open Order Quantity]) AS [Order Quantity]#(lf)        , SUM([OO].[Open Order Amount]) AS [Order Amount]#(lf)        , CONVERT(DATE, [D2].[FiscalWeekLastDate]) AS [OrigReqWkEnding]#(lf)        , CONVERT(DATE, [D].[FiscalWeekLastDate]) AS [CurReqWkEnding]#(lf)        , CONVERT(DATE, [D3].[FiscalWeekLastDate]) AS [ShipWkEnding]#(lf)        , CONVERT(DATE, [D4].[FiscalWeekLastDate]) AS [WrittenWkEnding]#(lf)        , [Sales Type] = 'Actuals'#(lf)        , [Status] = 'Open Order'#(lf)        , [Inventory Allocated Flag]#(lf)    FROM [AFISales_DW].[FactOpenOrders] AS OO#(lf)    LEFT JOIN [Enterprise_DW].[DimDate] AS D#(lf)        ON DATEADD(DAY, - [OO].[Load Lead Time], [OO].[Current Request Date]) = [D].[DateID]#(lf)    LEFT JOIN [Enterprise_DW].[DimDate] AS D2#(lf)        ON DATEADD(DAY, - [OO].[Load Lead Time], [OO].[Original Request Date]) = [D2].[DateID]#(lf)    LEFT JOIN [Enterprise_DW].[DimDate] AS D3#(lf)        ON DATEADD(DAY, - [OO].[Load Lead Time], [OO].[Current Promise Date]) = [D3].[DateID]#(lf)    LEFT JOIN [Enterprise_DW].[DimDate] AS D4#(lf)        ON CONVERT(DATE, [OO].[Order Taken Date]) = [D4].[DateID]#(lf)    WHERE 1 = 1#(lf)--AND [OO].[Inventory Allocated Flag] = '2'#(lf)        AND TRIM([OO].[Warehouse]) <> '232'#(lf)        AND (#(lf)            [D].[FiscalWeekLastDate] BETWEEN @StartDate AND @EndDate#(lf)            OR [D2].[FiscalWeekLastDate] BETWEEN @StartDate AND @EndDate#(lf)            OR [D3].[FiscalWeekLastDate] BETWEEN @StartDate AND @EndDate#(lf)            )#(lf)        AND OO.[Warehouse] NOT IN#(lf)            ('232', '   ','10 ','14 ','18 ','2  ','21 ','55 ','6  ','7  ','8  ','9  ','C99','N/A','P  ','R  ','W  ')#(lf)    GROUP BY [OO].[Customer Account Number]#(lf)        , [OO].[Item Sku]#(lf)        , [OO].[Warehouse]#(lf)        , [D].[FiscalWeekLastDate]#(lf)        , [D2].[FiscalWeekLastDate]#(lf)        , [D3].[FiscalWeekLastDate]#(lf)        , [D4].[FiscalWeekLastDate]#(lf)        , [Inventory Allocated Flag]#(lf)) [ACT]#(lf)LEFT JOIN (#(lf)     SELECT [CPD2].[Item SKU] AS [Marketable SKU]#(lf)        , [CPD].[Qty In Box]#(lf)    FROM [SupplyChain_DW].[DimCurrentProductDetails] AS [CPD]#(lf)    LEFT JOIN [SupplyChain_DW].[DimCurrentProductDetails] AS CPD2#(lf)        ON [CPD].[Item SKU] = LEFT(TRIM([CPD2].[Item SKU]), LEN(TRIM([CPD2].[Item SKU])) - 1)#(lf)    INNER JOIN [MasterData_ItemMaster_AFI].[ITMEXT] AS EXT#(lf)        ON [CPD2].[Item SKU] = [EXT].[ITNBR]#(lf)            AND [EXT].[GDESCD] = '700'#(lf)    ) AS MC#(lf)    ON [ACT].[Item SKU] = [MC].[Marketable SKU]#(lf)LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [D1]#(lf)    ON [ACT].[OrigReqWkEnding] = [D1].[DateID]#(lf)LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [D2]#(lf)    ON [ACT].[CurReqWkEnding] = [D2].[DateID]#(lf)LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [D3]#(lf)    ON [ACT].[ShipWkEnding] = [D3].[DateID]#(lf)LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [D4]#(lf)    ON [ACT].[WrittenWkEnding] = [D4].[DateID]#(lf) \", CreateNavigationProperties=false]),","    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"OrigReqWkEnding\", type date}, {\"CurReqWkEnding\", type date}, {\"ShipWkEnding\", type date}})","in","    #\"Changed Type\""],"type":"m"}}]},{"name":"Dim Warehouse","annotations":[{"name":"PBI_ResultType","value":"Table"},{"name":"PBI_NavigationStepName","value":"Navigation"}],"columns":[{"name":"Warehouse Code","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"4ec0b3cf-daa2-45b5-bf00-68cd90aad1ff","sourceColumn":"Warehouse Code","summarizeBy":"none"},{"name":"Intransit Warehouse","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"a9389c33-253f-4a7e-b1e3-89bf6b67ac04","sourceColumn":"Intransit Warehouse","summarizeBy":"none"},{"name":"Container Direct Warehouse","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"396c9d0b-1fbf-4fda-9ae7-61ddc0af5888","sourceColumn":"Container Direct Warehouse","summarizeBy":"none"},{"name":"Controlled Warehouse","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"0","lineageTag":"362713b4-bb04-4087-a9df-734be9e60e5c","sourceColumn":"Controlled Warehouse","summarizeBy":"sum"},{"name":"Warehouse Location","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"5ea66c95-82ec-4f48-941f-f5437de8dfb3","sourceColumn":"Warehouse Location","summarizeBy":"none"},{"name":"Warehouse Order Group","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"149038a9-819a-4ba1-bd61-5c3b7273ca88","sourceColumn":"Warehouse Order Group","summarizeBy":"none"},{"name":"Warehouse Group","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"724393f4-b12e-4ba1-9b64-873ebd4e029c","sourceColumn":"Warehouse Group","summarizeBy":"none"}],"lineageTag":"12f83e5a-2110-4aa2-ae67-c4a1e3181056","partitions":[{"name":"Dim Warehouse","mode":"import","queryGroup":"Dim Query","source":{"expression":["let","    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"SELECT [Warehouse Code]#(lf)      ,[Intransit Warehouse]#(lf)      ,[Container Direct Warehouse]#(lf)      ,[Controlled Warehouse]#(lf)      ,[Warehouse Location]#(lf)      ,[Warehouse Order Group]#(lf)      ,CASE  #(lf)            WHEN [Warehouse Code] = '335' THEN 'Ashton'#(lf)            WHEN [Warehouse Code] IN ('C','CNW', 'IOR', 'AF') THEN 'Containers'#(lf)            ELSE 'AFI'#(lf)       END AS [Warehouse Group]#(lf)  FROM [AFISales_DW].[DimAshleyWarehouseMaster]#(lf)  WHERE [Warehouse Code] <> ''#(lf)  \", CreateNavigationProperties=false])","in","    Source"],"type":"m"}}]},{"name":"_Measures","annotations":[{"name":"PBI_ResultType","value":"Exception"}],"lineageTag":"297e52b5-1e7a-42df-b4e7-4d8bd5a39c8e","measures":[{"name":"Total Current Order Qty","displayFolder":"Actual Orders","expression":["","  VAR qty = CALCULATE(","    SUM('Fact Actuals'[Order Quantity]),","    USERELATIONSHIP('Fact Actuals'[CurReqWkEnding], 'Dim Date'[DateID])","  )","","  VAR total_ord_qty = qty","  RETURN","  total_ord_qty"],"formatString":"#,0","lineageTag":"ba984c04-d834-4a48-8a06-ac85a9a990f1"},{"name":"Total Origin Order Qty","displayFolder":"Actual Orders","expression":["","  SUM('Fact Actuals'[Order Quantity])"],"formatString":"#,0","lineageTag":"565a7c1f-1d1e-41a8-bc4d-b888b413886f"},{"name":"Derived Ratios","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"Derived Measures","expression":["","DIVIDE(","    // Chia qty item không phải main piece cho qty main piece","    CALCULATE(","        [Total Order & FCT]","    ),","    CALCULATE(","        // Tính lượng actual order tới tháng hiện tại","        CALCULATE(","            SUMX(","                'Fact Actuals'","                ,[Order Quantity]","            ),","            FILTER('Dim Date', 'Dim Date'[FiscalMonthIndicator] < 0)","        )","        // Cộng thêm lượng FC cho tháng n+1 trở đi","            + ","        CALCULATE(","            SUMX(","                'Fact L1 Forecast'","                ,[RSLF]","            ),","            FILTER('Dim Date', 'Dim Date'[FiscalMonthIndicator] >= 0)","        )","        // Filter Sum của main piece","        // ALLSELECTED Để bỏ filter context của các SKU trong visual -> Lấy giá trị của Main piece","        ,ALLSELECTED('Dim Product Detail'[Item SKU])","        ,ALLSELECTED('Dim Product Detail'[Item Description])","        ,'Dim Product Detail'[Main Piece Item]","    ),","    1",")"],"lineageTag":"1afb5e25-14d9-4303-a60b-94ae50d82143"},{"name":"Rolling Avg Derived Ratios","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"Derived Measures","expression":["","VAR max_date = CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] < 0)","","VAR period = DATESINPERIOD(","    'Dim Date'[FiscalMonthLastDate]","    ,max_date","    ,-91 * DIVIDE(SELECTEDVALUE('Parameter Average Period'[Period], 3), 3)","    // ,-91","    ,DAY",")","","VAR derived_with_smoothing = ","    CALCULATE(","        AVERAGEX(","            VALUES('Dim Date'[FiscalMonth])","            ,[Derived Ratios]","        )","        ,ALL('Dim Date'[FiscalMonthIndicator])","        // ,DimDate[FiscalMonthIndicator] < 0","        ,period","    )","","VAR derived_without_smoothing =","    CALCULATE(","        AVERAGEX(","            VALUES('Dim Date'[FiscalMonth])","            ,[Derived Ratios]","        )","        ,ALL('Dim Date'[FiscalMonthIndicator])","        // ,DimDate[FiscalMonthIndicator] < 0","    )","","VAR result = ","IF(","    ISBLANK(CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] < 0))","    ,[Derived Ratios]","    ,IF(COUNTROWS(period) = 0, derived_without_smoothing, derived_with_smoothing)",")","","RETURN result","// RETURN cur_month"],"lineageTag":"1fbed66d-d182-43e1-90fa-c48069426767"},{"name":"FC Qty","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"FC Audit Measures","expression":"SUM('Fact L1 Forecast'[RSLF])","formatString":"#,0","lineageTag":"04d67309-f699-4a50-aca9-4b4f06f67cae"},{"name":"Total Order & FCT","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Actual Orders","expression":["","CALCULATE(","    [Total Origin Order Qty]","    ,FILTER(","        'Dim Date'","        ,[FiscalMonthIndicator] < 0","    )",") + ","CALCULATE(","    [FC Qty]","    ,FILTER(","        'Dim Date'","        ,[FiscalMonthIndicator] >= 0","    )",")"],"formatString":"#,0","lineageTag":"a5a663e1-01b6-4f5a-bf8a-36542544bec8"},{"name":"Derive Ratio Change","displayFolder":"Derived Measures","expression":["","VAR cur_value = [Rolling Avg Derived Ratios]","","VAR last_month_value = ","IF(","    SELECTEDVALUE('Dim Date'[FiscalMonth]) IN {3, 6, 9, 12}","    ,CALCULATE(","        [Rolling Avg Derived Ratios]","        ,DATEADD('Dim Date'[FiscalMonthLastDate], -35, DAY)","    )","    ,CALCULATE(","        [Rolling Avg Derived Ratios]","        ,DATEADD('Dim Date'[FiscalMonthLastDate], -28, DAY)","    )",")","","VAR changed_value =","CALCULATE(","    cur_value - last_month_value",")","","RETURN changed_value"],"formatString":"0%;-0%;0%","lineageTag":"f90ab57d-0874-420f-b24a-25e2cf6c84de"},{"name":"Annual RSLF","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"FC Audit Measures","expression":["","CALCULATE(","    [FC Qty]","    , ALL('Dim Date')","    , DATESINPERIOD(","        'Dim Date'[FiscalMonthFMT]","        , MAX('Dim Date'[FiscalMonthFMT])","        , -12","        , MONTH","    )",")"],"formatString":"#,0","lineageTag":"ceafee0e-8e1c-4614-bac4-9dea85c6d457"},{"name":"Total Order Before n","displayFolder":"Actual Orders","expression":["","CALCULATE(","    [Total Origin Order Qty]","    ,FILTER(","        'Dim Date'","        ,[FiscalMonthIndicator] < 0","    )",")"],"formatString":"0","lineageTag":"4813b908-1707-48c2-82ad-1b24a3de8c23"},{"name":"Warehouse Spit","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"Derived Measures","expression":["","","// Tính sum all whse, filter all warehousecode trừ C/CNW, Remove filter context","VAR all_whse = CALCULATE([Total Order & FCT], FILTER(ALL('Dim Warehouse'[Warehouse Code]), not('Dim Warehouse'[Warehouse Code] IN {\"C\", \"CNW\"})))","// Tính split của fct","VAR split = DIVIDE([Total Order & FCT], all_whse)","// Tìm max date","VAR max_date = CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] < 0)","// Tìm period bằng cách lấy max date trừ đi 91 ngày","VAR period = DATESINPERIOD(","    'Dim Date'[FiscalMonthLastDate]","    ,max_date","    ,-91 * DIVIDE(SELECTEDVALUE('Parameter Average Period'[Period], 3), 3)","    // ,-91","    ,DAY",")","// Nếu nhỏ hơn tháng n, thì tính split, còn lại để fct","// Iterate từng dòng, tính value từng whse ko tính C/CNW chia cho tổng số lượng ko tính whse C/CNW","VAR split_with_smoothing = ","IF(","    ISBLANK(CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] < 0))","    ,split","    ,DIVIDE(","        // Tính Sum actual rolling theo period và chia cho Sum Total Actual rolling average","        CALCULATE(","            SUMX(","                VALUES( 'Dim Date'[FiscalMonthLastDate] )","                , [Total Order & FCT]","            )","            , FILTER(","                // Dùng hàm VALUES để keep filter context cho từng warehouse","                VALUES('Dim Warehouse'[Warehouse Code])","                , NOT('Dim Warehouse'[Warehouse Code] IN {\"C\", \"CNW\"})","            )","            , period","        )","        ,CALCULATE(","            SUMX(","                VALUES('Dim Date'[FiscalMonthLastDate])","                ,[Total Order & FCT]","            )","            , FILTER(","                // Dùng hàm ALL để remove filter context cho từng warehouse","                ALL('Dim Warehouse'[Warehouse Code])","                , NOT('Dim Warehouse'[Warehouse Code] IN {\"C\", \"CNW\"})","            )","            // ,DimDate[FiscalMonthIndicator] < 0","            , period","        )","    )",")","","VAR split_without_smoothing =","IF(","    ISBLANK(CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] < 0))","    ,split","    ,DIVIDE(","        // Tính Sum actual rolling theo period và chia cho Sum Total Actual rolling average","        CALCULATE(","            SUMX(","                VALUES( 'Dim Date'[FiscalMonthLastDate] )","                , [Total Order & FCT]","            )","            , FILTER(","                // Dùng hàm VALUES để keep filter context cho từng warehouse","                VALUES('Dim Warehouse'[Warehouse Code])","                , NOT('Dim Warehouse'[Warehouse Code] IN {\"C\", \"CNW\"})","            )","        )","        ,CALCULATE(","            SUMX(","                VALUES('Dim Date'[FiscalMonthLastDate])","                ,[Total Order & FCT]","            )","            , FILTER(","                // Dùng hàm ALL để remove filter context cho từng warehouse","                ALL('Dim Warehouse'[Warehouse Code])","                , NOT('Dim Warehouse'[Warehouse Code] IN {\"C\", \"CNW\"})","            )","        )","    )",")","","VAR result =","IF(","    ISBLANK(CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] < 0))","    , split","    , IF(COUNTROWS(period) = 0, split_without_smoothing, split_with_smoothing)",")","","RETURN result","",""],"lineageTag":"35f0d028-751b-4619-9786-14e4b66456ff"},{"name":"Warehouse Split Change","displayFolder":"Derived Measures","expression":["","VAR cur_value = [Warehouse Spit]","","VAR last_month_value = ","IF(","    SELECTEDVALUE('Dim Date'[FiscalMonth]) IN {3, 6, 9, 12}","    ,CALCULATE(","        [Warehouse Spit]","        ,DATEADD('Dim Date'[FiscalMonthLastDate], -35, DAY)","    )","    ,CALCULATE(","        [Warehouse Spit]","        ,DATEADD('Dim Date'[FiscalMonthLastDate], -28, DAY)","    )",")","","VAR changed_value =","CALCULATE(","    cur_value - last_month_value",")","","RETURN changed_value"],"formatString":"0%;-0%;0%","lineageTag":"a683fa3d-dc6f-492a-86d7-5cb599f57a9a"},{"name":"ABS Forecast Error","displayFolder":"FC Accuracy\\Error","expression":["","SUMX('Fact FC Accuracy', ABS('Fact FC Accuracy'[Promoted Resultant Forecast Quantity] - 'Fact FC Accuracy'[Actual Demand Quantity]))"],"formatString":"#,0","lineageTag":"fb1a7157-7ab4-4000-915f-48e43618f250"},{"name":"Forecast Bias","displayFolder":"FC Accuracy\\WMAPE - Bias - FVA","expression":["","DIVIDE(","    [Forecast Error]","    , [Total Demand]","    , 1",")"],"formatString":"0.0%;-0.0%;0.0%","lineageTag":"76515aca-03ed-4a0e-9dfa-04a9ba7dafa7"},{"name":"Total Forecast","displayFolder":"FC Accuracy\\Actual - Forecast","expression":"SUM('Fact FC Accuracy'[Promoted Resultant Forecast Quantity])","formatString":"#,0","lineageTag":"70fadc54-895a-418d-bf4d-bbbcbc25fcb3"},{"name":"L1 PRSLF wMAPE","displayFolder":"FC Accuracy\\WMAPE - Bias - FVA","expression":["","","VAR item_error = ","ADDCOLUMNS(","    'Fact FC Accuracy'","    , \"Error\", CALCULATE(ABS(SUMX('Fact FC Accuracy', 'Fact FC Accuracy'[Promoted Resultant Forecast Quantity] - 'Fact FC Accuracy'[Actual Demand Quantity])))",")","","VAR abs_error = ABS([ABS Forecast Error])","","VAR wMAPE = DIVIDE(","    // CALCULATE(","    //     AVERAGEX(","    //         item_error","    //         , [Error]","    //     )","    // )","    SUMX('Fact FC Accuracy', ABS('Fact FC Accuracy'[Promoted Resultant Forecast Quantity] - 'Fact FC Accuracy'[Actual Demand Quantity]))","    , SUMX('Fact FC Accuracy','Fact FC Accuracy'[Actual Demand Quantity])","    , 1",")","","RETURN wMAPE"],"formatString":"0.0%;-0.0%;0.0%","lineageTag":"8134120a-f1d8-49ef-bc5d-704dc9d5b34c"},{"name":"L2 PRSLF wMAPE","displayFolder":"FC Accuracy\\WMAPE - Bias - FVA","expression":["","VAR summary =","ADDCOLUMNS(","    SUMMARIZE(","        'Fact FC Accuracy'","        , 'Dim Product Detail'[Item SKU]","    )","    , \"Error\"","    , CALCULATE(","        ABS(","            SUMX(","                'Fact FC Accuracy', 'Fact FC Accuracy'[Promoted Resultant Forecast Quantity] - 'Fact FC Accuracy'[Actual Demand Quantity]","            )","        )","    )","    , \"Demand\"","    , CALCULATE(","        SUMX('Fact FC Accuracy', [Actual Demand Quantity])","    )",")","","VAR result =","DIVIDE(","    CALCULATE(","        AVERAGEX(summary, [Error])","    )","    , CALCULATE(","        AVERAGEX(summary, [Demand])","    ), ","    1",")","","RETURN result"],"formatString":"0.0%;-0.0%;0.0%","lineageTag":"3a52dbf2-f4a9-4d88-b039-dfea7e438976"},{"name":"L3 PRSLF wMAPE","displayFolder":"FC Accuracy\\WMAPE - Bias - FVA","expression":["","VAR summary =","ADDCOLUMNS(","    SUMMARIZE(","        'Fact FC Accuracy'","        , 'Dim Product Detail'[Item Ext Series Number]","    )","    , \"Error\"","    , CALCULATE(","        ABS(","            SUMX(","                'Fact FC Accuracy', 'Fact FC Accuracy'[Promoted Resultant Forecast Quantity] - 'Fact FC Accuracy'[Actual Demand Quantity]","            )","        )","    )",")","","VAR result =","DIVIDE(","    CALCULATE(","        SUMX(summary, [Error])","    )","    , SUM('Fact FC Accuracy'[Actual Demand Quantity])","    , 1",")","","RETURN result"],"formatString":"0.0%;-0.0%;0.0%","lineageTag":"f00f8346-f544-4575-939d-e40dc0ae6aee"},{"name":"Total Demand Trend","displayFolder":"FC Accuracy\\Actual - Forecast","expression":"CALCULATE(SUM('Fact FC Accuracy'[Actual Demand Quantity]), DATESINPERIOD('Dim Date'[FiscalMonthLastDate], LASTDATE('Dim Date'[FiscalMonthLastDate]), -6, MONTH))","formatString":"0","lineageTag":"9b000c80-635d-45ce-b2cb-1a38566a6927"},{"name":"Total Forecast Trend","displayFolder":"FC Accuracy\\Misc","expression":"CALCULATE(SUM('Fact FC Accuracy'[Promoted Resultant Forecast Quantity]), DATESINPERIOD('Dim Date'[FiscalMonthLastDate], LASTDATE('Dim Date'[FiscalMonthLastDate]), -6, MONTH))","formatString":"0","lineageTag":"7ba6c46e-5520-43d6-8223-ace61f35e7dc"},{"name":"Total Forecast Bias Trend","displayFolder":"FC Accuracy\\Misc","expression":"DIVIDE(([Total Forecast Trend] - [Total Demand Trend]), [Total Forecast Trend])","formatString":"0.0%;-0.0%;0.0%","lineageTag":"9f3d8afa-6fa6-44b9-924b-084d7a0c88d8"},{"name":"L1 Naive wMAPE","displayFolder":"FC Accuracy\\WMAPE - Bias - FVA","expression":["","","VAR item_error = ","ADDCOLUMNS(","    'Fact FC Accuracy'","    , \"Error\", CALCULATE(ABS(SUMX('Fact FC Accuracy', 'Fact FC Accuracy'[Naive Forecast] - 'Fact FC Accuracy'[Actual Demand Quantity])))",")","","VAR wMAPE = DIVIDE(","    CALCULATE(","        AVERAGEX(","            item_error","            , [Error]","        )","    )","    , AVERAGE('Fact FC Accuracy'[Actual Demand Quantity])","    , 1",")","","RETURN wMAPE"],"formatString":"0.0%;-0.0%;0.0%","lineageTag":"5253a7cd-691f-4785-9e4f-2327fdb0e37c"},{"name":"L1 Forecast Value Added","displayFolder":"FC Accuracy\\WMAPE - Bias - FVA","expression":"[L1 PRSLF wMAPE] - [L1 Naive wMAPE]","formatString":"0.0%;-0.0%;0.0%","lineageTag":"6baf2cd7-f98e-44a8-bd73-564eb59a4266"},{"name":"Total Demand","displayFolder":"FC Accuracy\\Actual - Forecast","expression":"SUM('Fact FC Accuracy'[Actual Demand Quantity])","formatString":"#,0","lineageTag":"cae5fd4c-7dd9-43f5-b76f-912668901b26"},{"name":"L4 PRSLF wMAPE","displayFolder":"FC Accuracy\\WMAPE - Bias - FVA","expression":["","VAR summary =","ADDCOLUMNS(","    SUMMARIZE(","        'Fact FC Accuracy'","        , 'Dim Product Detail'[Collective Class]","    )","    , \"Error\"","    , CALCULATE(","        ABS(","            SUMX(","                'Fact FC Accuracy', 'Fact FC Accuracy'[Promoted Resultant Forecast Quantity] - 'Fact FC Accuracy'[Actual Demand Quantity]","            )","        )","    )",")","","VAR result =","DIVIDE(","    CALCULATE(","        SUMX(summary, [Error])","    )","    , SUM('Fact FC Accuracy'[Actual Demand Quantity])","    , 1",")","","RETURN result"],"formatString":"0.0%;-0.0%;0.0%","lineageTag":"71cc5e72-fddc-4d59-81bb-e3e82c6e379d"},{"name":"%L3 GAP RSLF & Bottom Up","displayFolder":"FC Audit Measures","expression":["","VAR val = ","CALCULATE(","    [Resultant] / [Bottom Up]","    ,FILTER(","        'Fact L3 Forecast'","        ,[MFCI] <> BLANK()","    )",")","RETURN","IF (ISBLANK(val), BLANK(), val - 1)"],"formatString":"0%;-0%;0%","lineageTag":"c96dbe22-76e6-463f-84e1-2a82afe69878"},{"name":"L3 GAP Forced & Unforced","displayFolder":"FC Audit Measures","expression":["","DIVIDE(","    SUM('Fact L3 Forecast'[FFSF]), SUM('Fact L3 Forecast'[SYSF])",")"],"formatString":"0%;-0%;0%","lineageTag":"fb9b4290-2a60-4997-b888-504ceaaff2c4"},{"name":"L3 GAP RSLF & Unforced","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"FC Audit Measures","expression":["","VAR val = ","CALCULATE(","    [Resultant] - [Unforced]",")","RETURN","IF (ISBLANK(val), BLANK(), val)"],"lineageTag":"59ee1725-2c37-49bb-93ef-c8c48f57341e"},{"name":"Item Split (No Derived)","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"Derived Measures","expression":["","","// Tính sum all whse, filter all warehousecode trừ C/CNW, Remove filter context","VAR all_item = CALCULATE([Total Order & FCT], ALL('Dim Product Detail'[Item SKU]))","// Tính split của fct","VAR split = DIVIDE([Total Order & FCT], all_item)","// Tìm max date","VAR max_date = CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] < 0)","// Tìm period bằng cách lấy max date trừ đi 91 ngày","VAR period = DATESINPERIOD(","    'Dim Date'[FiscalMonthLastDate]","    ,max_date","    ,-91 * DIVIDE(SELECTEDVALUE('Parameter Average Period'[Period], 3), 3)","    ,DAY",")","// Nếu nhỏ hơn tháng n, thì tính split, còn lại để fct","// Iterate từng dòng, tính value từng whse ko tính C/CNW chia cho tổng số lượng ko tính whse C/CNW","VAR split_with_smoothing =","    DIVIDE(","        // Tính Sum actual rolling theo period và chia cho Sum Total Actual rolling average","        CALCULATE(","            SUMX(","                VALUES( 'Dim Date'[FiscalMonthLastDate] )","                , [Total Order & FCT]","            )","            , VALUES('Dim Product Detail'[Item SKU]) // Dùng hàm VALUES để keep filter context cho từng warehouse","            , period","        )","        ,CALCULATE(","            SUMX(","                VALUES('Dim Date'[FiscalMonthLastDate])","                ,[Total Order & FCT]","            )","            , ALL('Dim Product Detail'[Item SKU]) // Dùng hàm ALL để remove filter context cho từng warehouse","            , period","        )","    )","","VAR split_without_smoothing =","    DIVIDE(","        // Tính Sum actual rolling theo period và chia cho Sum Total Actual rolling average","        CALCULATE(","            SUMX(","                VALUES( 'Dim Date'[FiscalMonthLastDate] )","                , [Total Order & FCT]","            )","            , VALUES('Dim Product Detail'[Item SKU]) // Dùng hàm VALUES để keep filter context cho từng warehouse","        )","        ,CALCULATE(","            SUMX(","                VALUES('Dim Date'[FiscalMonthLastDate])","                ,[Total Order & FCT]","            )","            , ALL('Dim Product Detail'[Item SKU]) // Dùng hàm ALL để remove filter context cho từng warehouse","        )","    )","VAR result = ","IF(","    ISBLANK(CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] < 0))","    , split","    , IF(COUNTROWS(period) = 0, split_without_smoothing, split_with_smoothing)",")","","RETURN result"],"lineageTag":"17263efc-01cf-462f-8ee4-4df0e7a3d84c"},{"name":"Item Split Change","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"Derived Measures","expression":["","VAR cur_value = [Item Split (No Derived)]","","VAR last_month_value = ","IF(","    SELECTEDVALUE('Dim Date'[FiscalMonth]) IN {3, 6, 9, 12}","    ,CALCULATE(","        [Item Split (No Derived)]","        ,DATEADD('Dim Date'[FiscalMonthLastDate], -35, DAY)","    )","    ,CALCULATE(","        [Item Split (No Derived)]","        ,DATEADD('Dim Date'[FiscalMonthLastDate], -28, DAY)","    )",")","","VAR changed_value =","CALCULATE(","    cur_value - last_month_value",")","","RETURN cur_value - last_month_value"],"lineageTag":"836252d1-6507-4efe-b377-58687212dca6"},{"name":"GAP P.Drop","displayFolder":"FC Audit Measures","expression":["","CALCULATE(","    [%L3 GAP RSLF & Bottom Up]","    ,'Fact L3 Forecast'[Future Status] = \"P\"",")"],"formatString":"0%;-0%;0%","lineageTag":"d0d7b2de-5b04-4037-a6f0-98539f17d58a"},{"name":"GAP New","displayFolder":"FC Audit Measures","expression":["","CALCULATE(","    [%L3 GAP RSLF & Bottom Up]","    , 'Fact L3 Forecast'[Current Status] = \"N\"",")"],"formatString":"0%;-0%;0%","lineageTag":"1f03af60-75fb-48b5-8b90-e705ba9d6842"},{"name":"GAP Current","displayFolder":"FC Audit Measures","expression":["","CALCULATE(","    [%L3 GAP RSLF & Bottom Up]","    , ('Fact L3 Forecast'[Current Status] = \"C\") && NOT('Fact L3 Forecast'[Future Status] IN {\"P\", \"F\"})",")"],"formatString":"0%;-0%;0%","lineageTag":"07c2a4b4-3c3d-47b9-b46f-c7f8d80dd3ff"},{"name":"Count D Indicator","displayFolder":"FC Audit Measures","expression":["","CALCULATE(","    COUNT('Fact L3 Forecast'[Lvl 3 Fcst_1])","    ,('Fact L3 Forecast'[MFCI] = \"D\")",")"],"formatString":"0","lineageTag":"635f7c2d-366b-4a73-9368-7a99d661b90f"},{"name":"Count H Indicator","displayFolder":"FC Audit Measures","expression":["","CALCULATE(","    COUNT('Fact L3 Forecast'[Lvl 3 Fcst_1])","    ,'Fact L3 Forecast'[MFCI] = \"H\"",")"],"formatString":"0","lineageTag":"4b40cafb-1e0d-415b-96d4-ce6a5a9abf27"},{"name":"Count Series","displayFolder":"FC Audit Measures","expression":["","CALCULATE(","    COUNT(","    'Fact L3 Forecast'[Lvl 3 Fcst_1]","    )","    , 'Dim Date'[FiscalMonthIndicator] >= 0",")"],"formatString":"#,0","lineageTag":"8cc7f5dd-9a6e-492e-89c5-d5972c1ee272"},{"name":"First Current Order Flag","displayFolder":"Actual Orders","expression":["","  VAR all_qty = CALCULATE(","    SUM('Fact Actuals'[Order Quantity])","    ,USERELATIONSHIP('Fact Actuals'[CurReqWkEnding], 'Dim Date'[DateID])","    ,all('Dim Date'[FiscalMonthLastDate])","  )","","  VAR flag = DIVIDE([Total Current Order Qty], all_qty)","  RETURN","  IF(flag = 1, \"#01B8AA\")"],"lineageTag":"1c450a80-6ee9-4873-9fc9-5ac81abc5766"},{"name":"First Current Order Font","displayFolder":"Actual Orders","expression":["","  VAR all_qty = CALCULATE(","    SUM('Fact Actuals'[Order Quantity])","    ,USERELATIONSHIP('Fact Actuals'[CurReqWkEnding], 'Dim Date'[DateID])","    ,all('Dim Date'[FiscalMonthLastDate])","  )","","  VAR flag = DIVIDE([Total Current Order Qty], all_qty)","  RETURN","  IF(flag = 1, \"white\")"],"lineageTag":"37e419e2-1826-4eaf-b56c-e1ba2ee23406"},{"name":"First Origin Order Flag","displayFolder":"Actual Orders","expression":["","  VAR all_qty = CALCULATE(","    SUM('Fact Actuals'[Order Quantity])","    ,all('Dim Date'[FiscalMonthLastDate])","  )","","  VAR flag = DIVIDE([Total Origin Order Qty], all_qty)","  RETURN","  IF(flag = 1, \"#01B8AA\")"],"lineageTag":"1595e0a8-55c3-4c84-8725-3196736b187e"},{"name":"First Origin Order Font","displayFolder":"Actual Orders","expression":["","  VAR all_qty = CALCULATE(","    SUM('Fact Actuals'[Order Quantity])","    ,all('Dim Date'[FiscalMonthLastDate])","  )","","  VAR flag = DIVIDE([Total Origin Order Qty], all_qty)","  RETURN","  IF(flag = 1, \"white\")"],"lineageTag":"4d355a90-bc3a-4196-afde-a252f87c2a9e"},{"name":"Total Shipped Order Qty","displayFolder":"Actual Orders","expression":["","  VAR qty = CALCULATE(","    SUM('Fact Actuals'[Order Quantity]),","    USERELATIONSHIP('Fact Actuals'[ShipWkEnding], 'Dim Date'[DateID])","  )","","  VAR total_ord_qty = qty","  RETURN","  total_ord_qty"],"formatString":"#,0","lineageTag":"156373d2-f7d8-4031-bb5a-2e48076f62b1"},{"name":"3M Rolling Avg","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"Actual Orders","expression":["","VAR max_date = CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] < 0)","","VAR period = DATESINPERIOD(","    'Dim Date'[FiscalMonthLastDate]","    ,max_date","    ,-91","    // ,-91","    ,DAY",")","","VAR derived_with_smoothing = ","    CALCULATE(","        AVERAGEX(","            VALUES('Dim Date'[FiscalMonth])","            ,[Total Origin Order Qty]","        )","        ,ALL('Dim Date'[FiscalMonthIndicator])","        // ,DimDate[FiscalMonthIndicator] < 0","        ,period","    )","","VAR derived_without_smoothing =","    CALCULATE(","        AVERAGEX(","            VALUES('Dim Date'[FiscalMonth])","            ,[Derived Ratios]","        )","        ,ALL('Dim Date'[FiscalMonthIndicator])","        // ,DimDate[FiscalMonthIndicator] < 0","    )","","VAR result = ","IF(","    ISBLANK(CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] < 0))","    ,[Derived Ratios]","    ,IF(COUNTROWS(period) = 0, derived_without_smoothing, derived_with_smoothing)",")","","RETURN derived_with_smoothing","// RETURN cur_month"],"lineageTag":"0c74278d-239c-40b2-ba9b-8ddcb0b91075"},{"name":"Forecast Error","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"FC Accuracy\\Error","expression":["","SUMX('Fact FC Accuracy', ('Fact FC Accuracy'[Promoted Resultant Forecast Quantity] - 'Fact FC Accuracy'[Actual Demand Quantity]))"],"formatString":"#,0","lineageTag":"518c81f8-008c-40c0-8fe8-018550a58a86"},{"name":"PROL-RSLF Qty","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"FC Audit Measures","expression":"SUM('Fact L1 Forecast'[RSLF]) + SUM('Fact L1 Forecast'[Promo Lift]) ","formatString":"#,0","lineageTag":"23cfe092-3dc7-470d-abe6-9b734344b3e5"},{"name":"Total Order & Promo FCT","displayFolder":"Actual Orders","expression":["","CALCULATE(","    [Total Origin Order Qty]","    ,FILTER(","        'Dim Date'","        ,[FiscalMonthIndicator] < 0","    )",") + ","CALCULATE(","    [PROL-RSLF Qty]","    ,FILTER(","        'Dim Date'","        ,[FiscalMonthIndicator] >= 0","    )","    , 'Fact L1 Forecast'[Forecast Lag] = \"Lag 0\"",")"],"formatString":"#,0","lineageTag":"8579091e-219e-446c-9194-448465a9ab9b"},{"name":"Actuals Year n-1","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Forecast Review","expression":["","CALCULATE(","    [Total Order & Promo FCT]","    , 'Dim Date'[FiscalYearIndicator] = -1",")"],"formatString":"#,0","lineageTag":"e3745aca-c8d6-4ecf-b680-52f1299fe63c"},{"name":"Act/Fcst Year n","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Forecast Review","expression":["","CALCULATE(","    [Total Order & Promo FCT]","    , 'Dim Date'[FiscalYearIndicator] = 0",")"],"formatString":"#,0","lineageTag":"3d112592-d997-4697-b14d-a0bbd4e30ebe"},{"name":"Promo Year N","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Forecast Review","expression":["","CALCULATE(","    SUM('Fact L1 Forecast'[Promo Lift])","    , 'Dim Date'[FiscalYearIndicator] = 0","    , 'Dim Date'[FiscalMonthIndicator] >= 0",")"],"formatString":"#,0","lineageTag":"13eeca1f-353c-4566-b301-9e4b324c6ff0"},{"name":"YoY Growth","displayFolder":"Forecast Review","expression":["","DIVIDE([Act/Fcst Year n], [Actuals Year n-1]) - 1"],"formatString":"#,0.00%;-#,0.00%;#,0.00%","lineageTag":"b8d355ee-5aa2-4ee7-8ae5-c216092cc906"},{"name":"Fcst Year n+1","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Forecast Review","expression":["","CALCULATE(","    [Total Order & Promo FCT]","    , 'Dim Date'[FiscalYearIndicator] = 1",")"],"formatString":"#,0","lineageTag":"f2cba6c2-b6d0-4efc-a7f5-de16567e9d1f"},{"name":"YoY Growth n+1","displayFolder":"Forecast Review","expression":["","DIVIDE([Fcst Year n+1], [Act/Fcst Year n]) - 1"],"formatString":"0.00%;-0.00%;0.00%","lineageTag":"256248c4-3ea9-45ca-a15e-c1d3bdd7df68"},{"name":"Invoiced","displayFolder":"Forecast Review","expression":["","CALCULATE(","    [Total Origin Order Qty]","    , 'Fact Actuals'[Status] = \"Invoiced\"","    , 'Dim Date'[FiscalYearIndicator] = 0",")"],"formatString":"0","lineageTag":"0967938b-a2ab-4137-b6bc-07d949c99fcc"},{"name":"Open Order","displayFolder":"Forecast Review","expression":["","CALCULATE(","    [Total Origin Order Qty]","    , 'Fact Actuals'[Status] = \"Open Order\"","    , 'Dim Date'[FiscalYearIndicator] = 0",")"],"formatString":"0","lineageTag":"a0821cf6-e212-45c5-ba88-0e7dabb77951"},{"name":"Net FCT","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"Forecast Review","expression":["","CALCULATE(","    IF(ISBLANK([PROL-RSLF Qty])","    , BLANK()","    , [PROL-RSLF Qty] - [Invoiced] - [Open Order]","    )","    , 'Dim Date'[FiscalYearIndicator] = 0",")"],"lineageTag":"7f4b14a8-f05e-4fcb-8444-82c3290b8b2f"},{"name":"Total Order & Bottom Up Fct","displayFolder":"Actual Orders","expression":["","CALCULATE(","    [Total Origin Order Qty]","    ,FILTER(","        'Dim Date'","        ,[FiscalMonthIndicator] < 0","    )",")","+ ","CALCULATE(","    [Bottom Up]","    , FILTER(","        'Dim Date'","        ,[FiscalMonthIndicator] >= 0","    )",")"],"formatString":"#,0","lineageTag":"75b200e8-3106-40dc-9457-fafadc77c53d"},{"name":"Act/Bottom up Fcst Year n","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Forecast Review","expression":["","CALCULATE(","    [Total Order & Bottom Up Fct]","    , 'Dim Date'[FiscalYearIndicator] = 0",")"],"formatString":"#,0","lineageTag":"b507d8cd-10ec-47ba-831c-7c005a56bc26"},{"name":"Bottom up Fcst Year n+1","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Forecast Review","expression":["","CALCULATE(","    [Total Order & Bottom Up Fct]","    , 'Dim Date'[FiscalYearIndicator] = 1",")"],"formatString":"#,0","lineageTag":"89d4d05b-b01b-4fd6-a56f-d36945b64950"},{"name":"YoY Bottom Up Growth","displayFolder":"Forecast Review","expression":["","DIVIDE([Act/Bottom up Fcst Year n], [Actuals Year n-1]) - 1"],"formatString":"0.00%;-0.00%;0.00%","lineageTag":"eecfcc3b-20d1-4c88-bf63-24282106243a"},{"name":"YoY Bottom Up Growth n+1","displayFolder":"Forecast Review","expression":["","DIVIDE([Bottom up Fcst Year n+1], [Act/Bottom up Fcst Year n]) - 1"],"formatString":"0.00%;-0.00%;0.00%","lineageTag":"51e7d968-cf3a-4b90-88d0-2eb0ee8a0d88"},{"name":"Total Invoiced Less 6m Item Forecast","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"FC Accuracy\\Misc","expression":["","CALCULATE(","    SUM('Fact FC Accuracy'[Promoted Resultant Forecast Quantity])","    , 'Fact FC Accuracy'[Invoice Status] = \"Invoiced equal/less than 6m\"",")"],"formatString":"#,0","lineageTag":"b8a50376-8d88-44e4-bce5-97301664e37a"},{"name":"Total Invoiced over 6m Item Forecast","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"FC Accuracy\\Misc","expression":["","CALCULATE(","    SUM('Fact FC Accuracy'[Promoted Resultant Forecast Quantity])","    , 'Fact FC Accuracy'[Invoice Status] = \"Invoiced greater than 6m\"",")"],"formatString":"#,0","lineageTag":"0f06396e-966d-43c6-8d4a-b0d993a8c822"},{"name":"Total Not Invoiced Item Forecast","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"FC Accuracy\\Misc","expression":["","CALCULATE(","    SUM('Fact FC Accuracy'[Promoted Resultant Forecast Quantity])","    , 'Fact FC Accuracy'[Invoice Status] = \"Not invoiced\"",")"],"lineageTag":"6a990e65-4d95-47a3-aa73-a99fee5e4bba"},{"name":"Average Item Demand","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"FC Accuracy\\Actual - Forecast","expression":["","","VAR total_dmd =","AVERAGEX(","    SUMMARIZE(","        'Fact FC Accuracy'","        , [Item SKU]","        , [FiscalMonthYear]","        , \"Sum_Demand\", SUM('Fact FC Accuracy'[Actual Demand Quantity])","    )","    , [Sum_Demand]",")","","VAR sku_counts =","DISTINCTCOUNT('Fact FC Accuracy'[Item SKU])","","","VAR result =","DIVIDE(","    total_dmd","    , sku_counts",")","","RETURN total_dmd"],"lineageTag":"f3aa0364-8733-4649-becc-d96d3d16c496"},{"name":"Posted Open Order","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"CRD Changed","expression":["","CALCULATE(","    SUM('Fact CRD Change'[Open Order Quantity])","    , 'Fact CRD Change'[Changed After Posted Flag] = 1",")"],"lineageTag":"5693268b-a151-4afd-8296-0cbc768e525f"},{"name":"CRD Open Order","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"CRD Changed","expression":["","SUM('Fact CRD Change'[Open Order Quantity])"],"formatString":"#,0","lineageTag":"9e86652f-3dc7-403b-afe5-6abc3003c114"},{"name":"Actuals Year n-2","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Forecast Review","expression":["","CALCULATE(","    [Total Order & Promo FCT]","    , 'Dim Date'[FiscalYearIndicator] = -2",")"],"formatString":"#,0","lineageTag":"e362f5c7-c62e-4fea-94b1-987de798a092"},{"name":"YoY Bottom Up Growth n-1","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"Forecast Review","expression":["","DIVIDE([Act/Bottom up Fcst Year n], [Actuals Year n-2]) - 1"],"lineageTag":"be48104c-fe88-4268-9418-d09edbf1f204"},{"name":"YoY Growth n-1","displayFolder":"Forecast Review","expression":["","DIVIDE([Actuals Year n-1], [Actuals Year n-2]) - 1"],"formatString":"0.00%;-0.00%;0.00%","lineageTag":"f1c863f6-4683-413d-9dfa-dee6ddf199d5"},{"name":"Total Resultant Forecast","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"FC Accuracy\\Actual - Forecast","expression":"SUM('Fact FC Accuracy'[Resultant Forecast])","lineageTag":"434d8961-0619-497c-ba9f-32232440c3a3"},{"name":"L1 RSLF wMAPE","displayFolder":"FC Accuracy\\WMAPE - Bias - FVA","expression":["","","VAR item_error = ","ADDCOLUMNS(","    'Fact FC Accuracy'","    , \"Error\", CALCULATE(ABS(SUMX('Fact FC Accuracy', 'Fact FC Accuracy'[Resultant Forecast] - 'Fact FC Accuracy'[Actual Demand Quantity])))",")","","VAR abs_error = ABS([ABS Forecast Error])","","VAR wMAPE = DIVIDE(","    CALCULATE(","        AVERAGEX(","            item_error","            , [Error]","        )","    )","    , AVERAGE('Fact FC Accuracy'[Actual Demand Quantity])","    , 1",")","","RETURN wMAPE"],"formatString":"0.0%;-0.0%;0.0%","lineageTag":"541900cc-8aa9-429b-ae60-95202d03c3dd"},{"name":"CPFR Value Added","displayFolder":"FC Accuracy\\WMAPE - Bias - FVA","expression":"[L1 PRSLF wMAPE] - [L1 RSLF wMAPE]","formatString":"0.0%;-0.0%;0.0%","lineageTag":"f224e1f3-b045-48db-88a2-70ae623c0ff1"},{"name":"RSLF Error","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"FC Accuracy\\Error","expression":["","SUMX('Fact FC Accuracy', ('Fact FC Accuracy'[Resultant Forecast] - 'Fact FC Accuracy'[Actual Demand Quantity]))"],"lineageTag":"623666c5-e042-4cb4-808b-d7f98b8a5546"},{"name":"RSLF Bias","displayFolder":"FC Accuracy\\WMAPE - Bias - FVA","expression":["","DIVIDE(","    [RSLF Error]","    , [Total Demand]","    , 1",")"],"formatString":"0.0%;-0.0%;0.0%","lineageTag":"349c946d-4c1e-4727-a5fa-21bcfe72f251"},{"name":"Current YTD","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Actual Orders","expression":["","VAR _startdate = ","CALCULATE(","    MIN('Dim Date'[FiscalMonthLastDate])","    , ('Dim Date'[FiscalMonth] >= 1) && ('Dim Date'[FiscalYearIndicator] = 0)","    , REMOVEFILTERS('Dim Date')",")","","VAR _enddate = ","CALCULATE(","    MAX('Dim Date'[FiscalMonthLastDate])","    , ('Dim Date'[FiscalMonthIndicator] <= -1) && ('Dim Date'[FiscalYearIndicator] = 0)","    , REMOVEFILTERS('Dim Date')",")","","VAR _result =","CALCULATE(","    [Total Current Order Qty]","    , DATESBETWEEN(","        'Dim Date'[FiscalMonthLastDate]","        , _startdate","        , _enddate","    )",")","","VAR _month_name = ","CALCULATE(","    TOPN(","        1,","        VALUES('Dim Date'[Fiscal Month Name])","    )    ","    , 'Dim Date'[FiscalMonthIndicator] = 0",")","","RETURN IF(","    _month_name = \"Jan\"","    , CALCULATE(","        [Total Current Order & Promo FCT], 'Dim Date'[FiscalYearIndicator] = -1","    )","    , _result",")"],"formatString":"#,0","lineageTag":"d534f108-327d-46c4-93ee-c12a946d821b"},{"name":"Current YTD Change","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Actual Orders","expression":["","[Current YTD] - [Current YTD n-1]"],"formatString":"#,0","lineageTag":"d2a123ed-e51d-4f49-abc1-f577d9946e12"},{"name":"Current YTD n-1","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Actual Orders","expression":["","VAR _startdate = ","CALCULATE(","    MIN('Dim Date'[FiscalMonthLastDate])","    , ('Dim Date'[FiscalMonth] >= 1) && ('Dim Date'[FiscalYearIndicator] = -1)",")","","VAR _enddate = ","CALCULATE(","    MAX('Dim Date'[FiscalMonthLastDate])","    , ('Dim Date'[FiscalMonthIndicator] <= -13) && ('Dim Date'[FiscalYearIndicator] = -1)",")","","VAR _result =","CALCULATE(","    [Total Current Order Qty]","    , DATESBETWEEN(","        'Dim Date'[FiscalMonthLastDate]","        , _startdate","        , _enddate","    )","    , REMOVEFILTERS('Dim Date')",")","","VAR _month_name = ","CALCULATE(","    TOPN(","        1,","        VALUES('Dim Date'[Fiscal Month Name])","    )    ","    , 'Dim Date'[FiscalMonthIndicator] = 0",")","","RETURN IF (","    _month_name = \"Jan\"","    , CALCULATE([Total Current Order & Promo FCT], 'Dim Date'[FiscalYearIndicator] = -2)","    , _result",")"],"formatString":"#,0","lineageTag":"296fbc51-3f34-4645-9c89-2c67a9f7ba27"},{"name":"Current YTD YoY","displayFolder":"Actual Orders","expression":["","VAR result = ","CALCULATE(","    DIVIDE(","        [Current YTD]","        , [Current YTD n-1]","    )",")","RETURN","IF(","    ISBLANK([Current YTD]) && ISBLANK([Current YTD n-1])","    , BLANK()","    , result - 1",")"],"formatString":"#,0.0%;-#,0.0%;#,0.0%","lineageTag":"215c3aee-7106-44b9-8ed3-5a6516b6fa25"},{"name":"Total Current Order & Promo FCT","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Actual Orders","expression":["","CALCULATE(","    [Total Current Order Qty]","    ,FILTER(","        'Dim Date'","        ,[FiscalMonthIndicator] < 0","    )",") + ","CALCULATE(","    [PROL-RSLF Qty]","    ,FILTER(","        'Dim Date'","        ,[FiscalMonthIndicator] >= 0","    )","    , 'Fact L1 Forecast'[Forecast Lag] = \"Lag 0\"",")"],"formatString":"#,0","lineageTag":"d337915c-0519-4761-a234-82d1ae258afd"},{"name":"Current Ord Y-1","displayFolder":"Actual Orders","expression":["","CALCULATE(","    [Total Current Order Qty]