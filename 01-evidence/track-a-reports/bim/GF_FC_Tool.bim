":"FiscalMonthLastDate","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"UnderlyingDateTimeDataType","value":"Date"}],"dataType":"dateTime","formatString":"Long Date","lineageTag":"1d7ef4d0-f365-4c48-8266-c408209be39d","sourceColumn":"FiscalMonthLastDate","summarizeBy":"none"},{"name":"Warehouse Group","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"fa002d73-e637-4705-9182-48b15bfbb9d9","sourceColumn":"Warehouse Group","summarizeBy":"none"}],"lineageTag":"86d989af-2fe4-4792-bb11-b260259e0780","partitions":[{"name":"Fact. ABC XYZ","mode":"import","queryGroup":"Dim Query","source":{"expression":["let","    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"SELECT [Item SKU]#(lf)    , [Current Status]#(lf)    , [Future Status]#(lf)    , [Manufacturing Status]#(lf)    , [Initial Invoice Period]#(lf)    , [Import/Domestic Code]#(lf)    , [Avg Wkly Demand]#(lf)    , [Std Dev of Demand]#(lf)    , [CoefVar]#(lf)    , [ABC Code]#(lf)    , [XYZ Code]#(lf)    , [ABCXYZ Code]#(lf)    , [ABC Logility]#(lf)    , [ForecastPriority]#(lf)    , [SnapshotMonthYear]#(lf)    , [DD].[FiscalMonthLastDate]#(lf)    , [Warehouse Group]#(lf)FROM SupplyChain_Enh.ItemABCCode_AFI AS ABC#(lf)LEFT JOIN (SELECT DISTINCT [FiscalMonthYear], [FiscalMonthLastDate] FROM [Enterprise_DW].[DimDate_NonRetail]) AS DD#(lf)       ON [ABC].[SnapshotMonthYear] = [DD].[FiscalMonthYear]#(lf)WHERE [SnapshotMonthYear] = (#(lf)        SELECT MAX([SnapshotMonthYear])#(lf)        FROM SupplyChain_Enh.ItemABCCode_AFI#(lf)        )#(lf)  AND [Warehouse Group] = 'AFI'\", CreateNavigationProperties=false]),","    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"FiscalMonthLastDate\", type date}}),","    #\"Trimmed Text\" = Table.TransformColumns(#\"Changed Type\",{{\"Item SKU\", Text.Trim, type text}})","in","    #\"Trimmed Text\""],"type":"m"}}]},{"name":"Fact FC Accuracy","annotations":[{"name":"PBI_ResultType","value":"Exception"},{"name":"PBI_NavigationStepName","value":"Navigation"}],"columns":[{"name":"AFI Warehouse Code","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"0e1bbe9a-c6d4-4b35-91dc-33ea836e53b6","sourceColumn":"AFI Warehouse Code","summarizeBy":"none"},{"name":"Forecast Period","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"changedProperties":[{"property":"SortByColumn"}],"dataType":"string","lineageTag":"1821000d-dc4f-4180-b292-b5163abc12ec","sortByColumn":"Forecast Period - sort","sourceColumn":"Forecast Period","summarizeBy":"none"},{"name":"Actual Demand Quantity","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"#,0","lineageTag":"4771eb44-8e4e-4d56-87ed-ddf6a4e2e98c","sourceColumn":"Actual Demand Quantity","summarizeBy":"sum"},{"name":"Promoted Resultant Forecast Quantity","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"double","formatString":"#,0","lineageTag":"2ca48e84-0578-4889-be25-5fdafc0f7dac","sourceColumn":"Promoted Resultant Forecast Quantity","summarizeBy":"sum"},{"name":"Naive Forecast","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"0","lineageTag":"80e4166f-b005-4391-9b68-1daa0e1748b8","sourceColumn":"Naive Forecast","summarizeBy":"sum"},{"name":"Forecast Period - sort","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"changedProperties":[{"property":"SortByColumn"}],"dataType":"int64","formatString":"0","lineageTag":"ec3b36e2-78b6-42f9-a4fe-e616d50f0517","sourceColumn":"Forecast Period - sort","summarizeBy":"sum"},{"name":"Series Number","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"56545b2c-0434-4d6a-a717-e05bafd3290a","sourceColumn":"Series Number","summarizeBy":"none"},{"name":"Snapshot Date","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"UnderlyingDateTimeDataType","value":"Date"}],"changedProperties":[{"property":"DataType"}],"dataType":"dateTime","formatString":"Short Date","lineageTag":"c02a316b-a169-40a5-99b7-a6f9c0e772ea","sourceColumn":"Snapshot Date","summarizeBy":"none","variations":[{"name":"Variation","defaultHierarchy":{"hierarchy":"Date Hierarchy","table":"LocalDateTable_c10fe989-2379-4798-95c3-2aaebfd10a50"},"isDefault":true,"relationship":"8f8e029f-750b-4774-b835-4e4cb23a6cc0"}]},{"name":"Customer Groups","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"9c811a5a-a3c4-4289-94b3-add5d35e6e93","sourceColumn":"Customer Groups","summarizeBy":"none"},{"name":"Item SKU","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"76c3f520-56bf-44c3-ab3e-64e12c61719d","sourceColumn":"Item SKU","summarizeBy":"none"},{"name":"Collective Class","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"4f61ab40-fba1-4e0d-8fcf-9728914628d3","sourceColumn":"Collective Class","summarizeBy":"none"},{"name":"Resultant Forecast","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"6b883e44-5317-4542-b4f2-7bee3da1c356","sourceColumn":"Resultant Forecast","summarizeBy":"sum"},{"name":"Month Of Invoice At Snapshot","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"0","lineageTag":"f26ebabb-0f0e-40eb-9c7d-9fe4d7e128f0","sourceColumn":"Month Of Invoice At Snapshot","summarizeBy":"sum"},{"name":"FiscalMonthYear","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"UnderlyingDateTimeDataType","value":"Date"}],"changedProperties":[{"property":"DataType"}],"dataType":"dateTime","formatString":"Long Date","lineageTag":"ffd17988-02fe-46fe-98a9-52533528b6f2","sourceColumn":"FiscalMonthYear","summarizeBy":"none"},{"name":"Invoice Status","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"191a8d0c-ebb1-4dbf-b9bb-63f7dfcb6b9a","sourceColumn":"Invoice Status","summarizeBy":"none"}],"lineageTag":"c05a294d-cf06-4728-938f-727309dde076","partitions":[{"name":"Fact FC Accuracy","mode":"import","queryGroup":"Fact Query","source":{"expression":["let","    Query1 = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"DECLARE @CCParam NVARCHAR(MAX),#(lf)        @PeriodParam NVARCHAR(12);#(lf)#(lf)SET @CCParam = 'HSENT';#(lf)SET @PeriodParam = '90 Days';#(lf)#(lf)------------------------------------------------------------#(lf)-- Drop temp tables if they already exist#(lf)------------------------------------------------------------#(lf)IF OBJECT_ID('tempdb..#Final_Table') IS NOT NULL#(lf)    DROP TABLE #Final_Table;#(lf)#(lf)IF OBJECT_ID('tempdb..#Scaffold') IS NOT NULL#(lf)    DROP TABLE #Scaffold;#(lf)#(lf)IF OBJECT_ID('tempdb..#DemandForecast_Snapshot') IS NOT NULL#(lf)    DROP TABLE #DemandForecast_Snapshot;#(lf)#(lf)IF OBJECT_ID('tempdb..#Aggregate_Demand') IS NOT NULL#(lf)    DROP TABLE #Aggregate_Demand;#(lf)#(lf)IF OBJECT_ID('tempdb..#Actual_Demand') IS NOT NULL#(lf)    DROP TABLE #Actual_Demand;#(lf)#(lf)IF OBJECT_ID('tempdb..#SnapshotDate') IS NOT NULL#(lf)    DROP TABLE #SnapshotDate;#(lf)#(lf)------------------------------------------------------------#(lf)-- Materialize SnapshotDate#(lf)------------------------------------------------------------#(lf)SELECT#(lf)    [FiscalYear],#(lf)    [FiscalMonth],#(lf)    [FiscalMonthYear],#(lf)    [FiscalMonthIndicator],#(lf)    [Month Name],#(lf)    CASE [Periods]#(lf)        WHEN '2w'   THEN '2 Weeks'#(lf)        WHEN '30d'  THEN '30 Days'#(lf)        WHEN '60d'  THEN '60 Days'#(lf)        WHEN '90d'  THEN '90 Days'#(lf)        WHEN '120d' THEN '120 Days'#(lf)    END AS [Periods],#(lf)    CASE [Snapshot Date]#(lf)        WHEN '2025-03-10' THEN '2025-03-24'#(lf)        WHEN '2025-11-10' THEN '2025-11-12' -- add Nov cycle deviation#(lf)        WHEN '2025-12-08' THEN '2025-12-16' -- add Dec cycle deviation#(lf)        ELSE [Snapshot Date]#(lf)    END AS [Snapshot Date]#(lf)INTO #SnapshotDate#(lf)FROM (#(lf)    SELECT DISTINCT#(lf)        [2w].[FiscalYear],#(lf)        [2w].[FiscalMonth],#(lf)        [2w].[FiscalMonthYear],#(lf)        [2w].[FiscalMonthIndicator],#(lf)        DATEFROMPARTS([2w].[FiscalYear], [2w].[FiscalMonth], 1) AS [Month Name],#(lf)        [2w].[DateID]   AS [2w],#(lf)        [30d].[DateID]  AS [30d],#(lf)        [60d].[DateID]  AS [60d],#(lf)        [90d].[DateID]  AS [90d],#(lf)        [120d].[DateID] AS [120d]#(lf)    FROM [Enterprise_DW].[DimDate_NonRetail] [2w]#(lf)#(lf)    LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [30d]#(lf)        ON DATEFROMPARTS([2w].[FiscalYear], [2w].[FiscalMonth], 1) = DATEADD(M, 1, DATEFROMPARTS([30d].[FiscalYear], [30d].[FiscalMonth], 1))#(lf)       AND [30d].[FiscalWeekOfMonth] = 3#(lf)       AND [30d].[FiscalDayOfWeek] = 2#(lf)#(lf)    LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [60d]#(lf)        ON DATEFROMPARTS([2w].[FiscalYear], [2w].[FiscalMonth], 1) = DATEADD(M, 2, DATEFROMPARTS([60d].[FiscalYear], [60d].[FiscalMonth], 1))#(lf)       AND [60d].[FiscalWeekOfMonth] = 3#(lf)       AND [60d].[FiscalDayOfWeek] = 2#(lf)#(lf)    LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [90d]#(lf)        ON DATEFROMPARTS([2w].[FiscalYear], [2w].[FiscalMonth], 1) = DATEADD(M, 3, DATEFROMPARTS([90d].[FiscalYear], [90d].[FiscalMonth], 1))#(lf)       AND [90d].[FiscalWeekOfMonth] = 3#(lf)       AND [90d].[FiscalDayOfWeek] = 2#(lf)#(lf)    LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [120d]#(lf)        ON DATEFROMPARTS([2w].[FiscalYear], [2w].[FiscalMonth], 1) = DATEADD(M, 4, DATEFROMPARTS([120d].[FiscalYear], [120d].[FiscalMonth], 1))#(lf)       AND [120d].[FiscalWeekOfMonth] = 3#(lf)       AND [120d].[FiscalDayOfWeek] = 2#(lf)#(lf)    WHERE [2w].[FiscalWeekOfMonth] = 3#(lf)      AND [2w].[FiscalMonthIndicator] BETWEEN -25 AND -1#(lf)      AND [2w].[FiscalDayOfWeek] = 2#(lf)) base#(lf)UNPIVOT ([Snapshot Date] FOR [Periods] IN ([2w], [30d], [60d], [90d], [120d])) AS unpvt;#(lf)#(lf)------------------------------------------------------------#(lf)-- Materialize Actual_Demand#(lf)------------------------------------------------------------#(lf)SELECT#(lf)    TRIM([DMD].[Customergroups]) AS [Customergroups],#(lf)    [DMD].[Year Period],#(lf)    [N_DMD].[Year Period] AS [Naive Year Period],#(lf)    TRIM([DMD].[Item]) AS [Item],#(lf)    TRIM([DMD].[Location]) AS [Warehouse],#(lf)    [DMD].[Actual demand],#(lf)    [N_DMD].[Actual Demand] AS [Naive Forecast]#(lf)INTO #Actual_Demand#(lf)FROM [SupplyChain_Enh].[ItemActualDemand_Logility] [DMD]#(lf)LEFT JOIN [SupplyChain_Enh].[ItemActualDemand_Logility] [N_DMD]#(lf)    ON [DMD].[Customergroups] = [N_DMD].[Customergroups]#(lf)   AND [DMD].[Item] = [N_DMD].[Item]#(lf)   AND [DMD].[Location] = [N_DMD].[Location]#(lf)   AND [DMD].[Year Period] = DATEADD(M, 1, [N_DMD].[Year Period]);#(lf)#(lf)------------------------------------------------------------#(lf)-- Materialize Aggregate_Demand#(lf)------------------------------------------------------------#(lf)SELECT#(lf)    'AFICONS' AS [Customergroups],#(lf)    [DMD].[Year Period],#(lf)    TRIM([DMD].[Item]) AS [Item],#(lf)    TRIM([DMD].[Location]) AS [Warehouse],#(lf)    SUM([DMD].[Actual demand]) AS [Actual demand],#(lf)    SUM([N_DMD].[Actual Demand]) AS [Naive Forecast]#(lf)INTO #Aggregate_Demand#(lf)FROM [SupplyChain_Enh].[ItemActualDemand_Logility] [DMD]#(lf)LEFT JOIN [SupplyChain_Enh].[ItemActualDemand_Logility] [N_DMD]#(lf)    ON [DMD].[Customergroups] = [N_DMD].[Customergroups]#(lf)   AND [DMD].[Item] = [N_DMD].[Item]#(lf)   AND [DMD].[Location] = [N_DMD].[Location]#(lf)   AND [DMD].[Year Period] = DATEADD(M, 1, [N_DMD].[Year Period])#(lf)WHERE [DMD].[Year Period] >= '2025-03-01'#(lf)GROUP BY#(lf)    [DMD].[Year Period],#(lf)    TRIM([DMD].[Item]),#(lf)    TRIM([DMD].[Location]);#(lf)#(lf)------------------------------------------------------------#(lf)-- Materialize DemandForecast_Snapshot#(lf)------------------------------------------------------------#(lf)SELECT#(lf)    [SS].[Periods] AS [Forecast Period],#(lf)    [SS].[Month Name],#(lf)    [DFC].[dfcCustomergroups] AS [Customer Group],#(lf)    [DFC].[dfcFiscalMonth] AS [FiscalMonthYear],#(lf)    [DFC].[dfcItem] AS [Item SKU],#(lf)    [DFC].[dfcWarehouse] AS [AFI Warehouse Code],#(lf)    [FCC].[ForeCastType] AS [Forecast Model],#(lf)    [DFC_L2].[dfcFCSTTypeCode] AS [L2 Forecast Model],#(lf)    [ABC].[ABC Code] AS [Fcst ABC],#(lf)    [ABC].[XYZ Code] AS [Fcst XYZ],#(lf)    [ABC].[ABCXYZ Code] AS [Fcst ABC/XYZ],#(lf)    [ABC].[ForecastPriority],#(lf)    [DFC].[dfcResultantForecast] AS [Resultant Forecast],#(lf)    [DFC].[dfcPromotionalLift] AS [Promo Lift],#(lf)    ([DFC].[dfcResultantForecast] + [DFC].[dfcPromotionalLift]) AS [Total Forecast],#(lf)    CONVERT(DATE, [DFC].[dfcSnapshot]) AS [Snapshot Date]#(lf)INTO #DemandForecast_Snapshot#(lf)FROM [SupplyChain_Enh].[DemandForecastSnapshot] AS [DFC]#(lf)#(lf)LEFT JOIN [SupplyChain_Enh].[ForecastCommonContainer_Logility] [FCC]#(lf)    ON [DFC].[dfcItem] = [FCC].[Item-Lvl1]#(lf)   AND [DFC].[dfcWarehouse] = [FCC].[Location]#(lf)   AND CONVERT(DATE, [DFC].[dfcSnapshot]) = CONVERT(DATE, [FCC].[FileDate])#(lf)   AND [DFC].[dfcCustomergroups] = [FCC].[DfcCustomergroupS]#(lf)#(lf)INNER JOIN #SnapshotDate [SS]#(lf)    ON [DFC].[dfcFiscalMonth] = [SS].[FiscalMonthYear]#(lf)   AND CONVERT(DATE, [DFC].[dfcSnapshot]) = CONVERT(DATE, [SS].[Snapshot Date])#(lf)-- AND [SS].[Periods] = @PeriodParam#(lf)#(lf)LEFT JOIN [SupplyChain_Enh].[ItemABCCode_AFI] AS [ABC]#(lf)    ON [DFC].[dfcItem] = [ABC].[Item SKU]#(lf)   AND [DFC].[dfcFiscalMonth] = [ABC].[SnapshotMonthYear]#(lf)   AND [ABC].[Warehouse Group] = 'AFI'#(lf)#(lf)LEFT JOIN (#(lf)    SELECT#(lf)        [dfcItem],#(lf)        [dfcFiscalMonth],#(lf)        [dfcPermComptQty],#(lf)        [dfcFCSTTypeCode],#(lf)        [dfcCustomergroups],#(lf)        [dfcMgmtCode],#(lf)        [SnapshotDate]#(lf)    FROM [SupplyChain_Enh].[DemandForecastSnapshotL3Daily]#(lf)) AS [DFC_L2]#(lf)    ON [DFC].[dfcItem] = [DFC_L2].[dfcItem]#(lf)   AND [DFC].[dfcCustomergroups] = [DFC_L2].[dfcCustomergroups]#(lf)   AND [DFC].[dfcFiscalMonth] = [DFC_L2].[dfcFiscalMonth]#(lf)   AND CONVERT(DATE, [DFC].[dfcSnapshot]) = CONVERT(DATE, [DFC_L2].[SnapshotDate])#(lf)#(lf)WHERE [DFC].[dfcWarehouse] NOT IN (#(lf)    '232', ' ', '10', '14', '18', '2', '21', '55', '6', '7', '8', '9',#(lf)    'C', 'CNW', 'C99', 'N/A', 'P', 'R', 'W', '101', '12', '151', '213'#(lf))#(lf)-- AND [DFC].[dfcCustomergroups] = @CCParam#(lf);#(lf)#(lf)------------------------------------------------------------#(lf)-- Create scaffold#(lf)-- [CustomerGroups], [Item SKU], [Warehouse] from Actual_Demand#(lf)------------------------------------------------------------#(lf)SELECT#(lf)    [D].[Customergroups] AS [Customer Group],#(lf)    [D].[Item] AS [Item SKU],#(lf)    [D].[Collective Class],#(lf)    [D].[Series Number],#(lf)    [D].[Current Status],#(lf)    [D].[Future Status],#(lf)    CASE#(lf)        WHEN (CONVERT(DATE, [S].[Snapshot Date]) < [D].[Initial Invoice Month])#(lf)             OR ([D].[Initial Invoice Month] IS NULL)#(lf)            THEN 0#(lf)        ELSE DATEDIFF(MONTH, [D].[Initial Invoice Month], CONVERT(DATE, [S].[Snapshot Date])) + 1#(lf)    END AS [Month Of Invoice At Snapshot],#(lf)    CASE#(lf)        WHEN [D].[Initial Invoice Month] IS NULL#(lf)            THEN 'Not invoiced'#(lf)        WHEN DATEDIFF(MONTH, [D].[Initial Invoice Month], CONVERT(DATE, [S].[Snapshot Date])) + 1 <= 6#(lf)            THEN 'Invoiced equal/less than 6m'#(lf)        ELSE 'Invoiced greater than 6m'#(lf)    END AS [Invoice Status],#(lf)    [D].[Warehouse] AS [AFI Warehouse Code],#(lf)    [S].[Month Name] AS [FiscalMonthYear],#(lf)    CONVERT(DATE, [S].[Snapshot Date]) AS [Snapshot Date],#(lf)    [S].[Periods] AS [Forecast Period]#(lf)INTO #Scaffold#(lf)FROM (#(lf)    SELECT DISTINCT#(lf)        [Customergroups],#(lf)        [Item],#(lf)        [CPD].[Collective Class] AS [Collective Class],#(lf)        [CPD].[Item Ext Series Number] AS [Series Number],#(lf)        [CPD].[AFI Item Status] AS [Current Status],#(lf)        [CPD].[Future Status],#(lf)        [CPD].[Initial Invoice Month],#(lf)        [Warehouse]#(lf)    FROM #Actual_Demand [DMD]#(lf)    LEFT JOIN (#(lf)        SELECT#(lf)            *,#(lf)            DATEFROMPARTS(RIGHT([CPD].[Initial Invoice Period], 4), LEFT([CPD].[Initial Invoice Period], 2), 1) AS [Initial Invoice Month]#(lf)        FROM [PowerBI_SupplyChain].[CurrentProductDetails] [CPD]#(lf)    ) [CPD]#(lf)        ON [DMD].[Item] = TRIM([CPD].[Item SKU])#(lf)) [D]#(lf)CROSS JOIN (#(lf)    SELECT DISTINCT#(lf)        [Month Name],#(lf)        [Snapshot Date],#(lf)        [Periods]#(lf)    FROM #SnapshotDate#(lf)) [S];#(lf)#(lf)------------------------------------------------------------#(lf)-- Join Demand + Forecast to scaffold and preserve snapshot logic#(lf)------------------------------------------------------------#(lf)SELECT *#(lf)INTO #Final_Table#(lf)FROM (#(lf)#(tab)SELECT#(lf)#(tab)#(tab)[Scf].[Forecast Period],#(lf)#(tab)#(tab)[Scf].[FiscalMonthYear],#(lf)#(tab)#(tab)[Scf].[Customer Group],#(lf)#(tab)#(tab)[Scf].[Collective Class],#(lf)#(tab)#(tab)[Scf].[Series Number],#(lf)#(tab)#(tab)[Scf].[Item SKU],#(lf)#(tab)#(tab)[Scf].[AFI Warehouse Code],#(lf)#(tab)#(tab)[Scf].[Current Status],#(lf)#(tab)#(tab)[Scf].[Future Status],#(lf)#(tab)#(tab)[Base].[Forecast Model],#(lf)#(tab)#(tab)[Base].[L2 Forecast Model],#(lf)#(tab)#(tab)[Base].[Fcst ABC],#(lf)#(tab)#(tab)[Base].[Fcst XYZ],#(lf)#(tab)#(tab)[Base].[Fcst ABC/XYZ],#(lf)#(tab)#(tab)[Base].[ForecastPriority],#(lf)#(tab)#(tab)ISNULL([Base].[Resultant Forecast], 0) [Resultant Forecast],#(lf)#(tab)#(tab)ISNULL([Base].[Promo Lift], 0) [Promo Lift],#(lf)#(tab)#(tab)ISNULL([Base].[Total 