"    SUM('Fact L1 Forecast'[RSLF]) * 100","    , MAX('Fact Seasonal Factor'[SEAS_FCTR])",")","VAR promo = SUM('Fact L1 Forecast'[Promo Lift]) ","VAR result = rslf + promo","","RETURN result"],"formatString":"#,0","lineageTag":"43b8edb5-5c4f-4978-9d5a-00db6c29764e"},{"name":"Total Seas Adj Cur Ord & Promo FCT","annotations":[{"name":"PBI_FormatHint","value":"{\"isDecimal\":true}"}],"displayFolder":"Actual Orders","expression":["","CALCULATE(","    [Total Seas Adj Cur Ord Qty]","    ,FILTER(","        'Dim Date'","        ,[FiscalMonthIndicator] < 0","    )",") + ","CALCULATE(","    [Seas Adj PROL-RSLF Qty]","    ,FILTER(","        'Dim Date'","        ,[FiscalMonthIndicator] >= 0","    )","    , 'Fact L1 Forecast'[Forecast Lag] = \"Lag 0\"",")"],"formatString":"#,0","lineageTag":"6ccbe9d5-d58f-4954-ac0b-3ca6f6f4231e"},{"name":"Current Rolling Avg","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"Actual Orders","expression":["","VAR max_date = CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] < 0)","","VAR period = DATESINPERIOD(","    'Dim Date'[FiscalMonthLastDate]","    ,max_date","    ,-91 * DIVIDE(SELECTEDVALUE('Parameter Average Period'[Period], 3), 3)","    // ,-91","    ,DAY",")","","VAR derived_with_smoothing = ","    CALCULATE(","        AVERAGEX(","            VALUES('Dim Date'[FiscalMonthLastDate])","            ,[Total Current Order Qty]","        )","        // ,ALL('Dim. Date'[FiscalMonthIndicator])","        // ,DimDate[FiscalMonthIndicator] < 0","        ,period","    )","","VAR derived_without_smoothing =","    CALCULATE(","        AVERAGEX(","            VALUES('Dim Date'[FiscalMonthLastDate])","            ,[Total Current Order Qty]","        )","        ,ALL('Dim Date'[FiscalMonthIndicator])","        // ,DimDate[FiscalMonthIndicator] < 0","    )","","VAR result = ","IF(","    ISBLANK(CALCULATE(MAX('Dim Date'[DateID]), 'Dim Date'[FiscalMonthIndicator] <= 0))","    ,[Total Current Order Qty]","    ,IF(COUNTROWS(period) = 0, derived_without_smoothing, derived_with_smoothing)",")","","RETURN result","// RETURN cur_month"],"lineageTag":"54de49a6-e6e1-483b-8c26-5ee9e7694a1b"},{"name":"Current Trend Line","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"Actual Orders","expression":["","var tbl =","FILTER(","    SELECTCOLUMNS(","        ALLSELECTED('Dim Date'[FiscalMonthLastDate])","        , \"Known X\", 'Dim Date'[FiscalMonthLastDate]","        , \"Known Y\", [Current Rolling Avg]","    ),","    AND (","         NOT ( ISBLANK([Known X]) )","        ,NOT ( ISBLANK([Known Y]) )","    )",")","var temp =","LINESTX(","    tbl, [Known Y], [Known X]",")","","var slope = SELECTCOLUMNS(temp, [Slope1])","var intercept = SELECTCOLUMNS(temp, [Intercept])","var x = MAX('Dim Date'[FiscalMonthLastDate])","","RETURN sumx(","    DISTINCT('Dim Date'[FiscalMonthLastDate])","    , intercept + slope * 'Dim Date'[FiscalMonthLastDate]",")"],"lineageTag":"c3df3214-5f5c-48ab-afa9-3116644f2aa2"},{"name":"Forecast Consumption","displayFolder":"Actual Orders","expression":["","CALCULATE(","    DIVIDE(","        [Cons%_FUTO]","        , [Working_Total_Forecast]","    )","    , 'Fact L1 Forecast'[Forecast Lag] = \"Lag 0\"",")"],"formatString":"0.0%;-0.0%;0.0%","lineageTag":"fc8eb2be-12ef-4379-baa6-bf9b05d080e8"},{"name":"FUTO","annotations":[{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"displayFolder":"Actual Orders","expression":["","CALCULATE(","    SUM('Fact L1 Forecast'[Future Order])","    , 'Fact L1 Forecast'[Forecast Lag] = \"Lag 0\"",")"],"lineageTag":"dd1afd66-0aa3-4a12-a602-fa13c1f426d2"},{"name":"Number of Weeks","displayFolder":"FC Consumption","expression":["","VAR snapshot_date = ","CALCULATE(","    MAX('Fact L1 Forecast'[Version Date])","    , 'Fact L1 Forecast'[Forecast Lag] = \"Lag 0\"",")","","VAR _fiscalmonthyear = ","CALCULATE(","    MAX('Dim Date'[FiscalMonthYear])","    , 'Dim Date'[DateID] = snapshot_date   ",")","","RETURN","CALCULATE(","    DISTINCTCOUNT('Dim Date'[FiscalWeek])","    , 'Dim Date'[FiscalMonthYear] = _fiscalmonthyear",")"],"formatString":"0","lineageTag":"bcefcb69-7dc9-41f6-9b79-e1e8d918b6ed"},{"name":"Day of Month","displayFolder":"FC Consumption","expression":["","VAR snapshot_date = ","CALCULATE(","    MAX('Fact L1 Forecast'[Version Date])","    , 'Fact L1 Forecast'[Forecast Lag] = \"Lag 0\"",")","","RETURN","CALCULATE(","    MAX('Dim Date'[FiscalDayOfMonth])","    , 'Dim Date'[DateID] = snapshot_date",")"],"formatString":"0","lineageTag":"56992bd7-0498-4a1b-b38c-d70118746167"},{"name":"Week of Month","displayFolder":"FC Consumption","expression":["","VAR snapshot_date = ","CALCULATE(","    MAX('Fact L1 Forecast'[Version Date])","    , 'Fact L1 Forecast'[Forecast Lag] = \"Lag 0\"",")","RETURN","CALCULATE(","    MAX('Dim Date'[FiscalWeekOfMonth])","    , 'Dim Date'[DateID] = snapshot_date",")"],"formatString":"0","lineageTag":"329cdca2-ff4d-4fc5-8e7d-0a9572932515"},{"name":"Goal Consumption CusCC","displayFolder":"FC Consumption","expression":["","","VAR _dayofmonth = [Day of Month]","VAR _numofweek = [Number of Weeks]","","VAR _collectiveclass = SELECTEDVALUE('Dim Collective Class'[Collective Class], \"CUSTOMER LEVEL\")","VAR _customergroup = SELECTEDVALUE('Dim  Customer Group'[Customer Group], \"COMPANY LEVEL\")","","VAR result = ","CALCULATE(","    MAX('Fact Goal Consumption CusCC'[Goal Consumption])","    , FILTER(","        'Fact Goal Consumption CusCC'","        , ('Fact Goal Consumption CusCC'[Day of Month] = _dayofmonth) && ","        ('Fact Goal Consumption CusCC'[Weeks in Month] = _numofweek) &&","        ('Fact Goal Consumption CusCC'[Customer Group] = _customergroup) &&","        ('Fact Goal Consumption CusCC'[Collective Class] = _collectiveclass)","    )",")","","RETURN result"],"formatString":"0.0%;-0.0%;0.0%","lineageTag":"7ca46a67-0e52-4b9b-99be-dfddaa35dd06"},{"name":"Test","expression":["","VAR _dayofmonth = [Day of Month]","VAR _numofweek = [Number of Weeks]","","VAR _collectiveclass = SELECTEDVALUE('Dim Collective Class'[Collective Class], \"CUSTOMER LEVEL\")","VAR _customergroup = SELECTEDVALUE('Dim  Customer Group'[Customer Group], \"COMPANY LEVEL\")","","VAR result = ","CALCULATE(","    MAX('Fact Goal Consumption CusCC'[Goal Consumption])","    , FILTER(","        'Fact Goal Consumption CusCC'","        , ('Fact Goal Consumption CusCC'[Day of Month] = _dayofmonth) && ","        ('Fact Goal Consumption CusCC'[Weeks in Month] = _numofweek) &&","        ('Fact Goal Consumption CusCC'[Customer Group] = _customergroup) &&","        ('Fact Goal Consumption CusCC'[Collective Class] = _collectiveclass)","    )",")","","RETURN _collectiveclass"],"lineageTag":"59490905-5164-4e0e-b65f-ff23cb002c60"},{"name":"Goal Consumption CusWH","displayFolder":"FC Consumption","expression":["","","VAR _dayofmonth = [Day of Month]","VAR _numofweek = [Number of Weeks]","","VAR _collectiveclass = SELECTEDVALUE('Dim Collective Class'[Collective Class], \"CUSTOMER LEVEL\")","VAR _customergroup = SELECTEDVALUE('Dim  Customer Group'[Customer Group], \"COMPANY LEVEL\")","","VAR result = ","CALCULATE(","    MAX('Fact Goal Consumption CusWH'[Goal Consumption])","    , FILTER(","        'Fact Goal Consumption CusWH'","        , ('Fact Goal Consumption CusWH'[Day of Month] = _dayofmonth) && ","        ('Fact Goal Consumption CusWH'[Weeks in Month] = _numofweek) &&","        ('Fact Goal Consumption CusWH'[Customer Group] = _customergroup) &&","        ('Fact Goal Consumption CusWH'[Collective Class] = _collectiveclass)","    )",")","","RETURN result"],"formatString":"0.0%;-0.0%;0.0%","lineageTag":"96ee0cb3-a019-4127-bb77-5c12a6dcd666"},{"name":"Goal Consumption","displayFolder":"FC Consumption","expression":["","VAR _warehouseSelected = HASONEVALUE('Dim Warehouse'[Warehouse Code])","","VAR result = ","    IF(","        _warehouseSelected,","        [Goal Consumption CusWH],","        [Goal Consumption CusCC]