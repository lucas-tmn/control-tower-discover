ary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0#(lf)             AND CAST(CASE WHEN [MaxDemand]=0  THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.05  AND [MaxDemand]>0 THEN 'Customer behaviour'#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0 THEN 'Not defined'#(lf)            ELSE ''#(lf)        END AS [Imbalance reason]#(lf)    FROM DC_SS_MAX#(lf)),#(lf)#(lf)-- ----------------------------------------------------------------#(lf)-- SEGMENT 7: DINING | WAREHOUSE | FORECAST  (threshold: 0.05)#(lf)-- ----------------------------------------------------------------#(lf)DW_FC_ACTIVE AS (#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_FC_WH#(lf)    UNION#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_DEMAND_WH#(lf)),#(lf)DW_FC_MAPPED AS (#(lf)    SELECT DISTINCT A.[Warehouse], D.[Comparison Type], D.[Series Number], D.[Bed Size]#(lf)    FROM DW_FC_ACTIVE A INNER JOIN FILTERED_DIN D ON A.[Item SKU]=D.[Item SKU]#(lf)),#(lf)DW_FC_GRID AS (#(lf)    SELECT AM.[Warehouse],UC.[Collective Class],UC.[Comparison Type],AM.[Series Number],AM.[Bed Size],UC.[Component Type]#(lf)    FROM DW_FC_MAPPED AM#(lf)    INNER JOIN (SELECT DISTINCT [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type] FROM FILTERED_DIN) UC#(lf)        ON AM.[Comparison Type]=UC.[Comparison Type] AND AM.[Series Number]=UC.[Series Number] AND AM.[Bed Size]=UC.[Bed Size]#(lf)),#(lf)DW_FC_AGG AS (#(lf)    SELECT F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[Forecast]) AS [PrimaryVal]#(lf)    FROM FACT_FC_WH F INNER JOIN FILTERED_DIN D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)DW_FC_DAGG AS (#(lf)    SELECT F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[