HEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4)) AS [Imbalance Ratio by Demand],#(lf)        CASE WHEN [MaxDemand]>0 AND CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.05 THEN 'Imbalance' ELSE '' END AS [Imbalance by Demand],#(lf)        CAST((CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) - CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))) AS DECIMAL(18,4)) AS [Ratio Difference],#(lf)        CASE#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0#(lf)             AND CAST(CASE WHEN [MaxDemand]=0  THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.05  AND [MaxDemand]>0 THEN 'Customer behaviour'#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0 THEN 'Not defined'#(lf)            ELSE ''#(lf)        END AS [Imbalance reason]#(lf)    FROM DW_FC_MAX#(lf)),#(lf)#(lf)-- ----------------------------------------------------------------#(lf)-- SEGMENT 8: DINING | WAREHOUSE | SAFETY STOCK  (threshold: 0.05)#(lf)-- ----------------------------------------------------------------#(lf)DW_SS_ACTIVE AS (#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_SS_WH#(lf)    UNION#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_DEMAND_WH#(lf)),#(lf)DW_SS_MAPPED AS (#(lf)    SELECT DISTINCT A.[Warehouse], D.[Comparison Type], D.[Series Number], D.[Bed Size]#(lf)    FROM DW_SS_ACTIVE A INNER JOIN FILTERED_DIN D ON A.[Item SKU]=D.[Item SKU]#(lf)),#(lf)DW_SS_GRID AS (#(lf)    SELECT AM.[Warehouse],UC.[Collective Class],UC.[Comparison Type],AM.[Series Number],AM.[Bed Size],UC.[Component Type]#(lf)    FROM DW_SS_MAPPED AM#(lf)    INNER JOIN (SELECT DISTINCT [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type] FROM FILTERED_DIN) UC#(lf)        ON AM.[Comparison Type]=UC.[Comparison Type] AND AM.[Series Number]=UC.[Series Number] AND AM.[Bed Size]=UC.[Bed Size]#(lf)),#(lf)DW_SS_AGG AS (#(lf)    SELECT F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[Avg_Safety_Stock]) AS [PrimaryVal]#(lf)    FROM FACT_SS_WH F INNER JOIN FILTERED_DIN D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)DW_SS_DAGG AS (#(lf)    SELECT F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[L12M ACTD]) AS [L12M ACTD]#(lf)    FROM FACT_DEMAND_WH F INNER JOIN FILTERED_DIN D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)DW_SS_DATA AS (#(lf)    SELECT G.*, ISNULL(A.[PrimaryVal],0) AS [PrimaryVal], ISNULL(D.[L12M ACTD],0) AS [L12M ACTD]#(lf)    FROM DW_SS_GRID G#(lf)    LEFT JOIN DW_SS_AGG  A ON G.[Warehouse]=A.[Warehouse] AND G.[Comparison Type]=A.[Comparison Type] AND G.[Series Number]=A.[Series Number] AND G.[Bed Size]=A.[Bed Size] AND G.[Component Type]=A.[Component Type]#(lf)    LEFT JOIN DW_SS_DAGG D ON G.[Warehouse]=D.[Warehouse] AND G.[Comparison Type]=D.[Comparison Type] AND G.[Series Number]=D.[Series Number] AND G.[Bed Size]=D.[Bed Size] AND G.[Component Type]=D.[Component Type]#(lf)),#(lf)DW_SS_MAX AS (#(lf)    SELECT *,#(lf)        MAX([PrimaryVal]) OVER (PARTITION BY [Warehouse],[Comparison Type],[Series Number],[Bed Size]) AS [MaxPrimary],#(lf)        MAX([L12M ACTD])  OVER (PARTITION BY [Warehouse],[Comparison Type],[Series Number],[Bed Size]) AS [MaxDemand]#(lf)    FROM DW_SS_DATA#(lf)),#(lf)DW_SS_OUT AS (#(lf)    SELECT#(lf)        'Warehouse' AS [Level], 'Safety Stock' AS [Metric], [Warehouse],#(lf)        [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type],#(lf)        NULL AS [Forecast], NULL AS [Max Forecast], NULL AS [Imbalance Ratio by FC], NULL AS [Imbalance by FC],#(lf)        [PrimaryVal] AS [Safety Stock], [MaxPrimary] AS [Max Safety Stock],#(lf)        CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) AS [Imbalance Ratio by SS],#(lf)        CASE WHEN [MaxPrimary]>0 AND CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 THEN 'Imbalance' ELSE '' END AS [Imbalance by SS],#(lf)        [L12M ACTD], [MaxDemand] AS [Max Demand],#(lf)        CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4)) AS [Imbalance Ratio by Demand],#(lf)        CASE WHEN [MaxDemand]>0 AND CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.05 THEN 'Imbalance' ELSE '' END AS [Imbalance by Demand],#(lf)        CAST((CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) - CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))) AS DECIMAL(18,4)) AS [Ratio Difference],#(lf)        CASE#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0#(lf)             AND CAST(CASE WHEN [MaxDemand]=0  THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.05  AND [MaxDemand]>0 THEN 'Customer behaviour'#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0 THEN 'Not defined'#(lf)            ELSE ''#(lf)        END AS [Imbalance reason]#(lf)    FROM DW_SS_MAX#(lf))#(lf)#(lf)-- ================================================================#(lf)--