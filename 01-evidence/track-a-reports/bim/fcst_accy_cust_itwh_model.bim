            "annotations": [
              {
                "name": "GroupingDesignState",
                "value": "{\"Version\":0,\"Sources\":[{\"Name\":\"c\",\"Entity\":\"CustItWHAccy\"}],\"GroupedColumns\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"c\"}},\"Property\":\"ForecastPeriod\"}}],\"GroupItems\":[{\"DisplayName\":\"(Blank)\",\"BlankDefaultPlaceholder\":true},{\"DisplayName\":\"___90Days\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"c\"}},\"Property\":\"ForecastPeriod\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'90Days'\"}}]]}}},{\"DisplayName\":\"__60Days\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"c\"}},\"Property\":\"ForecastPeriod\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'60Days'\"}}]]}}},{\"DisplayName\":\"_30Days\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"c\"}},\"Property\":\"ForecastPeriod\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'30Days'\"}}]]}}},{\"DisplayName\":\"2Week\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"c\"}},\"Property\":\"ForecastPeriod\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'2Week'\"}}]]}}}]}"
              },
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "SWITCH(",
              "\tTRUE,",
              "\tISBLANK('CustItWHAccy'[ForecastPeriod]),",
              "\t\"(Blank)\",",
              "\t'CustItWHAccy'[ForecastPeriod] IN {\"90Days\"},",
              "\t\"___90Days\",",
              "\t'CustItWHAccy'[ForecastPeriod] IN {\"60Days\"},",
              "\t\"__60Days\",",
              "\t'CustItWHAccy'[ForecastPeriod] IN {\"30Days\"},",
              "\t\"_30Days\",",
              "\t'CustItWHAccy'[ForecastPeriod] IN {\"2Week\"},",
              "\t\"2Week\",",
