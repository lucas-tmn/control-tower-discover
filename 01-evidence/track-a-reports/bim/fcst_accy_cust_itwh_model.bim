            "expression": [
              "switch(TRUE()",
              "                            ,RIGHT(z_ProductDetails[Collective Class],3) = \"RTA\",\"RTA & METAL BEDS\"",
              "                            ,z_ProductDetails[Collective Class] = \"METAL BEDS\",\"RTA & METAL BEDS\",z_ProductDetails[Collective Class] = \"BEDROOM\",\"CASEGOODS\"",
