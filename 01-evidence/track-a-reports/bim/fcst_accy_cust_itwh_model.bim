        "lineageTag": "e8a656a6-bbbe-48e3-8526-8a688f894838",
        "partitions": [
          {
            "name": "PlannerAssignment",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = SharePoint.Tables(\"https://masterashley.sharepoint.com/sites/supplychain-DemandPlanning\", [ApiVersion = 15]),",
                "    #\"531a515e-a80c-46ba-be53-5a789f7b2b5f\" = Source{[Id=\"531a515e-a80c-46ba-be53-5a789f7b2b5f\"]}[Items],",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"531a515e-a80c-46ba-be53-5a789f7b2b5f\",{{\"ID\", \"ID.1\"}}),",
                "    #\"Removed Other Columns\" = Table.SelectColumns(#\"Renamed Columns\",{\"Id\", \"CollectiveClass\", \"LifeCyclePlannerId\", \"CustomerGroup0\", \"ForecastAnalyst0Id\", \"CategoryAnalystId\", \"CustDemandPlannerId\", \"Modified\"}),",
                "    #\"Inserted Merged Column\" = Table.AddColumn(#\"Removed Other Columns\", \"CustGrp-CC\", each Text.Combine({[CustomerGroup0], [CollectiveClass]}, \"-\"), type text),",
                "    #\"Merged Queries\" = Table.NestedJoin(#\"Inserted Merged Column\", {\"LifeCyclePlannerId\"}, Users, {\"Id\"}, \"Life Cycle Planner\", JoinKind.LeftOuter),",
                "    #\"Merged Queries1\" = Table.NestedJoin(#\"Merged Queries\", {\"ForecastAnalyst0Id\"}, Users, {\"Id\"}, \"FC Analyst\", JoinKind.LeftOuter),",
                "    #\"Merged Queries2\" = Table.NestedJoin(#\"Merged Queries1\", {\"CategoryAnalystId\"}, Users, {\"Id\"}, \"Category Analyst\", JoinKind.LeftOuter),",
                "    #\"Merged Queries3\" = Table.NestedJoin(#\"Merged Queries2\", {\"CustDemandPlannerId\"}, Users, {\"Id\"}, \"Customer Demand Planner\", JoinKind.LeftOuter),",
                "    #\"Expanded FC Analyst\" = Table.ExpandTableColumn(#\"Merged Queries3\", \"FC Analyst\", {\"PlannerName\"}, {\"FC Analyst.PlannerName\"}),",
                "    #\"Expanded Category Analyst\" = Table.ExpandTableColumn(#\"Expanded FC Analyst\", \"Category Analyst\", {\"PlannerName\"}, {\"Category Analyst.PlannerName\"}),",
                "    #\"Expanded Customer Demand Planner\" = Table.ExpandTableColumn(#\"Expanded Category Analyst\", \"Customer Demand Planner\", {\"PlannerName\"}, {\"Customer Demand Planner.PlannerName\"}),",
                "    #\"Expanded Life Cycle Planner\" = Table.ExpandTableColumn(#\"Expanded Customer Demand Planner\", \"Life Cycle Planner\", {\"PlannerName\"}, {\"Life Cycle Planner.PlannerName\"}),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Expanded Life Cycle Planner\",{{\"FC Analyst.PlannerName\", \"FC Analyst\"}, {\"Customer Demand Planner.PlannerName\", \"Cust Demand Planner\"}, {\"Category Analyst.PlannerName\", \"Category Analyst\"}, {\"Life Cycle Planner.PlannerName\", \"Life Cycle Planner\"}, {\"CustomerGroup0\", \"CustomerGroup\"}})",
                "in",
                "    #\"Renamed Columns1\""
              ],
              "type": "m"
            }
          }
        ]
      },
