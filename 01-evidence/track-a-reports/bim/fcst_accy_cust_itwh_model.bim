        "lineageTag": "232081fb-e99f-43d6-9213-20fa7feb86cb",
        "partitions": [
          {
            "name": "CustItWHAccy",
            "mode": "import",
            "source": {
              "expression": [
                "// SQL Query Template",
                "",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\",",
                "                [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "",
                "",
                "with ForecastTimePeriods as(SELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '2Week'",
                "\t\t\t\t\t\t,[SortFcstPer] = 14",
                "\t\t\t\t\t\t,CASE WHEN dateadd(day,15,lag2wk.[FiscalMonthFirstDate]) = '11/10/2025' -- add Nov cycle deviation",
                "\t\t\t\t\t\t    THEN '11/12/2025'",
                "\t\t\t\t\t\tWHEN dateadd(day,15,lag2wk.[FiscalMonthFirstDate]) = '12/08/2025' -- add Dec cycle deviation",
                "\t\t\t\t\t\t    THEN '12/16/2025'",
                "\t\t\t\t\t\t\twhen lag2wk.[FiscalMonthFirstDate] = '12/28/2025' then '1/15/2026' -- add Jan cycle deviation",
                "\t\t\t\t\t\t\twhen lag2wk.[FiscalMonthFirstDate] = '01/25/2025' then '2/16/2026' -- add Feb cycle deviation",
                "      when  lag2wk.[FiscalMonthFirstDate] = '3/28/2026' then '3/16/2026'",
                "      when  lag2wk.[FiscalMonthFirstDate] = '3/29/2026' then '4/20/2026'",
                "      when  lag2wk.[FiscalMonthFirstDate] = '4/26/2026' then '5/16/2026'",
                "      when  lag2wk.[FiscalMonthFirstDate] = '5/24/2026' then '6/15/2026'",
                "\t\t\t\t\t\t\tELSE dateadd(day,15,lag2wk.[FiscalMonthFirstDate]) --default 3rd Monday as forecast cycle",
                "\t\t\t\t\tEND  as [SnapshotDate]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -24 and 0",
                "\t\t\t\t\t\t\t\t\t)lag2wk",
                "\t\t\t\t\t\ton lag2wk.[FiscalMonthIndicator]+0 = dd.[FiscalMonthIndicator]",
                "",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1",
                "",
                "\t\t\t\t\tUNION",
                "",
                "\t\t\t\t\tSELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '30Days'",
                "\t\t\t\t\t\t,[SortFcstPer] = 30",
                "\t\t\t\t\t\t,CASE WHEN dateadd(day,15,lag30d.[FiscalMonthFirstDate]) = '11/10/2025' -- add Nov cycle deviation",
                "\t\t\t\t\t\t    THEN '11/12/2025'",
                "\t\t\t\t\t\tWHEN dateadd(day,15,lag30d.[FiscalMonthFirstDate]) = '12/08/2025' -- add Dec cycle deviation",
                "\t\t\t\t\t\t    THEN '12/16/2025'",
                "\t\t\t\t\t\t\twhen lag30d.[FiscalMonthFirstDate] = '12/28/2025' then '1/15/2026' -- add Jan cycle deviation",
                "\t\t\t\t\t\t\twhen lag30d.[FiscalMonthFirstDate] = '01/25/2025' then '2/16/2026' -- add Feb cycle deviation",
                "      when  lag30d.[FiscalMonthFirstDate] = '3/28/2026' then '3/16/2026'",
                "      when  lag30d.[FiscalMonthFirstDate] = '3/29/2026' then '4/20/2026'",
                "      when  lag30d.[FiscalMonthFirstDate] = '4/26/2026' then '5/16/2026'",
                "      when  lag30d.[FiscalMonthFirstDate] = '5/24/2026' then '6/15/2026'",
                "\t\t\t\t\t\t\tELSE dateadd(day,15,lag30d.[FiscalMonthFirstDate]) --default 3rd Monday as forecast cycle",
                "\t\t\t\t\tEND   as [30Days]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -25 and -1",
                "\t\t\t\t\t\t\t\t\t)lag30d",
                "\t\t\t\t\t\ton lag30d.[FiscalMonthIndicator]+1 = dd.[FiscalMonthIndicator]",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1",
                "",
                "\t\t\t\t\tUNION",
                "",
                "\t\t\t\t\tSELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '60Days'",
                "\t\t\t\t\t\t,[SortFcstPer] = 60",
                "\t\t\t\t\t\t,CASE WHEN dateadd(day,15,lag60d.[FiscalMonthFirstDate]) = '11/10/2025' -- add Nov cycle deviation",
                "\t\t\t\t\t\t    THEN '11/12/2025'",
                "\t\t\t\t\t\tWHEN dateadd(day,15,lag60d.[FiscalMonthFirstDate]) = '12/08/2025' -- add Dec cycle deviation",
                "\t\t\t\t\t\t    THEN '12/16/2025'",
                "\t\t\t\t\t\t\twhen lag60d.[FiscalMonthFirstDate] = '12/28/2025' then '1/15/2026' -- add Jan cycle deviation",
                "\t\t\t\t\t\t\twhen lag60d.[FiscalMonthFirstDate] = '01/25/2025' then '2/16/2026' -- add Feb cycle deviation",
                "      when  lag60d.[FiscalMonthFirstDate] = '3/28/2026' then '3/16/2026'",
                "      when  lag60d.[FiscalMonthFirstDate] = '3/29/2026' then '4/20/2026'",
                "      when  lag60d.[FiscalMonthFirstDate] = '4/26/2026' then '5/16/2026'",
                "      when  lag60d.[FiscalMonthFirstDate] = '5/24/2026' then '6/15/2026'",
                "\t\t\t\t\t\t\tELSE dateadd(day,15,lag60d.[FiscalMonthFirstDate]) --default 3rd Monday as forecast cycle",
                "\t\t\t\t\tEND  as [60Days]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -26 and -2",
                "\t\t\t\t\t\t\t\t\t)lag60d",
                "\t\t\t\t\t\ton lag60d.[FiscalMonthIndicator]+2 = dd.[FiscalMonthIndicator]",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1",
                "",
                "\t\t\t\t\tUNION",
                "",
                "\t\t\t\t\tSELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '90Days'",
                "\t\t\t\t\t\t,[SortFcstPer] = 90",
                "\t\t\t\t\t\t,CASE WHEN dateadd(day,15,lag90d.[FiscalMonthFirstDate]) = '11/10/2025' -- add Nov cycle deviation",
                "\t\t\t\t\t\t    THEN '11/12/2025'",
                "\t\t\t\t\t\tWHEN dateadd(day,15,lag90d.[FiscalMonthFirstDate]) = '12/08/2025' -- add Dec cycle deviation",
                "\t\t\t\t\t\t    THEN '12/16/2025'",
                "\t\t\t\t\t\t\twhen lag90d.[FiscalMonthFirstDate] = '12/28/2025' then '1/15/2026' -- add Jan cycle deviation",
                "\t\t\t\t\t\t\twhen lag90d.[FiscalMonthFirstDate] = '01/25/2025' then '2/16/2026' -- add Feb cycle deviation",
                "      when  lag90d.[FiscalMonthFirstDate] = '3/28/2026' then '3/16/2026'",
                "      when  lag90d.[FiscalMonthFirstDate] = '3/29/2026' then '4/20/2026'",
                "      when  lag90d.[FiscalMonthFirstDate] = '4/26/2026' then '5/16/2026'",
                "      when  lag90d.[FiscalMonthFirstDate] = '5/24/2026' then '6/15/2026'",
                "\t\t\t\t\t\t\tELSE dateadd(day,15,lag90d.[FiscalMonthFirstDate]) --default 3rd Monday as forecast cycle",
                "\t\t\t\t\tEND   as [90Days]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -27 and -3",
                "\t\t\t\t\t\t\t\t\t)lag90d",
                "\t\t\t\t\t\ton lag90d.[FiscalMonthIndicator]+3 = dd.[FiscalMonthIndicator]",
                "",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1  )",
                "",
                "SELECT [vFC].[Item SKU]",
                "\t\t\t  ,[vFC].[Warehouse]",
                "\t\t\t  ,[vFC].[Customer Group]",
                "\t\t\t  ,[vFC].[FiscalMonthYear]",
                "\t\t\t  ,[vFC].[FiscalMonthLastDate]",
                "\t\t\t  ,[vFC].[SortFcstPer]",
                "\t\t\t  ,[vFC].[ForecastPeriod]",
                "\t\t\t  ,[vFC].[Total Forecast]",
                "\t\t\t  ,ISNULL([vFC].[Actual Demand],0) AS [Actual Demand]",
                "\t\t\t  ,ISNULL([vFC].[NaiveFcst],0) AS [NaiveFcst]",
                "\t\t\t  ,[vFC].[Snapshot Date] ",
                "",
                "-----------------------------------------------------------",
                "---------value add FC = Monday Week 3 Snapshots------------",
                "------------------------------------------------------------",
                "FROM(",
                "------------------------------------------------------------",
                "--Post March 2025 Snapshots = Cust Item Warehouse Accuracy--",
                "------------------------------------------------------------",
                "\t\tSELECT isnull([FC].[Item SKU],[ACT].[Item]) as [Item SKU]",
                "\t\t\t  ,isnull([FC].[Warehouse], [ACT].[Location]) as [Warehouse]",
                "\t\t\t  ,isnull([FC].[Customer Group], [Act].[CustomerGroups]) as [Customer Group]",
                "\t\t\t  ,isnull([FC].[FiscalMonthYear], [Act].[Year Period]) as [FiscalMonthYear]",
                "\t\t\t  ,isnull([FC].[FiscalMonthLastDate], [Act].[FiscalMonthLastDate]) as [FiscalMonthLastDate]",
                "\t\t\t  ,isnull([FC].[SortFcstPer], [Act].[SortFcstPer]) as [SortFcstPer]",
                "\t\t\t  ,isnull([FC].[ForecastPeriod],[Act].[ForecastPeriod]) as [ForecastPeriod]",
                "\t\t\t  ,isnull([FC].[Total Forecast],0) as [Total Forecast]",
                "\t\t\t  ,ISNULL([ACT].[Actual Demand],0) AS [Actual Demand]",
                "\t\t\t  ,ISNULL([NF].[NaiveFcst],0) AS [NaiveFcst]",
                "\t\t\t  ,isnull([FC].[Snapshot Date],[ACT].[SnapshotDate]) as [Snapshot Date]",
                "",
                "\t\t\t  ",
                "",
                "",
                "\t\t  FROM (",
                "",
                "\t\tSELECT [DFC].[dfcItem] AS [Item SKU]",
                "\t\t\t  ,[DFC].[dfcWarehouse] AS [Warehouse]",
                "\t\t\t  ,[DFC].[dfcCustomerGroups] AS [Customer Group]",
                "\t\t\t  ,[DFC].[dfcFiscalMonth] AS [FiscalMonthYear]",
                "\t\t\t  ,[FTP].[FiscalMonthLastDate]",
                "\t\t\t  ,[FTP].[SortFcstPer]",
                "\t\t\t  ,[FTP].[ForecastPeriod]",
                "\t\t\t  ,SUM([DFC].[dfcResultantForecast] + [DFC].[dfcPromotionalLift]) AS [Total Forecast]",
                "\t\t\t  ,CONVERT(DATE, [DFC].[dfcSnapshot]) AS [Snapshot Date]",
                "\t\t  FROM [SupplyChain_Enh].[DemandForecastSnapshot] AS DFC",
                "\t\t  INNER JOIN ForecastTimePeriods AS FTP",
                "\t\t  ON [DFC].[dfcFiscalMonth] = [FTP].[FiscalMonthYear]",
                "\t\t\tAND [DFC].[dfcSnapshot] = [FTP].[SnapshotDate]",
                "",
                "\t\t   GROUP BY [DFC].[dfcItem]",
                "\t\t\t\t   ,[DFC].[dfcWarehouse]",
                "\t\t\t\t   ,[DFC].[dfcCustomerGroups]",
                "\t\t\t\t   ,[DFC].[dfcFiscalMonth]",
                "\t\t\t\t   ,[FTP].[FiscalMonthLastDate]",
                "\t\t\t\t   ,[FTP].[ForecastPeriod]",
                "\t\t\t\t   ,[FTP].[SortFcstPer]",
                "\t\t\t\t   ,[DFC].[dfcSnapshot]",
                "\t\t\t) AS FC",
                "",
                "\t\t\tfull OUTER JOIN (",
                "\t\t",
                "\tSELECT [IAD].[Item]",
                "\t\t\t  ,[IAD].[Location]",
                "\t\t\t\t  ,[IAD].[CustomerGroups]",
                "\t\t\t  ,FORMAT([IAD].[Year Period],'yyyyMM') AS [Year Period]",
                "\t\t\t  ,dd_act.[FiscalMonthLastDate]",
                "\t\t\t  ,SUM([IAD].[Actual demand]) AS [Actual Demand]",
                "\t\t\t  ,FTP.[ForecastPeriod]",
                "\t\t\t  ,FTP.[SortFcstPer]",
                "\t\t\t  ,FTP.[SnapshotDate]",
                "\t\t  FROM [SupplyChain_Enh].[ItemActualDemand_Logility] AS IAD",
                "\t\t   INNER JOIN (SELECT DISTINCT [FiscalMonthYear],[FiscalMonthIndicator], [FiscalMonthLastDate]",
                "\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -12 and -1",
                "\t\t\t\t\t\t\t)dd_act",
                "\t\t\t\ton dd_act.[FiscalMonthYear] = FORMAT([IAD].[Year Period],'yyyyMM')",
                "\t\t\tINNER JOIN ForecastTimePeriods AS FTP",
                "\t\t\t\ton FTP.[FiscalMonthLastDate] = dd_act.[FiscalMonthLastDate]",
                "\t\t  WHERE [IAD].[Company] = 'AFI'",
                "\t\t\t",
                "\t\t  GROUP BY [IAD].[Item]",
                "\t\t\t\t  ,[IAD].[Location]",
                "\t\t\t\t  ,[IAD].[Year Period]",
                "\t\t\t\t  ,[IAD].[CustomerGroups]",
                "\t\t\t  ,dd_act.[FiscalMonthLastDate]",
                "\t\t\t  ,FTP.[ForecastPeriod]",
                "\t\t\t  ,FTP.[SortFcstPer]",
                "\t\t\t  ,FTP.[SnapshotDate]",
                "\t\t\t) AS ACT",
                "\t\t\tON [FC].[Item SKU] = [ACT].[Item]",
                "\t\t\t  AND [FC].[Warehouse] = [ACT].[Location]",
                "\t\t\t  AND [FC].[FiscalMonthYear] = [ACT].[Year Period]\t  ",
                "\t\t\t  AND [FC].[Customer Group] = [ACT].[CustomerGroups]",
                "\t\t\t  and [FC].[ForecastPeriod] = [ACT].[ForecastPeriod]",
                "",
                "\t\tLEFT JOIN (",
                "\t\tSELECT [N].[Item SKU] AS [Item SKU]",
                "\t\t\t  ,[N].[Warehouse] AS [Warehouse]",
                "\t\t\t  ,[N].[Customer Group]",
                "\t\t\t  ,[D2].[FiscalMonthYear]",
                "\t\t\t  ,CAST([N].[Qty] * [D2].[NumWeeks] AS INT) AS [NaiveFcst]",
                "\t\t  FROM (",
                "\t\tSELECT [ACT].[Item SKU]",
                "\t\t\t  ,[ACT].[Warehouse]",
                "\t\t\t  ,[CUS].[Customer Group]",
                "\t\t\t  ,[DD].[FiscalMonthIndicator]",
                "\t\t\t  ,[D2].[FiscalMonthYear]",
                "\t\t\t  ,SUM([ACT].[Order Quantity])/[D2].[NumWeeks] AS [Qty]",
                "",
                "\t\t  FROM [SupplyChain_Enh].[ActualsCustItemWH_AFI] AS ACT",
                "\t\t  LEFT JOIN [Enterprise_DW].[DimDate] AS DD",
                "\t\t\tON [ACT].[CurReqWkEnding] = [DD].[DateID]",
                "\t\t  LEFT JOIN [PowerBI_SupplyChain].[CustomerAcctMaster_AFI] AS CUS",
                "\t\t    ON [ACT].[Account And ShipTo Number] = [CUS].[Account And ShipTo Number]",
                "\t\t  INNER JOIN (",
                "\t\tSELECT [FiscalMonthYear]",
                "\t\t\t  ,[FiscalMonthLastDate]",
                "\t\t\t  ,COUNT(DISTINCT [FiscalWeekLastDate]) AS [NumWeeks]",
                "\t\t  FROM [Enterprise_DW].[DimDate]",
                "\t\t  WHERE [FiscalMonthIndicator] >= -12",
                "\t\t  GROUP BY [FiscalMonthYear]",
                "\t\t\t\t  ,[FiscalMonthLastDate]",
                "\t\t  ) AS D2 ",
                "\t\t  ON [DD].[FiscalMonthLastDate] = [D2].[FiscalMonthLastDate]",
                "  ",
                "\t\t  WHERE [ACT].[Warehouse] NOT IN ('C','CNW','C35','55')",
                "",
                "",
                "\t\tGROUP BY [ACT].[Item SKU]",
                "\t\t\t\t,[ACT].[Warehouse]",
                "\t\t\t\t,[CUS].[Customer Group]",
                "\t\t\t\t,[DD].[FiscalMonthIndicator]",
                "\t\t\t\t,[D2].[NumWeeks]",
                "\t\t\t\t,[D2].[FiscalMonthYear]",
                "",
                "\t\t\t) AS N",
                "\t\t  INNER JOIN (",
                "\t\tSELECT [FiscalMonthYear]",
                "\t\t\t  ,[FiscalMonthLastDate]",
                "\t\t\t  ,[FiscalMonthIndicator]",
                "\t\t\t  ,COUNT(DISTINCT [FiscalWeekLastDate]) AS [NumWeeks]",
                "\t\t  FROM [Enterprise_DW].[DimDate]",
                "\t\t  WHERE [FiscalMonthIndicator] < 0",
                "\t\t  and [FiscalMonthIndicator] >= -13",
                "\t\t  GROUP BY [FiscalMonthYear]",
                "\t\t\t\t  ,[FiscalMonthLastDate]",
                "\t\t\t\t  ,[FiscalMonthIndicator]",
                "\t\t  ) AS D2",
                "\t\t  ON ([N].[FiscalMonthIndicator]+1) = [D2].[FiscalMonthIndicator]",
                "",
                "",
                "\t\t) AS NF",
                "\t\t  ON [FC].[Item SKU] = [NF].[Item SKU]",
                "\t\t   AND [FC].[Warehouse] = [NF].[Warehouse]",
                "\t\t   AND [FC].[FiscalMonthYear] = [NF].[FiscalMonthYear]",
                "\t\t   and [FC].[Customer Group] = [NF].[Customer Group] ",
                "\t\t  ",
                "\t\t  WHERE (isnull([FC].[Total Forecast],0) > 0 OR ISNULL([ACT].[Actual Demand], 0) > 0)",
                "\t\t\tAND isnull([FC].[FiscalMonthLastDate],[ACT].[FiscalMonthLastDate]) < GETDATE()",
                "\t\t\tAND isnull([FC].[Snapshot Date],[Act].[SnapshotDate]) >= '3/15/2025'",
                "\t\tUNION",
                "",
                "------------------------------------------------------",
                "--Pre March 2025 Snapshots = Item Warehouse Accuracy--",
                "------------------------------------------------------",
                "",
                "\t\tSELECT [FC].[Item SKU]",
                "\t\t\t  ,[FC].[Warehouse]",
                "\t\t\t  ,'AFICONS' as [Customer Group]",
                "\t\t\t  ,[FC].[FiscalMonthYear]",
                "\t\t\t  ,[FC].[FiscalMonthLastDate]",
                "\t\t\t  ,[FC].[SortFcstPer]",
                "\t\t\t  ,[FC].[ForecastPeriod]",
                "\t\t\t  ,[FC].[Total Forecast]",
                "\t\t\t  ,ISNULL([ACT].[Actual Demand],0) AS [Actual Demand]",
                "\t\t\t  ,ISNULL([NF].[NaiveFcst],0) AS [NaiveFcst]",
                "\t\t\t  ,[FC].[Snapshot Date] ",
                "\t\t  FROM (",
                "",
                "\t\tSELECT [DFC].[dfcItem] AS [Item SKU]",
                "\t\t\t  ,[DFC].[dfcWarehouse] AS [Warehouse]",
                "\t\t\t  ,[DFC].[dfcFiscalMonth] AS [FiscalMonthYear]",
                "\t\t\t  ,[FTP].[FiscalMonthLastDate]",
                "\t\t\t  ,[FTP].[SortFcstPer]",
                "\t\t\t  ,[FTP].[ForecastPeriod]",
                "\t\t\t  ,SUM([DFC].[dfcResultantForecast] + [DFC].[dfcPromotionalLift]) AS [Total Forecast]",
                "\t\t\t  ,CONVERT(DATE, [DFC].[dfcSnapshot]) AS [Snapshot Date]",
                "\t\t  FROM [SupplyChain_Enh].[DemandForecastSnapshot] AS DFC",
                "\t\t  INNER JOIN (SELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '2Week'",
                "\t\t\t\t\t\t,[SortFcstPer] = 14",
                "\t\t\t\t\t\t,dateadd(day,15,lag2wk.[FiscalMonthFirstDate]) as [SnapshotDate]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -24 and 0",
                "\t\t\t\t\t\t\t\t\t)lag2wk",
                "\t\t\t\t\t\ton lag2wk.[FiscalMonthIndicator]+0 = dd.[FiscalMonthIndicator]",
                "",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1",
                "",
                "\t\t\t\t\tUNION",
                "",
                "\t\t\t\t\tSELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '30Days'",
                "\t\t\t\t\t\t,[SortFcstPer] = 30",
                "\t\t\t\t\t\t,dateadd(day,15,lag30d.[FiscalMonthFirstDate]) as [30Days]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -25 and -1",
                "\t\t\t\t\t\t\t\t\t)lag30d",
                "\t\t\t\t\t\ton lag30d.[FiscalMonthIndicator]+1 = dd.[FiscalMonthIndicator]",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1",
                "",
                "\t\t\t\t\tUNION",
                "",
                "\t\t\t\t\tSELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '60Days'",
                "\t\t\t\t\t\t,[SortFcstPer] = 60",
                "\t\t\t\t\t\t,dateadd(day,15,lag60d.[FiscalMonthFirstDate]) as [60Days]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -26 and -2",
                "\t\t\t\t\t\t\t\t\t)lag60d",
                "\t\t\t\t\t\ton lag60d.[FiscalMonthIndicator]+2 = dd.[FiscalMonthIndicator]",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1",
                "",
                "\t\t\t\t\tUNION",
                "",
                "\t\t\t\t\tSELECT DISTINCT",
                "\t\t\t\t\t\tdd.[FiscalYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonth]",
                "\t\t\t\t\t\t,dd.[FiscalMonthYear]",
                "\t\t\t\t\t\t,dd.[FiscalMonthFirstDate]",
                "\t\t\t\t\t\t,dd.[FiscalMonthLastDate]",
                "\t\t\t\t\t\t,[ForecastPeriod] = '90Days'",
                "\t\t\t\t\t\t,[SortFcstPer] = 90",
                "\t\t\t\t\t\t,dateadd(day,15,lag90d.[FiscalMonthFirstDate]) as [90Days]",
                "\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail] dd",
                "\t\t\t\t\tLEFT JOIN (SELECT DISTINCT [FiscalMonthFirstDate],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -27 and -3",
                "\t\t\t\t\t\t\t\t\t)lag90d",
                "\t\t\t\t\t\ton lag90d.[FiscalMonthIndicator]+3 = dd.[FiscalMonthIndicator]",
                "",
                "\t\t\t\t\tWHERE dd.[FiscalMonthIndicator] between -12 and -1",
                "",
                "\t\t\t\t\t\t\t   \t\t\t \t\t  \t\t  \t\t \t   ",
                "",
                "",
                "\t\t  ) AS FTP",
                "\t\t  ON [DFC].[dfcFiscalMonth] = [FTP].[FiscalMonthYear]",
                "\t\t\tAND [DFC].[dfcSnapshot] = [FTP].[SnapshotDate]",
                "",
                "\t\t   GROUP BY [DFC].[dfcItem]",
                "\t\t\t\t   ,[DFC].[dfcWarehouse]",
                "\t\t\t\t   ,[DFC].[dfcFiscalMonth]",
                "\t\t\t\t   ,[FTP].[FiscalMonthLastDate]",
                "\t\t\t\t   ,[FTP].[ForecastPeriod]",
                "\t\t\t\t   ,[FTP].[SortFcstPer]",
                "\t\t\t\t   ,[DFC].[dfcSnapshot]",
                "\t\t\t) AS FC",
                "",
                "\t\t\tLEFT JOIN (",
                "\t\tSELECT [IAD].[Item]",
                "\t\t\t  ,[IAD].[Location]",
                "\t\t\t  ,FORMAT([IAD].[Year Period],'yyyyMM') AS [Year Period]",
                "\t\t\t  ,SUM([IAD].[Actual demand]) AS [Actual Demand]",
                "\t\t  FROM [SupplyChain_Enh].[ItemActualDemand_Logility] AS IAD",
                "\t\t   INNER JOIN (SELECT DISTINCT [FiscalMonthYear],[FiscalMonthIndicator]",
                "\t\t\t\t\t\t\tFROM [Enterprise_DW].[dimDate_nonRetail]",
                "\t\t\t\t\t\t\tWHERE [FiscalMonthIndicator] between -12 and -1",
                "\t\t\t\t\t\t\t)dd_act",
                "\t\t\t\ton dd_act.[FiscalMonthYear] = FORMAT([IAD].[Year Period],'yyyyMM')",
                "",
                "\t\t  WHERE [IAD].[Company] = 'AFI'",
                "\t\t\t",
                "",
                "\t\t  GROUP BY [IAD].[Item]",
                "\t\t\t\t  ,[IAD].[Location]",
                "\t\t\t\t  ,[IAD].[Year Period]",
                "\t\t\t) AS ACT",
                "\t\t\tON [FC].[Item SKU] = [ACT].[Item]",
                "\t\t\t  AND [FC].[Warehouse] = [ACT].[Location]",
                "\t\t\t  AND [FC].[FiscalMonthYear] = [ACT].[Year Period]",
                "",
                "\t\tLEFT JOIN (",
                "\t\tSELECT [N].[Item SKU] AS [Item SKU]",
                "\t\t\t  ,[N].[Warehouse] AS [Warehouse]",
                "\t\t\t  ,[D2].[FiscalMonthYear]",
                "\t\t\t  ,CAST([N].[Qty] * [D2].[NumWeeks] AS INT) AS [NaiveFcst]",
                "\t\t  FROM (",
                "\t\tSELECT [ACT].[Item SKU]",
                "\t\t\t  ,[ACT].[Warehouse]",
                "\t\t\t  ,[DD].[FiscalMonthIndicator]",
                "\t\t\t  ,[D2].[FiscalMonthYear]",
                "\t\t\t  ,SUM([ACT].[Order Quantity])/[D2].[NumWeeks] AS [Qty]",
                "",
                "\t\t  FROM [SupplyChain_Enh].[ActualsCustItemWH_AFI] AS ACT",
                "\t\t  LEFT JOIN [Enterprise_DW].[DimDate] AS DD",
                "\t\t\tON [ACT].[CurReqWkEnding] = [DD].[DateID]",
                "\t\t  --LEFT JOIN [PowerBI_SupplyChain].[CustomerAcctMaster_AFI] AS CUS",
                "\t\t  --  ON [ACT].[Account And ShipTo Number] = [CUS].[Account And ShipTo Number]",
                "\t\t  INNER JOIN (",
                "\t\tSELECT [FiscalMonthYear]",
                "\t\t\t  ,[FiscalMonthLastDate]",
                "\t\t\t  ,COUNT(DISTINCT [FiscalWeekLastDate]) AS [NumWeeks]",
                "\t\t  FROM [Enterprise_DW].[DimDate]",
                "\t\t  WHERE [FiscalMonthIndicator] >= -13",
                "\t\t  GROUP BY [FiscalMonthYear]",
                "\t\t\t\t  ,[FiscalMonthLastDate]",
                "\t\t  ) AS D2 ",
                "\t\t  ON [DD].[FiscalMonthLastDate] = [D2].[FiscalMonthLastDate]",
                "  ",
                "\t\t  WHERE [ACT].[Warehouse] NOT IN ('C','CNW','C35','55')",
                "",
                "",
                "\t\tGROUP BY [ACT].[Item SKU]",
                "\t\t\t\t,[ACT].[Warehouse]",
                "\t\t\t\t,[DD].[FiscalMonthIndicator]",
                "\t\t\t\t,[D2].[NumWeeks]",
                "\t\t\t\t,[D2].[FiscalMonthYear]",
                "",
                "\t\t\t) AS N",
                "\t\t  INNER JOIN (",
                "\t\tSELECT [FiscalMonthYear]",
                "\t\t\t  ,[FiscalMonthLastDate]",
                "\t\t\t  ,[FiscalMonthIndicator]",
                "\t\t\t  ,COUNT(DISTINCT [FiscalWeekLastDate]) AS [NumWeeks]",
                "\t\t  FROM [Enterprise_DW].[DimDate]",
                "\t\t  WHERE [FiscalMonthIndicator] < 0",
                "\t\t  and [FiscalMonthIndicator] >= -13",
                "\t\t  GROUP BY [FiscalMonthYear]",
                "\t\t\t\t  ,[FiscalMonthLastDate]",
                "\t\t\t\t  ,[FiscalMonthIndicator]",
                "\t\t  ) AS D2",
                "\t\t  ON ([N].[FiscalMonthIndicator]+1) = [D2].[FiscalMonthIndicator]",
                "",
                "",
                "\t\t) AS NF",
                "\t\t  ON [FC].[Item SKU] = [NF].[Item SKU]",
                "\t\t   AND [FC].[Warehouse] = [NF].[Warehouse]",
                "\t\t   AND [FC].[FiscalMonthYear] = [NF].[FiscalMonthYear]",
                "",
                "\tWHERE ([FC].[Total Forecast] > 0 OR ISNULL([ACT].[Actual Demand], 0) > 0)",
                "\tAND [FC].[FiscalMonthLastDate] < GETDATE()",
                "\tAND [FC].[Snapshot Date] < '3/15/2025'",
                "",
                "",
                ")vFC",
                "",
                "",
                "",
                "    ",
                "    \", CreateNavigationProperties=false]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"FiscalMonthLastDate\", type date}, {\"Snapshot Date\", type date}, {\"Total Forecast\", Int64.Type}})",
                "in",
                "    #\"Changed Type\""
              ],
              "type": "m"
            }
          }
        ]
      },
