      {
        "name": "_Measures",
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ],
        "columns": [
          {
            "name": "z_Measures",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "lineageTag": "f429d575-d7b0-44f2-8fb5-ba8f62042cde",
            "sourceColumn": "z_Measures",
            "summarizeBy": "none"
          }
        ],
        "lineageTag": "d3ffbfeb-9127-482f-be08-90be2a94e213",
        "measures": [
          {
            "name": "Total Forecast",
            "expression": "CALCULATE(SUM(CustItWHAccy[Total Forecast]))",
            "formatString": "#,0",
            "lineageTag": "2cc26fcc-3b8b-467b-86a6-873f49e91bee"
          },
          {
            "name": "Total Demand",
            "expression": "CALCULATE(SUM(CustItWHAccy[Actual Demand]))",
            "formatString": "#,0",
            "lineageTag": "65c26607-9be1-4492-8f05-35ea85fdc6fa"
          },
          {
            "name": "Error Qty",
            "expression": "[Total Forecast] - [Total Demand]",
            "formatString": "#,0",
            "lineageTag": "7fc0c547-063d-4f73-857a-b9d8f721c6d9"
          },
          {
            "name": "Bias %",
            "expression": "DIVIDE([Error Qty],[Total Demand])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "b3df8d3c-c4e5-4684-9fff-79e1c32cce91"
          },
          {
            "name": "Mean ABS Dev_CIW",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "AVERAGEX(CustItWHAccy,[ABS(Error)])",
            "formatString": "0",
            "lineageTag": "c37dd194-333c-4203-ae47-6308c1082f72"
          },
          {
            "name": "Mean Act Demand_CIW",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "AVERAGEX ( CustItWHAccy, [Actual Demand] )"
            ],
            "lineageTag": "f08ef1af-5e11-4de1-943c-2081b8608e47"
          },
          {
            "name": "wMAPE",
            "expression": "DIVIDE([Mean ABS Dev_CIW],[Mean Act Demand_CIW])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "b4ea9080-befb-4d44-8768-355570542e10"
          },
          {
            "name": "(N)Mean ABS Dev_CIW",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "AVERAGEX(CustItWHAccy,[(N)ABS(Error)])",
            "lineageTag": "b9cf6082-40f7-41e0-b56c-021cd7b24f28"
          },
          {
            "name": "(N)wMAPE",
            "expression": "DIVIDE([(N)Mean ABS Dev_CIW],[Mean Act Demand_CIW])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "38b9d9cf-b65a-4076-a44f-d40fa0d06fa6"
          },
          {
            "name": "ABS Percent Error_CIW",
            "expression": "DIVIDE(ABS([Total Demand]-[Total Forecast]),[Total Demand])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "8a2cf090-431c-4914-8d62-8cd85986ef7b"
          },
          {
            "name": "MAPE_CIW",
            "expression": "AVERAGEX(CustItWHAccy,[ABSPError])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "04eddf5e-11b3-4b5b-9560-de6dab07efe4"
          },
          {
            "name": "(N)Forecast_CIW",
            "expression": "CALCULATE(SUM(CustItWHAccy[NaiveFcst]))",
            "formatString": "#,0",
            "lineageTag": "5dc15d98-2ca0-43aa-a325-e3911231c85f"
          },
          {
            "name": "(N)Bias %_CIW",
            "expression": "DIVIDE([(N)Error_CIW],[Total Demand])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "c83489f5-6c8c-409f-a1d5-371a1a1717d4"
          },
          {
            "name": "(N)Error_CIW",
            "expression": "CALCULATE(SUM(CustItWHAccy[(N)Error]))",
            "formatString": "0",
            "lineageTag": "48abd315-7eed-4443-98a5-8a5708709d30"
          },
