                                                          "name":  "Embedding for your organziation",
                                                          "displayFolder":  "Embedding",
                                                          "expression":  "CALCULATE([Report views], \u0027Report views\u0027[OriginalConsumptionMethod] = \"Embedding for your organization\")",
                                                          "formatString":  "0",
