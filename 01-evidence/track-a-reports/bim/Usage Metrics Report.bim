                                 {
                                     "name":  "Model measures",
                                     "annotations":  [
                                                         {
                                                             "name":  "PBI_QueryRelationships",
                                                             "value":  "{\"columnCount\":0,\"keyColumnNames\":[],\"queryRelationships\":[],\"columnIdentities\":[],\"ColumnCount\":0,\"KeyColumnNames\":[],\"ColumnIdentities\":[],\"RelationshipInfo\":[]}"
                                                         },
                                                         {
                                                             "name":  "PBI_ResultType",
                                                             "value":  "Table"
                                                         }
                                                     ],
                                     "lineageTag":  "088a20e1-ae21-42a9-b384-bdf3e6170eca",
                                     "measures":  [
                                                      {
                                                          "name":  "Report views",
                                                          "displayFolder":  "Views",
                                                          "expression":  "COUNTROWS(\u0027Report views\u0027) + 0",
                                                          "formatString":  "#,0",
                                                          "lineageTag":  "e30bc543-d24a-4c1c-97ba-76cb3c232692"
                                                      },
                                                      {
                                                          "name":  "Report viewers",
                                                          "displayFolder":  "Views",
                                                          "expression":  "DISTINCTCOUNT(\u0027Report views\u0027[UserKey]) + 0",
                                                          "formatString":  "#,0",
                                                          "lineageTag":  "a166ded4-cd2f-45c6-a53e-fb421a373ca8"
                                                      },
                                                      {
                                                          "name":  "Page view share",
                                                          "displayFolder":  "Views",
                                                          "expression":  "DIVIDE(COUNTROWS(\u0027Report page views\u0027), CALCULATE(COUNTROWS(\u0027Report page views\u0027), ALL(\u0027Report pages\u0027[SectionName])), 0)",
                                                          "formatString":  "#,0%;-#,0%;#,0%",
                                                          "lineageTag":  "81811df5-4b28-4e16-8be4-9ddf691c8a88"
                                                      },
                                                      {
                                                          "name":  "View trend",
                                                          "displayFolder":  "Trends",
                                                          "expression":  [
                                                                             "",
                                                                             "var numberOfDays = DATEDIFF(MIN(\u0027Report views\u0027[Date]), MAX(\u0027Report views\u0027[Date]),DAY) + 1",
                                                                             "var periodLength = INT(numberOfDays/2) - 1",
                                                                             "var firstPeriod = CALCULATE([Report views], DATESBETWEEN(\u0027Report views\u0027[Date], MIN(\u0027Report views\u0027[Date]), MIN(\u0027Report views\u0027[Date]) + periodLength))",
                                                                             "var secondPeriod = CALCULATE([Report views], DATESBETWEEN(\u0027Report views\u0027[Date], MAX(\u0027Report views\u0027[Date]) - periodLength, MAX(\u0027Report views\u0027[Date])))",
                                                                             "return DIVIDE(secondPeriod - firstPeriod, firstPeriod)  + 0"
                                                                         ],
                                                          "formatString":  "0.0%;-0.0%;0.0%",
                                                          "lineageTag":  "1dd53109-3e61-4cc7-ad7d-eb03d77871eb"
                                                      },
                                                      {
                                                          "name":  "P-50",
                                                          "displayFolder":  "Load times",
                                                          "expression":  "PERCENTILE.INC(\u0027Report load times\u0027[loadTime], 0.5) + 0",
                                                          "formatString":  "0.0",
                                                          "lineageTag":  "3bf432cc-7c82-4db8-a036-06459d3cf2f8"
                                                      },
                                                      {
                                                          "name":  "P-50 7d",
                                                          "displayFolder":  "Load times",
                                                          "expression":  "CALCULATE([P-50], ALL(Dates), DATESINPERIOD(\u0027Report load times\u0027[Date], max(\u0027Report load times\u0027[Date]), -7, DAY)) + 0",
                                                          "formatString":  "0.00",
                                                          "lineageTag":  "1019dead-90a4-4576-94c7-1845f8bbaafc"
                                                      },
                                                      {
                                                          "name":  "P-25",
                                                          "displayFolder":  "Load times",
                                                          "expression":  "PERCENTILE.INC(\u0027Report load times\u0027[loadTime], 0.25) + 0",
                                                          "lineageTag":  "14078391-c661-43b0-b33e-b153b0bbaad2"
                                                      },
                                                      {
                                                          "name":  "P-10",
                                                          "displayFolder":  "Load times",
                                                          "expression":  "PERCENTILE.INC(\u0027Report load times\u0027[loadTime], 0.1) + 0",
                                                          "formatString":  "0.0",
                                                          "lineageTag":  "dad447f9-10c9-49ab-a653-23480fd853af"
                                                      },
                                                      {
                                                          "name":  "P-90 7d",
                                                          "displayFolder":  "Load times",
                                                          "expression":  "CALCULATE([P-90], ALL(Dates), DATESINPERIOD(\u0027Report load times\u0027[Date], max(\u0027Report load times\u0027[Date]), -7, DAY)) + 0",
                                                          "lineageTag":  "ee6c4532-e8ec-466b-b4dd-d9243c5bdc6e"
                                                      },
                                                      {
                                                          "name":  "P-10 7d",
                                                          "displayFolder":  "Load times",
                                                          "expression":  "CALCULATE([P-10], DATESINPERIOD(\u0027Report load times\u0027[Date], max(\u0027Report load times\u0027[Date]), -7, DAY)) + 0",
                                                          "formatString":  "0.0",
                                                          "lineageTag":  "2dfe41a8-9420-40b7-890e-d72c1bb7016e"
                                                      },
                                                      {
                                                          "name":  "Typical report opening interval",
                                                          "displayFolder":  "Display strings",
                                                          "expression":  [
                                                                             "IF(ISBLANK(MAX(\u0027Report load times\u0027[loadTime]) ), ",
                                                                             "    \"This report has no performance measurements.\",",
                                                                             "    IF(HASONEVALUE(\u0027Report load times\u0027[loadTime]), ",
                                                                             "        \"This report only has a single performance measurement. The load time was \" \u0026 MAX(\u0027Report load times\u0027[loadTime]) \u0026 \" seconds.\", ",
                                                                             "        IF([P-10] = [P-50] = [P-25], ",
                                                                             "            \"Across all measurements, this report loaded in  \" \u0026 MAX(\u0027Report load times\u0027[loadTime]) \u0026 \" seconds.\", ",
                                                                             "            \"For most of the users your report opens within \" \u0026 INT([P-10 7d]) \u0026 \" and \" \u0026 INT([P-90 7d]) \u0026 \" seconds.\" )))"
                                                                         ],
                                                          "lineageTag":  "5e54e9e2-73e4-4c54-88c0-a5f7d037dd75"
                                                      },
                                                      {
                                                          "name":  "Rank string",
                                                          "displayFolder":  "Display strings",
                                                          "expression":  "IF(HASONEVALUE(Reports[ReportGuid]), IF(ISBLANK(MAX(\u0027Report rank\u0027[ReportRank])), \"\", \"Rank \" \u0026 MAX(\u0027Report rank\u0027[ReportRank]) \u0026 \" across \"\u0026 [Total Org Report Count] \u0026 \" reports in the organization\"), \"\")",
                                                          "lineageTag":  "6103e7f1-6d5a-4b66-a861-9fa85f636c51"
                                                      },
                                                      {
                                                          "name":  "Performance trend",
                                                          "displayFolder":  "Trends",
                                                          "expression":  [
                                                                             "",
                                                                             "var numberOfDays = DATEDIFF(MIN(\u0027Report views\u0027[Date]), MAX(\u0027Report views\u0027[Date]),DAY) + 1",
                                                                             "var periodLength = INT(numberOfDays/2) - 1",
                                                                             "var firstPeriod = CALCULATE([P-50], DATESBETWEEN(\u0027Report load times\u0027[Date], MIN(\u0027Report load times\u0027[Date]), MIN(\u0027Report load times\u0027[Date]) + periodLength))",
                                                                             "var secondPeriod = CALCULATE([P-50], DATESBETWEEN(\u0027Report load times\u0027[Date], MAX(\u0027Report load times\u0027[Date]) - periodLength, MAX(\u0027Report load times\u0027[Date])))",
                                                                             "return DIVIDE(secondPeriod - firstPeriod, firstPeriod) + 0 * -1"
                                                                         ],
                                                          "formatString":  "0.0%;-0.0%;0.0%",
                                                          "lineageTag":  "aec92e0b-abcf-40e5-a8e4-30ce423660bf"
                                                      },
                                                      {
                                                          "name":  "Typical report opening time",
