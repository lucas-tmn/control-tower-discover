            "expression": "if(abs([Trend Average] - [ST Average]) < 'Qty Diff'[Qty Diff Value],0,if(CALCULATE(sum('Trend Data'[Trend Avg])) < if(calculate(sum('Trend Data'[Min]))<0,0,calculate(sum('Trend Data'[Min]))), -1, if(CALCULATE(sum('Trend Data'[Trend Avg])) > calculate(sum('Trend Data'[Max])), 1,0)))",
