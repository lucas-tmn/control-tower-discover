            "summarizeBy": "none"
          },
          {
            "name": "Account Group",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "lineageTag": "81a7eab4-0b21-483b-86a4-7f3ef4b6f335",
            "sourceColumn": "Account Group",
            "summarizeBy": "none"
          }
        ],
        "lineageTag": "4620bb51-a501-4161-b6dd-fa2684ee3c9d",
        "partitions": [
          {
            "name": "Customers",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Sql.Database(\"Ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"   ",
                "           SELECT ",
                "       [CUS].[Account And ShipTo Number]",
                "      ,[CUS].[Account Number]",
                "      ,[CUS].[Account Name]",
                "      ,[CUS].[Customer Group]",
                "      ,[CUS].[ABC Account-Current Year]",
                "      ,case when [CUS].[ABC Account-Current Year] <> 'A' then 'Non-A Accounts - Various' else [CUS].[Account Group] end as [Account Group]",
                "FROM [PowerBI_SupplyChain].[CustomerAcctMaster_AFI] AS CUS",
                "",
                "Union",
                "Select 'AFICONS','AFICONS','AFICONS','AFICONS','','AFICONS'",
                "Union",
                "Select 'ECOMM','ECOMM','ECOMM','ECOMM','','ECOMM'",
                "Union",
                "Select 'HSENT','HSENT','HSENT','HSENT','','HSENT'",
                "Union",
                "Select 'HSLIC','HSLIC','HSLIC','HSLIC','','HSLIC'",
                "Union",
                "Select 'INT','INT','INT','INT','','INT'",
                "Union",
                "Select 'MASSRENT','MASSRENT','MASSRENT','MASSRENT','','MASSRENT'",
                "Union",
                "Select 'NFM','NFM','NFM','NFM','','NFM'",
                "Union",
                "Select 'RHCUST','RHCUST','RHCUST','RHCUST','','RHCUST'",
                "    \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
