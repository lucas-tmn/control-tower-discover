          },
          {
            "name": "dfcCustomerGroups",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "lineageTag": "43ae5846-827b-40e8-9bc4-bffe617f23be",
            "sourceColumn": "dfcCustomerGroups",
            "summarizeBy": "none"
          }
        ],
        "lineageTag": "bca6188e-14eb-4ac6-919e-061f669644ec",
        "partitions": [
          {
            "name": "FC",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Sql.Database(\"Ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "        --Get Max File Date from Forecast Levels Table to Pull Most Recent Forecasts",
                "declare @maxfiledate as date",
                "set @maxfiledate = (select max(FileDate) From [SupplyChain_Enh].[DemandForecastLevels_Logility])",
                "",
                "",
                "--Select Item/Locations with Current Forecasts",
                "SELECT distinct",
                "\t[Item-Lvl1]",
                "\t,[Location]",
                ",[dfcCustomerGroups]",
                "\t,CASE WHEN [Location] IN ('1','15','17','19','28','42','5','ECR') THEN 'AFI'",
                "\t\tWHEN [Location] = '335'\tTHEN 'ASH'",
                "\t\tWHEN [Location] IN ('C','CNW','C35') THEN 'CND'",
                "\t\tELSE 'OTH'",
                "\tEND as WhGrp",
                "into #itwhselect     ",
                "FROM [SupplyChain_Enh].[ForecastCommonContainer_Logility]",
                "where [FileDate] = @maxfiledate",
                "",
                "",
                "--Select the last 6 and next 12 months",
                "select distinct ",
                "\tcast(cast(dd.[Fiscal Month Desc ID] as varchar(6)) + '15' as date) as [Fiscal Month]",
                "\t,datediff(month,getdate(), cast(cast(dd.[Fiscal Month Desc ID] as varchar(6)) + '01' as date) ) as FiscMonthInd",
                "\tinto #dateselect",
                "from [SupplyChain_DW].[DimDateFile] dd ",
                "where cast(cast(dd.[Fiscal Month Desc ID] as varchar(6)) + '01' as date) > dateadd(mm,-6,dateadd(dd,-day(getdate()),getdate()))",
                "and cast(cast(dd.[Fiscal Month Desc ID] as varchar(6)) + '01' as date) < dateadd(mm,12,dateadd(dd,-day(getdate()),getdate()))",
                "",
                "",
                "",
                "",
                "--Get Monthly and Weekly Forecasts by Item/Warehouse",
                "select distinct",
                "\tdd.[Fiscal Month]",
                "\t,fct.[Item-Lvl1]",
                ",fct.[dfcCustomerGroups]",
                "\t,fct.[WhGrp]",
                "\t,concat(trim(fct.[Item-Lvl1]),trim(fct.[Location]),dd.[Fiscal Month]) as [ItWhMonth]\t\t",
                "\t,concat(trim(fct.[Item-Lvl1]),trim(fct.[Location])) as [ItWh]",
                "\t,concat(trim(fct.[Item-Lvl1]),trim(fct.[WhGrp])) as [ItWhGr]",
                "\t,sum(case when did.[FiscMonthInd] = 0 then [Result_Fc_0]",
                "\t\twhen did.[FiscMonthInd] = 1 then [Result_Fc_1]",
                "\t\twhen did.[FiscMonthInd] = 2 then [Result_Fc_2]",
                "\t\twhen did.[FiscMonthInd] = 3 then [Result_Fc_3]",
                "\t\twhen did.[FiscMonthInd] = 4 then [Result_Fc_4]",
                "\t\twhen did.[FiscMonthInd] = 5 then [Result_Fc_5]",
                "\t\twhen did.[FiscMonthInd] = 6 then [Result_Fc_6]",
                "\t\twhen did.[FiscMonthInd] = 7 then [Result_Fc_7]",
                "\t\twhen did.[FiscMonthInd] = 8 then [Result_Fc_8]",
                "\t\twhen did.[FiscMonthInd] = 9 then [Result_Fc_9]",
                "\t\twhen did.[FiscMonthInd] = 10 then [Result_Fc_10]",
                "\t\twhen did.[FiscMonthInd] = 11 then [Result_Fc_11]",
                "\t\telse 0",
                "\t\tend) as FC",
                "\t,sum(case when did.[FiscMonthInd] = 0 and Result_Fc_0 <> 0then 1",
                "\t\twhen did.[FiscMonthInd] = 1 and Result_Fc_1 <> 0 then 2",
                "\t\twhen did.[FiscMonthInd] = 2 and Result_Fc_2 <> 0 then 3",
                "\t\twhen did.[FiscMonthInd] = 3 and Result_Fc_3 <> 0 then 4",
                "\t\twhen did.[FiscMonthInd] = 4 and Result_Fc_4 <> 0 then 5",
                "\t\twhen did.[FiscMonthInd] = 5 and Result_Fc_5 <> 0 then 6",
                "\t\twhen did.[FiscMonthInd] = 6 and Result_Fc_6 <> 0 then 7",
                "\t\twhen did.[FiscMonthInd] = 7 and Result_Fc_7 <> 0 then 8",
                "\t\twhen did.[FiscMonthInd] = 8 and Result_Fc_8 <> 0 then 9",
                "\t\twhen did.[FiscMonthInd] = 9 and Result_Fc_9 <> 0 then 10",
                "\t\twhen did.[FiscMonthInd] = 10 and Result_Fc_10 <> 0 then 11",
                "\t\twhen did.[FiscMonthInd] = 11 and Result_Fc_11 <> 0 then 12",
                "\t\telse null",
                "\t\tend)  as [Month Indicator]",
                "",
                "\t--add # of weeks for rows with valid FC value to calculate avg weekly FC ",
                "\t,case when sum(case when did.[FiscMonthInd] = 0 then [Result_Fc_0]",
                "\t\t\t\twhen did.[FiscMonthInd] = 1 then [Result_Fc_1]",
                "\t\t\t\twhen did.[FiscMonthInd] = 2 then [Result_Fc_2]",
                "\t\t\t\twhen did.[FiscMonthInd] = 3 then [Result_Fc_3]",
                "\t\t\t\twhen did.[FiscMonthInd] = 4 then [Result_Fc_4]",
                "\t\t\t\twhen did.[FiscMonthInd] = 5 then [Result_Fc_5]",
                "\t\t\t\twhen did.[FiscMonthInd] = 6 then [Result_Fc_6]",
                "\t\t\t\twhen did.[FiscMonthInd] = 7 then [Result_Fc_7]",
                "\t\t\t\twhen did.[FiscMonthInd] = 8 then [Result_Fc_8]",
                "\t\t\t\twhen did.[FiscMonthInd] = 9 then [Result_Fc_9]",
                "\t\t\t\twhen did.[FiscMonthInd] = 10 then [Result_Fc_10]",
                "\t\t\t\twhen did.[FiscMonthInd] = 11 then [Result_Fc_11]",
                "\t\t\t\telse 0",
                "\t\t\t\tend) = 0 then 0",
                "\t\twhen month(dd.[Fiscal Month]) in ('3','6','9','12') then 5 else 4 end as [Weeks]",
                "",
                "from #dateselect dd",
                "cross join #itwhselect fct -- cross join to make a record for each item/warehouse/date combination",
                "left join #dateselect did",
                "\ton dd.[Fiscal Month] = did.[Fiscal Month]",
                "left join  [SupplyChain_Enh].[ForecastCommonContainer_Logility] fcv",
                "\ton fct.[Item-Lvl1] = fcv.[Item-Lvl1]",
                "\tand fct.[Location] = fcv.[Location]",
                "\tand fct.[dfcCustomerGroups]= fcv.[dfcCustomerGroups]",
                "\tand fcv.[FileDate] = @maxfiledate",
                "",
                "group by",
                "\tdd.[Fiscal Month]",
                "\t,fct.[Item-Lvl1]",
                ",fct.[dfcCustomerGroups]",
                "\t,fct.[WhGrp]",
                "\t,concat(trim(fct.[Item-Lvl1]),trim(fct.[Location])) ",
                "\t,concat(trim(fct.[Item-Lvl1]),trim(fct.[WhGrp]))",
                "\t,concat(trim(fct.[Item-Lvl1]),trim(fct.[Location]),dd.[Fiscal Month])",
                "",
                "--drop temp tables",
                "drop table #dateselect",
                "drop table #itwhselect",
                "    ",
                "     \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
