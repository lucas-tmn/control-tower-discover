        "lineageTag": "fe451d9a-6352-426d-a76e-bdb41d9f9392",
        "partitions": [
          {
            "name": "Trend Data",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Sql.Database(\"Ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"",
                "    ",
                "",
                "    ",
                "--A-Account Item WhGroup Trends",
                "",
                "--------------------------------",
                "-----DECLARE VARIABLES----------",
                "--------------------------------",
                "declare @TrendEnd INT",
                "declare @TrendWeeks INT",
                "declare @LongTermWeeks INT  ",
                "declare @ShortTermWeeks INT",
                "declare @Stdevs INT",
                "",
                "------SET VARIABLES------------",
                "set @Stdevs = 1.5",
                "set @TrendWeeks = 6",
                "set @LongTermWeeks = 26",
                "set @ShortTermWeeks = 13",
                "set @TrendEnd = -1",
                "",
                "-----CALCULATED VARIABLES-------",
                "declare @TrendStart INT",
                "declare @LongTermStart INT",
                "declare @LongTermEnd INT",
                "declare @ShortTermStart INT",
                "declare @ShortTermEnd INT",
                "set @TrendStart = @TrendEnd - @TrendWeeks +1",
                "set @LongTermEnd = @TrendStart -1",
                "set @LongTermStart = @LongTermEnd - @LongTermWeeks",
                "set @ShortTermEnd = @TrendStart -1",
                "set @ShortTermStart = @ShortTermEnd - @ShortTermWeeks",
                "  ",
                "----------------------------------------------",
                "-----TEMPORARY TABLES FOR FILTERING-----------",
                "----------------------------------------------",
                "",
                "\t\t---------DATES--------------------",
                "\t\t----ALL DATES----",
                "\t\tselect distinct ",
                "\t\t\t[DD].[FiscalWeekIndicator]",
                "\t\t\t,[DD].[DateID]",
                "\t\t\t,@LongTermWeeks+@TrendWeeks as Wks",
                "\t\tinto #alldates",
                "\t\tfrom [Enterprise_DW].[DimDate] DD",
                "\t\tWHERE [DD].[FiscalWeekIndicator] BETWEEN @LongTermStart AND @TrendEnd",
                "\t\t----LONG TERM DATES-----",
                "\t\tselect distinct ",
                "\t\t\t[DD].[FiscalWeekIndicator]",
                "\t\t\t,[DD].[DateID]",
                "\t\t\t,@LongTermWeeks as Wks",
                "\t\tinto #LongTermdates",
                "\t\tfrom [Enterprise_DW].[DimDate] DD",
                "\t\tWHERE [DD].[FiscalWeekIndicator] BETWEEN @LongTermStart AND @LongTermEnd",
                "\t\t----SHORT TERM DATES-----",
                "\t\tselect distinct ",
                "\t\t\t[DD].[FiscalWeekIndicator]",
                "\t\t\t,[DD].[DateID]",
                "\t\t\t,@ShortTermWeeks as Wks",
                "\t\tinto #ShortTermdates",
                "\t\tfrom [Enterprise_DW].[DimDate] DD",
                "\t\tWHERE [DD].[FiscalWeekIndicator] BETWEEN @ShortTermStart AND @ShortTermEnd",
                "\t\t----TREND DATES-----",
                "\t\tselect distinct ",
                "\t\t\t[DD].[FiscalWeekIndicator]",
                "\t\t\t,[DD].[DateID]",
                "\t\t\t,@TrendWeeks as Wks",
                "\t\tinto #trenddates",
                "\t\tfrom [Enterprise_DW].[DimDate] DD",
                "\t\tWHERE [DD].[FiscalWeekIndicator] BETWEEN @TrendStart AND @TrendEnd",
                "",
                "--ItemList (New or Current Sellable Items)",
                "select  ",
                "\t[Item SKU]",
                "\t,[Item Ext Series Number]",
                "into #itemlist",
                "from [SupplyChain_DW].[DimCurrentProductDetails]",
                "where [Current Status] in ('N','C')",
                "and [Sellable Item Flag]='Y'",
                "",
                "",
                "",
                "--Account List (Active A Accounts, combine DSG)",
                "select ",
                "\tCASE WHEN [ABC Account-Current Year] <> 'A' THEN [Customer Group]",
                "\t\t\t\tELSE  [Account And ShipTo Number]",
                "\t\t\t\t\t\t\t\tend ",
                "\t\t\tAS [Account Group]",
                "\t\t,[Account And ShipTo Number]",
                "into #acctlist",
                "from [PowerBI_SupplyChain].[CustomerAcctMaster_AFI] ",
                "where [Customer Account Status] = 'A'",
                "\t--and [ABC Account-Current Year] = 'A'",
                "",
                "",
                "",
                "",
                "",
                "--------------------------------------------------------",
                "--------TEMP TABLES FOR SALES DATA----------------------",
                "--------------------------------------------------------",
                "",
                "--SALES BY ITEM, WAREHOUSE GROUP, ACCOUNT, AND WEEK exluding Ads and Blanket Orders",
                "",
                "--select unique account, item, warehouse group ",
                "SELECT DISTINCT",
                "\t[FOH].[Item SKU]",
                "\t,CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR') THEN 'AFI'",
                "\t\t\t\tWHEN [FOH].[Warehouse] = '335' THEN 'ASH'",
                "\t\t\t\tWHEN [FOH].[Warehouse] IN ('C','CNW','C35') THEN 'CND'",
                "\t\t\t\tELSE 'OTH' END as [Warehouse Group]",
                "\t,[DC].[Account Group]",
                "\t,concat(trim([FOH].[Item SKU]),trim(CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR') THEN 'AFI'",
                "\t\t\t\tWHEN [FOH].[Warehouse] = '335' THEN 'ASH'",
                "\t\t\t\tWHEN [FOH].[Warehouse] IN ('C','CNW','C35') THEN 'CND'",
                "\t\t\t\tELSE 'OTH' END),trim([DC].[Account Group])) as [ItWhGrAcct]",
                "\t,concat(trim([FOH].[Item SKU]),trim(CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR') THEN 'AFI'",
                "\t\t\t\tWHEN [FOH].[Warehouse] = '335' THEN 'ASH'",
                "\t\t\t\tWHEN [FOH].[Warehouse] IN ('C','CNW','C35') THEN 'CND'",
                "\t\t\t\tELSE 'OTH' END)) as [ItWhGr]",
                "into #uniquerecords",
                "from  [AFISales_DW].[FactOrderHistory] as FOH",
                "INNER JOIN #alldates as DD",
                "\t\tON [FOH].[AHORDT_Date] = [DD].[DateID]",
                "INNER JOIN #itemlist as CPD",
                "\ton [CPD].[Item SKU] = [FOH].[Item SKU]",
                "INNER JOIN #acctlist as DC",
                "\tON [FOH].[Account And ShipTo Number] = [DC].[Account And ShipTo Number]",
                "",
                "",
                "",
                "",
                "--Trend Calculations",
                "select distinct",
                "\tconcat(trim([FOH].[Item SKU]),trim(CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR') THEN 'AFI'",
                "\t\t\t\tWHEN [FOH].[Warehouse] = '335' THEN 'ASH'",
                "\t\t\t\tWHEN [FOH].[Warehouse] IN ('C','CNW','C35') THEN 'CND'",
                "\t\t\t\tELSE 'OTH' END),trim([DC].[Account Group])) as [ItWhGrAcct]",
                "\t\t,cast(SUM([FOH].[Quantity Ordered]) / avg(DD.Wks) as dec(10,2)) as [Avg]",
                "\t\t,min([DateID]) as [Start]",
                "\t\t,min([DateID]) as [End]",
                "",
                "INTO #trendcalculations",
                "FROM [AFISales_DW].[FactOrderHistory] AS FOH",
                "\tINNER JOIN #trenddates as DD",
                "\t\tON [FOH].[AHORDT_Date] = [DD].[DateID]",
                "\tINNER JOIN #itemlist as CPD",
                "\t\ton [CPD].[Item SKU] = [FOH].[Item SKU]",
                "\tINNER JOIN #acctlist as DC",
                "\t\tON [FOH].[Account And ShipTo Number] = [DC].[Account And ShipTo Number]",
                "WHERE",
                "\t[FOH].[3rd Order Type] <> 'ADVERTISEMENT'",
                "\tAND [FOH].[Secondary Order Type] <> 'BLANKET ORDERS'",
                "\tAND [FOH].[Warehouse] NOT IN ('151','16 ','213','215','232','50 ','55 ','60 ','70 ')",
                "GROUP BY ",
                "concat(trim([FOH].[Item SKU]),trim(CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR') THEN 'AFI'",
                "\t\t\t\tWHEN [FOH].[Warehouse] = '335' THEN 'ASH'",
                "\t\t\t\tWHEN [FOH].[Warehouse] IN ('C','CNW','C35') THEN 'CND'",
                "\t\t\t\tELSE 'OTH' END),trim([DC].[Account Group]))",
                "",
                "--Short Term Calculations",
                "select distinct",
                "\tconcat(trim([FOH].[Item SKU]),trim(CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR') THEN 'AFI'",
                "\t\t\t\tWHEN [FOH].[Warehouse] = '335' THEN 'ASH'",
                "\t\t\t\tWHEN [FOH].[Warehouse] IN ('C','CNW','C35') THEN 'CND'",
                "\t\t\t\tELSE 'OTH' END),trim([DC].[Account Group])) as [ItWhGrAcct]",
                "\t\t,cast(SUM([FOH].[Quantity Ordered]) / avg(DD.Wks) as dec(10,2)) as [Avg]",
                "\t\t,min([DateID]) as [Start]",
                "\t\t,max([DateID]) as [End]",
                "",
                "INTO #ShortTermcalculations",
                "FROM [AFISales_DW].[FactOrderHistory] AS FOH",
                "\tINNER JOIN #ShortTermdates as DD",
                "\t\tON [FOH].[AHORDT_Date] = [DD].[DateID]",
                "\tINNER JOIN #itemlist as CPD",
                "\t\ton [CPD].[Item SKU] = [FOH].[Item SKU]",
                "\tINNER JOIN #acctlist as DC",
                "\t\tON [FOH].[Account And ShipTo Number] = [DC].[Account And ShipTo Number]",
                "WHERE",
                "\t[FOH].[3rd Order Type] <> 'ADVERTISEMENT'",
                "\tAND [FOH].[Secondary Order Type] <> 'BLANKET ORDERS'",
                "\tAND [FOH].[Warehouse] NOT IN ('151','16 ','213','215','232','50 ','55 ','60 ','70 ')",
                "GROUP BY ",
                "concat(trim([FOH].[Item SKU]),trim(CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR') THEN 'AFI'",
                "\t\t\t\tWHEN [FOH].[Warehouse] = '335' THEN 'ASH'",
                "\t\t\t\tWHEN [FOH].[Warehouse] IN ('C','CNW','C35') THEN 'CND'",
                "\t\t\t\tELSE 'OTH' END),trim([DC].[Account Group]))",
                "",
                "",
                "--Long Term Calculations (use cross join to incorporate weeks with 0 into standard deviation)",
                "select distinct",
                "\t\tur.[ItWhGrAcct]",
                "\t\t,cast(stdev([FOH].[Quantity Ordered])as dec(38,4)) as [Stdev]",
                "\t\t,min([DateID]) as [Start]",
                "\t\t,min([DateID]) as [End]",
                "",
                "INTO #LongTermcalculations",
                "FROM #LongTermdates  ",
                "cross join  #uniquerecords ur",
                "left join (\tSELECT DISTINCT",
                "\t\t\t\tconcat(trim([FOH].[Item SKU]),trim(CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR') THEN 'AFI'",
                "\t\t\t\t\tWHEN [FOH].[Warehouse] = '335' THEN 'ASH'",
                "\t\t\t\t\tWHEN [FOH].[Warehouse] IN ('C','CNW','C35') THEN 'CND'",
                "\t\t\t\t\tELSE 'OTH' END),trim([DC].[Account Group])) ",
                "\t\t\t\tas [ItWhGrAcct]",
                "\t\t\t\t,[DD].[FiscalWeekIndicator]\t\t\t\t",
                "\t\t\t\t,SUM(coalesce([FOH].[Quantity Ordered],0)) as [Quantity Ordered]",
                "\t\tFROM [AFISales_DW].[FactOrderHistory] AS FOH",
                "\t\tINNER JOIN #acctlist as DC",
                "\t\t\tON [FOH].[Account And ShipTo Number] = [DC].[Account And ShipTo Number]",
                "\t\tINNER JOIN #longtermdates ld",
                "\t\t\tON [FOH].[AHORDT_Date] = [LD].[DateID]",
                "\t\tleft join [Enterprise_DW].[DimDate] DD",
                "\t\t\ton DD.[DateID] = FOH.[AHORDT_Date]",
                "\t\tgroup by",
                "\t\t\tconcat(trim([FOH].[Item SKU]),trim(CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR') THEN 'AFI'",
                "\t\t\t\t\tWHEN [FOH].[Warehouse] = '335' THEN 'ASH'",
                "\t\t\t\t\tWHEN [FOH].[Warehouse] IN ('C','CNW','C35') THEN 'CND'",
                "\t\t\t\t\tELSE 'OTH' END),trim([DC].[Account Group])) ",
                "\t\t\t\t,[DD].[FiscalWeekIndicator]\t\t",
                "",
                "",
                "\t\t) as FOH",
                "\ton FOH.[ItWhGrAcct] = ur.[ItWhGrAcct]",
                "",
                "group by ur.[ItWhGrAcct]",
                "",
                "\t",
                "",
                "\t",
                "",
                "",
                "",
                "",
                "",
                "\t",
                "-------------------------------------------------",
                "--------Final Report-----------------------------",
                "-------------------------------------------------",
                "   ",
                "-- declare @TrendEnd INT, @TrendWeeks INT, @LongTermWeeks INT, @ShortTermWeeks INT, @Stdevs INT, @TrendStart INT, @LongTermStart INT, @LongTermEnd INT, @ShortTermStart INT, @ShortTermEnd INT; set @Stdevs = 2; set @TrendWeeks = 6; set @LongTermWeeks = 26; set @ShortTermWeeks = 13; set @TrendEnd = -1; set @TrendStart = @TrendEnd - @TrendWeeks + 1; set @LongTermEnd = @TrendStart - 1; set @LongTermStart = @LongTermEnd - @LongTermWeeks; set @ShortTermEnd = @TrendStart - 1; set @ShortTermStart = @ShortTermEnd - @ShortTermWeeks;",
                "",
                "SELECT DISTINCT",
                "\t[AIW].[Item SKU]",
                "\t,[AIW].[Warehouse Group]",
                "\t,[AIW].[Account Group]",
                "\t,[AIW].[ItWhGrAcct]",
                "\t,[AIW].[ItWhGr]",
                "\t,coalesce(TOH.[Avg],0)   as [Trend Avg]",
                "\t,coalesce(SOH.[Avg],0)  as [Short Term Average]",
                "",
                "\t\t",
                "\t,Case When coalesce(SOH.[Avg],0) - (@stdevs *coalesce([BOH].[Stdev],0)) < 0 then 0",
                "\t\t\tElse coalesce(SOH.[Avg],0) - (@stdevs *coalesce([BOH].[Stdev],0)) ",
                "\t\tEnd  as [Min] --Short Term Average - Base Standard Deviation = Min (must be >=0)",
                "\t,coalesce(SOH.[Avg],0) + (@stdevs *coalesce([BOH].[Stdev],0)) as [Max] --Short Term Average - Base Standard Deviation = Max",
                "\t,case\twhen coalesce(TOH.[Avg],0) < (coalesce(SOH.[Avg],0) - (@stdevs *coalesce([BOH].[Stdev],0))) then coalesce(SOH.[Avg],0) - (@stdevs *coalesce([BOH].[Stdev],0))  --If Trend Avg < Min then use Min as Expected",
                "\t\t\twhen coalesce(TOH.[Avg],0) > (coalesce(SOH.[Avg],0) + (@stdevs *coalesce([BOH].[Stdev],0))) then coalesce(SOH.[Avg],0) + (@stdevs *coalesce([BOH].[Stdev],0))  --If Trend Avg > Max then use Max as Expected",
                "\t\t\telse coalesce(TOH.[Avg],0)   --If Min <= Trend Avg <= Max then use Trend Avg as Expected",
                "\t\tend ",
                "\t\tas [Expected Value] ",
                "",
                "\t,(select min([DateID]) from #trenddates) as [Trend Start]",
                "\t,(select max([DateID]) from #trenddates)  as [Trend End]",
                "\t,(select min([DateID]) from #ShortTermdates) as [Short Term Start]",
                "\t,(select max([DateID]) from #ShortTermdates)  as [Short Term End]",
                "\t,(select min([DateID]) from #LongTermdates) as [Base Start]",
                "\t,(select max([DateID]) from #LongTermdates)  as [Base End] ",
                "\t",
                "FROM #uniquerecords AIW",
                "\tLEFT JOIN #trendcalculations AS TOH",
                "\t\t on [AIW].[ItWhGrAcct] = [TOH].[ItWhGrAcct]",
                "\tLEFT JOIN #LongTermcalculations AS BOH",
                "\t\tON [AIW].[ItWhGrAcct] = [BOH].[ItWhGrAcct]",
                "\t\tLEFT JOIN #ShortTermcalculations AS SOH",
                "\t\tON [AIW].[ItWhGrAcct] = [SOH].[ItWhGrAcct]",
                "\t",
                "",
                "\t",
                "",
                "  drop table #alldates ",
                "  drop table #LongTermdates",
                "  drop table #ShortTermdates",
                "  drop table #trenddates",
                "  drop table #itemlist",
                "  drop table #acctlist",
                "  drop table #uniquerecords",
                "  drop table #trendcalculations",
                "  drop table #ShortTermcalculations",
                "  drop table #LongTermcalculations",
                "",
                "    ",
                "",
                "    \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
