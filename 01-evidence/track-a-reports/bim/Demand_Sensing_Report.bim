        "partitions": [
          {
            "name": "Warehouses",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Sql.Database(\"Ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"SELECT TOP (1000) WHSE.[AFIWarehousesKey]#(lf)      ,WHSE.[Warehouse Code]#(lf)#(tab)  ,CASE WHEN WHSE.[Warehouse Code] IN ('1','15','17','19','28','42','5','ECR') THEN 'AFI'#(lf)#(tab)#(tab)#(tab)#(tab)WHEN WHSE.[Warehouse Code] = '335' THEN 'ASH'#(lf)#(tab)#(tab)#(tab)#(tab)WHEN WHSE.[Warehouse Code] IN ('C','CNW','C35') THEN 'CND'#(lf)#(tab)#(tab)#(tab)#(tab)ELSE 'OTH' END as [Warehouse Group]#(lf)      ,WHSE.[Intransit Warehouse]#(lf)      ,WHSE.[Container Direct Warehouse]#(lf)      ,WHSE.[Controlled Warehouse]#(lf)      ,WHSE.[Warehouse Location]#(lf)      ,WHSE.[Warehouse Order Group]#(lf)      ,WHSE.[Finance Inventory Report Flag]#(lf)  FROM [SupplyChain_DW].[DimAFIWarehouses] WHSE#(lf)\", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
