          {
            "name": "Writ Acct +/-",
            "expression": "if(CALCULATE(sum('Weekly Writ Qties'[Qty Ordered])) < calculate(sum('Trend Data'[Min])), -1, if(CALCULATE(sum('Weekly Writ Qties'[Qty Ordered])) > calculate(sum('Trend Data'[Max])), 1,0))",
