          },
          {
            "name": "Writ Acct +/- (2)",
            "expression": "if(and(CALCULATE(sum('Weekly Writ Qties'[Qty Ordered])) < calculate(sum('Trend Data'[Min])),calculate(sum('Trend Data'[Min]))>0), -1, if(CALCULATE(sum('Weekly Writ Qties'[Qty Ordered])) > calculate(sum('Trend Data'[Max])), 1,0))",
