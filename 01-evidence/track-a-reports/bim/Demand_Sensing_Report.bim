Year] <> 'A' THEN 'Non-A Accounts'#(lf)#(tab)#(tab)#(tab)#(tab)ELSE [Customer Name]#(lf)#(tab)#(tab)#(tab)#(tab)end --combine DSG and non-A Accounts#(lf)#(tab)#(tab)#(tab),' - '#(lf)#(tab)#(tab)#(tab),CASE WHEN [Customer Account Number] IN ('9946600','9958100','9955000','9966100','9981000','9983000','9977400','9985500','9955100','9956600','9983800','9989200','9974000') THEN 'Various Account Numbers'#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)WHEN [ABC Account-Current Year] <> 'A' THEN 'Various'#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE [Customer Account Number]#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)end#(lf)#(tab)#(tab)) AS [Account Group]#(lf)#(tab)#(tab),[Account And ShipTo Number]#(lf)into #acctlist#(lf)from [AFISales_DW].[DimCustomers]#(lf)where [Customer Account Status] = 'A'#(lf)#(lf)--------------------------------------------------------#(lf)--------TEMP TABLES FOR SALES DATA----------------------#(lf)--------------------------------------------------------#(lf)--SALES BY ITEM, WAREHOUSE GROUP, ACCOUNT, AND WEEK#(lf)select distinct#(lf)#(tab)[FOH].[Item SKU]#(lf)#(tab),CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR')#(lf)#(tab)#(tab)#(tab)THEN 'AFI'#(lf)#(tab)#(tab)WHEN [FOH].[Warehouse] = '335'#(lf)#(tab)#(tab)#(tab)THEN 'ASH'#(lf)#(tab)#(tab)WHEN [FOH].[Warehouse] IN ('C','CNW','C35')#(lf)#(tab)#(tab)#(tab)THEN 'CND'#(lf)#(tab)#(tab)ELSE 'OTH'#(lf)#(tab)END AS [Warehouse Group]#(lf)#(tab),[DC].[Account Group]#(lf)#(tab),concat(trim([FOH].[Item SKU]),trim(CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR')#(lf)#(tab)#(tab)#(tab)THEN 'AFI'#(lf)#(tab)#(tab)#(tab)WHEN [FOH].[Warehouse] = '335'#(lf)#(tab)#(tab)#(tab)THEN 'ASH'#(lf)#(tab)#(tab)#(tab)WHEN [FOH].[Warehouse] IN ('C','CNW','C35')#(lf)#(tab)#(tab)#(tab)THEN 'CND'#(lf)#(tab)#(tab)#(tab)ELSE 'OTH'#(lf)#(tab)#(tab)#(tab)END),trim([DC].[Account Group])#(lf)#(tab)) as [ItWhGrAcct]#(lf)#(tab),concat([FOH].[Item SKU],CASE WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR')#(lf)#(tab)#(tab)#(tab)THEN 'AFI'#(lf)#(tab)#(tab)#(tab)WHEN [FOH].[Warehouse] = '335'#(lf)#(tab)#(tab)#(tab)THEN 'ASH'#(lf)#(tab)#(tab)#(tab)WHEN [FOH].[Warehouse] IN ('C','CNW','C35')#(lf)#(tab)#(tab)#(tab)THEN 'CND'#(lf)#(tab)#(tab)#(tab)ELSE 'OTH'#(lf)#(tab)#(tab)#(tab)END#(lf)#(tab)) as [ItWh]#(lf)#(tab),[DD].[FiscalWeekLastDate]#(lf)#(tab),[DD].[FiscalWeekIndicator]#(lf)#(tab),SUM([FOH].[Quantity Ordered]) AS [Quantity Ordered]#(lf)into #tempsalestable#(lf)from  [AFISales_DW].[FactOrderHistory] AS FOH#(lf)#(tab)INNER JOIN #alldates as DD#(lf)#(tab)#(tab)ON [FOH].[AHORDT_Date] = [DD].[DateID]#(lf)#(tab)INNER JOIN #itemlist as CPD#(lf)#(tab)#(tab)on [CPD].[Item SKU] = [FOH].[Item SKU]#(lf)#(tab)INNER JOIN #acctlist as DC#(lf)#(tab)#(tab)ON [FOH].[Account And ShipTo Number] = [DC].[Account And ShipTo Number]#(lf)where#(lf)#(tab)[FOH].[3rd Order Type] <> 'ADVERTISEMENT'#(lf)#(tab)AND [FOH].[Secondary Order Type] <> 'BLANKET ORDERS'#(lf)#(tab)AND [FOH].[Warehouse] NOT IN ('151','16 ','213','215','232','50 ','55 ','60 ','70 ')#(lf)GROUP BY #(lf)[FOH].[Item SKU]#(lf)#(tab),CASE#(lf)#(tab)#(tab)WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR')#(lf)#(tab)#(tab)#(tab)THEN 'AFI'#(lf)#(tab)#(tab)WHEN [FOH].[Warehouse] = '335'#(lf)#(tab)#(tab)#(tab)THEN 'ASH'#(lf)#(tab)#(tab)WHEN [FOH].[Warehouse] IN ('C','CNW','C35')#(lf)#(tab)#(tab)#(tab)THEN 'CND'#(lf)#(tab)#(tab)ELSE 'OTH'#(lf)#(tab)END #(lf)#(tab),[DC].[Account Group]#(lf)#(tab),concat([FOH].[Item SKU],CASE#(lf)#(tab)#(tab)WHEN [FOH].[Warehouse] IN ('1','15','17','19','28','42','5','ECR')#(lf)#(tab)#(tab)#(tab)THEN 'AFI'#(lf)#(tab)#(tab)WHEN [FOH].[Warehouse] = '335'#(lf)#(tab)#(tab)#(tab)THEN 'ASH'#(lf)#(tab)#(tab)WHEN [FOH].[Warehouse] IN ('C','CNW','C35')#(lf)#(tab)#(tab)#(tab)THEN 'CND'#(lf)#(tab)#(tab)ELSE 'OTH'#(lf)#(tab)END) #(lf)#(tab),[DD].[FiscalWeekLastDate]#(tab)#(lf)#(tab),[DD].[FiscalWeekIndicator]#(lf)#(lf)#(lf)#(lf)#(lf)------------------------------------------#(lf)-------FINAL 