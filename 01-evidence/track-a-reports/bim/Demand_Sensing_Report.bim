          },
          {
            "name": "Future Flag",
            "expression": "if(CALCULATE(max('Orders by Request Month'[Cur Req Fiscal Month]))>today(),1,if(CALCULATE(max('Orders by Request Month'[Cur Req Fiscal Month]))<EDATE(TODAY(),-1),-1,0))",
