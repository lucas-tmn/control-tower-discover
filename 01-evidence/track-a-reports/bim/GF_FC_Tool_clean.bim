ance' ELSE '' END AS [Imbalance by FC],#(lf)        NULL AS [Safety Stock], NULL AS [Max Safety Stock], NULL AS [Imbalance Ratio by SS], NULL AS [Imbalance by SS],#(lf)        [L12M ACTD], [MaxDemand] AS [Max Demand],#(lf)        CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4)) AS [Imbalance Ratio by Demand],#(lf)        CASE WHEN [MaxDemand]>0 AND CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.05 THEN 'Imbalance' ELSE '' END AS [Imbalance by Demand],#(lf)        CAST((CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) - CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))) AS DECIMAL(18,4)) AS [Ratio Difference],#(lf)        CASE#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0#(lf)             AND CAST(CASE WHEN [MaxDemand]=0  THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.05  AND [MaxDemand]>0 THEN 'Customer behaviour'#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0 THEN 'Not defined'#(lf)            ELSE ''#(lf)        END AS [Imbalance reason]#(lf)    FROM DW_FC_MAX#(lf)),#(lf)#(lf)-- ----------------------------------------------------------------#(lf)-- SEGMENT 8: DINING | WAREHOUSE | SAFETY STOCK  (threshold: 0.05)#(lf)-- ----------------------------------------------------------------#(lf)DW_SS_ACTIVE AS (#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_SS_WH#(lf)    UNION#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_DEMAND_WH#(lf)),#(lf)DW_SS_MAPPED AS (#(lf)    SELECT DISTINCT A.[Warehouse], D.[Comparison Type], D.[Series Number], D.[Bed Size]#(lf)    FROM DW_SS_ACTIVE A INNER JO