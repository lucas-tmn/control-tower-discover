ceColumn":"Customer Group","summarizeBy":"none"},{"name":"Warehouse","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"61d8c733-5eb2-4268-8756-a7473dd9f32d","sourceColumn":"Warehouse","summarizeBy":"none"},{"name":"Day of Month","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"0","lineageTag":"d154aac6-44cd-41e4-b34f-156bdad47935","sourceColumn":"Day of Month","summarizeBy":"sum"},{"name":"Weeks in Month","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"0","lineageTag":"67c58911-da08-4546-8749-4042dadd3b05","sourceColumn":"Weeks in Month","summarizeBy":"sum"},{"name":"Goal Consumption","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"31a589ed-a98d-45ce-a978-cf365ea682b5","sourceColumn":"Goal Consumption","summarizeBy":"sum"},{"name":"CusCC","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"38c82e0c-b21d-494a-8e65-17d98a8033b4","sourceColumn":"CusCC","summarizeBy":"none"},{"name":"Key","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","expression":"'Fact Goal Consumption CusWH'[Collective Class] & [Day of Month] & [Weeks in Month] & 'Fact Goal Consumption CusWH'[Customer Group]","isDataTypeInferred":true,"lineageTag":"d6317280-07fc-461b-ba7e-d020f098a084","summarizeBy":"none","type":"calculated"}],"lineageTag":"8161e834-b5bc-4a32-89f4-fe7cb48e1546","partitions":[{"name":"Fact Goal Consumption CusWH","mode":"import","queryGroup":"Fact Query","source":{"expression":["let","    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"SET NOCOUNT ON#(lf)#(lf)DECLARE @dataDate NVARCHAR(MAX)#(lf)#(lf)-- LEFT JOIN [PowerBI_SupplyChain].[CustomerAcctMaster_AFI] [DC]#(lf)-- SET @dataDate = (#(lf)--         SELECT MAX(CONVERT(DATE, dfcSnapshot))#(lf)--         FROM [SupplyChain_Enh].[DemandForecastSnapshot] [DF]#(lf)--         LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [DD] ON dfcSnapshot = DateID#(lf)--         WHERE [FiscalMonthIndicator] BETWEEN -1 AND 0#(lf)--         GROUP BY [FiscalMonthYear]#(lf)--         );#(lf)-- Temp table#(lf)SELECT *#(lf)INTO #WH_MTD#(lf)FROM (#(lf)    SELECT [DFC].[Collective Class]#(lf)        , [Customer Group]#(lf)        , [dfcFiscalMonth]#(lf)        , [FiscalDayOfMonth]#(lf)        , [DFC].[Warehouse]#(lf)        , [dfcSnapshot]#(lf)        -- , [dfcOrderFutureQty]#(lf)        -- , [INV].[CUMSUM]#(lf)        , [dfcOrderFutureQty] + COALESCE([CUMSUM], 0) [dfcOrderFutureQty]#(lf)    FROM (#(lf)        SELECT #(lf)              [CPD].[Collective Class]#(lf)            , [DC].[Customer Group]#(lf)            , [DD].[FiscalMonthYear] [dfcFiscalMonth]#(lf)            , [DIM].[FiscalDayOfMonth]#(lf)            , TRIM([ACT].[Warehouse]) [Warehouse]#(lf)            -- , TRIM([ACT].[Item Sku]) [dfcItem]#(lf)            , CONVERT(DATE, [ACT].[Inserted Date]) [dfcSnapshot]#(lf)            , SUM([ACT].[Open Order Quantity]) [dfcOrderFutureQty]#(lf)        FROM [AFISales_DW].[FactOpenOrdersSnapshot] [ACT]#(lf)        LEFT JOIN [PowerBI_SupplyChain].[CustomerAcctMaster_AFI] [DC]#(lf)            ON TRIM([ACT].[Account And ShipTo Number]) = TRIM([DC].[Account And ShipTo Number])#(lf)        LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [DD]#(lf)            ON DATEADD(DAY, - [ACT].[Load Lead Time], [ACT].[Current Request Date]) = [DD].[DateID]#(lf)        LEFT JOIN (#(lf)            SELECT #(lf)                [Item SKU]#(lf)                , [Collective Class]#(lf)                -- , CASE #(lf)                --     WHEN [CPD].[Collective Class] IN ('ACCESSORIES', 'THROWS & PILLOWS', 'RUGS', 'LAMPS')#(lf)                --         THEN 'ACCENTS'#(lf)                --     ELSE [CPD].[Collective Class]#(lf)                --     END AS [Collective Class]#(lf)            FROM [PowerBI_SupplyChain].[CurrentProductDetails] [CPD]#(lf)        ) AS CPD#(lf)            ON TRIM([ACT].[Item Sku]) = [CPD].[Item SKU]#(lf)        INNER JOIN (#(lf)            SELECT [DateID]#(lf)                , [FiscalDayOfMonth]#(lf)                , [FiscalMonthYear]#(lf)            FROM [Enterprise_DW].[DimDate]#(lf)            WHERE [FiscalMonthIndicator] BETWEEN - 24 AND - 1#(lf)                AND [fiscaldayofWeek] <> 1#(lf)            ) AS DIM#(lf)            ON CONVERT(DATE, [ACT].[Inserted Date]) = [DIM].[DateID]#(lf)                AND [DD].[FiscalMonthYear] = [DIM].[FiscalMonthYear]#(lf)        WHERE TRIM([ACT].[Warehouse]) IN ('1', '1A', '15', '15A', '17', '17A', '19', '28', '28A', '5', '5A', '335', 'ECR', 'ECA')#(lf)        GROUP BY [DC].[Customer Group]#(lf)            , [CPD].[Collective Class]#(lf)            , [DD].[FiscalMonthYear]#(lf)            , [DIM].[FiscalDayOfMonth]#(lf)            , TRIM([ACT].[Warehouse])#(lf)            , CONVERT(DATE, [ACT].[Inserted Date])#(lf)        ) DFC#(lf)    LEFT JOIN (#(lf)        SELECT [Collective Class]#(lf)            -- , [Item SKU]#(lf)            , [CustomerGroup]#(lf)            , [FiscalMonthYear]#(lf)            , [InvoiceDate]#(lf)            , [Warehouse]#(lf)            , [Order Quantity]#(lf)            , SUM([Order Quantity]) OVER (#(lf)                PARTITION BY [CustomerGroup]#(lf)                , [Collective Class]#(lf)                , [Warehouse]#(lf)                , [FiscalMonthYear] ORDER BY [InvoiceDate]#(lf)                ) [CUMSUM]#(lf)        FROM (#(lf)            SELECT [Customer Group] AS [CustomerGroup]#(lf)                -- , CASE #(lf)                --     WHEN [CPD].[Collective Class] IN ('ACCESSORIES', 'THROWS & PILLOWS', 'RUGS', 'LAMPS')#(lf)                --         THEN 'ACCENTS'#(lf)                --     ELSE [CPD].[Collective Class]#(lf)                --     END AS [Collective Class]#(lf)                , [CPD].[Collective Class]#(lf)                , TRIM([ID].[Warehouse]) AS [Warehouse]#(lf)                , CASE #(lf)                    WHEN [D].[FiscalMonthYear] IS NULL#(lf)                        THEN [D3].[FiscalMonthYear]#(lf)                    ELSE [D].[FiscalMonthYear]#(lf)                    END AS [FiscalMonthYear]#(lf)                , [D3].[DateID] [InvoiceDate]#(lf)                , ROUND(SUM([ID].[QuantityShipped]), 0) AS [Order Quantity]#(lf)            FROM [Wholesale_SalesHistory_AFI].[InvoiceDetail] AS ID#(lf)            LEFT JOIN [Wholesale_SalesHistory_AFI].[InvoiceHeader] AS IH#(lf)                ON [ID].[InvoiceNumber] = [IH].[InvoiceNumber]#(lf)                    AND [ID].[OrderNumber] = [IH].[OrderNumber]#(lf)                    AND [ID].[Warehouse] = [IH].[Warehouse]#(lf)            LEFT JOIN [PowerBI_SupplyChain].[CustomerAcctMaster_AFI] [DC]#(lf)                ON TRIM([IH].[CustomerNumber]) = TRIM([DC].[Account Number])#(lf)                    AND TRIM([IH].[ShiptoNumber]) = TRIM([DC].[ShipTo Number])#(lf)            LEFT JOIN [Enterprise_DW].[DimDate] AS D#(lf)                ON DATEADD(DAY, - [IH].[LeadTime], CONVERT(DATE, [ID].[RequestDate])) = [D].[DateID]#(lf)            LEFT JOIN [Enterprise_DW].[DimDate] AS D3#(lf)                ON CONVERT(DATE, [ID].[InvoiceDate]) = [D3].[DateID]#(lf)            LEFT JOIN (#(lf)                SELECT #(lf)                    [Item SKU]#(lf)                    , [Collective Class]#(lf)                    -- , CASE #(lf)                    --     WHEN [CPD].[Collective Class] IN ('ACCESSORIES', 'THROWS & PILLOWS', 'RUGS', 'LAMPS')#(lf)                    --         THEN 'ACCENTS'#(lf)                    --     ELSE [CPD].[Collective Class]#(lf)                    --     END AS [Collective Class]#(lf)                FROM [PowerBI_SupplyChain].[CurrentProductDetails] [CPD]#(lf)            ) AS CPD#(lf)                ON TRIM([ID].[ItemNumber]) = [CPD].[Item SKU]#(lf)            WHERE TRIM([ID].[Warehouse]) IN ('1', '1A', '15', '15A', '17', '17A', '19', '28', '28A', '5', '5A', '335', 'ECR', 'ECA')#(lf)            GROUP BY [Customer Group]#(lf)                , [CPD].[Collective Class]#(lf)                , [ID].[Warehouse]#(lf)                , [D3].[DateID]#(lf)                , [D].[FiscalMonthYear]#(lf)                , [D3].[FiscalMonthYear]#(lf)            ) TEMP#(lf)        ) INV#(lf)        ON [DFC].[Customer Group] = [INV].[CustomerGroup]#(lf)            AND [DFC].[Warehouse] = [INV].[Warehouse]#(lf)            AND [DFC].[Collective Class] = [INV].[Collective Class]#(lf)            AND [DFC].[dfcFiscalMonth] = [INV].[FiscalMonthYear]#(lf)            AND [DFC].[dfcSnapshot] = [INV].[InvoiceDate]#(lf)    ) MTD;#(lf)#(lf)SELECT COALESCE([Collective Class], 'CUSTOMER LEVEL') [Collective Class]#(lf)    , COALESCE([Customer Group], 'COMPANY LEVEL') [Customer Group]#(lf)    , [Warehouse]#(lf)    , [Day of Month]#(lf)    , [Weeks in Month]#(lf)    -- , [DayAct]#(lf)    -- , [MonthEndAct]#(lf)    , [Goal Consumption]#(lf)FROM (#(lf)    SELECT [Collective Class]#(lf)        , [Customer Group]#(lf)        , [Warehouse]#(lf)        , [Day of Month]#(lf)        , [Weeks in Month]#(lf)        -- , SUM([DayAct]) [DayAct]#(lf)        -- , SUM([MonthEndAct]) [MonthEndAct]#(lf)        , SUM([DayAct]) / SUM([MonthEndAct]) [Goal Consumption]#(lf)    FROM (#(lf)        SELECT [DACT].[Collective Class]#(lf)            , [DACT].[Customer Group]#(lf)            , [DACT].[Warehouse]#(lf)            , [DACT].[FiscalDayOfMonth] [Day of Month]#(lf)            , [MACT].[Weeks in Month]#(lf)            , CASE #(lf)                WHEN [DACT].[dfcOrderFutureQty] > [MACT].[dfcOrderFutureQty]#(lf)                    THEN [MACT].[dfcOrderFutureQty]#(lf)                ELSE [DACT].[dfcOrderFutureQty]#(lf)                END AS [DayAct]#(lf)            , [MACT].[dfcOrderFutureQty] [MonthEndAct]#(lf)        FROM #WH_MTD [DACT]#(lf)        LEFT JOIN (#(lf)            SELECT [Collective Class]#(lf)                , [Customer Group]#(lf)                , [Warehouse]#(lf)                , [dfcFiscalMonth]#(lf)                , [dfcSnapshot]#(lf)                , [Weeks in Month]#(lf)                , [dfcOrderFutureQty]#(lf)            FROM #WH_MTD [DFC]#(lf)            INNER JOIN (#(lf)                SELECT [FiscalMonth]#(lf)                    , [FiscalMonthLastDate]#(lf)                    , [FiscalMonthYear]#(lf)                    , COUNT(DISTINCT [FiscalWeekLastDate]) AS [Weeks in Month]#(lf)                FROM [Enterprise_DW].[DimDate]#(lf)                WHERE [FiscalMonthIndicator] BETWEEN - 24 AND - 1#(lf)                GROUP BY [FiscalMonth]#(lf)                    , [FiscalMonthLastDate]#(lf)                    , [FiscalMonthYear]#(lf)                ) AS DD#(lf)                ON CONVERT(DATE, [DFC].[dfcSnapshot]) = [DD].[FiscalMonthLastDate]#(lf)                    AND [DFC].[dfcFiscalMonth] = [DD].[FiscalMonthYear]#(lf)            ) [MACT]#(lf)            ON [DACT].[Customer Group] = [MACT].[Customer Group]#(lf)                AND [DACT].[Collective Class] = [MACT].[Collective Class]#(lf)                AND [DACT].[Warehouse] = [MACT].[Warehouse]#(lf)                AND [DACT].[dfcFiscalMonth] = [MACT].[dfcFiscalMonth]#(lf)        WHERE [MACT].[dfcOrderFutureQty] > 0#(lf)            AND [DACT].[FiscalDayOfMonth] IS NOT NULL#(lf)        ) goal#(lf)    GROUP BY ROLLUP (#(lf)        ( [Day of Month]#(lf)        , [Weeks in Month]#(lf)         , [Warehouse] #(lf)#(tab)#(tab))#(lf)#(tab)#(tab), [Customer Group]#(lf)        , [Collective Class]#(lf)    )#(lf)    ) goal_consumption#(lf)#(tab)#(lf)UNION ALL #(lf)#(lf)SELECT COALESCE([Collective Class], 'CUSTOMER LEVEL') [Collective Class]#(lf)    , 'COMPANY LEVEL' AS [Customer Group]#(lf)    , [Warehouse]#(lf)    , [Day of Month]#(lf)    , [Weeks in Month]#(lf)    -- , [DayAct]#(lf)    -- , [MonthEndAct]#(lf)    , [Goal Consumption]#(lf)FROM (#(lf)    SELECT [Collective Class]#(lf)        --, [Customer Group]#(lf)        , [Warehouse]#(lf)        , [Day of Month]#(lf)        , [Weeks in Month]#(lf)        -- , SUM([DayAct]) [DayAct]#(lf)        -- , SUM([MonthEndAct]) [MonthEndAct]#(lf)        , SUM([DayAct]) / SUM([MonthEndAct]) [Goal Consumption]#(lf)    FROM (#(lf)        SELECT [DACT].[Collective Class]#(lf)            , [DACT].[Customer Group]#(lf)            , [DACT].[Warehouse]#(lf)            , [DACT].[FiscalDayOfMonth] [Day of Month]#(lf)            , [MACT].[Weeks in Month]#(lf)            , CASE #(lf)                WHEN [DACT].[dfcOrderFutureQty] > [MACT].[dfcOrderFutureQty]#(lf)                    THEN [MACT].[dfcOrderFutureQty]#(lf)                ELSE [DACT].[dfcOrderFutureQty]#(lf)                END AS [DayAct]#(lf)            , [MACT].[dfcOrderFutureQty] [MonthEndAct]#(lf)        FROM #WH_MTD [DACT]#(lf)        LEFT JOIN (#(lf)            SELECT [Collective Class]#(lf)                , [Customer Group]#(lf)                , [Warehouse]#(lf)                , [dfcFiscalMonth]#(lf)                , [dfcSnapshot]#(lf)                , [Weeks in Month]#(lf)                , [dfcOrderFutureQty]#(lf)            FROM #WH_MTD [DFC]#(lf)            INNER JOIN (#(lf)                SELECT [FiscalMonth]#(lf)                    , [FiscalMonthLastDate]#(lf)                    , [FiscalMonthYear]#(lf)                    , COUNT(DISTINCT [FiscalWeekLastDate]) AS [Weeks in Month]#(lf)                FROM [Enterprise_DW].[DimDate]#(lf)                WHERE [FiscalMonthIndicator] BETWEEN - 24 AND - 1#(lf)                GROUP BY [FiscalMonth]#(lf)                    , [FiscalMonthLastDate]#(lf)                    , [FiscalMonthYear]#(lf)                ) AS DD#(lf)                ON CONVERT(DATE, [DFC].[dfcSnapshot]) = [DD].[FiscalMonthLastDate]#(lf)                    AND [DFC].[dfcFiscalMonth] = [DD].[FiscalMonthYear]#(lf)            ) [MACT]#(lf)            ON [DACT].[Customer Group] = [MACT].[Customer Group]#(lf)                AND [DACT].[Collective Class] = [MACT].[Collective Class]#(lf)                AND [DACT].[Warehouse] = [MACT].[Warehouse]#(lf)                AND [DACT].[dfcFiscalMonth] = [MACT].[dfcFiscalMonth]#(lf)        WHERE [MACT].[dfcOrderFutureQty] > 0#(lf)            AND [DACT].[FiscalDayOfMonth] IS NOT NULL#(lf)        ) goal#(lf)    GROUP BY#(lf)          [Day of Month]#(lf)        , [Weeks in Month]#(lf)        , [Warehouse] #(lf)        , [Collective Class]#(lf)    ) goal_consumption\", CreateNavigationProperties=false]),","    #\"Added Custom\" = Table.AddColumn(Source, \"CusCC\", each [Customer Group]&[Collective Class])","in","    #\"Added Custom\""],"type":"m"}}]},{"name":"Fact L3 Forecast Model","annotations":[{"name":"PBI_NavigationStepName","value":"Navigation"},{"name":"PBI_ResultType","value":"Table"}],"columns":[{"name":"SCP_SEQ_NBR","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"be0a8ca5-1052-4528-b9d1-00a58d3aae6c","sourceColumn":"SCP_SEQ_NBR","summarizeBy":"sum"},{"name":"LVL_NBR","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"6ec871f6-2a01-41c3-a03c-698071d185ce","sourceColumn":"LVL_NBR","summarizeBy":"sum"},{"name":"CustomerGroup","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"71c079f9-8e7b-480c-ab02-69eb60d162c8","sourceColumn":"CustomerGroup","summarizeBy":"none"},{"name":"CollectiveClass","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"c9d876b1-10ad-4b68-9c51-27f6c7bb5e0c","sourceColumn":"CollectiveClass","summarizeBy":"none"},{"name":"FCST_2_ID","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"ab6412ff-eabb-4635-a169-2e5d4c5a1d46","sourceColumn":"FCST_2_ID","summarizeBy":"none"},{"name":"FCST_3_ID","annotations"