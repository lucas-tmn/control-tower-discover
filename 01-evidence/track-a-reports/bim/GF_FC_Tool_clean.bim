\", \"Lag90\"","    , \"60 Days\", \"Lag60\"","    , \"30 Days\", \"Lag30\"","    , \"2 Weeks\", \"Lag2w\"",")"],"isDataTypeInferred":true,"lineageTag":"4c15b85d-18ee-4f97-8907-be1bc4cbac4c","summarizeBy":"none","type":"calculated"},{"name":"Sorted","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","expression":["","SWITCH(","    [KPI]","    , \"Forecast\", 1","    , \"Demand\", 2","    , \"Net Error\", 3","    , \"Bias\", 4","    , \"wMAPE\", 5",")"],"formatString":"0","isDataTypeInferred":true,"lineageTag":"ea101970-1b1f-4236-9168-e33a95e5f6ec","summarizeBy":"sum","type":"calculated"}],"lineageTag":"73100b8d-d6c0-41d4-ae5a-d8deedc5ce2d","measures":[{"name":"Selection","expression":["","VAR _KPI = MAX('Dynamic Fields (FC Accuracy)'[KPI])","VAR _Value = ","    SWITCH(","        _KPI,","        \"Forecast\", [Total Forecast],","        \"Demand\", [Total Demand],","        \"Net Error\", [Forecast Error],","        \"Bias\", [Forecast Bias],","        \"wMAPE\", [L1 PRSLF wMAPE]","    )","VAR _Format = ","    SWITCH(","        _KPI,","        \"Bias\", \"#,0.0%\",","        \"wMAPE\", \"#,0.0%\",","        \"Forecast\", \"#,0\",","        \"Demand\", \"#,0\",","        \"Net Error\", \"#,0\"","    )","RETURN","    IF(","        ISBLANK(_KPI) || ISBLANK(_Value),","        BLANK(),","        FORMAT(_Value, _Format)","    )"],"lineageTag":"3ca84fdd-cd0f-48b4-befe-c2be88ae9431"}],"partitions":[{"name":"Dynamic Fields (FC Accuracy)","mode":"import","source":{"expression":["","CROSSJOIN(","    DATATABLE(","        \"Horizon\", STRING, {{\"120 Days\"}, {\"90 Days\"}, {\"60 Days\"}, {\"60 Days\"}, {\"30 Days\"}, {\"2 Weeks\"}}),","    DATATABLE(","        \"KPI\", STRING, {{\"Forecast\"}, {\"Demand\"}, {\"Net Error\"}, {\"Bias\"}, {\"wMAPE\"}})",")"],"type":"calculated"}}]},{"name":"Parameter Cur Goal Cons%","annotations":[{"name":"PBI_Id","value":"f63b6338b2bf48bb83a379ed44102476"}],"columns":[{"name":"Parameter Cur Goal Cons%","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","isDataTypeInferred":true,"isNameInferred":false,"lineageTag":"c520a7bc-6c7c-4107-86fb-49acbb7b815c","relatedColumnDetails":{"groupByColumns":[{"groupingColumn":"Parameter Cur Goal Cons% Fields"}]},"sortByColumn":"Parameter Cur Goal Cons% Order","sourceColumn":"[Value1]","summarizeBy":"none","type":"calculatedTableColumn"},{"name":"Parameter Cur Goal Cons% Fields","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","extendedProperties":[{"name":"ParameterMetadata","type":"json","value":{"kind":2,"version":3}}],"isDataTypeInferred":true,"isHidden":true,"isNameInferred":false,"lineageTag":"961c92e5-46e7-4fd8-bc1c-d07a22abc679","sortByColumn":"Parameter Cur Goal Cons% Order","sourceColumn":"[Value2]","summarizeBy":"none","type":"calculatedTableColumn"},{"name":"Parameter Cur Goal Cons% Order","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"0","isDataTypeInferred":true,"isHidden":true,"isNameInferred":false,"lineageTag":"709fb333-24a3-4662-9bbd-ee99d35a76fb","sourceColumn":"[Value3]","summarizeBy":"sum","type":"calculatedTableColumn"}],"lineageTag":"a5498796-1a89-4765-bf06-0db9741323d8","partitions":[{"name":"Parameter Cur Goal Cons%","mode":"import","source":{"expression":["{","    (\"Collective Class\", NAMEOF('Dim Collective Class'[Collective Class]), 0),","    (\"Item Ext Series Number\", NAMEOF('Dim Series'[Item Ext Series Number]), 1),","    (\"Item SKU\", NAMEOF('Dim Product Detail'[Item SKU]), 2),","    (\"Warehouse Code\", NAMEOF('Dim Warehouse'[Warehouse Code]), 3)","}"],"type":"calculated"}}]},{"name":"Fact BedroomDining Balancing","annotations":[{"name":"PBI_NavigationStepName","value":"Navigation"},{"name":"PBI_ResultType","value":"Table"}],"columns":[{"name":"Level","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"4b290a2e-4d6f-4a7c-90c4-e7a49454f571","sourceColumn":"Level","summarizeBy":"none"},{"name":"Metric","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"8b5e6925-da77-46c1-98dc-09e7dfeac892","sourceColumn":"Metric","summarizeBy":"none"},{"name":"Warehouse","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"f7ae3b23-d4c7-4aed-a264-d2a60d0b18f1","sourceColumn":"Warehouse","summarizeBy":"none"},{"name":"Collective Class","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"b6a28d94-9f18-4411-9320-b96316d934cf","sourceColumn":"Collective Class","summarizeBy":"none"},{"name":"Comparison Type","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"eb18caf0-12e2-46df-9390-08cfe198d390","sourceColumn":"Comparison Type","summarizeBy":"none"},{"name":"Series Number","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"d7da28ee-5266-417d-bf73-5f856620e9e0","sourceColumn":"Series Number","summarizeBy":"none"},{"name":"Bed Size","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"c247c285-b5b6-4519-a0ce-899de3ff08e6","sourceColumn":"Bed Size","summarizeBy":"none"},{"name":"Component Type","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"27e4cbf4-b216-4073-b719-59d1dc9db38e","sourceColumn":"Component Type","summarizeBy":"none"},{"name":"Forecast","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"f1c9dd45-25e6-4b76-b835-649973385ce2","sourceColumn":"Forecast","summarizeBy":"sum"},{"name":"Max Forecast","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"6254b98f-e56f-4dcf-be44-8b8cf2424c8d","sourceColumn":"Max Forecast","summarizeBy":"sum"},{"name":"Imbalance Ratio by FC","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"2e792848-3658-4de7-97a9-061b10b17591","sourceColumn":"Imbalance Ratio by FC","summarizeBy":"sum"},{"name":"Imbalance by FC","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"608bc136-e338-4f0c-bed9-81bc1279753f","sourceColumn":"Imbalance by FC","summarizeBy":"none"},{"name":"Safety Stock","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"790ced82-bf8f-4744-8bc3-1a1ffb257d63","sourceColumn":"Safety Stock","summarizeBy":"sum"},{"name":"Max Safety Stock","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"ccdc7c2e-af48-464e-8952-f3d39b09f97f","sourceColumn":"Max Safety Stock","summarizeBy":"sum"},{"name":"Imbalance Ratio by SS","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"60e2371b-bf19-49a9-a38e-cd742c503199","sourceColumn":"Imbalance Ratio by SS","summarizeBy":"sum"},{"name":"Imbalance by SS","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"cb5498d0-6361-4bec-8ef9-21a182448ee0","sourceColumn":"Imbalance by SS","summarizeBy":"none"},{"name":"L12M ACTD","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"498df253-a9b1-4a1f-b33b-242e7cbb05c6","sourceColumn":"L12M ACTD","summarizeBy":"sum"},{"name":"Max Demand","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"b5c1d30f-604a-49a3-bc85-bd0a77ad5ee3","sourceColumn":"Max Demand","summarizeBy":"sum"},{"name":"Imbalance Ratio by Demand","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"double","formatString":"0.0%;-0.0%;0.0%","lineageTag":"8f3d2171-0271-4f71-9a1e-3c3986cc3b5f","sourceColumn":"Imbalance Ratio by Demand","summarizeBy":"sum"},{"name":"Imbalance by Demand","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"3e7ff4e4-1c54-47ce-a116-9b075fd6ee87","sourceColumn":"Imbalance by Demand","summarizeBy":"none"},{"name":"Ratio Difference","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"dfa46bbb-6e5e-4e47-a26e-6f034fc7f17c","sourceColumn":"Ratio Difference","summarizeBy":"sum"},{"name":"Imbalance reason","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"12598388-b653-48e1-b136-d383306d0ed9","sourceColumn":"Imbalance reason","summarizeBy":"none"},{"name":"Imbalance Flag","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","expression":["","IF(","    ISBLANK('Fact BedroomDining Balancing'[Imbalance reason]) || 'Fact BedroomDining Balancing'[Imbalance reason] = \"\"","    , \"No\"","    , \"Imbalance\"",")"],"isDataTypeInferred":true,"lineageTag":"b5c5da41-a005-4807-ab60-3c7d04817769","summarizeBy":"none","type":"calculated"}],"lineageTag":"e1f42697-6ee0-4e05-a55f-d872fa0a3d1c","partitions":[{"name":"Fact BedroomDining Balancing","mode":"import","queryGroup":"Fact Query","source":{"expression":["let","    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"-- ================================================================#(lf)-- UNIFIED BALANCING QUERY#(lf)-- Replaces all 8 separate SQL queries (aa through hh).#(lf)--#(lf)-- Optimization summary vs. original:#(lf)--   DimCurrentProductDetails   : 8 scans -> 2 (BED + DIN)#(lf)--   DemandForecastSnapshot     : 4 scans -> 2 (Company + WH)#(lf)--   ForecastCommonContainer    : 8 scans -> 2 (Company + WH)#(lf)--   PlanDetailTimelineSnapshot : 4 scans -> 2 (Company + WH)#(lf)--   MAX subqueries             : computed per-query -> 3 shared CTEs#(lf)--   DIM_FISCAL subquery        : 4 scans -> 1 shared CTE#(lf)--   JOIN change on snapshots   : correlated subquery -> INNER JOIN (sargable)#(lf)--#(lf)-- Output columns (all 8 original outputs unified):#(lf)--   Level, Metric, Warehouse, Collective Class, Comparison Type,#(lf)--   Series Number, Bed Size, Component Type,#(lf)--   Forecast, Max Forecast, Imbalance Ratio by FC, Imbalance by FC,#(lf)--   Safety Stock, Max Safety Stock, Imbalance Ratio by SS, Imbalance by SS,#(lf)--   L12M ACTD, Max Demand, Imbalance Ratio by Demand, Imbalance by Demand,#(lf)--   Ratio Difference, Imbalance reason#(lf)-- ================================================================#(lf)#(lf)WITH#(lf)#(lf)-- ================================================================#(lf)-- PHASE 1: SNAPSHOT ANCHORS (each computed once)#(lf)-- Replaces inline correlated subqueries that ran once per segment.#(lf)-- Changed to INNER JOIN in fact CTEs for better sargability.#(lf)-- ================================================================#(lf)MAX_FC_SNAPSHOT AS (#(lf)    SELECT MAX([dfcSnapshot]) AS [Val]#(lf)    FROM [SupplyChain_Enh].[DemandForecastSnapshot]#(lf)),#(lf)MAX_DEMAND_DATE AS (#(lf)    SELECT MAX([FileDate]) AS [Val]#(lf)    FROM [SupplyChain_Enh].[ForecastCommonContainer_Logility]#(lf)),#(lf)MAX_SS_SNAPSHOT AS (#(lf)    SELECT MAX([SnapshotDate]) AS [Val]#(lf)    FROM [SupplyChain_Enh].[PlanDetailTimelineSnapshot]#(lf)),#(lf)DIM_FISCAL AS (#(lf)    SELECT DISTINCT [FiscalMonthYear], [FiscalMonthIndicator]#(lf)    FROM [Enterprise_DW].[DimDate_NonRetail]#(lf)),#(lf)#(lf)-- ================================================================#(lf)-- PHASE 2: PRODUCT DIMENSION - BEDROOM (was repeated 6 times)#(lf)-- ================================================================#(lf)DIM_BED AS (#(lf)    SELECT#(lf)        'BEDROOM'                               AS [Collective Class],#(lf)        TRIM(CPD.[Item Ext Series Number])      AS [Series Number],#(lf)        TRIM(CPD.[Item SKU])                    AS [Item SKU],#(lf)        CASE#(lf)            WHEN CPD.[Item Description] LIKE 'Q/K/CK%'                THEN 'Queen/King/Cal King Bed'#(lf)            WHEN CPD.[Item Description] LIKE '%QUEEN/KING%'            THEN 'Queen/King/Cal King Bed'#(lf)            WHEN CPD.[Item Description] LIKE '%CAL%KING%'#(lf)              OR CPD.[Item Description] LIKE '%CALIFORNIA%KING%'#(lf)              OR CPD.[Item Description] LIKE 'CK %'                    THEN 'Cal King Bed'#(lf)            WHEN CPD.[Item Description] LIKE '%King%Cal%'#(lf)              OR CPD.[Item Description] LIKE '%K/CK%'#(lf)              OR CPD.[Item Description] LIKE '%K/CAL%'#(lf)              THEN CASE WHEN CPD.[Item Description] NOT LIKE 'Q%'      THEN 'K/CK Bed' ELSE 'Other' END#(lf)            WHEN CPD.[Item Description] LIKE '%Queen%'#(lf)              OR CPD.[Item Description] LIKE '%Q %'#(lf)              OR CPD.[Item Description] LIKE 'Q %'#(lf)              OR CPD.[Item Description] LIKE '%QN %'#(lf)              THEN CASE WHEN CPD.[Item Description] NOT LIKE '%QUEEN/%' THEN 'Queen Bed' ELSE 'Other' END#(lf)            WHEN CPD.[Item Description] LIKE '%King%'#(lf)              OR CPD.[Item Description] LIKE '%KING %'#(lf)              OR CPD.[Item Description] LIKE 'K %'#(lf)              OR CPD.[Item Description] LIKE 'KG %'#(lf)              THEN CASE#(lf)                  WHEN CPD.[Item Description] NOT LIKE '%Cal%'#(lf)                   AND CPD.[Item Description] NOT LIKE 'CK%'#(lf)                   AND CPD.[Item Description] NOT LIKE '%QUEEN/%'#(lf)                   AND CPD.[Item Description] NOT LIKE '%Twin%'#(lf)                   AND CPD.[Item Description] NOT LIKE '%full%'#(lf)                   AND CPD.[Item Description] NOT LIKE '%T/F%'#(lf)                   AND CPD.[Item Description] NOT LIKE '%Q/K%' THEN 'King Bed'#(lf)                  ELSE 'Other' END#(lf)            WHEN CPD.[Item Description] LIKE '%QUEEN%KING%'#(lf)              OR CPD.[Item Description] LIKE '%Q/K%'#(lf)              THEN CASE WHEN CPD.[Item Description] NOT LIKE '%CK%'   THEN 'Queen/King Bed' ELSE 'Other' END#(lf)            WHEN CPD.[Item Description] LIKE '%Twin%Full%'#(lf)              OR CPD.[Item Description] LIKE '%T/F%'#(lf)              THEN CASE WHEN CPD.[Item Description] NOT LIKE '%Queen%' AND CPD.[Item Description] NOT LIKE '%King%' THEN 'Twin/Full Bed' ELSE 'Other' END#(lf)            WHEN CPD.[Item Description] LIKE '%full%'#(lf)              OR CPD.[Item Description] LIKE 'F %'#(lf)              OR CPD.[Item Description] LIKE '%F '#(lf)              THEN CASE WHEN CPD.[Item Description] NOT LIKE '%Twin%'  AND CPD.[Item Description] NOT LIKE '%QUEEN%' AND CPD.[Item Description] NOT LIKE '%King%' AND CPD.[Item Description] NOT LIKE '%QN%' THEN 'Full Bed' ELSE 'Other' END#(lf)            WHEN CPD.[Item Description] LIKE '%twin%'#(lf)              OR CPD.[Item Description] LIKE 'T %'#(lf)              OR CPD.[Item Description] LIKE '%T '#(lf)              THEN CASE WHEN CPD.[Item Description] NOT LIKE '%full%'  THEN 'Twin Bed' ELSE 'Other' END#(lf)            WHEN CPD.[Item Description] LIKE '%UNDER BED STORAGE%'#(lf)              OR CPD.[Item Description] LIKE '%UNDER%BED%STORAGE%'#(lf)              OR CPD.[Item Description] LIKE '%UNDERBED%STORAGE%'      THEN 'T/F'#(lf)            ELSE 'Other'#(lf)        END AS [Bed Size Detail],#(lf)        CASE#(lf)            WHEN CPD.[Item Description] LIKE '% POSTS %' OR CPD.[Item Description] LIKE '% POSTS' OR CPD.[Item Description] LIKE '% POST %' OR CPD.[Item Description] LIKE '% POST' THEN 'POSTS'#(lf)            WHEN CPD.[Item Description] LIKE '% BED'     OR CPD.[Item Description] LIKE '%BED%W/ROLL SLATS%' OR CPD.[Item Description] LIKE '%DAYBED%' OR CPD.[Item Description] LIKE '%BUNK BED W/LADDER%' THEN 'Combo'#(lf)            WHEN CPD.[Item Description] LIKE '%HB/FB%CANOPY%' THEN 'HB/FB Canopy'#(lf)            WHEN CPD.[Item Description] LIKE '%BUNK BED PANELS%' OR CPD.[Item Description] LIKE '%FTBD%HDBD%' OR CPD.[Item Description] LIKE '%HD%FT%' OR CPD.[Item Description] LIKE '%Head%Foot%' OR CPD.[Item Description] LIKE '%HB/FB%' OR CPD.[Item Description] LIKE '%HB/%FB%' THEN 'HB/FB'#(lf)            WHEN (CPD.[Item Description] LIKE '%FOOTBOARD W/RAILS%' OR CPD.[Item Description] LIKE '%FTBD W/RAILS%' OR CPD.[Item Description] LIKE '%FOOTBOARD/RAILS%' OR CPD.[Item Description] LIKE '%FTBD/RAILS%' OR CPD.[Item Description] LIKE '%FOOTBOARD AND RAILS%' OR CPD.[Item Description] LIKE '%FOOTBOARD WITH RAILS%')#(lf)             AND CPD.[Item Description] NOT LIKE '%HDBD%' AND CPD.[Item Description] NOT LIKE '%HEAD%' AND CPD.[Item Description] NOT LIKE '%HB%' THEN 'FB/Rails'#(lf)            WHEN (CPD.[Item Description] LIKE '%FTBD%' OR CPD.[Item Description] LIKE '%FT%' OR CPD.[Item Description] LIKE '%Foot%')#(lf)             AND CPD.[Item Description] NOT LIKE '%HDBD%' AND CPD.[Item Description] NOT LIKE '%head%' THEN 'Footboard'#(lf)            WHEN (CPD.[Item Description] LIKE '%HDBD%' OR CPD.[Item Description] LIKE '%head%')#(lf)             AND CPD.[Item Description] NOT LIKE '%FTBD%' AND CPD.[Item Description] NOT LIKE '%FT%' AND CPD.[Item Description] NOT LIKE '%Foot%' THEN 'Headboard'#(lf)            WHEN CPD.[Item Description] LIKE '%Rail%'#(lf)             AND CPD.[Item Description] NOT LIKE '%FTBD%' AND CPD.[Item Description] NOT LIKE '%FT%' AND CPD.[Item Description] NOT LIKE '%Foot%' AND CPD.[Item Description] NOT LIKE '%HDBD%' AND CPD.[Item Description] NOT LIKE '%head%' THEN 'Rails'#(lf)            WHEN CPD.[Item Description] LIKE '%UNDER BED STORAGE%' OR CPD.[Item Description] LIKE '%UNDER%BED%STORAGE%' OR CPD.[Item Description] LIKE '%UNDERBED%STORAGE%' THEN 'Rails Under Bed Storage'#(lf)            WHEN CPD.[Item Description] LIKE '%POSTER%Rail%' THEN 'Rail Poster'#(lf)            ELSE ''#(lf)        END AS [Component Type Detail]#(lf)    FROM [SupplyChain_DW].[DimCurrentProductDetails] AS CPD#(lf)    WHERE CPD.[Item Ext Series Number] <> ''#(lf)      AND CPD.[Current Status]          NOT IN ('D')#(lf)      AND CPD.[Item Forecast PLanner ID] <> ''#(lf)      AND CPD.[Item Code]               = 'Bed'#(lf)      AND CPD.[Collective Class]        = 'BEDROOM'#(lf)),#(lf)#(lf)-- ================================================================#(lf)-- PHASE 3: PRODUCT DIMENSION - DINING (was repeated 4 times)#(lf)-- ================================================================#(lf)DIM_DIN AS (#(lf)    SELECT#(lf)        'DINING'                                AS [Collective Class],#(lf)        TRIM(CPD.[Item Ext Series Number])      AS [Series Number],#(lf)        TRIM(CPD.[Item SKU])                    AS [Item SKU],#(lf)        'N/A'                                   AS [Bed Size Detail],#(lf)        CASE#(lf)            WHEN CPD.[Item Description] LIKE '%TABLE BASE%' OR CPD.[Item Description] LIKE 'TBL BASE' THEN 'Table Base'#(lf)            WHEN CPD.[Item Description] LIKE '%TABLE TOP%'  OR CPD.[Item Description] LIKE 'TBL TOP'  THEN 'Table Top'#(lf)            ELSE ''#(lf)        END AS [Component Type Detail]#(lf)    FROM [SupplyChain_DW].[DimCurrentProductDetails] AS CPD#(lf)    WHERE CPD.[Item Ext Series Number] <> ''#(lf)      AND CPD.[Collective Class]        = 'DINING'#(lf)      AND CPD.[Current Status]          NOT IN ('D')#(lf)      AND CPD.[Item Forecast PLanner ID] <> ''#(lf)),#(lf)#(lf)-- ================================================================#(lf)-- PHASE 4: BEDROOM COMPONENT BRANCHES (unchanged logic)#(lf)-- ================================================================#(lf)BED_RAILS_HEAD AS (#(lf)    SELECT [Collective Class], 'Rails vs Headboard' AS [Comparison Type], [Series Number], [Item SKU],#(lf)        CASE#(lf)            WHEN [Bed Size Detail] IN ('Queen/King/Cal King Bed','K/CK Bed','King Bed','Queen Bed','Queen/King Bed','Cal King Bed') THEN 'C/K/Q Bed'#(lf)            WHEN [Bed Size Detail] IN ('Twin/Full Bed','Full Bed','Twin Bed','T/F') THEN 'T/F Bed'#(lf)            ELSE [Bed Size Detail]#(lf)        END AS [Bed Size],#(lf)        CASE#(lf)            WHEN [Component Type Detail] IN ('Headboard','HB/FB','HB/FB Canopy')                    THEN 'Headboard'#(lf)            WHEN [Component Type Detail] IN ('Rails','FB/Rails','Rails Under Bed Storage','Rail Poster') THEN 'Rails'#(lf)            ELSE ''#(lf)        END AS [Component Type]#(lf)    FROM DIM_BED#(lf)),#(lf)BED_HEAD_FOOT AS (#(lf)    SELECT [Collective Class], 'Headboard vs Footboard' AS [Comparison Type], [Series Number], [Item SKU],#(lf)        CASE#(lf)            WHEN [Bed Size Detail] IN ('Cal King Bed','K/CK Bed','King Bed') THEN 'K/CK Bed'#(lf)            WHEN [Bed Size Detail]  = 'Queen Bed'                            THEN 'Queen Bed'#(lf)            ELSE [Bed Size Detail]#(lf)        END AS [Bed Size],#(lf)        CASE#(lf)            WHEN [Component Type Detail] IN ('HB/FB','HB/FB Canopy') THEN 'HB/FB'#(lf)            WHEN [Component Type Detail] IN ('Footboard','FB/Rails')  THEN 'Footboard'#(lf)            WHEN [Component Type Detail]  = 'Headboard'               THEN 'Headboard'#(lf)            ELSE ''#(lf)        END AS [Component Type]#(lf)    FROM DIM_BED#(lf)),#(lf)FILTERED_BED AS (#(lf)    SELECT * FROM BED_RAILS_HEAD WHERE [Component Type] IN ('Headboard','Rails')#(lf)    UNION ALL#(lf)    SELECT * FROM BED_HEAD_FOOT WHERE [Component Type] IN ('Headboard','Footboard')#(lf)),#(lf)#(lf)-- ================================================================#(lf)-- PHASE 5: DINING COMPONENT BRANCH#(lf)-- ================================================================#(lf)FILTERED_DIN AS (#(lf)    SELECT#(lf)        [Collective Class],#(lf)        'Table Top vs Table Base' AS [Comparison Type],#(lf)        [Series Number], [Item SKU],#(lf)        [Bed Size Detail]       AS [Bed Size],#(lf)        [Component Type Detail] AS [Component Type]#(lf)    FROM DIM_DIN#(lf)    WHERE [Component Type Detail] IN ('Table Top','Table Base')#(lf)),#(lf)#(lf)-- ================================================================#(lf)-- PHASE 6: SHARED FACT SOURCES#(lf)-- Each source table is now scanned exactly ONCE per granularity level.#(lf)-- Correlated MAX subqueries replaced with INNER JOIN to snapshot CTEs.#(lf)-- ================================================================#(lf)#(lf)-- Forecast - Company level#(lf)FACT_FC_CO AS (#(lf)    SELECT DFC.[dfcItem] AS [Item SKU],#(lf)           SUM(DFC.[dfcResultantForecast] + DFC.[dfcPromotionalLift]) AS [Forecast]#(lf)    FROM [SupplyChain_Enh].[DemandForecastSnapshot] DFC#(lf)    INNER JOIN MAX_FC_SNAPSHOT  MX  ON DFC.[dfcSnapshot]      = MX.[Val]#(lf)    INNER JOIN DIM_FISCAL        DD  ON DFC.[dfcFiscalMonth]   = DD.[FiscalMonthYear]#(lf)    LEFT  JOIN [PowerBI_SupplyChain].[CurrentProductDetails] CPD ON DFC.[dfcItem] = CPD.[Item SKU]#(lf)    WHERE DD.[FiscalMonthIndicator] BETWEEN 0 AND 11#(lf)      AND CPD.[Manufacturing Status] NOT IN ('R','T','D')#(lf)    GROUP BY DFC.[dfcItem]#(lf)),#(lf)#(lf)-- Forecast - Warehouse level#(lf)FACT_FC_WH AS (#(lf)    SELECT DFC.[dfcWarehouse] AS [Warehouse],#(lf)           DFC.[dfcItem]      AS [Item SKU],#(lf)           SUM(DFC.[dfcResultantForecast] + DFC.[dfcPromotionalLift]) AS [Forecast]#(lf)    FROM [SupplyChain_Enh].[DemandForecastSnapshot] DFC#(lf)    INNER JOIN MAX_FC_SNAPSHOT  MX  ON DFC.[dfcSnapshot]      = MX.[Val]#(lf)    INNER JOIN DIM_FISCAL        DD  ON DFC.[dfcFiscalMonth]   = DD.[FiscalMonthYear]#(lf)    LEFT  JOIN [PowerBI_SupplyChain].[CurrentProductDetails] CPD ON DFC.[dfcItem] = CPD.[Item SKU]#(lf)    WHERE DD.[FiscalMonthIndicator] BETWEEN 0 AND 11#(lf)      AND CPD.[Manufacturing Status] NOT IN ('R','T','D')#(lf)    GROUP BY DFC.[dfcWarehouse], DFC.[dfcItem]#(lf)),#(lf)#(lf)-- Demand - Company level#(lf)FACT_DEMAND_CO AS (#(lf)    SELECT FCC.[Item-Lvl1] AS [Item SKU],#(lf)           SUM(ISNULL(FCC.[ACT_DEMD_0],0)+ISNULL(FCC.[ACT_DEMD_1],0)+ISNULL(FCC.[ACT_DEMD_2],0)+#(lf)               ISNULL(FCC.[ACT_DEMD_3],0)+ISNULL(FCC.[ACT_DEMD_4],0)+ISNULL(FCC.[ACT_DEMD_5],0)+#(lf)               ISNULL(FCC.[ACT_DEMD_6],0)+ISNULL(FCC.[ACT_DEMD_7],0)+ISNULL(FCC.[ACT_DEMD_8],0)+#(lf)               ISNULL(FCC.[ACT_DEMD_9],0)+ISNULL(FCC.[ACT_DEMD_10],0)+ISNULL(FCC.[ACT_DEMD_11],0)#(lf)           ) AS [L12M ACTD]#(lf)    FROM [SupplyChain_Enh].[ForecastCommonContainer_Logility] FCC#(lf)    INNER JOIN MAX_DEMAND_DATE   MD  ON FCC.[FileDate]         = MD.[Val]#(lf)    LEFT  JOIN [PowerBI_SupplyChain].[CurrentProductDetails] CPD ON FCC.[Item-Lvl1] = CPD.[Item SKU]#(lf)    WHERE FCC.[Location] IN ('1','15','17','28','335','5','ECR')#(lf)      AND CPD.[AFI Item Status]      NOT IN ('D','I','R','T')#(lf)      AND CPD.[Manufacturing Status] NOT IN ('Discontinued','Tentative')#(lf)    GROUP BY FCC.[Item-Lvl1]#(lf)),#(lf)#(lf)-- Demand - Warehouse level#(lf)FACT_DEMAND_WH AS (#(lf)    SELECT FCC.[Location]  AS [Warehouse],#(lf)           FCC.[Item-Lvl1] AS [Item SKU],#(lf)           SUM(ISNULL(FCC.[ACT_DEMD_0],0)+ISNULL(FCC.[ACT_DEMD_1],0)+ISNULL(FCC.[ACT_DEMD_2],0)+#(lf)               ISNULL(FCC.[ACT_DEMD_3],0)+ISNULL(FCC.[ACT_DEMD_4],0)+ISNULL(FCC.[ACT_DEMD_5],0)+#(lf)               ISNULL(FCC.[ACT_DEMD_6],0)+ISNULL(FCC.[ACT_DEMD_7],0)+ISNULL(FCC.[ACT_DEMD_8],0)+#(lf)               ISNULL(FCC.[ACT_DEMD_9],0)+ISNULL(FCC.[ACT_DEMD_10],0)+ISNULL(FCC.[ACT_DEMD_11],0)#(lf)           ) AS [L12M ACTD]#(lf)    FROM [SupplyChain_Enh].[ForecastCommonContainer_Logility] FCC#(lf)    INNER JOIN MAX_DEMAND_DATE   MD  ON FCC.[FileDate]         = MD.[Val]#(lf)    LEFT  JOIN [PowerBI_SupplyChain].[CurrentProductDetails] CPD ON FCC.[Item-Lvl1] = CPD.[Item SKU]#(lf)    WHERE FCC.[Location] IN ('1','15','17','28','335','5','ECR')#(lf)      AND CPD.[AFI Item Status]      NOT IN ('D','I','R','T')#(lf)      AND CPD.[Manufacturing Status] NOT IN ('Discontinued','Tentative')#(lf)    GROUP BY FCC.[Location], FCC.[Item-Lvl1]#(lf)),#(lf)#(lf)-- Safety Stock - Company level#(lf)FACT_SS_CO AS (#(lf)    SELECT PTL.PTLITNBR AS [Item SKU],#(lf)           CAST(#(lf)               (SUM(PTL.PTLWEEK1)+SUM(PTL.PTLWEEK2)+SUM(PTL.PTLWEEK3)+SUM(PTL.PTLWEEK4)+#(lf)                SUM(PTL.PTLWEEK5)+SUM(PTL.PTLWEEK6)+SUM(PTL.PTLWEEK7)+SUM(PTL.PTLWEEK8)) * 1.0#(lf)               / NULLIF(#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK1)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK2)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK3)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK4)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK5)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK6)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK7)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK8)<>0 THEN 1 ELSE 0 END), 0)#(lf)           AS DECIMAL(18,4)) AS [Avg_Safety_Stock]#(lf)    FROM [SupplyChain_Enh].[PlanDetailTimelineSnapshot] PTL#(lf)    INNER JOIN MAX_SS_SNAPSHOT MS ON PTL.[SnapshotDate] = MS.[Val]#(lf)    WHERE PTL.PTLDATATYPE = 'SAFETY STK'#(lf)    GROUP BY PTL.PTLITNBR#(lf)),#(lf)#(lf)-- Safety Stock - Warehouse level#(lf)FACT_SS_WH AS (#(lf)    SELECT PTL.PTLWHSE   AS [Warehouse],#(lf)           PTL.PTLITNBR  AS [Item SKU],#(lf)           CAST(#(lf)               (SUM(PTL.PTLWEEK1)+SUM(PTL.PTLWEEK2)+SUM(PTL.PTLWEEK3)+SUM(PTL.PTLWEEK4)+#(lf)                SUM(PTL.PTLWEEK5)+SUM(PTL.PTLWEEK6)+SUM(PTL.PTLWEEK7)+SUM(PTL.PTLWEEK8)) * 1.0#(lf)               / NULLIF(#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK1)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK2)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK3)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK4)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK5)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK6)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK7)<>0 THEN 1 ELSE 0 END)+#(lf)                   (CASE WHEN SUM(PTL.PTLWEEK8)<>0 THEN 1 ELSE 0 END), 0)#(lf)           AS DECIMAL(18,4)) AS [Avg_Safety_Stock]#(lf)    FROM [SupplyChain_Enh].[PlanDetailTimelineSnapshot] PTL#(lf)    INNER JOIN MAX_SS_SNAPSHOT MS ON PTL.[SnapshotDate] = MS.[Val]#(lf)    WHERE PTL.PTLDATATYPE = 'SAFETY STK'#(lf)    GROUP BY PTL.PTLWHSE, PTL.PTLITNBR#(lf)),#(lf)#(lf)-- ================================================================#(lf)-- PHASE 7: REUSABLE PIPELINE MACRO (applied 8 times via naming)#(lf)--#(lf)-- Pattern per segment:#(lf)--   _GRID   -> BASE_GRID  (active dimension combinations)#(lf)--   _AGG    -> aggregated primary metric onto grid#(lf)--   _DAGG   -> aggregated demand onto grid#(lf)--   _DATA   -> GRID + left joins to _AGG and _DAGG#(lf)--   _MAX    -> window MAX per partition#(lf)--   _RATIO  -> imbalance ratio calculation#(lf)--   _FLAGS  -> threshold flags#(lf)-- ================================================================#(lf)#(lf)-- ----------------------------------------------------------------#(lf)-- SEGMENT 1: BEDROOM | COMPANY | FORECAST#(lf)-- ----------------------------------------------------------------#(lf)BC_FC_ACTIVE AS (#(lf)    SELECT [Item SKU] FROM FACT_FC_CO#(lf)    UNION#(lf)    SELECT [Item SKU] FROM FACT_DEMAND_CO#(lf)),#(lf)BC_FC_MAPPED AS (#(lf)    SELECT DISTINCT D.[Comparison Type], D.[Series Number], D.[Bed Size]#(lf)    FROM BC_FC_ACTIVE A INNER JOIN FILTERED_BED D ON A.[Item SKU] = D.[Item SKU]#(lf)),#(lf)BC_FC_GRID AS (#(lf)    SELECT UC.[Collective Class], UC.[Comparison Type], AM.[Series Number], AM.[Bed Size], UC.[Component Type]#(lf)    FROM BC_FC_MAPPED AM#(lf)    INNER JOIN (SELECT DISTINCT [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type] FROM FILTERED_BED) UC#(lf)        ON AM.[Comparison Type]=UC.[Comparison Type] AND AM.[Series Number]=UC.[Series Number] AND AM.[Bed Size]=UC.[Bed Size]#(lf)),#(lf)BC_FC_AGG AS (#(lf)    SELECT D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[Forecast]) AS [PrimaryVal]#(lf)    FROM FACT_FC_CO F INNER JOIN FILTERED_BED D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)BC_FC_DAGG AS (#(lf)    SELECT D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[L12M ACTD]) AS [L12M ACTD]#(lf)    FROM FACT_DEMAND_CO F INNER JOIN FILTERED_BED D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)BC_FC_DATA AS (#(lf)    SELECT G.*, ISNULL(A.[PrimaryVal],0) AS [PrimaryVal], ISNULL(D.[L12M ACTD],0) AS [L12M ACTD]#(lf)    FROM BC_FC_GRID G#(lf)    LEFT JOIN BC_FC_AGG  A ON G.[Comparison Type]=A.[Comparison Type] AND G.[Series Number]=A.[Series Number] AND G.[Bed Size]=A.[Bed Size] AND G.[Component Type]=A.[Component Type]#(lf)    LEFT JOIN BC_FC_DAGG D ON G.[Comparison Type]=D.[Comparison Type] AND G.[Series Number]=D.[Series Number] AND G.[Bed Size]=D.[Bed Size] AND G.[Component Type]=D.[Component Type]#(lf)),#(lf)BC_FC_MAX AS (#(lf)    SELECT *,#(lf)        MAX([PrimaryVal])  OVER (PARTITION BY [Comparison Type],[Series Number],[Bed Size]) AS [MaxPrimary],#(lf)        MAX([L12M ACTD])   OVER (PARTITION BY [Comparison Type],[Series Number],[Bed Size]) AS [MaxDemand]#(lf)    FROM BC_FC_DATA#(lf)),#(lf)BC_FC_OUT AS (#(lf)    SELECT#(lf)        'Company' AS [Level], 'Forecast' AS [Metric], NULL AS [Warehouse],#(lf)        [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type],#(lf)        [PrimaryVal] AS [Forecast], [MaxPrimary] AS [Max Forecast],#(lf)        CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) AS [Imbalance Ratio by FC],#(lf)        CASE WHEN [MaxPrimary]>0 AND CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 THEN 'Imbalance' ELSE '' END AS [Imbalance by FC],#(lf)        NULL AS [Safety Stock], NULL AS [Max Safety Stock], NULL AS [Imbalance Ratio by SS], NULL AS [Imbalance by SS],#(lf)        [L12M ACTD], [MaxDemand] AS [Max Demand],#(lf)        CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4)) AS [Imbalance Ratio by Demand],#(lf)        CASE WHEN [MaxDemand]>0 AND CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.15 THEN 'Imbalance' ELSE '' END AS [Imbalance by Demand],#(lf)        CAST((CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) - CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))) AS DECIMAL(18,4)) AS [Ratio Difference],#(lf)        CASE#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 AND [MaxPrimary]>0#(lf)             AND CAST(CASE WHEN [MaxDemand]=0  THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.15  AND [MaxDemand]>0 THEN 'Customer behaviour'#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 AND [MaxPrimary]>0 THEN 'Not defined'#(lf)            ELSE ''#(lf)        END AS [Imbalance reason]#(lf)    FROM BC_FC_MAX#(lf)),#(lf)#(lf)-- ----------------------------------------------------------------#(lf)-- SEGMENT 2: BEDROOM | COMPANY | SAFETY STOCK#(lf)-- ----------------------------------------------------------------#(lf)BC_SS_ACTIVE AS (#(lf)    SELECT [Item SKU] FROM FACT_SS_CO#(lf)    UNION#(lf)    SELECT [Item SKU] FROM FACT_DEMAND_CO#(lf)),#(lf)BC_SS_MAPPED AS (#(lf)    SELECT DISTINCT D.[Comparison Type], D.[Series Number], D.[Bed Size]#(lf)    FROM BC_SS_ACTIVE A INNER JOIN FILTERED_BED D ON A.[Item SKU]=D.[Item SKU]#(lf)),#(lf)BC_SS_GRID AS (#(lf)    SELECT UC.[Collective Class],UC.[Comparison Type],AM.[Series Number],AM.[Bed Size],UC.[Component Type]#(lf)    FROM BC_SS_MAPPED AM#(lf)    INNER JOIN (SELECT DISTINCT [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type] FROM FILTERED_BED) UC#(lf)        ON AM.[Comparison Type]=UC.[Comparison Type] AND AM.[Series Number]=UC.[Series Number] AND AM.[Bed Size]=UC.[Bed Size]#(lf)),#(lf)BC_SS_AGG AS (#(lf)    SELECT D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[Avg_Safety_Stock]) AS [PrimaryVal]#(lf)    FROM FACT_SS_CO F INNER JOIN FILTERED_BED D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)BC_SS_DAGG AS (#(lf)    SELECT D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[L12M ACTD]) AS [L12M ACTD]#(lf)    FROM FACT_DEMAND_CO F INNER JOIN FILTERED_BED D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)BC_SS_DATA AS (#(lf)    SELECT G.*, ISNULL(A.[PrimaryVal],0) AS [PrimaryVal], ISNULL(D.[L12M ACTD],0) AS [L12M ACTD]#(lf)    FROM BC_SS_GRID G#(lf)    LEFT JOIN BC_SS_AGG  A ON G.[Comparison Type]=A.[Comparison Type] AND G.[Series Number]=A.[Series Number] AND G.[Bed Size]=A.[Bed Size] AND G.[Component Type]=A.[Component Type]#(lf)    LEFT JOIN BC_SS_DAGG D ON G.[Comparison Type]=D.[Comparison Type] AND G.[Series Number]=D.[Series Number] AND G.[Bed Size]=D.[Bed Size] AND G.[Component Type]=D.[Component Type]#(lf)),#(lf)BC_SS_MAX AS (#(lf)    SELECT *,#(lf)        MAX([PrimaryVal]) OVER (PARTITION BY [Comparison Type],[Series Number],[Bed Size]) AS [MaxPrimary],#(lf)        MAX([L12M ACTD])  OVER (PARTITION BY [Comparison Type],[Series Number],[Bed Size]) AS [MaxDemand]#(lf)    FROM BC_SS_DATA#(lf)),#(lf)BC_SS_OUT AS (#(lf)    SELECT#(lf)        'Company' AS [Level], 'Safety Stock' AS [Metric], NULL AS [Warehouse],#(lf)        [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type],#(lf)        NULL AS [Forecast], NULL AS [Max Forecast], NULL AS [Imbalance Ratio by FC], NULL AS [Imbalance by FC],#(lf)        [PrimaryVal] AS [Safety Stock], [MaxPrimary] AS [Max Safety Stock],#(lf)        CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) AS [Imbalance Ratio by SS],#(lf)        CASE WHEN [MaxPrimary]>0 AND CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 THEN 'Imbalance' ELSE '' END AS [Imbalance by SS],#(lf)        [L12M ACTD], [MaxDemand] AS [Max Demand],#(lf)        CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4)) AS [Imbalance Ratio by Demand],#(lf)        CASE WHEN [MaxDemand]>0 AND CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.15 THEN 'Imbalance' ELSE '' END AS [Imbalance by Demand],#(lf)        CAST((CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) - CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))) AS DECIMAL(18,4)) AS [Ratio Difference],#(lf)        CASE#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 AND [MaxPrimary]>0#(lf)             AND CAST(CASE WHEN [MaxDemand]=0  THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.15  AND [MaxDemand]>0 THEN 'Customer behaviour'#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 AND [MaxPrimary]>0 THEN 'Not defined'#(lf)            ELSE ''#(lf)        END AS [Imbalance reason]#(lf)    FROM BC_SS_MAX#(lf)),#(lf)#(lf)-- ----------------------------------------------------------------#(lf)-- SEGMENT 3: BEDROOM | WAREHOUSE | FORECAST#(lf)-- ----------------------------------------------------------------#(lf)BW_FC_ACTIVE AS (#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_FC_WH#(lf)    UNION#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_DEMAND_WH#(lf)),#(lf)BW_FC_MAPPED AS (#(lf)    SELECT DISTINCT A.[Warehouse], D.[Comparison Type], D.[Series Number], D.[Bed Size]#(lf)    FROM BW_FC_ACTIVE A INNER JOIN FILTERED_BED D ON A.[Item SKU]=D.[Item SKU]#(lf)),#(lf)BW_FC_GRID AS (#(lf)    SELECT AM.[Warehouse], UC.[Collective Class],UC.[Comparison Type],AM.[Series Number],AM.[Bed Size],UC.[Component Type]#(lf)    FROM BW_FC_MAPPED AM#(lf)    INNER JOIN (SELECT DISTINCT [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type] FROM FILTERED_BED) UC#(lf)        ON AM.[Comparison Type]=UC.[Comparison Type] AND AM.[Series Number]=UC.[Series Number] AND AM.[Bed Size]=UC.[Bed Size]#(lf)),#(lf)BW_FC_AGG AS (#(lf)    SELECT F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[Forecast]) AS [PrimaryVal]#(lf)    FROM FACT_FC_WH F INNER JOIN FILTERED_BED D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)BW_FC_DAGG AS (#(lf)    SELECT F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[L12M ACTD]) AS [L12M ACTD]#(lf)    FROM FACT_DEMAND_WH F INNER JOIN FILTERED_BED D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)BW_FC_DATA AS (#(lf)    SELECT G.*, ISNULL(A.[PrimaryVal],0) AS [PrimaryVal], ISNULL(D.[L12M ACTD],0) AS [L12M ACTD]#(lf)    FROM BW_FC_GRID G#(lf)    LEFT JOIN BW_FC_AGG  A ON G.[Warehouse]=A.[Warehouse] AND G.[Comparison Type]=A.[Comparison Type] AND G.[Series Number]=A.[Series Number] AND G.[Bed Size]=A.[Bed Size] AND G.[Component Type]=A.[Component Type]#(lf)    LEFT JOIN BW_FC_DAGG D ON G.[Warehouse]=D.[Warehouse] AND G.[Comparison Type]=D.[Comparison Type] AND G.[Series Number]=D.[Series Number] AND G.[Bed Size]=D.[Bed Size] AND G.[Component Type]=D.[Component Type]#(lf)),#(lf)BW_FC_MAX AS (#(lf)    SELECT *,#(lf)        MAX([PrimaryVal]) OVER (PARTITION BY [Warehouse],[Comparison Type],[Series Number],[Bed Size]) AS [MaxPrimary],#(lf)        MAX([L12M ACTD])  OVER (PARTITION BY [Warehouse],[Comparison Type],[Series Number],[Bed Size]) AS [MaxDemand]#(lf)    FROM BW_FC_DATA#(lf)),#(lf)BW_FC_OUT AS (#(lf)    SELECT#(lf)        'Warehouse' AS [Level], 'Forecast' AS [Metric], [Warehouse],#(lf)        [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type],#(lf)        [PrimaryVal] AS [Forecast], [MaxPrimary] AS [Max Forecast],#(lf)        CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) AS [Imbalance Ratio by FC],#(lf)        CASE WHEN [MaxPrimary]>0 AND CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 THEN 'Imbalance' ELSE '' END AS [Imbalance by FC],#(lf)        NULL AS [Safety Stock], NULL AS [Max Safety Stock], NULL AS [Imbalance Ratio by SS], NULL AS [Imbalance by SS],#(lf)        [L12M ACTD], [MaxDemand] AS [Max Demand],#(lf)        CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4)) AS [Imbalance Ratio by Demand],#(lf)        CASE WHEN [MaxDemand]>0 AND CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.15 THEN 'Imbalance' ELSE '' END AS [Imbalance by Demand],#(lf)        CAST((CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) - CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))) AS DECIMAL(18,4)) AS [Ratio Difference],#(lf)        CASE#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 AND [MaxPrimary]>0#(lf)             AND CAST(CASE WHEN [MaxDemand]=0  THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.15  AND [MaxDemand]>0 THEN 'Customer behaviour'#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 AND [MaxPrimary]>0 THEN 'Not defined'#(lf)            ELSE ''#(lf)        END AS [Imbalance reason]#(lf)    FROM BW_FC_MAX#(lf)),#(lf)#(lf)-- ----------------------------------------------------------------#(lf)-- SEGMENT 4: BEDROOM | WAREHOUSE | SAFETY STOCK#(lf)-- ----------------------------------------------------------------#(lf)BW_SS_ACTIVE AS (#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_SS_WH#(lf)    UNION#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_DEMAND_WH#(lf)),#(lf)BW_SS_MAPPED AS (#(lf)    SELECT DISTINCT A.[Warehouse], D.[Comparison Type], D.[Series Number], D.[Bed Size]#(lf)    FROM BW_SS_ACTIVE A INNER JOIN FILTERED_BED D ON A.[Item SKU]=D.[Item SKU]#(lf)),#(lf)BW_SS_GRID AS (#(lf)    SELECT AM.[Warehouse],UC.[Collective Class],UC.[Comparison Type],AM.[Series Number],AM.[Bed Size],UC.[Component Type]#(lf)    FROM BW_SS_MAPPED AM#(lf)    INNER JOIN (SELECT DISTINCT [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type] FROM FILTERED_BED) UC#(lf)        ON AM.[Comparison Type]=UC.[Comparison Type] AND AM.[Series Number]=UC.[Series Number] AND AM.[Bed Size]=UC.[Bed Size]#(lf)),#(lf)BW_SS_AGG AS (#(lf)    SELECT F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[Avg_Safety_Stock]) AS [PrimaryVal]#(lf)    FROM FACT_SS_WH F INNER JOIN FILTERED_BED D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)BW_SS_DAGG AS (#(lf)    SELECT F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[L12M ACTD]) AS [L12M ACTD]#(lf)    FROM FACT_DEMAND_WH F INNER JOIN FILTERED_BED D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)BW_SS_DATA AS (#(lf)    SELECT G.*, ISNULL(A.[PrimaryVal],0) AS [PrimaryVal], ISNULL(D.[L12M ACTD],0) AS [L12M ACTD]#(lf)    FROM BW_SS_GRID G#(lf)    LEFT JOIN BW_SS_AGG  A ON G.[Warehouse]=A.[Warehouse] AND G.[Comparison Type]=A.[Comparison Type] AND G.[Series Number]=A.[Series Number] AND G.[Bed Size]=A.[Bed Size] AND G.[Component Type]=A.[Component Type]#(lf)    LEFT JOIN BW_SS_DAGG D ON G.[Warehouse]=D.[Warehouse] AND G.[Comparison Type]=D.[Comparison Type] AND G.[Series Number]=D.[Series Number] AND G.[Bed Size]=D.[Bed Size] AND G.[Component Type]=D.[Component Type]#(lf)),#(lf)BW_SS_MAX AS (#(lf)    SELECT *,#(lf)        MAX([PrimaryVal]) OVER (PARTITION BY [Warehouse],[Comparison Type],[Series Number],[Bed Size]) AS [MaxPrimary],#(lf)        MAX([L12M ACTD])  OVER (PARTITION BY [Warehouse],[Comparison Type],[Series Number],[Bed Size]) AS [MaxDemand]#(lf)    FROM BW_SS_DATA#(lf)),#(lf)BW_SS_OUT AS (#(lf)    SELECT#(lf)        'Warehouse' AS [Level], 'Safety Stock' AS [Metric], [Warehouse],#(lf)        [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type],#(lf)        NULL AS [Forecast], NULL AS [Max Forecast], NULL AS [Imbalance Ratio by FC], NULL AS [Imbalance by FC],#(lf)        [PrimaryVal] AS [Safety Stock], [MaxPrimary] AS [Max Safety Stock],#(lf)        CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) AS [Imbalance Ratio by SS],#(lf)        CASE WHEN [MaxPrimary]>0 AND CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 THEN 'Imbalance' ELSE '' END AS [Imbalance by SS],#(lf)        [L12M ACTD], [MaxDemand] AS [Max Demand],#(lf)        CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4)) AS [Imbalance Ratio by Demand],#(lf)        CASE WHEN [MaxDemand]>0 AND CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.15 THEN 'Imbalance' ELSE '' END AS [Imbalance by Demand],#(lf)        CAST((CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) - CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))) AS DECIMAL(18,4)) AS [Ratio Difference],#(lf)        CASE#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 AND [MaxPrimary]>0#(lf)             AND CAST(CASE WHEN [MaxDemand]=0  THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.15  AND [MaxDemand]>0 THEN 'Customer behaviour'#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.15 AND [MaxPrimary]>0 THEN 'Not defined'#(lf)            ELSE ''#(lf)        END AS [Imbalance reason]#(lf)    FROM BW_SS_MAX#(lf)),#(lf)#(lf)-- ----------------------------------------------------------------#(lf)-- SEGMENT 5: DINING | COMPANY | FORECAST  (threshold: 0.05)#(lf)-- ----------------------------------------------------------------#(lf)DC_FC_ACTIVE AS (#(lf)    SELECT [Item SKU] FROM FACT_FC_CO#(lf)    UNION#(lf)    SELECT [Item SKU] FROM FACT_DEMAND_CO#(lf)),#(lf)DC_FC_MAPPED AS (#(lf)    SELECT DISTINCT D.[Comparison Type], D.[Series Number], D.[Bed Size]#(lf)    FROM DC_FC_ACTIVE A INNER JOIN FILTERED_DIN D ON A.[Item SKU]=D.[Item SKU]#(lf)),#(lf)DC_FC_GRID AS (#(lf)    SELECT UC.[Collective Class],UC.[Comparison Type],AM.[Series Number],AM.[Bed Size],UC.[Component Type]#(lf)    FROM DC_FC_MAPPED AM#(lf)    INNER JOIN (SELECT DISTINCT [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type] FROM FILTERED_DIN) UC#(lf)        ON AM.[Comparison Type]=UC.[Comparison Type] AND AM.[Series Number]=UC.[Series Number] AND AM.[Bed Size]=UC.[Bed Size]#(lf)),#(lf)DC_FC_AGG AS (#(lf)    SELECT D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[Forecast]) AS [PrimaryVal]#(lf)    FROM FACT_FC_CO F INNER JOIN FILTERED_DIN D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)DC_FC_DAGG AS (#(lf)    SELECT D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[L12M ACTD]) AS [L12M ACTD]#(lf)    FROM FACT_DEMAND_CO F INNER JOIN FILTERED_DIN D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)DC_FC_DATA AS (#(lf)    SELECT G.*, ISNULL(A.[PrimaryVal],0) AS [PrimaryVal], ISNULL(D.[L12M ACTD],0) AS [L12M ACTD]#(lf)    FROM DC_FC_GRID G#(lf)    LEFT JOIN DC_FC_AGG  A ON G.[Comparison Type]=A.[Comparison Type] AND G.[Series Number]=A.[Series Number] AND G.[Bed Size]=A.[Bed Size] AND G.[Component Type]=A.[Component Type]#(lf)    LEFT JOIN DC_FC_DAGG D ON G.[Comparison Type]=D.[Comparison Type] AND G.[Series Number]=D.[Series Number] AND G.[Bed Size]=D.[Bed Size] AND G.[Component Type]=D.[Component Type]#(lf)),#(lf)DC_FC_MAX AS (#(lf)    SELECT *,#(lf)        MAX([PrimaryVal]) OVER (PARTITION BY [Comparison Type],[Series Number],[Bed Size]) AS [MaxPrimary],#(lf)        MAX([L12M ACTD])  OVER (PARTITION BY [Comparison Type],[Series Number],[Bed Size]) AS [MaxDemand]#(lf)    FROM DC_FC_DATA#(lf)),#(lf)DC_FC_OUT AS (#(lf)    SELECT#(lf)        'Company' AS [Level], 'Forecast' AS [Metric], NULL AS [Warehouse],#(lf)        [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type],#(lf)        [PrimaryVal] AS [Forecast], [MaxPrimary] AS [Max Forecast],#(lf)        CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) AS [Imbalance Ratio by FC],#(lf)        CASE WHEN [MaxPrimary]>0 AND CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 THEN 'Imbalance' ELSE '' END AS [Imbalance by FC],#(lf)        NULL AS [Safety Stock], NULL AS [Max Safety Stock], NULL AS [Imbalance Ratio by SS], NULL AS [Imbalance by SS],#(lf)        [L12M ACTD], [MaxDemand] AS [Max Demand],#(lf)        CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4)) AS [Imbalance Ratio by Demand],#(lf)        CASE WHEN [MaxDemand]>0 AND CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.05 THEN 'Imbalance' ELSE '' END AS [Imbalance by Demand],#(lf)        CAST((CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) - CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))) AS DECIMAL(18,4)) AS [Ratio Difference],#(lf)        CASE#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0#(lf)             AND CAST(CASE WHEN [MaxDemand]=0  THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.05  AND [MaxDemand]>0 THEN 'Customer behaviour'#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0 THEN 'Not defined'#(lf)            ELSE ''#(lf)        END AS [Imbalance reason]#(lf)    FROM DC_FC_MAX#(lf)),#(lf)#(lf)-- ----------------------------------------------------------------#(lf)-- SEGMENT 6: DINING | COMPANY | SAFETY STOCK  (threshold: 0.05)#(lf)-- ----------------------------------------------------------------#(lf)DC_SS_ACTIVE AS (#(lf)    SELECT [Item SKU] FROM FACT_SS_CO#(lf)    UNION#(lf)    SELECT [Item SKU] FROM FACT_DEMAND_CO#(lf)),#(lf)DC_SS_MAPPED AS (#(lf)    SELECT DISTINCT D.[Comparison Type], D.[Series Number], D.[Bed Size]#(lf)    FROM DC_SS_ACTIVE A INNER JOIN FILTERED_DIN D ON A.[Item SKU]=D.[Item SKU]#(lf)),#(lf)DC_SS_GRID AS (#(lf)    SELECT UC.[Collective Class],UC.[Comparison Type],AM.[Series Number],AM.[Bed Size],UC.[Component Type]#(lf)    FROM DC_SS_MAPPED AM#(lf)    INNER JOIN (SELECT DISTINCT [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type] FROM FILTERED_DIN) UC#(lf)        ON AM.[Comparison Type]=UC.[Comparison Type] AND AM.[Series Number]=UC.[Series Number] AND AM.[Bed Size]=UC.[Bed Size]#(lf)),#(lf)DC_SS_AGG AS (#(lf)    SELECT D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[Avg_Safety_Stock]) AS [PrimaryVal]#(lf)    FROM FACT_SS_CO F INNER JOIN FILTERED_DIN D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)DC_SS_DAGG AS (#(lf)    SELECT D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[L12M ACTD]) AS [L12M ACTD]#(lf)    FROM FACT_DEMAND_CO F INNER JOIN FILTERED_DIN D ON F.[Item SKU]=D.[Item SKU]#(lf)    GROUP BY D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type]#(lf)),#(lf)DC_SS_DATA AS (#(lf)    SELECT G.*, ISNULL(A.[PrimaryVal],0) AS [PrimaryVal], ISNULL(D.[L12M ACTD],0) AS [L12M ACTD]#(lf)    FROM DC_SS_GRID G#(lf)    LEFT JOIN DC_SS_AGG  A ON G.[Comparison Type]=A.[Comparison Type] AND G.[Series Number]=A.[Series Number] AND G.[Bed Size]=A.[Bed Size] AND G.[Component Type]=A.[Component Type]#(lf)    LEFT JOIN DC_SS_DAGG D ON G.[Comparison Type]=D.[Comparison Type] AND G.[Series Number]=D.[Series Number] AND G.[Bed Size]=D.[Bed Size] AND G.[Component Type]=D.[Component Type]#(lf)),#(lf)DC_SS_MAX AS (#(lf)    SELECT *,#(lf)        MAX([PrimaryVal]) OVER (PARTITION BY [Comparison Type],[Series Number],[Bed Size]) AS [MaxPrimary],#(lf)        MAX([L12M ACTD])  OVER (PARTITION BY [Comparison Type],[Series Number],[Bed Size]) AS [MaxDemand]#(lf)    FROM DC_SS_DATA#(lf)),#(lf)DC_SS_OUT AS (#(lf)    SELECT#(lf)        'Company' AS [Level], 'Safety Stock' AS [Metric], NULL AS [Warehouse],#(lf)        [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type],#(lf)        NULL AS [Forecast], NULL AS [Max Forecast], NULL AS [Imbalance Ratio by FC], NULL AS [Imbalance by FC],#(lf)        [PrimaryVal] AS [Safety Stock], [MaxPrimary] AS [Max Safety Stock],#(lf)        CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) AS [Imbalance Ratio by SS],#(lf)        CASE WHEN [MaxPrimary]>0 AND CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 THEN 'Imbalance' ELSE '' END AS [Imbalance by SS],#(lf)        [L12M ACTD], [MaxDemand] AS [Max Demand],#(lf)        CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4)) AS [Imbalance Ratio by Demand],#(lf)        CASE WHEN [MaxDemand]>0 AND CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.05 THEN 'Imbalance' ELSE '' END AS [Imbalance by Demand],#(lf)        CAST((CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4)) - CAST(CASE WHEN [MaxDemand]=0 THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))) AS DECIMAL(18,4)) AS [Ratio Difference],#(lf)        CASE#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0#(lf)             AND CAST(CASE WHEN [MaxDemand]=0  THEN 0.0 ELSE ([MaxDemand]-[L12M ACTD])*1.0/[MaxDemand] END AS DECIMAL(18,4))>0.05  AND [MaxDemand]>0 THEN 'Customer behaviour'#(lf)            WHEN CAST(CASE WHEN [MaxPrimary]=0 THEN 0.0 ELSE ([MaxPrimary]-[PrimaryVal])*1.0/[MaxPrimary] END AS DECIMAL(18,4))>0.05 AND [MaxPrimary]>0 THEN 'Not defined'#(lf)            ELSE ''#(lf)        END AS [Imbalance reason]#(lf)    FROM DC_SS_MAX#(lf)),#(lf)#(lf)-- ----------------------------------------------------------------#(lf)-- SEGMENT 7: DINING | WAREHOUSE | FORECAST  (threshold: 0.05)#(lf)-- ----------------------------------------------------------------#(lf)DW_FC_ACTIVE AS (#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_FC_WH#(lf)    UNION#(lf)    SELECT [Warehouse],[Item SKU] FROM FACT_DEMAND_WH#(lf)),#(lf)DW_FC_MAPPED AS (#(lf)    SELECT DISTINCT A.[Warehouse], D.[Comparison Type], D.[Series Number], D.[Bed Size]#(lf)    FROM DW_FC_ACTIVE A INNER JOIN FILTERED_DIN D ON A.[Item SKU]=D.[Item SKU]#(lf)),#(lf)DW_FC_GRID AS (#(lf)    SELECT AM.[Warehouse],UC.[Collective Class],UC.[Comparison Type],AM.[Series Number],AM.[Bed Size],UC.[Component Type]#(lf)    FROM DW_FC_MAPPED AM#(lf)    INNER JOIN (SELECT DISTINCT [Collective Class],[Comparison Type],[Series Number],[Bed Size],[Component Type] FROM FILTERED_DIN) UC#(lf)        ON AM.[Comparison Type]=UC.[Comparison Type] AND AM.[Series Number]=UC.[Series Number] AND AM.[Bed Size]=UC.[Bed Size]#(lf)),#(lf)DW_FC_AGG AS (#(lf)    SELECT F.[Warehouse],D.[Comparison Type],D.[Series Number],D.[Bed Size],D.[Component Type], SUM(F.[Forecast]) AS [PrimaryVal]#(lf)    FROM FACT_FC_WH F INNER 