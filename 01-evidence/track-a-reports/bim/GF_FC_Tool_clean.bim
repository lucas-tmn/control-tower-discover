ecast Derived From]#(lf)      ,[DFC].[dfcDerivedFCSTFctr] AS [Forecast Derived Ratios]#(lf)      ,[DFC].[dfcOrderFutureQty] AS [Future Order]#(lf)      ,[DFC].[dfcMgmtCode] AS [RSLF Indicator]#(lf)      ,[DFC_L2].[dfcPermComptQty] AS [L2 Permanent Component]#(lf)      ,[DFC_L2].[dfcFCSTTypeCode] AS [L2 Forecast Model]#(lf)      ,[DFC].[dfcCustomergroups]#(lf)      ,CONCAT([DFC].[dfcCustomergroups], [DFC].[dfcCollectiveClass]) [CusGroupCC]#(lf)      ,CONVERT(DATE, [DFC].[dfcSnapshot]) AS [Version Date]#(lf)      , 'Lag 0' AS [Forecast Lag]#(lf)#(lf)  FROM [SupplyChain_Enh].[DemandForecastSnapshot] [DFC]#(lf)  #(lf)  LEFT JOIN (#(lf)    SELECT DISTINCT [FiscalMonthYear], [FiscalMonthLastDate], [FiscalMonthIndicator]#(lf)    FROM [Enterprise_DW].[DimDate_NonRetail]#(lf)  ) AS DD#(lf)    ON [DFC].[dfcFiscalMonth] = [DD].[FiscalMonthYear]#(lf)#(lf)  LEFT JOIN (#(lf)    SELECT [dfhItem]#(lf)      ,[dfhWarehouse]#(lf)      ,[dfhFiscalMonth]#(lf)      ,[dfhActualDemand]#(lf)      ,[dfhSnapshot]#(lf)      ,[dfhDemandAdjustmentQty]#(lf)      ,[dfhDemandCode]#(lf)      ,[DfhCustomerGroups]#(lf)    FROM [SupplyChain_Enh].[DemandForecastHistorySnapshot]#(lf)    -- WHERE [DfhCustomerGroups] = 'AFICONS'#(lf)  ) AS [DFH]#(lf)    ON [DFC].[dfcItem] = [DFH].[dfhItem]#(lf)   AND [DFC].[dfcWarehouse] = [DFH].[dfhWarehouse]#(lf)   AND [DFC].[dfcFiscalMonth] = [DFH].[dfhFiscalMonth]#(lf)   AND CONVERT(DATE, [DFC].[dfcSnapshot]) = CONVERT(DATE, [DFH].[dfhSnapshot])#(lf)   AND [DFC].[dfcCustomergroups] = [DFH].[DfhCustomerGroups]#(lf)#(lf)   LEFT JOIN (#(lf)    SELECT [dfcItem]#(lf)      ,[dfcFiscalMonth]#(lf)      ,[dfcPermComptQty]#(lf)      ,[dfcFCSTTypeCode]#(lf)      ,[dfcMgmtCode]#(lf)      ,[SnapshotDate]#(lf)      ,[dfcCustomergroups]#(lf)    FROM [SupplyChain_Enh].[DemandForecastSnapshotL3Daily]#(lf)    -- WHERE [dfcCustomergroups] = 'AFICONS'#(lf)   ) AS [DFC_L2]#(lf)    ON [DFC].[dfcItem] = [DFC_L2].[dfcItem]#(lf)    AND [DFC].[dfcFiscalMonth] = [DFC_L2].[dfcFiscalMonth]#(lf)    AND CONVERT(DATE, [DFC].[dfcSnapshot]) = CONVERT(DATE, [DFC_L2].[SnapshotDate])#(lf)    AND [DFC].[dfcCustomergroups] = [DFC_L2].[dfcCustomergroups]#(lf)#(lf)--   WHERE CONVERT(DATE, [DFC].[dfcSnapshot]) IN (@today, @last30day, @last60day, @last90day)#(lf)  WHERE CONVERT(DATE, [DFC].[dfcSnapshot]) IN (@today)#(lf)    AND [DD].[FiscalMonthIndicator] BETWEEN -1 AND 12#(lf)    -- AND [DFC].[dfcFCSTTypeCode] <> 'I'#(lf)    -- AND [DFC].[dfcCustomergroups] = 'AFICONS'\", CreateNavigationProperties=false]),","    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"Forecast Month\", type date}})","in","    #\"Changed Type\""],"type":"m"}}]},{"name":"LocalDateTable_284ae5a8-0974-4b2a-9ec3-9d6e84d08b6b","annotations":[{"name":"__PBI_LocalDateTable","value":"true"}],"columns":[{"name":"Date","annotations":[{"name":"SummarizationSetBy","value":"User"}],"dataCategory":"PaddedDateTableDates","dataType":"dateTime","isHidden":true,"isNameInferred":true,"lineageTag":"321dea82-874b-4ad9-bf2e-5f45c4497281","sourceColumn":"[Date]","summarizeBy":"none","type":"calculatedTableColumn"},{"name":"Year","annotations":[{"name":"SummarizationSetBy","value":"User"},{"name":"TemplateId","value":"Year"}],"dataCategory":"Years","dataType":"int64","expression":"YEAR([Date])","isHidden":true,"lineageTag":"cfb04b4e-158b-4897-b334-e9132e724108","summarizeBy":"none","type":"calculated"},{"name":"MonthNo","annotations":[{"name":"SummarizationSetBy","value":"User"},{"name":"TemplateId","value":"MonthNumber"}],"dataCategory":"MonthOfYear","dataType":"int64","expression":"MONTH([Date])","isHidden":true,"lineageTag":"9d0d5032-4b59-4cfa-a759-4f5941b95eb6","summarizeBy":"none","type":"calculated"},{"name":"Month","annotations":[{"name":"SummarizationSetBy","value":"User"},{"name":"TemplateId","value":"Month"}],"dataCategory":"Months","dataType":"string","expression":"FORMAT([Date], \"MMMM\")","isHidden":true,"lineageTag":"7c795682-60ed-4c37-aea3-6bb311a88d3b","sortByColumn":"MonthNo","summarizeBy":"no