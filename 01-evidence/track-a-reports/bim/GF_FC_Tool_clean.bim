lse])","in","    Source"],"type":"m"}}]},{"name":"Fact Actuals","annotations":[{"name":"PBI_ResultType","value":"Exception"},{"name":"PBI_NavigationStepName","value":"Navigation"}],"columns":[{"name":"Customer Account Number","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"4214c88a-8aa2-41b3-bd29-51165174c94a","sourceColumn":"Customer Account Number","summarizeBy":"none"},{"name":"Item SKU","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"6b7d9468-2e80-4a9f-8945-0f23cd03d00f","sourceColumn":"Item SKU","summarizeBy":"none"},{"name":"Warehouse","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"4242b506-67f6-4f73-a9f3-b53d364e847f","sourceColumn":"Warehouse","summarizeBy":"none"},{"name":"Order Quantity","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"double","formatString":"#,0","lineageTag":"428d65fe-f2f3-4c26-a623-b496dcd9c519","sourceColumn":"Order Quantity","summarizeBy":"sum"},{"name":"Order Amount","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"4bed48e4-40c5-43f5-a2ce-131185b60d51","sourceColumn":"Order Amount","summarizeBy":"sum"},{"name":"OrigReqWkEnding","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"UnderlyingDateTimeDataType","value":"Date"}],"dataType":"dateTime","formatString":"Short Date","lineageTag":"5b469287-47db-49c7-8471-b7d612312cab","sourceColumn":"OrigReqWkEnding","summarizeBy":"none"},{"name":"CurReqWkEnding","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"UnderlyingDateTimeDataType","value":"Date"}],"dataType":"dateTime","formatString":"Short Date","lineageTag":"36056c3a-17e9-4a6d-9f40-513e586057da","sourceColumn":"CurReqWkEnding","summarizeBy":"none"},{"name":"ShipWkEnding","annotations":[{"name":"