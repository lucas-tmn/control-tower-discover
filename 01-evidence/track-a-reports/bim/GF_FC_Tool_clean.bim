Name","value":"Navigation"}],"columns":[{"name":"Collective Class","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"f52ecad8-202b-4765-9b73-5982ab942fbb","sourceColumn":"Collective Class","summarizeBy":"none"},{"name":"Day of Month","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"0","lineageTag":"86ce2c29-1d20-4953-95d5-583da139a44c","sourceColumn":"Day of Month","summarizeBy":"sum"},{"name":"Weeks in Month","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"0","lineageTag":"66ec4030-9e98-402d-96aa-49b300a37127","sourceColumn":"Weeks in Month","summarizeBy":"sum"},{"name":"Customer Group","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"761c7d54-9768-4649-a8e8-2521ea21206b","sourceColumn":"Customer Group","summarizeBy":"none"},{"name":"Goal Consumption","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"double","formatString":"0.0%;-0.0%;0.0%","lineageTag":"cb2a67d9-ce63-401e-9bc2-3a9f4209f523","sourceColumn":"Goal Consumption","summarizeBy":"sum"},{"name":"CusCC","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"a46970ed-6e8e-4783-a1c8-ef32a14acfa1","sourceColumn":"CusCC","summarizeBy":"none"},{"name":"Key","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","expression":"'Fact Goal Consumption CusCC'[Collective Class] & [Day of Month] & [Weeks in Month] & 'Fact Goal Consumption CusCC'[Customer Group]","isDataTypeInferred":true,"lineageTag":"3d7b42d8-2f44-46b1-b98d-94e08410edbc","summarizeBy":"none","type":"calculated"}],"lineageTag":"3ba3765b-86b3-4e3d-9525-cf3cde595735","partitions":[{"name":"Fact Goal Consumption CusCC","mode":"import","queryGroup":"Fact Query","source":{"expression":["let","    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"SET NOCOUNT ON#(lf)#(lf)DECLARE @dataDate NVARCHAR(MAX)#(lf)#(lf)-- Temp table#(lf)SELECT *#(lf)INTO #MTD#(lf)FROM (#(lf)    SELECT [DFC].[Collective Class]#(lf)        , [Customer Group]#(lf)        , [dfcFiscalMonth]#(lf)        , [FiscalDayOfMonth]#(lf)        , [dfcSnapshot]#(lf)        , [dfcOrderFutureQty] + COALESCE([CUMSUM], 0) [dfcOrderFutureQty]#(lf)    FROM (#(lf)        SELECT [CPD].[Collective Class]#(lf)            , [DC].[Customer Group]#(lf)            , [DD].[FiscalMonthYear] [dfcFiscalMonth]#(lf)            , [DIM].[FiscalDayOfMonth]#(lf)            , CONVERT(DATE, [ACT].[Inserted Date]) [dfcSnapshot]#(lf)            , SUM([ACT].[Open Order Quantity]) [dfcOrderFutureQty]#(lf)        FROM [AFISales_DW].[FactOpenOrdersSnapshot] [ACT]#(lf)        LEFT JOIN [PowerBI_SupplyChain].[CustomerAcctMaster_AFI] [DC]#(lf)            ON TRIM([ACT].[Account And ShipTo Number]) = TRIM([DC].[Account And ShipTo Number])#(lf)        LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [DD]#(lf)            ON DATEADD(DAY, - [ACT].[Load Lead Time], [ACT].[Current Request Date]) = [DD].[DateID]#(lf)        LEFT JOIN (#(lf)            SELECT [Item SKU]#(lf)                , [Collective Class]#(lf)            FROM [PowerBI_SupplyChain].[CurrentProductDetails] [CPD]#(lf)            ) AS CPD#(lf)            ON TRIM([ACT].[Item Sku]) = [CPD].[Item SKU]#(lf)        INNER JOIN (#(lf)            SELECT [DateID]#(lf)                , [FiscalDayOfMonth]#(lf)                , [FiscalMonthYear]#(lf)            FROM [Enterprise_DW].[DimDate]#(lf)            WHERE [FiscalMonthIndicator] BETWEEN - 24 AND - 1#(lf)                AND [fiscaldayofWeek] <> 1#(lf)            ) AS DIM#(lf)            ON CONVERT(DATE, [ACT].[Inserted Date]) = [DIM].[DateID]#(lf)                AND [DD].[FiscalMonthYear] = [DIM].[FiscalMonthYear]#(lf)        WHERE TRIM([ACT].[Warehouse]) IN ('1', '1A', '15', '15A', '17', '17A', '19', '28', '28A', '5', '5A', '335', 'ECR', 'ECA')#(lf)        GROUP BY [DC].[Customer Group]#(lf)            , [CPD].[Collective Class]#(lf)            , [DD].[FiscalMonthYear]#(lf)            , [DIM].[FiscalDayOfMonth]#(lf)            , CONVERT(DATE, [ACT].[Inserted Date])#(lf)        ) DFC#(lf)    LEFT JOIN (#(lf)        SELECT [Collective Class]#(lf)            , [CustomerGroup]#(lf)            , [FiscalMonthYear]#(lf)            , [InvoiceDate]#(lf)            , [Order Quantity]#(lf)            , SUM([Order Quantity]) OVER (#(lf)                PARTITION BY [CustomerGroup]#(lf)                , [Collective Class]#(lf)                , [FiscalMonthYear] ORDER BY [InvoiceDate]#(lf)                ) [CUMSUM]#(lf)        FROM (#(lf)            SELECT [Customer Group] AS [CustomerGroup]#(lf)                , [CPD].[Collective Class]#(lf)                , CASE #(lf)                    WHEN [D].[FiscalMonthYear] IS NULL#(lf)                        THEN [D3].[FiscalMonthYear]#(lf)                    ELSE [D].[FiscalMonthYear]#(lf)                    END AS [FiscalMonthYear]#(lf)                , [D3].[DateID] [InvoiceDate]#(lf)                , ROUND(SUM([ID].[QuantityShipped]), 0) AS [Order Quantity]#(lf)            FROM [Wholesale_SalesHistory_AFI].[InvoiceDetail] AS ID#(lf)            LEFT JOIN [Wholesale_SalesHistory_AFI].[InvoiceHeader] AS IH#(lf)                ON [ID].[InvoiceNumber] = [IH].[InvoiceNumber]#(lf)                    AND [ID].[OrderNumber] = [IH].[OrderNumber]#(lf)                    AND [ID].[Warehouse] = [IH].[Warehouse]#(lf)            LEFT JOIN [PowerBI_SupplyChain].[CustomerAcctMaster_AFI] [DC]#(lf)                ON TRIM([IH].[CustomerNumber]) = TRIM([DC].[Account Number])#(lf)                    AND TRIM([IH].[ShiptoNumber]) = TRIM([DC].[ShipTo Number])#(lf)            LEFT JOIN [Enterprise_DW].[DimDate] AS D#(lf)                ON DATEADD(DAY, - [IH].[LeadTime], CONVERT(DATE, [ID].[RequestDate])) = [D].[DateID]#(lf)            LEFT JOIN [Enterprise_DW].[DimDate] AS D3#(lf)                ON CONVERT(DATE, [ID].[InvoiceDate]) = [D3].[DateID]#(lf)            LEFT JOIN (#(lf)                SELECT [Item SKU]#(lf)                    , [Collective Class]#(lf)                FROM [PowerBI_SupplyChain].[CurrentProductDetails] [CPD]#(lf)                ) AS CPD#(lf)                ON TRIM([ID].[ItemNumber]) = [CPD].[Item SKU]#(lf)            WHERE TRIM([ID].[Warehouse]) IN ('1', '1A', '15', '15A', '17', '17A', '19', '28', '28A', '5', '5A', '335', 'ECR', 'ECA')#(lf)            GROUP BY [Customer Group]#(lf)                , [CPD].[Collective Class]#(lf)                -- , [ID].[ItemNumber]#(lf)                , [D3].[DateID]#(lf)                , [D].[FiscalMonthYear]#(lf)                , [D3].[FiscalMonthYear]#(lf)            ) TEMP#(lf)        ) INV#(lf)        ON [DFC].[Customer Group] = [INV].[CustomerGroup]#(lf)            AND [DFC].[Collective Class] = [INV].[Collective Class]#(lf)            AND [DFC].[dfcFiscalMonth] = [INV].[FiscalMonthYear]#(lf)            AND [DFC].[dfcSnapshot] = [INV].[InvoiceDate]#(lf)    ) MTD;#(lf)#(lf)SELECT COALESCE([Customer Group], 'COMPANY LEVEL') [Customer Group]#(lf)    , COALESCE([Collective Class], 'CUSTOMER LEVEL') [Collective Class]#(lf)    , [Day of Month]#(lf)    , [Weeks in Month]#(lf)    , [Goal Consumption]#(lf)FROM (#(lf)    SELECT [Collective Class]#(lf)        , [Customer Group]#(lf)        , [Day of Month]#(lf)        , [Weeks in Month]#(lf)        , SUM([DayAct]) / SUM([MonthEndAct]) [Goal Consumption]#(lf)    FROM (#(lf)        SELECT [DACT].[Collective Class]#(lf)            , [DACT].[Customer Group]#(lf)            , [DACT].[FiscalDayOfMonth] [Day of Month]#(lf)            , [MACT].[Weeks in Month]#(lf)            , CASE #(lf)                WHEN [DACT].[dfcOrderFutureQty] > [MACT].[dfcOrderFutureQty]#(lf)                    THEN [MACT].[dfcOrderFutureQty]#(lf)                ELSE [DACT].[dfcOrderFutureQty]#(lf)                END AS [DayAct]#(lf)            , [MACT].[dfcOrderFutureQty] [MonthEndAct]#(lf)        FROM #MTD [DACT]#(lf)        LEFT JOIN (#(lf)            SELECT [Collective Class]#(lf)                , [Customer Group]#(lf)                , [dfcFiscalMonth]#(lf)                , [dfcSnapshot]#(lf)                , [Weeks in Month]#(lf)                , [dfcOrderFutureQty]#(lf)            FROM #MTD [DFC]#(lf)            INNER JOIN (#(lf)                SELECT [FiscalMonth]#(lf)                    , [FiscalMonthLastDate]#(lf)                    , [FiscalMonthYear]#(lf)                    , COUNT(DISTINCT [FiscalWeekLastDate]) AS [Weeks in Month]#(lf)                FROM [Enterprise_DW].[DimDate]#(lf)                WHERE [FiscalMonthIndicator] BETWEEN - 24 AND - 1#(lf)                GROUP BY [FiscalMonth]#(lf)                    , [FiscalMonthLastDate]#(lf)                    , [FiscalMonthYear]#(lf)                ) AS DD#(lf)                ON CONVERT(DATE, [DFC].[dfcSnapshot]) = [DD].[FiscalMonthLastDate]#(lf)                    AND [DFC].[dfcFiscalMonth] = [DD].[FiscalMonthYear]#(lf)            ) [MACT]#(lf)            ON [DACT].[Customer Group] = [MACT].[Customer Group]#(lf)                AND [DACT].[Collective Class] = [MACT].[Collective Class]#(lf)                AND [DACT].[dfcFiscalMonth] = [MACT].[dfcFiscalMonth]#(lf)        WHERE [MACT].[dfcOrderFutureQty] > 0#(lf)            AND [DACT].[FiscalDayOfMonth] IS NOT NULL#(lf)        ) goal#(lf)    GROUP BY ROLLUP((#(lf)                [Day of Month]#(lf)                , [Weeks in Month]#(lf)                ), [Customer Group], [Collective Class])#(lf)    ) goal_consumption#(lf)-- WHERE [Customer Group] IS NOT NULL#(lf)#(lf)UNION ALL#(lf)#(lf)SELECT 'COMPANY LEVEL' AS [Customer Group]#(lf)#(tab), COALESCE([Collective Class], 'CUSTOMER LEVEL') [Collective Class]#(lf)    , [Day of Month]#(lf)    , [Weeks in Month]#(lf)    , [Goal Consumption]#(lf)FROM (#(lf)    SELECT [Collective Class]#(lf)        , [Day of Month]#(lf)        , [Weeks in Month]#(lf)        , SUM([DayAct]) / SUM([MonthEndAct]) [Goal Consumption]#(lf)    FROM (#(lf)        SELECT [DACT].[Collective Class]#(lf)            , [DACT].[Customer Group]#(lf)            , [DACT].[FiscalDayOfMonth] [Day of Month]#(lf)            , [MACT].[Weeks in Month]#(lf)            , CASE #(lf)                WHEN [DACT].[dfcOrderFutureQty] > [MACT].[dfcOrderFutureQty]#(lf)                    THEN [MACT].[dfcOrderFutureQty]#(lf)                ELSE [DACT].[dfcOrderFutureQty]#(lf)                END AS [DayAct]#(lf)            , [MACT].[dfcOrderFutureQty] [MonthEndAct]#(lf)        FROM #MTD [DACT]#(lf)        LEFT JOIN (#(lf)            SELECT [Collective Class]#(lf)                , [Customer Group]#(lf)                , [dfcFiscalMonth]#(lf)                , [dfcSnapshot]#(lf)                , [Weeks in Month]#(lf)                , [dfcOrderFutureQty]#(lf)            FROM #MTD [DFC]#(lf)            INNER JOIN (#(lf)                SELECT [FiscalMonth]#(lf)                    , [FiscalMonthLastDate]#(lf)                    , [FiscalMonthYear]#(lf)                    , COUNT(DISTINCT [FiscalWeekLastDate]) AS [Weeks in Month]#(lf)                FROM [Enterprise_DW].[DimDate]#(lf)                WHERE [FiscalMonthIndicator] BETWEEN - 24 AND - 1#(lf)                GROUP BY [FiscalMonth]#(lf)                    , [FiscalMonthLastDate]#(lf)                    , [FiscalMonthYear]#(lf)                ) AS DD#(lf)                ON CONVERT(DATE, [DFC].[dfcSnapshot]) = [DD].[FiscalMonthLastDate]#(lf)                    AND [DFC].[dfcFiscalMonth] = [DD].[FiscalMonthYear]#(lf)            ) [MACT]#(lf)            ON [DACT].[Customer Group] = [MACT].[Customer Group]#(lf)                AND [DACT].[Collective Class] = [MACT].[Collective Class]#(lf)                AND [DACT].[dfcFiscalMonth] = [MACT].[dfcFiscalMonth]#(lf)        WHERE [MACT].[dfcOrderFutureQty] > 0#(lf)            AND [DACT].[FiscalDayOfMonth] IS NOT NULL#(lf)        ) goal#(lf)    GROUP BY [Day of Month]#(lf)        , [Weeks in Month]#(lf)        , [Collective Class]#(lf)    ) goal_consumption#(lf)\", CreateNavigationProperties=false]),","    #\"Added Custom\" = Table.AddColumn(Source, \"CusCC\", each [Customer Group]&[Collective Class])","in","    #\"Added Custom\""],"type":"m"}}]},{"name":"Dim Collective Class","annotations":[{"name":"PBI_ResultType","value":"Table"},{"name":"PBI_NavigationStepName","value":"Navigation"}],"columns":[{"name":"Collective Class","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"f8c18220-aac9-43d3-bf5a-33627191e7ee","sourceColumn":"Collective Class","summarizeBy":"none"},{"name":"Collective Class Group","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"d2bf28ac-09ed-479a-af67-9691afa065ad","sourceColumn":"Collective Class Group","summarizeBy":"none"}],"lineageTag":"5cadede3-3ae8-40cb-a497-cd53758047bd","partitions":[{"name":"Dim Collective Class","mode":"import","queryGroup":"Dim Query","source":{"expression":["let","    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"SELECT DISTINCT [Collective Class]#(lf)    , CASE#(lf)        WHEN [Collective Class] IN ('ACCESSORIES', 'LAMPS', 'RUGS', 'THROWS & PILLOWS') THEN 'ACCENTS'#(lf)        WHEN [Collective Class] LIKE '%RTA' THEN 'RTA'#(lf)        WHEN [Collective Class] IN ('POP', 'TOB', 'METAL BEDS') THEN 'OTHERS'#(lf)        ELSE [Collective Class] END AS [Collective Class Group]#(lf)FROM [PowerBI_SupplyChain].[CurrentProductDetails]#(lf)WHERE [Collective Class] IS NOT NULL#(lf)\", CreateNavigationProperties=false])","in","    Source"],"type":"m"}}]},{"name":"Fact Annualize FC","annotations":[{"name":"PBI_NavigationStepName","value":"Navigation"},{"name":"PBI_ResultType","value":"Exception"}],"columns":[{"name":"FileDate","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"UnderlyingDateTimeDataType","value":"Date"}],"dataType":"dateTime","formatString":"Short Date","lineageTag":"096bdfaa-a781-42e