Source,{{\"FiscalMonthLastDate\", type date}}),","    #\"Trimmed Text\" = Table.TransformColumns(#\"Changed Type\",{{\"Item SKU\", Text.Trim, type text}})","in","    #\"Trimmed Text\""],"type":"m"}}]},{"name":"Fact FC Accuracy","annotations":[{"name":"PBI_ResultType","value":"Exception"},{"name":"PBI_NavigationStepName","value":"Navigation"}],"columns":[{"name":"AFI Warehouse Code","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"0e1bbe9a-c6d4-4b35-91dc-33ea836e53b6","sourceColumn":"AFI Warehouse Code","summarizeBy":"none"},{"name":"Forecast Period","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"changedProperties":[{"property":"SortByColumn"}],"dataType":"string","lineageTag":"1821000d-dc4f-4180-b292-b5163abc12ec","sortByColumn":"Forecast Period - sort","sourceColumn":"Forecast Period","summarizeBy":"none"},{"name":"Actual Demand Quantity","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"#,0","lineageTag":"4771eb44-8e4e-4d56-87ed-ddf6a4e2e98c","sourceColumn":"Actual Demand Quantity","summarizeBy":"sum"},{"name":"Promoted Resultant Forecast Quantity","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"double","formatString":"#,0","lineageTag":"2ca48e84-0578-4889-be25-5fdafc0f7dac","sourceColumn":"Promoted Resultant Forecast Quantity","summarizeBy":"sum"},{"name":"Naive Forecast","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"0","lineageTag":"80e4166f-b005-4391-9b68-1daa0e1748b8","sourceColumn":"Naive Forecast","summarizeBy":"sum"},{"name":"Forecast Period - sort","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"changedProperties":[{"property":"SortByColumn"}],"dataType":"int64","formatString":"0","lineageTag":"ec3b36e2-78b6-42f9-a4fe-e616d50f0517","sourceColumn":"Forecast Period - sort","summarizeBy":"sum"},{"name":"Series Number","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"56545b2c-0434-4d6a-a717-e05bafd3290a","sourceColumn":"Series Number","summarizeBy":"none"},{"name":"Snapshot Date","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"UnderlyingDateTimeDataType","value":"Date"}],"changedProperties":[{"property":"DataType"}],"dataType":"dateTime","formatString":"Short Date","lineageTag":"c02a316b-a169-40a5-99b7-a6f9c0e772ea","sourceColumn":"Snapshot Date","summarizeBy":"none","variations":[{"name":"Variation","defaultHierarchy":{"hierarchy":"Date Hierarchy","table":"LocalDateTable_c10fe989-2379-4798-95c3-2aaebfd10a50"},"isDefault":true,"relationship":"8f8e029f-750b-4774-b835-4e4cb23a6cc0"}]},{"name":"Customer Groups","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"9c811a5a-a3c4-4289-94b3-add5d35e6e93","sourceColumn":"Customer Groups","summarizeBy":"none"},{"name":"Item SKU","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"76c3f520-56bf-44c3-ab3e-64e12c61719d","sourceColumn":"Item SKU","summarizeBy":"none"},{"name":"Collective Class","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"4f61ab40-fba1-4e0d-8fcf-9728914628d3","sourceColumn":"Collective Class","summarizeBy":"none"},{"name":"Resultant Forecast","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"PBI_FormatHint","value":"{\"isGeneralNumber\":true}"}],"dataType":"double","lineageTag":"6b883e44-5317-4542-b4f2-7bee3da1c356","sourceColumn":"Resultant Forecast","summarizeBy":"sum"},{"name":"Month Of Invoice At Snapshot","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"int64","formatString":"0","lineageTag":"f26ebabb-0f0e-40eb-9c7d-9fe4d7e128f0","sourceColumn":"Month Of Invoice At Snapshot","summarizeBy":"sum"},{"name":"FiscalMonthYear","annotations":[{"name":"SummarizationSetBy","value":"Automatic"},{"name":"UnderlyingDateTimeDataType","value":"Date"}],"changedProperties":[{"property":"DataType"}],"dataType":"dateTime","formatString":"Long Date","lineageTag":"ffd17988-02fe-46fe-98a9-52533528b6f2","sourceColumn":"FiscalMonthYear","summarizeBy":"none"},{"name":"Invoice Status","annotations":[{"name":"SummarizationSetBy","value":"Automatic"}],"dataType":"string","lineageTag":"191a8d0c-ebb1-4dbf-b9bb-63f7dfcb6b9a","sourceColumn":"Invoice Status","summarizeBy":"none"}],"lineageTag":"c05a294d-cf06-4728-938f-727309dde076","partitions":[{"name":"Fact FC Accuracy","mode":"import","queryGroup":"Fact Query","source":{"expression":["let","    Query1 = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\", [Query=\"DECLARE @CCParam NVARCHAR(MAX),#(lf)        @PeriodParam NVARCHAR(12);#(lf)#(lf)SET @CCParam = 'HSENT';#(lf)SET @PeriodParam = '90 Days';#(lf)#(lf)------------------------------------------------------------#(lf)-- Drop temp tables if they already exist#(lf)------------------------------------------------------------#(lf)IF OBJECT_ID('tempdb..#Final_Table') IS NOT NULL#(lf)    DROP TABLE #Final_Table;#(lf)#(lf)IF OBJECT_ID('tempdb..#Scaffold') IS NOT NULL#(lf)    DROP TABLE #Scaffold;#(lf)#(lf)IF OBJECT_ID('tempdb..#DemandForecast_Snapshot') IS NOT NULL#(lf)    DROP TABLE #DemandForecast_Snapshot;#(lf)#(lf)IF OBJECT_ID('tempdb..#Aggregate_Demand') IS NOT NULL#(lf)    DROP TABLE #Aggregate_Demand;#(lf)#(lf)IF OBJECT_ID('tempdb..#Actual_Demand') IS NOT NULL#(lf)    DROP TABLE #Actual_Demand;#(lf)#(lf)IF OBJECT_ID('tempdb..#SnapshotDate') IS NOT NULL#(lf)    DROP TABLE #SnapshotDate;#(lf)#(lf)------------------------------------------------------------#(lf)-- Materialize SnapshotDate#(lf)------------------------------------------------------------#(lf)SELECT#(lf)    [FiscalYear],#(lf)    [FiscalMonth],#(lf)    [FiscalMonthYear],#(lf)    [FiscalMonthIndicator],#(lf)    [Month Name],#(lf)    CASE [Periods]#(lf)        WHEN '2w'   THEN '2 Weeks'#(lf)        WHEN '30d'  THEN '30 Days'#(lf)        WHEN '60d'  THEN '60 Days'#(lf)        WHEN '90d'  THEN '90 Days'#(lf)        WHEN '120d' THEN '120 Days'#(lf)    END AS [Periods],#(lf)    CASE [Snapshot Date]#(lf)        WHEN '2025-03-10' THEN '2025-03-24'#(lf)        WHEN '2025-11-10' THEN '2025-11-12' -- add Nov cycle deviation#(lf)        WHEN '2025-12-08' THEN '2025-12-16' -- add Dec cycle deviation#(lf)        ELSE [Snapshot Date]#(lf)    END AS [Snapshot Date]#(lf)INTO #SnapshotDate#(lf)FROM (#(lf)    SELECT DISTINCT#(lf)        [2w].[FiscalYear],#(lf)        [2w].[FiscalMonth],#(lf)        [2w].[FiscalMonthYear],#(lf)        [2w].[FiscalMonthIndicator],#(lf)        DATEFROMPARTS([2w].[FiscalYear], [2w].[FiscalMonth], 1) AS [Month Name],#(lf)        [2w].[DateID]   AS [2w],#(lf)        [30d].[DateID]  AS [30d],#(lf)        [60d].[DateID]  AS [60d],#(lf)        [90d].[DateID]  AS [90d],#(lf)        [120d].[DateID] AS [120d]#(lf)    FROM [Enterprise_DW].[DimDate_NonRetail] [2w]#(lf)#(lf)    LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [30d]#(lf)        ON DATEFROMPARTS([2w].[FiscalYear], [2w].[FiscalMonth], 1) = DATEADD(M, 1, DATEFROMPARTS([30d].[FiscalYear], [30d].[FiscalMonth], 1))#(lf)       AND [30d].[FiscalWeekOfMonth] = 3#(lf)       AND [30d].[FiscalDayOfWeek] = 2#(lf)#(lf)    LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [60d]#(lf)        ON DATEFROMPARTS([2w].[FiscalYear], [2w].[FiscalMonth], 1) = DATEADD(M, 2, DATEFROMPARTS([60d].[FiscalYear], [60d].[FiscalMonth], 1))#(lf)       AND [60d].[FiscalWeekOfMonth] = 3#(lf)       AND [60d].[FiscalDayOfWeek] = 2#(lf)#(lf)    LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [90d]#(lf)        ON DATEFROMPARTS([2w].[FiscalYear], [2w].[FiscalMonth], 1) = DATEADD(M, 3, DATEFROMPARTS([90d].[FiscalYear], [90d].[FiscalMonth], 1))#(lf)       AND [90d].[FiscalWeekOfMonth] = 3#(lf)       AND [90d].[FiscalDayOfWeek] = 2#(lf)#(lf)    LEFT JOIN [Enterprise_DW].[DimDate_NonRetail] [120d]#(lf)        ON DATEFROMPARTS([2w].[FiscalYear], [2w].[FiscalMonth], 1) = DATEADD(M, 4, DATEFROMPARTS([120d].[FiscalYear], [120d].[FiscalMonth], 1))#(lf)       AND [120d].[FiscalWeekOfMonth] = 3#(lf)       AND [120d].[FiscalDayOfWeek] = 2#(lf)#(lf)    WHERE [2w].[FiscalWeekOfMonth] = 3#(lf)      AND [2w].[FiscalMonthIndicator] BETWEEN -25 AND -1#(lf)      AND [2w].[FiscalDayOfWeek] = 2#(lf)) base#(lf)UNPIVOT ([Snapshot Date] FOR [Periods] IN ([2w], [30d], [60d], [90d], [120d])) AS unpvt;#(lf)#(lf)------------------------------------------------------------#(lf)-- Materialize Actual_Demand#(lf)------------------------------------------------------------#(lf)SELECT#(lf)    TRIM([DMD].[Customergroups]) AS [Customergroups],#(lf)    [DMD].[Year Period],#(lf)    [N_DMD].[Year Period] AS [Naive Year Period],#(lf)    TRIM([DMD].[Item]) AS [Item],#(lf)    TRIM([DMD].[Location]) AS [Warehouse],#(lf)    [DMD].[Actual demand],#(lf)    [N_DMD].[Actual Demand] AS [Naive Forecast]#(lf)INTO #Actual_Demand#(lf)FROM [SupplyChain_Enh].[ItemActualDemand_Logility] [DMD]#(lf)LEFT JOIN [SupplyChain_Enh].[ItemActualDemand_Logility] [N_DMD]#(lf)    ON [DMD].[Customergroups] = [N_DMD].[Customergroups]#(lf)   AND [DMD].[Item] = [N_DMD].[Item]#(lf)   AND [DMD].[Location] = [N_DMD].[Location]#(lf)   AND [DMD].[Year Period] = DATEADD(M, 1, [N_DMD].[Year Period]);#(lf)#(lf)------------------------------------------------------------#(lf)-- Materialize Aggregate_Demand#(lf)------------------------------------------------------------#(lf)SELECT#(lf)    'AFICONS' AS [Customergroups],#(lf)    [DMD].[Year Period],#(lf)    TRIM([DMD].[Item]) AS [Item],#(lf)    TRIM([DMD].[Location]) AS [Warehouse],#(lf)    SUM([DMD].[Actual demand]) AS [Actual demand],#(lf)    SUM([N_DMD].[Actual Demand]) AS [Naive Forecast]#(lf)INTO #Aggregate_Demand#(lf)FROM [SupplyChain_Enh].[ItemActualDemand_Logility] [DMD]#(lf)LEFT JOIN [SupplyChain_Enh].[ItemActualDemand_Logility] [N_DMD]#(lf)    ON [DMD].[Customergroups] = [N_DMD].[Customergroups]#(lf)   AND [DMD].[Item] = [N_DMD].[Item]#(lf)   AND [DMD].[Location] = [N_DMD].[Location]#(lf)   AND [DMD].[Year Period] = DATEADD(M, 1, [N_DMD].[Year Period])#(lf)WHERE [DMD].[Year Period] >= '2025-03-01'#(lf)GROUP BY#(lf)    [DMD].[Year Period],#(lf)    TRIM([DMD].[Item]),#(lf)    TRIM([DMD].[Location]);#(lf)#(lf)------------------------------------------------------------#(lf)-- Materialize DemandForecast_Snapshot#(lf)------------------------------------------------------------#(lf)SELECT#(lf)    [SS].[Periods] AS [Forecast Period],#(lf)    [SS].[Month Name],#(lf)    [DFC].[dfcCustomergroups] AS [Customer Group],#(lf)    [DFC].[dfcFiscalMonth] AS [FiscalMonthYear],#(lf)    [DFC].[dfcItem] AS [Item SKU],#(lf)    [DFC].[dfcWarehouse] AS [AFI Warehouse Code],#(lf)    [FCC].[ForeCastType] AS [Forecast Model],#(lf)    [DFC_L2].[dfcFCSTTypeCode] AS [L2 Forecast Model],#(lf)    [ABC].[ABC Code] AS [Fcst ABC],#(lf)    [ABC].[XYZ Code] AS [Fcst XYZ],#(lf)    [ABC].[ABCXYZ Code] AS [Fcst ABC/XYZ],#(lf)    [ABC].[ForecastPriority],#(lf)    [DFC].[dfcResultantForecast] AS [Resultant Forecast],#(lf)    [DFC].[dfcPromotionalLift] AS [Promo Lift],#(lf)    ([DFC].[dfcResultantForecast] + [DFC].[dfcPromotionalLift]) AS [Total Forecast],#(lf)    CONVERT(DATE, [DFC].[dfcSnapshot]) AS [Snapshot Date]#(lf)INTO #DemandForecast_Snapshot#(lf)FROM [SupplyChain_Enh].[DemandForecastSnapshot] AS [DFC]#(lf)#(lf)LEFT JOIN [SupplyChain_Enh].[ForecastCommonContainer_Logility] [FCC]#(lf)    ON [DFC].[dfcItem] = [FCC].[Item-Lvl1]#(lf)   AND [DFC].[dfcWarehouse] = [FCC].[Location]#(lf)   AND CONVERT(DATE, [DFC].[dfcSnapshot]) = CONVERT(DATE, [FCC].[FileDate])#(lf)   AND [DFC].[dfcCustomergroups] = [FCC].[DfcCustomergroupS]#(lf)#(lf)INNER JOIN #SnapshotDate [SS]#(lf)    ON [DFC].[dfcFiscalMonth] = [SS].[FiscalMonthYear]#(lf)   AND CONVERT(DATE, [DFC].[dfcSnapshot]) = CONVERT(DATE, [SS].[Snapshot Date])#(lf)-- AND [SS].[Periods] = @PeriodParam#(lf)#(lf)LEFT JOIN [SupplyChain_Enh].[ItemABCCode_AFI] AS [ABC]#(l