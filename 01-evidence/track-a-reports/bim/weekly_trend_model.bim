          {
            "name": "Account And ShipTo Number",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "lineageTag": "4d410912-29a7-4a17-85fc-70e413183c74",
