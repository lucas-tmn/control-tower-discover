            "summarizeBy": "none"
          }
        ],
        "lineageTag": "25959869-86c7-4bb8-9596-e3ee748f7a58",
        "partitions": [
          {
            "name": "Actuals-2e39586c-54bc-4039-b60e-6047bd5f8241",
            "mode": "import",
            "source": {
              "expression": [
                "// SQL Query Template",
                "",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\",",
                "                [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "",
                "",
                "/****** Weekly Invoiced, Written, Requested (Marketable Component Adjusted) ******/",
                "",
                "SELECT [ACT2].[Account And ShipTo Number]",
                "      ,[ACT2].[Item SKU]",
                "      ,[ACT2].[Warehouse]",
                "      ,[ACT2].[Sales Type]",
                "      ,[ACT2].[Order Status]",
                "      ,[ACT2].[FiscalWeekLastDate]",
                "      ,([ACT2].[Qty]/ISNULL([MC].[Qty In Box],1)) AS [Qty]",
                "      ,[ACT2].[Amt]",
                "FROM (",
                "SELECT [DC].[Account And ShipTo Number]",
                "\t  ,[CPD].[Item SKU]",
                "      ,[ID].[Warehouse]",
                "\t  ,[Sales Type] = 'Invoiced'",
                "\t  ,[Order Status] = 'Invoiced'",
                "\t  ,[DD].[FiscalWeekLastDate]",
                "\t  ,SUM([ID].[QuantityShipped]) AS [Qty]",
                "\t  ,SUM([ID].[NetSales]) AS [Amt]",
                "  FROM [Wholesale_SalesHistory_AFI].[InvoiceDetail] AS ID",
                "  ",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [ID].[InvoiceDate] = [DD].[DateID]",
                "  LEFT JOIN [SupplyChain_DW].[DimCurrentProductDetails] AS CPD",
                "    ON [ID].[ItemNumber] = [CPD].[Item SKU]",
                "  LEFT JOIN [AFISales_DW].[DimCustomers] AS DC",
                "    ON [ID].[CustomerNumber] = [DC].[Customer Account Number]",
                "\tAND [ID].[ShiptoNumber] = [DC].[Customer Shipto Number]",
                "  WHERE [ID].[Warehouse] NOT IN ('213','215','55')",
                "    AND [DD].[FiscalWeekIndicator] BETWEEN -26 AND 0",
                "\tAND [ID].[CustomerNumber] <> '3824800'",
                "\t",
                "",
                "  GROUP BY [DC].[Account And ShipTo Number]",
                "          ,[CPD].[Item SKU]",
                "          ,[ID].[Warehouse]",
                "          ,[DD].[FiscalWeekLastDate]",
                "",
                "  HAVING SUM([ID].[QuantityShipped]) <> 0",
                "",
                "UNION",
                "",
                "SELECT [DC].[Account And ShipTo Number]",
                "\t  ,[CPD].[Item SKU]",
                "      ,[ID].[Warehouse]",
                "\t  ,[Sales Type] = 'Written'",
                "\t  ,[Order Status] = 'Invoiced'",
                "\t  ,[DD].[FiscalWeekLastDate]",
                "\t  ,SUM([ID].[QuantityShipped]) AS [Qty]",
                "\t  ,SUM([ID].[NetSales]) AS [Amt]",
                "  FROM [Wholesale_SalesHistory_AFI].[InvoiceDetail] AS ID",
                "  ",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [ID].[OrderEntry] = [DD].[DateID]",
                "  LEFT JOIN [SupplyChain_DW].[DimCurrentProductDetails] AS CPD",
                "    ON [ID].[ItemNumber] = [CPD].[Item SKU]",
                "  LEFT JOIN [AFISales_DW].[DimCustomers] AS DC",
                "    ON [ID].[CustomerNumber] = [DC].[Customer Account Number]",
                "\tAND [ID].[ShiptoNumber] = [DC].[Customer Shipto Number]",
                "  WHERE [ID].[Warehouse] NOT IN ('213','215','55')",
                "    AND [DD].[FiscalWeekIndicator] BETWEEN -26 AND 0",
                "\tAND [ID].[CustomerNumber] <> '3824800'",
                "",
                "  GROUP BY [DC].[Account And ShipTo Number]",
                "          ,[CPD].[Item SKU]",
                "          ,[ID].[Warehouse]",
                "          ,[DD].[FiscalWeekLastDate]",
                "",
                "  HAVING SUM([ID].[QuantityShipped]) <> 0",
                "",
                "UNION",
                "",
                "SELECT [DC].[Account And ShipTo Number]",
                "\t  ,[CPD].[Item SKU]",
                "      ,[ID].[Warehouse]",
                "\t  ,[Sales Type] = 'Current Request'",
                "\t  ,[Order Status] = 'Invoiced'",
                "\t  ,[DD].[FiscalWeekLastDate]",
                "\t  ,SUM([ID].[QuantityShipped]) AS [Qty]",
                "\t  ,SUM([ID].[NetSales]) AS [Amt]",
                "  FROM [Wholesale_SalesHistory_AFI].[InvoiceDetail] AS ID",
                "  ",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [ID].[CurrentRequestDate] = [DD].[DateID]",
                "  LEFT JOIN [SupplyChain_DW].[DimCurrentProductDetails] AS CPD",
                "    ON [ID].[ItemNumber] = [CPD].[Item SKU]",
                "  LEFT JOIN [AFISales_DW].[DimCustomers] AS DC",
                "    ON [ID].[CustomerNumber] = [DC].[Customer Account Number]",
                "\tAND [ID].[ShiptoNumber] = [DC].[Customer Shipto Number]",
                "  WHERE [ID].[Warehouse] NOT IN ('213','215','55')",
                "    AND [DD].[FiscalWeekIndicator] BETWEEN -26 AND 13",
                "\tAND [ID].[CustomerNumber] <> '3824800'",
                "",
                "  GROUP BY [DC].[Account And ShipTo Number]",
                "          ,[CPD].[Item SKU]",
                "          ,[ID].[Warehouse]",
                "          ,[DD].[FiscalWeekLastDate]",
                "",
                "  HAVING SUM([ID].[QuantityShipped]) <> 0",
                "",
                "UNION ",
                "",
                "SELECT [OO].[Account And ShipTo Number]",
                "      ,[CPD].[Item SKU]",
                "      ,[OO].[Warehouse]",
                "\t  ,[Sales Type] = 'Written'",
                "\t  ,[Order Status] = 'Open'",
                "\t  ,[DD].[FiscalWeekLastDate]",
                "\t  ,SUM([OO].[Open Order Quantity]) AS [Qty]",
                "\t  ,SUM([OO].[Open Order Amount]) AS [Amt]",
                "  FROM [AFISales_DW].[FactOpenOrders] AS OO",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [OO].[Order Taken Date] = [DD].[DateID]",
                "  LEFT JOIN [SupplyChain_DW].[DimCurrentProductDetails] AS CPD",
                "    ON [OO].[Item Sku] = [CPD].[Item SKU]",
                "  WHERE [OO].[Inventory Allocated Flag] = '2'",
                "    AND [OO].[Warehouse] NOT IN ('213','215','55')",
                "\tAND [DD].[FiscalWeekIndicator] BETWEEN -26 AND 13",
                "\tAND [OO].[Customer Account Number] <> '3824800'",
                "",
                "  GROUP BY [OO].[Account And ShipTo Number]",
                "          ,[CPD].[Item SKU]",
                "          ,[OO].[Warehouse]",
                "          ,[DD].[FiscalWeekLastDate]",
                "",
                "UNION ",
                "",
                "SELECT [OO].[Account And ShipTo Number]",
                "      ,[CPD].[Item SKU]",
                "      ,[OO].[Warehouse]",
                "\t  ,[Sales Type] = 'Current Request'",
                "\t  ,[Order Status] = 'Open'",
                "\t  ,[DD].[FiscalWeekLastDate]",
                "\t  ,SUM([OO].[Open Order Quantity]) AS [Qty]",
                "\t  ,SUM([OO].[Open Order Amount]) AS [Amt]",
                "  FROM [AFISales_DW].[FactOpenOrders] AS OO",
                "  LEFT JOIN [Enterprise_DW].[DimDate] AS DD",
                "    ON [OO].[Current Request Date] = [DD].[DateID]",
                "  LEFT JOIN [SupplyChain_DW].[DimCurrentProductDetails] AS CPD",
                "    ON [OO].[Item Sku] = [CPD].[Item SKU]",
                "  WHERE [OO].[Inventory Allocated Flag] = '2'",
                "    AND [OO].[Warehouse] NOT IN ('213','215','55')",
                "\tAND [DD].[FiscalWeekIndicator] BETWEEN -26 AND 13",
                "\tAND [OO].[Customer Account Number] <> '3824800'",
                "",
                "  GROUP BY [OO].[Account And ShipTo Number]",
                "          ,[CPD].[Item SKU]",
                "          ,[OO].[Warehouse]",
                "          ,[DD].[FiscalWeekLastDate]",
                "",
                "  ) AS ACT2 ",
                "  LEFT JOIN ( ",
                "SELECT [CPD2].[Item SKU] AS [Marketable SKU]",
                "\t  ,[CPD].[Qty In Box]",
                "  FROM [SupplyChain_DW].[DimCurrentProductDetails] AS [CPD]",
                "  LEFT JOIN [SupplyChain_DW].[DimCurrentProductDetails] AS CPD2",
                "    ON [CPD].[Item SKU] = LEFT(TRIM([CPD2].[Item SKU]),LEN(TRIM([CPD2].[Item SKU]))-1)",
                "  INNER JOIN [MasterData_ItemMaster_AFI].[ITMEXT] AS EXT ",
                "    ON [CPD2].[Item SKU] = [EXT].[ITNBR]",
                "\t  AND [EXT].[GDESCD] = '700'",
                "  ) AS MC ",
                "  ON [ACT2].[Item SKU] = [MC].[Marketable SKU]",
                "",
                "                      \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
