        "columns": [
          {
            "name": "z_Measures",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "lineageTag": "f429d575-d7b0-44f2-8fb5-ba8f62042cde",
            "sourceColumn": "z_Measures",
            "summarizeBy": "none"
          }
        ],
        "lineageTag": "d3ffbfeb-9127-482f-be08-90be2a94e213",
        "measures": [
          {
            "name": "ACTD (accy)",
            "expression": "CALCULATE(SUM(FcstAccuracy[Actual Qty]))",
            "formatString": "#,0",
            "lineageTag": "62e97dc7-4ffe-42e9-8a4e-47fb35520c03"
          },
          {
            "name": "Lag Fcst",
            "expression": "CALCULATE(SUM(FcstAccuracy[Fcst Qty]))",
            "formatString": "#,0",
            "lineageTag": "023ded42-44a6-4c05-85a7-a7144af84c00"
          },
          {
            "name": "90Day Error",
            "expression": "[Lag Fcst] - [ACTD (accy)]",
            "formatString": "#,0",
            "lineageTag": "286c41b2-57a7-4b04-8ab4-ed2b3277f2b7"
          },
          {
            "name": "90Day Error %",
            "expression": "DIVIDE(CALCULATE(SUM(FcstAccuracy[Fcst Qty])),CALCULATE(SUM(FcstAccuracy[Actual Qty])))-1",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "b06c6a1e-ea0d-44b1-8f17-e8ad0f767088"
          },
          {
            "name": "Working Fcst",
            "expression": "CALCULATE(SUM(Forecast[Qty]))",
            "formatString": "#,0",
            "lineageTag": "63a15673-0b40-49b2-813a-7de47963911b"
          },
          {
            "name": "FUTO",
            "expression": "CALCULATE(SUM(Actuals[Qty]),Actuals[Sales Type]=\"Current Request\",FILTER(z_FiscalCal,z_FiscalCal[Fiscal Week Indicator]>=0))",
            "formatString": "#,0",
            "lineageTag": "2460b8c1-c694-44c2-aa7c-14e518252bee"
          },
          {
            "name": "Curr Qty",
            "expression": "CALCULATE(SUM(Actuals[Qty]),Actuals[Sales Type]=\"Current Request\")",
            "formatString": "#,0",
            "lineageTag": "c15cb20d-fb50-4f37-82cc-3dcb3627756d"
          },
          {
            "name": "Inv Qty",
            "expression": "CALCULATE(SUM(Actuals[Qty]),Actuals[Sales Type]=\"Invoiced\",FILTER(z_FiscalCal,z_FiscalCal[Fiscal Week Indicator]<1))",
            "formatString": "#,0",
            "lineageTag": "3eefac0a-ee3a-4dbd-bf92-3772d64e4fb2"
          },
          {
            "name": "Writ Qty",
            "expression": "CALCULATE(SUM(Actuals[Qty]),Actuals[Sales Type]=\"Written\",FILTER(z_FiscalCal,z_FiscalCal[Fiscal Week Indicator]<1))",
            "formatString": "#,0",
            "lineageTag": "c456e707-9258-4a71-8ba4-4315b3d30d66"
          },
          {
            "name": "Curr Req Qty",
            "expression": "CALCULATE(SUM(Actuals[Qty]),Actuals[Sales Type]=\"Current Request\")",
            "formatString": "#,0",
            "lineageTag": "27eb6aab-48ab-474d-a8db-fc55debe92ef"
          },
          {
            "name": "Inv Qty (CS)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "CALCULATE(SUM(Actuals[Qty]),Actuals[Sales Type]=\"Invoiced\",FILTER(z_FiscalCal,z_FiscalCal[Fiscal Week Indicator]<0))",
            "lineageTag": "5e438b15-b3f3-435f-a26b-116e9b349323"
          },
          {
            "name": "dfoFUTO",
            "expression": "CALCULATE(SUM(FutOrd[dfcOrderFutureQty]),z_FiscalCal[Fiscal Month Indicator]=0)",
            "formatString": "#,0",
            "lineageTag": "809f1173-6a9b-4188-83f8-8a2f64ad0327"
          },
          {
            "name": "dfoFcst",
            "expression": "CALCULATE(SUM(FutOrd[Total Forecast]),z_FiscalCal[Fiscal Month Indicator]=0)",
            "formatString": "#,0",
            "lineageTag": "774eb6f5-7dc6-47a3-b279-c2eb6b39fe08"
          },
          {
            "name": "dfoConsumption",
            "expression": "DIVIDE([dfoFUTO],[dfoFcst])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "40f2c4f7-bf1a-4d59-b7b7-45d5aec98989"
          },
          {
            "name": "dfoGap",
            "expression": "[dfoFUTO]-[dfoFcst]",
            "formatString": "#,0",
            "lineageTag": "3d789c10-e9da-4f73-a391-2435b6646cc1"
          }
        ],
        "partitions": [
          {
            "name": "_Measures-c360e994-e1cb-43f6-80d0-418bb185313f",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText(\"i45WSlSKjQUA\", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [z_Measures = _t]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"z_Measures\", type text}})",
                "in",
                "    #\"Changed Type\""
              ],
              "type": "m"
            }
          }
        ]
