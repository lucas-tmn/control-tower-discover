        "lineageTag": "a91dff71-4309-44f5-9af0-00050c411304",
        "partitions": [
          {
            "name": "Forecast-67f7b18c-58fa-4425-a35b-e0a6a492d4d3",
            "mode": "import",
            "source": {
              "expression": [
                "// SQL Query Template",
                "",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\",",
                "                [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "",
                "",
                "/* Weekly Forecast */",
                "",
                "SELECT [DFC].[DfcCustomerGroups] AS [CustGroup]",
                "      ,[CPD].[Item SKU]",
                "\t  ,[DFC].[dfcWarehouse] AS [Warehouse]",
                "\t  ,[Sales Type] = 'Fcst'",
                "\t  ,[Order Status] = 'Fcst'",
                "\t  ,[DD].[FiscalWeekLastDate]",
                "\t  ,CONVERT(NUMERIC, SUM(([DFC].[dfcResultantForecast]+[DFC].[dfcPromotionalLift])/[DD].[NumWeeks])) AS [Qty]",
                "\t  ,CONVERT(MONEY, SUM((([DFC].[dfcResultantForecast]+[DFC].[dfcPromotionalLift])/[DD].[NumWeeks])*[CPD].[FOB Price]),0) AS [Amt]",
                "\t  ,CONVERT(DATE,[DFC].[dtea]) AS [SnapshotDate]",
                "  FROM [Wholesale_DemandPlanning_AFI].[DemandForecast] AS DFC",
                "  INNER JOIN (",
                "SELECT [FiscalMonthYear]",
                "      ,[FiscalWeekLastDate]",
                "\t  ,[FiscalYear]",
                "\t  ,[FiscalMonth]",
                "\t  ,[NumWeeks] = ",
                "\t\t\tCASE ",
                "\t\t\t\tWHEN [FiscalMonth] IN ('3','6','9','12')",
                "\t\t\t\t\tTHEN 5",
                "\t\t\t\tELSE 4",
                "\t\t\tEND",
                "  FROM [Enterprise_DW].[DimDate]",
                " WHERE [FiscalMonthIndicator] BETWEEN 0 AND 6",
                "  GROUP BY [FiscalMonthYear]",
                "          ,[FiscalWeekLastDate]",
                "          ,[FiscalYear]",
                "          ,[FiscalMonth]",
                "  ) AS DD ",
                "  ON [DFC].[dfcFiscalMonth] = [DD].[FiscalMonthYear]",
                "  LEFT JOIN [SupplyChain_DW].[DimCurrentProductDetails] AS CPD",
                "    ON [DFC].[dfcItem] = [CPD].[Item SKU]",
                "  WHERE [DFC].[dtea] = (SELECT MAX([dtea]) FROM [Wholesale_DemandPlanning_AFI].[DemandForecast])",
                "    AND [CPD].[Collective Class] IS NOT NULL",
                "",
                "  GROUP BY [DFC].[DfcCustomerGroups]",
                "          ,[CPD].[Item SKU]",
                "          ,[DFC].[dfcWarehouse]",
                "          ,[DD].[FiscalWeekLastDate]",
                "          ,[DFC].[dtea]",
                "",
                "\tHAVING CONVERT(NUMERIC, SUM(([DFC].[dfcResultantForecast]+[DFC].[dfcPromotionalLift])/[DD].[NumWeeks])) <> 0",
                "",
                "                      \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
