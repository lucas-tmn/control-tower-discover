        "lineageTag": "243541ac-58e2-4d38-93fe-1826bacb51da",
        "partitions": [
          {
            "name": "FcstAccuracy-cffeee5b-c130-466b-8165-86cb16d2e9a1",
            "mode": "import",
            "source": {
              "expression": [
                "// SQL Query Template",
                "",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\",",
                "                [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "",
                "/* Get Forecasts at Snapshot Dates*/",
                "SELECT [FC].[CustGroup]",
                "      ,[FC].[Item SKU]",
                "\t  ,[FC].[Warehouse]",
                "\t  ,[Fcst Qty] = ",
                "\t\t\t\tCASE",
                "\t\t\t\t\tWHEN RIGHT([FC].[FiscalMonthYear],2) IN ('03','06','09','12')",
                "\t\t\t\t\t\tTHEN CAST(CEILING([FC].[PromoResultantForecast]/5) AS INT)",
                "\t\t\t\t\tELSE CAST(CEILING([FC].[PromoResultantForecast]/4) AS INT)",
                "\t\t\t\tEND",
                "\t  ,[FC].[FiscalMonthYear]",
                "\t  ,[FC].[Demanded Week Ending]",
                "\t  ,[FC].[Snapshot Date]",
                "\t  ,[FC].[Forecast Period]",
                "--INTO #Fcst",
                "  FROM (",
                "",
                "\t\tSELECT [FC].[dfcCustomergroups] AS [CustGroup]",
                "\t\t      ,TRIM(FC.[dfcItem]) AS [Item SKU]",
                "\t\t\t  ,TRIM(FC.[dfcWarehouse]) AS [Warehouse]",
                "\t\t\t  ,FC.[dfcFiscalMonth] AS [FiscalMonthYear]",
                "\t\t\t  --,[dfcMainPiece]",
                "\t\t\t  --,[dfcCollectiveClass]",
                "\t\t\t  --,[dfcResultantForecast] AS [ResultantForecast]",
                "\t\t\t  --,[dfcPromotionalLift] AS [PromotionalLift]",
                "\t\t\t  ,[PromoResultantForecast] = FC.[dfcResultantForecast] + FC.[dfcPromotionalLift]",
                "\t\t\t  ,CONVERT(DATE, FC.[dfcSnapshot]) AS [Snapshot Date]",
                "\t\t\t  ,[LTS].[Demanded Week Ending]",
                "\t\t\t  ,[LTS].[Forecast Period]",
                "\t\tFROM [SupplyChain_Enh].[DemandForecastSnapshot] AS FC",
                "\t\tINNER JOIN (",
                "",
                "",
                "\t\tSELECT DISTINCT DATEADD(WEEK, -13, CONVERT(DATE, [FiscalWeekLastDate])) AS [Weeks Snapshot Date]",
                "             ,[FiscalWeekLastDate] AS [Demanded Week Ending]",
                "             ,[FiscalMonthYear] ",
                "\t\t\t ,'12wk' AS [Forecast Period]",
                "         FROM [Enterprise_DW].[DimDate] ",
                "         WHERE [FiscalWeekIndicator] >= -26 ",
                "\t\t   AND [FiscalMonthIndicator] <= 0",
                "",
                "\t/* Delete everything below once we get to July 2025   */",
                "\t/*    Return to Standard 12Wk Lag                     */",
                "\t\t    AND [FiscalMonthYear] <= 202503  ",
                "",
                "\t\tUNION ",
                "",
                "\t\tSELECT DISTINCT DATEADD(WEEK, -3, CONVERT(DATE, [FiscalWeekLastDate])) AS [Weeks Snapshot Date]",
                "             ,[FiscalWeekLastDate] AS [Demanded Week Ending]",
                "             ,[FiscalMonthYear] ",
                "\t\t\t ,'2wk' AS [Forecast Period]",
                "         FROM [Enterprise_DW].[DimDate] ",
                "         WHERE [FiscalWeekIndicator] >= -26 ",
                "\t\t   AND [FiscalMonthIndicator] <= 0",
                "\t\t    AND [FiscalMonthYear] = 202504",
                "",
                "\t\tUNION ",
                "",
                "\t\tSELECT DISTINCT DATEADD(WEEK, -5, CONVERT(DATE, [FiscalWeekLastDate])) AS [Weeks Snapshot Date]",
                "             ,[FiscalWeekLastDate] AS [Demanded Week Ending]",
                "             ,[FiscalMonthYear] ",
                "\t\t\t ,'4wk' AS [Forecast Period]",
                "         FROM [Enterprise_DW].[DimDate] ",
                "         WHERE [FiscalWeekIndicator] >= -26 ",
                "\t\t   AND [FiscalMonthIndicator] <= 0",
                "\t\t    AND [FiscalMonthYear] = 202505",
                "",
                "\t\tUNION ",
                "",
                "\t\tSELECT DISTINCT DATEADD(WEEK, -9, CONVERT(DATE, [FiscalWeekLastDate])) AS [Weeks Snapshot Date]",
                "             ,[FiscalWeekLastDate] AS [Demanded Week Ending]",
                "             ,[FiscalMonthYear] ",
                "\t\t\t ,'8wk' AS [Forecast Period]",
                "         FROM [Enterprise_DW].[DimDate] ",
                "         WHERE [FiscalWeekIndicator] >= -26 ",
                "\t\t   AND [FiscalMonthIndicator] <= 0",
                "\t\t    AND [FiscalMonthYear] = 202506",
                "",
                "\t\tUNION ",
                "",
                "\t\tSELECT DISTINCT DATEADD(WEEK, -13, CONVERT(DATE, [FiscalWeekLastDate])) AS [Weeks Snapshot Date]",
                "             ,[FiscalWeekLastDate] AS [Demanded Week Ending]",
                "             ,[FiscalMonthYear] ",
                "\t\t\t ,'12wk' AS [Forecast Period]",
                "         FROM [Enterprise_DW].[DimDate] ",
                "         WHERE [FiscalWeekIndicator] >= -26 ",
                "\t\t   AND [FiscalMonthIndicator] <= 0",
                "\t\t    AND [FiscalMonthYear] >= 202507",
                "",
                "",
                "\t\t) AS LTS",
                "\t\t  ON [LTS].[Weeks Snapshot Date] = CONVERT(DATE, [FC].[dfcSnapshot])",
                "\t\t\tAND [LTS].[FiscalMonthYear] = [FC].[dfcFiscalMonth]",
                "",
                "\t\tWHERE ([FC].[dfcResultantForecast] +[FC].[dfcPromotionalLift]) > 0",
                "",
                "\t\t\t) AS FC",
                "",
                "                      \", CreateNavigationProperties=false]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"Demanded Week Ending\", type date}, {\"Snapshot Date\", type date}})",
                "in",
                "    #\"Changed Type\""
              ],
              "type": "m"
            }
          }
        ]
      },
