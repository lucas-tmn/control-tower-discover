        "partitions": [
          {
            "name": "FutOrd",
            "mode": "import",
            "source": {
              "expression": [
                "// SQL Query Template",
                "",
                "let",
                "    Source = Sql.Database(\"ashley-edw.database.windows.net\", \"ashley_edw\",",
                "                [CommandTimeout=#duration(0, 1, 0, 0), Query=\"",
                "",
                "SELECT [DFC].[dfcCustomerGroups]",
                "      ,[DFC].[dfcItem]",
                "      ,[DFC].[dfcWarehouse]",
                "      ,[DFC].[dfcFiscalMonth]",
                "      ,[DD].[FiscalMonthLastDate] ",
                "\t  ,[DFC].[dfcResultantForecast] + [DFC].[dfcPromotionalLift] AS [Total Forecast]",
                "\t  ,[DFC].[dfcOrderFutureQty]",
                "      ,[DFC].[dfcSnapshot]",
                "  FROM [SupplyChain_Enh].[DemandForecastSnapshot] AS DFC",
                "  INNER JOIN ( ",
                "",
                "SELECT DISTINCT [FiscalMonthYear]",
                "      ,[FiscalMonthLastDate]",
                "  FROM [Enterprise_DW].[DimDate]",
                "  WHERE [FiscalMonthIndicator] < 2",
                "",
                "  ) AS DD ",
                "  ON [DFC].[dfcFiscalMonth] = [DD].[FiscalMonthYear]",
                "",
                "  WHERE [DFC].[dfcSnapshot] = (SELECT MAX([dfcSnapshot]) FROM [SupplyChain_Enh].[DemandForecastSnapshot])",
                " --   AND [DFC].[dfcItem] = 'M69731'",
                "\t--AND [DFC].[dfcWarehouse] = '1'",
                "    ",
                "",
                "                      \", CreateNavigationProperties=false])",
                "in",
                "    Source"
              ],
              "type": "m"
            }
          }
        ]
      },
