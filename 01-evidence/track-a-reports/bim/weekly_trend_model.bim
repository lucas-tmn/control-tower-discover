                "            {\"MASSRENT\", \"MASSRENT\", \"MASSRENT\"},",
                "            {\"NFM\", \"NFM\", \"NFM\"},",
                "            {\"RHCUST\", \"RHCUST\", \"RHCUST\"}",
                "",
                "        }",
                "    ),",
                "    ",
                "    // Append the new rows to existing table",
                "    AppendedTable = Table.Combine({",
                "        CustomerMaster_AFI1,",
                "        NewRows",
                "    })",
