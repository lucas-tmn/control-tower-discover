          },
          {
            "name": "% Cust Order Covered - This_Week",
            "expression": "IFERROR(IF(([Firm Demand - This_Week] + [Net Forecast - This_Week] + [SI Negative - This_Week]) / ([Firm Demand - This_Week] + [Net Forecast - This_Week]) > 1, 1, IF(([Firm Demand - This_Week] + [Net Forecast - This_Week] + [SI Negative - This_Week]) / ([Firm Demand - This_Week] + [Net Forecast - This_Week]) < 0, 0, ([Firm Demand - This_Week] + [Net Forecast - This_Week] + [SI Negative - This_Week]) / ([Firm Demand - This_Week] + [Net Forecast - This_Week]))),0)",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "98acc345-cff1-4faf-b357-227fc50aaf3f"
          },
          {
            "name": "Firm Demand - Last_Week",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM('Demand Fulfillment'[Firm Demand - Last Week])) ",
            "formatString": "#,0",
