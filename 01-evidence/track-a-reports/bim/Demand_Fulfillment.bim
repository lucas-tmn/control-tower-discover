                "    CurrentProductDetails1 = #\"346f2aa1-dd50-4c11-9630-b17f75854663\"{[entity=\"CurrentProductDetails\"]}[Data]",
                "in",
                "    CurrentProductDetails1"
              ],
              "type": "m"
            }
          }
        ]
