            "expression": "IFERROR(IF(ABS([Total SI Negative]) / ([Total Firm Demand] + [Total Net Forecast]) > 1, 1, IF(ABS([Total SI Negative]) / ([Total Firm Demand] + [Total Net Forecast]) < 0, 0, ABS([Total SI Negative]) / ([Total Firm Demand] + [Total Net Forecast]))),0)",
