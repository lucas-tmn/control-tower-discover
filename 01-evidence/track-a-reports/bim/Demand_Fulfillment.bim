          {
            "name": "% Cust Order Covered - Last_Week",
            "expression": "IFERROR(IF(([Firm Demand - Last_Week] + [Net Forecast - Last_Week] + [SI Negative - Last_Week]) / ([Firm Demand - Last_Week] + [Net Forecast - Last_Week]) > 1, 1, IF(([Firm Demand - Last_Week] + [Net Forecast - Last_Week] + [SI Negative - Last_Week]) / ([Firm Demand - Last_Week] + [Net Forecast - Last_Week]) < 0, 0, ([Firm Demand - Last_Week] + [Net Forecast - Last_Week] + [SI Negative - Last_Week]) / ([Firm Demand - Last_Week] + [Net Forecast - Last_Week]))),0)",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "c613980f-aa53-4901-b15a-fc86f9fcf1f4"
          },
          {
            "name": "Demand Fulfillment Goal",
            "expression": ".90",
            "formatString": "0%;-0%;0%",
            "lineageTag": "577e507b-ce9a-43dc-815d-2ff73f0efa86"
          },
          {
            "name": "Total % Cust Orders Covered YTD",
            "expression": "CALCULATE([Total % Cust Orders Covered],DATESYTD('Demand Fulfillment'[Fiscal Date]))",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "5f17bfb9-1b81-4de3-9912-5dcbec0d6948"
          },
          {
            "name": "Total % Cust Orders Covered v2",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "IFERROR(IF([Total SI Negative] / ([Total Firm Demand] + [Total Net Forecast]) > 1, 1, IF([Total SI Negative] / ([Total Firm Demand] + [Total Net Forecast]) < 0, 0, [Total SI Negative] / ([Total Firm Demand] + [Total Net Forecast]))),0)",
            "formatString": "0.0%;-0.0%;0.0%",
