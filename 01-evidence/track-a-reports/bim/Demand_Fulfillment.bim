          },
          {
            "name": "Total % of Out of Stock",
            "expression": "(DIVIDE(ABS([Total SI Neg]),([Total Firm Dmnd]))*100)",
            "formatString": "0.00",
            "lineageTag": "b7f8b96b-86c0-4125-b459-c611222ee343"
          },
          {
            "name": "Ranking",
            "expression": "RANKX(ALL('Top Negatives'[DF Series Number],'Top Negatives'[Collective Class],'Top Negatives'[Vendor Name], 'Top Negatives'[Office Code]),CALCULATE(SUM('Top Negatives'[SI Neg $])*-1))",
            "formatString": "0",
            "lineageTag": "df320bbb-c509-4152-9154-9af9a4716e58"
          },
          {
            "name": "Total SI Neg $ %",
            "expression": "DIVIDE([Total SI Neg $],CALCULATE([Total SI Neg $],ALL('Top Negatives'[DF Series Number],'Top Negatives'[Collective Class],'Top Negatives'[Vendor Name],'Top Negatives'[Office Code])))",
            "extendedProperties": [
