                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM('Demand Fulfillment'[SI Negative - This Week]))-CALCULATE(SUM('Demand Fulfillment'[SI Negative - Last Week]))",
            "formatString": "#,0",
            "lineageTag": "141f804b-098d-4583-830f-3ba61c6a8001"
          },
          {
            "name": "SI Negative - This Wk over Last Wk %",
            "expression": "IFERROR(CALCULATE(SUM('Demand Fulfillment'[SI Negative - This Week]))/CALCULATE(SUM('Demand Fulfillment'[SI Negative - Last Week])),BLANK())",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "cff6838f-56cb-4f35-b82e-3fe5baf336c0"
          },
          {
            "name": "Total % Cust Orders Covered 6MMA",
            "expression": "AVERAGEX(DATESINPERIOD('Demand Fulfillment'[Fiscal Date],MAX('Demand Fulfillment'[Fiscal Date]),-182,DAY),[Total % Cust Orders Covered])",
            "formatString": "0.0%;-0.0%;0.0%",
