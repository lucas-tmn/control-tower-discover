            "lineageTag": "5cc40ca6-dfa4-4f6a-a1f2-cfafb61e3b61"
          },
          {
            "name": "Total % Cust Orders Covered",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "IFERROR(IF(([Total Firm Demand] + [Total Net Forecast] + [Total SI Negative]) / ([Total Firm Demand] + [Total Net Forecast]) > 1, 1, IF(([Total Firm Demand] + [Total Net Forecast] + [Total SI Negative]) / ([Total Firm Demand] + [Total Net Forecast]) < 0, 0, ([Total Firm Demand] + [Total Net Forecast] + [Total SI Negative]) / ([Total Firm Demand] + [Total Net Forecast]))),0)",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "a2cfaee8-0f0a-47dd-b6e3-096ef03cc767"
          },
          {
            "name": "Total Firm Demand",
            "expression": "CALCULATE(SUM('Demand Fulfillment'[Firm Demand]))",
            "formatString": "#,0",
            "lineageTag": "dc502fe5-b789-4a59-a945-71f1f87ca329"
          },
          {
            "name": "Total On Hand Qty",
            "expression": "CALCULATE(SUM('Demand Fulfillment'[On Hand Qty]))",
            "formatString": "#,0",
            "lineageTag": "6456f232-86e6-478f-bb4b-6c0a2bc2aa1f"
          },
          {
            "name": "Firm Demand - This Wk over Last Wk",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "CALCULATE(SUM('Demand Fulfillment'[Firm Demand - This Week]))-CALCULATE(SUM('Demand Fulfillment'[Firm Demand - Last Week]))",
            "formatString": "#,0",
            "lineageTag": "5250ca39-3720-49de-8d15-d544f9d35063"
          },
          {
            "name": "Firm Demand - This Wk over Last Wk %",
            "expression": "IFERROR(CALCULATE(SUM('Demand Fulfillment'[Firm Demand - This Week]))/CALCULATE(SUM('Demand Fulfillment'[Firm Demand - Last Week])),BLANK())",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "a12d90e7-17be-4808-9792-f3b4cc24f2b7"
          },
          {
            "name": "SI Negative - This Wk over Last Wk",
